---
import { href as buildHref } from '@edf/core/utils/url.js';

interface NavItem {
  label: string;
  href: string;
  solution?: string;
}

interface Props {
  currentPath: string;
  base: string;
}

const { currentPath, base } = Astro.props;

const navItems: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Scenario', href: '/scenario' },
  { label: 'Visibilità', href: '/visibilita' },
  { label: 'Conosci', href: '/conosci', solution: 'rtcdp' },
  { label: 'Acquisisci', href: '/acquisisci', solution: 'ajo-b2c,aem-sites' },
  { label: 'Coinvolgi', href: '/coinvolgi', solution: 'ajo-b2c,target' },
  { label: 'Contenuti', href: '/contenuti', solution: 'genstudio,aem-assets' },
  { label: 'Analizza', href: '/analizza', solution: 'cja' },
  { label: 'Coworker', href: '/coworker' },
  { label: 'B2B', href: '/b2b', solution: 'ajo-b2b,marketo' },
  { label: 'Motore', href: '/motore-adobe' },
  { label: 'Risultati', href: '/risultati' },
];

function resolveHref(path: string): string {
  return buildHref(base, path);
}

function isActive(path: string): boolean {
  const resolved = resolveHref(path);
  if (path === '/') return currentPath === resolved || currentPath === resolved.replace(/\/$/, '');
  return currentPath.startsWith(resolved);
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-[var(--surface-primary)]/95 backdrop-blur-sm border-b border-[var(--line-subtle)]"
  role="banner"
  style="view-transition-name: uni-nav;"
>
  <nav
    class="max-w-screen-xl mx-auto px-6 md:px-10 h-14 flex items-center justify-between"
    aria-label="Navigazione principale"
  >
    <a href={resolveHref('/')} class="flex items-center gap-2.5 no-underline group flex-shrink-0">
      <span
        class="font-[family-name:var(--font-display)] text-base font-light text-[var(--ink-primary)] tracking-tight group-hover:text-[var(--accent-primary)] transition-colors"
      >
        UniCredit × Adobe
      </span>
      <span class="unlimited-badge ml-2">Unlimited</span>
    </a>

    <ul class="hidden lg:flex flex-nowrap items-center gap-0.5 min-w-0 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden" role="list">
      {navItems.map((item) => {
        const itemHref = resolveHref(item.href);
        const active = isActive(item.href);
        return (
          <li class="flex-shrink-0">
            <a
              href={itemHref}
              data-nav-solution={item.solution ?? undefined}
              class:list={[
                'block whitespace-nowrap px-2.5 py-1.5 text-xs font-medium tracking-wide uppercase transition-colors duration-[var(--duration-fast)] no-underline rounded-sm',
                active
                  ? 'text-[var(--accent-primary)]'
                  : 'text-[var(--ink-tertiary)] hover:text-[var(--ink-primary)]',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <a
      href={buildHref(base.replace('/unicredit-engagement', ''), '/console/unicredit-engagement')}
      class="hidden lg:inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium tracking-wide border border-[var(--line-default)] text-[var(--ink-tertiary)] hover:border-[var(--accent-primary)] hover:text-[var(--accent-primary)] transition-colors no-underline rounded-sm"
      title="Experience Design Factory Console"
      data-admin-only
    >
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="2" y="2" width="5" height="5" rx="0.5"/>
        <rect x="9" y="2" width="5" height="5" rx="0.5"/>
        <rect x="2" y="9" width="5" height="5" rx="0.5"/>
        <rect x="9" y="9" width="5" height="5" rx="0.5"/>
      </svg>
      Console
    </a>

    <button
      class="lg:hidden p-2 -mr-2 text-[var(--ink-primary)] hover:text-[var(--accent-primary)] transition-colors"
      aria-expanded="false"
      aria-controls="mobile-nav-uc"
      aria-label="Apri menu di navigazione"
      id="uc-menu-toggle"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="6" x2="20" y2="6"/>
        <line x1="4" y1="12" x2="20" y2="12"/>
        <line x1="4" y1="18" x2="20" y2="18"/>
      </svg>
    </button>
  </nav>

  <div id="mobile-nav-uc" class="lg:hidden hidden bg-[var(--surface-primary)] border-b border-[var(--line-subtle)]">
    <ul class="px-6 py-3 space-y-0.5" role="list">
      {navItems.map((item) => {
        const itemHref = resolveHref(item.href);
        const active = isActive(item.href);
        return (
          <li>
            <a
              href={itemHref}
              data-nav-solution={item.solution ?? undefined}
              class:list={[
                'block px-3 py-2.5 text-sm rounded-sm transition-colors no-underline',
                active
                  ? 'text-[var(--accent-primary)] font-medium bg-[var(--surface-secondary)]'
                  : 'text-[var(--ink-secondary)] hover:text-[var(--ink-primary)] hover:bg-[var(--surface-secondary)]',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('uc-menu-toggle');
  const nav = document.getElementById('mobile-nav-uc');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('hidden');
    });
  }
  // With 12 sections the desktop rail can scroll horizontally on smaller laptops;
  // bring the active section into view so it's never hidden off the right edge.
  function centerActiveNav() {
    const rail = document.querySelector<HTMLElement>('header nav ul.overflow-x-auto');
    const active = rail && rail.querySelector('[aria-current="page"]');
    if (!rail || !active) return;
    const li = (active.closest('li') || active) as HTMLElement;
    rail.scrollLeft = li.offsetLeft - (rail.clientWidth - li.offsetWidth) / 2;
  }
  centerActiveNav();
  document.addEventListener('astro:page-load', centerActiveNav);
</script>
