---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const cxaPillars = [
  { id: 'digital', label: 'Digital Analytics', body: 'Misura ogni interazione digitale — app, web, call center — con la profondità di Adobe Analytics.' },
  { id: 'journeys', label: 'Customer & Group Journeys', body: "Unifica il percorso cross-channel in un workspace unico: dall'app alla filiale, dal push al mutuo firmato." },
  { id: 'marketing', label: 'Marketing Planning & ROI', body: 'Attribution causale AI-powered. Ottimizza budget in-flight con segnali di conversione reali, non proxy.' },
  { id: 'content', label: 'Content Intelligence', body: 'Misura quale contenuto porta a risultati — per segmento, canale e momento del journey.' },
];

const agentCapabilities = [
  {
    icon: '◉',
    title: 'Parla la lingua del business',
    body: 'Chiedi "perché le domande di mutuo sono calate questa settimana" e ottieni la risposta con root cause analysis in minuti, non giorni.',
  },
  {
    icon: '◈',
    title: 'Grounded in truth',
    body: 'Ogni insight è verificato sul motore analitico di Adobe. Ciò che emerge è fattuale — non solo plausibile.',
  },
  {
    icon: '◇',
    title: 'Built for trust',
    body: 'Gli analisti validano e collaborano sugli insight prima che arrivino al C-suite. L\'AI amplifica il team, non lo bypassa.',
  },
  {
    icon: '◆',
    title: 'Answers why in minutes',
    body: 'Root Cause Analysis individua automaticamente le anomalie e spiega le cause — su 4 milioni di clienti, in tempo reale.',
  },
];

const everywhereChannels = [
  { name: 'AI Assistant', sub: 'Adobe nativo', color: 'var(--accent-primary)' },
  { name: 'Microsoft Copilot', sub: 'nel workspace aziendale', color: 'var(--accent-secondary)' },
  { name: 'ChatGPT', sub: 'accesso universale', color: 'var(--accent-primary)' },
  { name: 'MCP Server', sub: 'qualsiasi client AI', color: 'var(--accent-secondary)' },
  { name: 'Data Insights Agent', sub: 'embed in ogni app', color: 'var(--accent-primary)' },
];

const llmInsightsPoints = [
  { label: 'Conversazione', body: 'Analizza come i clienti interagiscono con il Brand Concierge UniCredit — quali domande fanno, dove si bloccano.' },
  { label: 'Scoperta AI-driven', body: 'Misura quanto traffico arriva da LLM (Gemini, ChatGPT) e come si comporta rispetto ai canali tradizionali.' },
  { label: 'AI Journey', body: 'Traccia il percorso di clienti che iniziano da un assistente AI esterno e completano una transazione nel digital banking.' },
];

const bankingUseCases = [
  {
    tag: 'Retail Banking',
    title: 'Offline data ingestion',
    body: 'Connetti i dati di filiale e call center ai journey digitali. Comprendi il percorso completo del cliente — anche quando passa dall\'app allo sportello.',
    solution: 'CJA',
  },
  {
    tag: 'Churn Prevention',
    title: 'Segnali precoci di abbandono',
    body: 'CJA identifica pattern di engagement che precedono il churn 14-30 giorni prima. AJO attiva automaticamente journey di retention personalizzate.',
    solution: 'CJA + AJO',
  },
  {
    tag: 'Attribution',
    title: 'Full-funnel attribution causale',
    body: 'Collega i dati pubblicitari ai segnali comportamentali per ottimizzare budget campagna con AI causale proprietaria Adobe — non last-click.',
    solution: 'Marketing Campaign Analytics',
  },
];

const funnelSteps = [
  { event: 'Accesso app', users: '4.000.000', pct: 100 },
  { event: 'Sezione Prestiti', users: '820.000', pct: 20.5 },
  { event: 'Simulazione mutuo', users: '144.000', pct: 3.6 },
  { event: 'Appuntamento', users: '28.000', pct: 0.7 },
  { event: 'Contratto firmato', users: '9.200', pct: 0.23 },
];
---
<BaseLayout
  title="Adobe CX Analytics"
  description="L'intelligenza dati che trasforma ogni decisione: Data Insights Agent, LLM Insights, Marketing Campaign Analytics — per UniCredit."
  pageSolutions={['cja']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/coworker')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="06 · ADOBE CX ANALYTICS"
        numeral="06"
        title="L'intelligenza<br/>che decide"
        lead="Non più reportistica. Insight azionabili ovunque lavori il team — dall'analista al CEO, dall'app a Microsoft Copilot."
        size="phase"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Annuncio Adobe CX Analytics ───────────────────── -->
    <Slide id="slide-cxa-brand" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-8"
        scrim="bg-[var(--accent-primary)]/85"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-4" data-reveal>SUMMIT 2026 · ANNUNCIO CHIAVE</p>
      <h2
        class="text-[var(--ink-inverse)] mb-3"
        style="font-size: clamp(1rem, 1.4vw, 1.3rem); font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase;"
        data-reveal
        data-reveal-delay="0.05"
      >
        Announcing
      </h2>
      <p
        class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-8"
        style="font-size: clamp(3rem, 6.5vw, 6rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Adobe CX Analytics
      </p>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.35rem)] text-[var(--ink-inverse)]/80 max-w-3xl mb-10"
        data-reveal
        data-reveal-delay="0.2"
      >
        La piattaforma di intelligence unificata che connette analytics digitali, journey analytics, marketing ROI e content intelligence in un'unica fondazione — alimentata da Adobe AI Platform.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-2 gap-6"
        data-reveal
        data-reveal-delay="0.3"
      >
        {cxaPillars.map((p) => (
          <div class="p-6 bg-[var(--ink-inverse)]/10 border border-[var(--ink-inverse)]/20 rounded-sm text-left">
            <p class="text-sm font-semibold text-[var(--accent-secondary)] uppercase tracking-wider mb-2">{p.label}</p>
            <p class="text-sm text-[var(--ink-inverse)]/75 leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 flex items-start gap-4 p-4 bg-[var(--ink-inverse)]/10 border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-3xl mx-auto" data-reveal data-reveal-delay="0.45">
        <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/20 flex items-center justify-center">
          <span class="text-xs font-bold text-[var(--accent-primary)]">C</span>
        </div>
        <div>
          <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-inverse)]/50 mb-1">Il CMO, in questo momento</p>
          <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-inverse)]/80 italic leading-relaxed">«Ha chiesto al Data Insights Agent: "Perché il tasso di conversione mutui è calato del 12% questa settimana?" Ha ottenuto la risposta in 30 secondi, con root cause e next action.»</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Data Insights Agent ──────────────────────────── -->
    <Slide id="slide-agent" bg="primary" align="split">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 grid md:grid-cols-2 gap-10 md:gap-14 items-center">
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>DATA INSIGHTS AGENT</p>
            <h2
              class="slide-title text-[var(--ink-primary)] mb-5"
              style="font-size: clamp(2rem, 4vw, 3.75rem);"
              data-reveal
              data-reveal-delay="0.08"
            >
              L'analista AI che risponde al "perché"
            </h2>
            <p
              class="text-[var(--ink-secondary)] leading-relaxed mb-6"
              style="font-size: clamp(1rem, 1.35vw, 1.25rem);"
              data-reveal
              data-reveal-delay="0.15"
            >
              Chiedi in linguaggio naturale. Ottieni root cause analysis in minuti — non giorni. Verificato sul motore analitico Adobe, non generato.
            </p>
            <div class="p-4 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm" data-reveal data-reveal-delay="0.22">
              <p class="text-xs font-semibold text-[var(--ink-tertiary)] uppercase tracking-wide mb-2">Esempio UniCredit</p>
              <p class="text-sm text-[var(--ink-primary)] italic">"Perché le richieste di mutuo via app sono calate del 18% questa settimana rispetto alla media?"</p>
              <p class="text-xs text-[var(--accent-primary)] mt-2 font-medium">→ Root Cause: step 3 del flow aumentato a 4.2s dopo deploy v2.3.1 · segmento 35–44 anni più impattato</p>
            </div>
          </div>

          <div class="flex flex-col gap-4" data-reveal data-reveal-delay="0.3">
            {agentCapabilities.map((cap) => (
              <div class="flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
                <span class="text-[var(--accent-primary)] text-xl flex-shrink-0 mt-0.5">{cap.icon}</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--ink-primary)] mb-1">{cap.title}</p>
                  <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{cap.body}</p>
                </div>
              </div>
            ))}

            <div class="mt-4 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm" data-reveal data-reveal-delay="0.45">
              <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
                <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
              </div>
              <div>
                <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
                <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Il consulente ha notato che Marco non aveva aperto l'email del mutuo. Il Data Insights Agent lo aveva già segnalato come at-risk — e aveva suggerito un reminder SMS per mercoledì mattina.»</p>
              </div>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="analizza-dia-demo" label="Data Insights Agent — Demo Video" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Analytics Everywhere + MCP ───────────────────── -->
    <Slide id="slide-everywhere" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-data-dark')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>ANALYTICS EVERYWHERE</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        L'intelligence<br/>ovunque lavori il team
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        Tramite MCP (Model Context Protocol), Adobe CX Analytics espone i dati di CJA e Adobe Analytics a qualsiasi AI assistant — senza export, senza integrazione custom.
      </p>

      <div
        class="w-full max-w-3xl mx-auto grid grid-cols-3 md:grid-cols-5 gap-3 mb-10"
        data-reveal
        data-reveal-delay="0.22"
      >
        {everywhereChannels.map((ch, i) => (
          <div class="p-3 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-center">
            <p class="text-xs font-semibold text-[var(--ink-inverse)] mb-0.5">{ch.name}</p>
            <p class="text-sm text-[var(--color-grigio-400)]">{ch.sub}</p>
          </div>
        ))}
      </div>

      <div class="max-w-3xl mx-auto p-5 bg-[var(--color-grigio-500)]/8 border border-[var(--color-grigio-500)]/20 rounded-sm text-left" data-reveal data-reveal-delay="0.3">
        <p class="text-xs font-semibold text-[var(--accent-secondary)] uppercase tracking-wide mb-2">Il team Digital Channels — UniCredit</p>
        <p class="text-sm text-[var(--color-grigio-300)] leading-relaxed">Il team di Digital Channels può interrogare i dati di performance dell'app UniCredit direttamente da Microsoft Copilot nel loro workflow quotidiano — senza aprire un tool di analytics separato.</p>
      </div>
    </Slide>

    <!-- ── SLIDE 4: LLM Insights ──────────────────────────────────── -->
    <Slide id="slide-llm" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>LLM INSIGHTS · NUOVA CAPABILITY</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Misurare l'era dell'AI conversazionale
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-secondary)] max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        I clienti iniziano il percorso finanziario chiedendo a Gemini o ChatGPT. LLM Insights rende questo traffico misurabile per la prima volta.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5 mb-10"
        data-reveal
        data-reveal-delay="0.22"
      >
        {llmInsightsPoints.map((p) => (
          <div class="p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-xs font-semibold text-[var(--accent-primary)] uppercase tracking-wide mb-3">{p.label}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>

      <div class="max-w-3xl p-4 bg-[var(--accent-primary)]/8 border border-[var(--accent-primary)]/20 rounded-sm" data-reveal data-reveal-delay="0.3">
        <p class="text-sm text-[var(--ink-primary)] leading-relaxed">
          <span class="font-semibold">UniCredit relevance:</span> con l'espansione del Brand Concierge nel mobile banking, LLM Insights misura l'efficacia delle conversazioni AI — tasso di completamento task, satisfaction score, conversioni da dialogo a transazione.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Banking use cases + funnel ────────────────────── -->
    <Slide id="slide-banking" bg="secondary" align="split">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 grid md:grid-cols-2 gap-10 md:gap-14 items-center">
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>USE CASE · RETAIL BANKING</p>
            <h2
              class="slide-title text-[var(--ink-primary)] mb-7"
              style="font-size: clamp(2rem, 4vw, 3.75rem);"
              data-reveal
              data-reveal-delay="0.08"
            >
              Dove si perde<br/>il valore — e perché
            </h2>
            <div class="flex flex-col gap-3" data-reveal data-reveal-delay="0.15">
              {bankingUseCases.map((uc) => (
                <div class="p-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-sm font-semibold text-[var(--accent-primary)] uppercase tracking-wider">{uc.tag}</span>
                    <span class="text-sm text-[var(--ink-tertiary)] bg-[var(--surface-secondary)] border border-[var(--line-subtle)] px-1.5 py-0.5 rounded">{uc.solution}</span>
                  </div>
                  <p class="text-xs font-semibold text-[var(--ink-primary)] mb-1">{uc.title}</p>
                  <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{uc.body}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="flex flex-col gap-1.5" data-reveal data-reveal-delay="0.3">
            <p class="text-xs font-semibold text-[var(--ink-tertiary)] uppercase tracking-wide mb-3">Funnel mutuo — dato reale UniCredit 2024</p>
            {funnelSteps.map((step) => (
              <div class="flex items-center gap-3">
                <div
                  class="h-9 bg-[var(--accent-primary)] rounded-sm flex items-center px-3 text-white text-xs font-medium flex-shrink-0 transition-all"
                  style={`width: clamp(40px, ${step.pct * 0.85 + 15}%, 100%);`}
                >
                  {step.event}
                </div>
                <div class="flex-shrink-0">
                  <span class="text-xs font-semibold text-[var(--ink-primary)]">{step.users}</span>
                  <span class="text-sm text-[var(--ink-tertiary)] ml-1">({step.pct}%)</span>
                </div>
              </div>
            ))}
            <p class="text-sm text-[var(--ink-tertiary)] mt-2">Pattern illustrativo · struttura reale UniCredit Retail Banking</p>
          </div>
        </div>
        <MediaDemoSlot id="analizza-cxa-demo" label="CX Analytics — Dashboard Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 5b: LLM Insights + Mix Modeler ─────────────────── -->
    <Slide id="slide-llm-mix" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>LLM INSIGHTS + MIX MODELER</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2rem, 4vw, 3.75rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Da dove vengono davvero i tuoi clienti migliori
      </h2>
      <p
        class="text-[clamp(1rem,1.35vw,1.25rem)] text-[var(--ink-secondary)] max-w-3xl mb-8"
        data-reveal
        data-reveal-delay="0.15"
      >
        Il 40% dei nuovi clienti PMI di UniCredit arriva da LLM. LLM Insights lo misura — il primo strumento al mondo per tracciare il percorso da una conversazione AI a una conversione bancaria.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-6 mb-8"
        data-reveal
        data-reveal-delay="0.22"
      >
        <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-xs font-semibold text-[var(--accent-primary)] uppercase tracking-wide mb-3">LLM Insights</p>
          <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Misura quanti come Marco iniziano da ChatGPT, Copilot, Perplexity. Ottimizza la presenza AI. Attribuisce il valore — da mention a mutuo.</p>
        </div>
        <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-xs font-semibold text-[var(--accent-primary)] uppercase tracking-wide mb-3">Mix Modeler</p>
          <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Causal AI + full-funnel attribution. Il reel Instagram di Sofia ha generato €2.3M di pipeline mutui prima casa. Mix Modeler lo prova.</p>
        </div>
      </div>

      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-4 mb-8"
        data-reveal
        data-reveal-delay="0.3"
      >
        {[
          { stat: "40%", label: "dei lead PMI da LLM" },
          { stat: "€2.3M", label: "pipeline tracciata al reel" },
          { stat: "15–35%", label: "miglioramento ROI marketing" },
        ].map((m) => (
          <div class="text-center p-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
            <p class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-1" style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);">{m.stat}</p>
            <p class="text-xs text-[var(--ink-secondary)]">{m.label}</p>
          </div>
        ))}
      </div>

      <div class="flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-3xl mx-auto" data-reveal data-reveal-delay="0.45">
        <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
          <span class="text-xs font-bold text-[var(--accent-primary)]">C</span>
        </div>
        <div>
          <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Il CMO, in questo momento</p>
          <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Per la prima volta, riesce a rispondere a: "Qual è il ritorno sull'investimento della nostra presenza su ChatGPT?" E la risposta è: 3.4×.»</p>
        </div>
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-30">Fonte: Adobe Mix Modeler, settore banking benchmark · proiezione su campagna mutui PMI</p>
    </Slide>

    <!-- ── SLIDE 6: Marketing Campaign Analytics ─────────────────── -->
    <Slide id="slide-campaign" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('ai-platform')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-inverse)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>MARKETING CAMPAIGN ANALYTICS · GA H2 2026</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Full-funnel. Causale. Agentico.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-10"
        data-reveal
