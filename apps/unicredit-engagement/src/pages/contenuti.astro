---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const bottlenecks = [
  { problem: 'Ciclo creativo lento', detail: 'Servono 6–8 settimane dal brief alla campagna live, e intanto il momento buono è già passato.' },
  { problem: 'Varianti insufficienti', detail: 'Una campagna vuol dire un formato, una lingua, un tono: Marco e Sofia vedono lo stesso identico messaggio.' },
  { problem: 'Brand governance fragile', detail: 'Agenzie esterne, versioni non approvate e immagini out-of-brand che finiscono sui canali regionali.' },
];

const variants = [
  { segment: 'Famiglie 35–45', headline: 'Il mutuo che cresce con la tua famiglia', tone: 'Concreto, rassicurante', cta: 'Calcola la rata →' },
  { segment: 'Neolaureati / freelance', headline: 'La tua prima casa, alla tua portata', tone: 'Empatico, ottimista', cta: 'Scopri quanto puoi mutuare →' },
  { segment: 'Pensionati 65+', headline: 'Mutuo per donare sicurezza ai tuoi figli', tone: 'Rassicurante, istituzionale', cta: 'Parla con un consulente →' },
  { segment: 'Giovani coppie 30–40', headline: 'Costruite insieme il vostro nido', tone: 'Caldo, visuale', cta: 'Inizia la simulazione →' },
];

const tools = [
  { name: 'GenStudio for Performance Marketing', role: 'Varianti di copy e layout in pochi minuti, con le brand guidelines già integrate.', tag: 'GenStudio' },
  { name: 'Adobe Firefly', role: 'Immagini brand-safe generate su licenza commerciale, senza rischi sull\'IP.', tag: 'Firefly' },
  { name: 'AEM Assets', role: 'DAM unificato: ogni asset approvato, versionato e distribuito in automatico su tutti i canali.', tag: 'AEM Assets' },
  { name: 'AEM Sites (Edge Delivery)', role: "Pubblica su web e app alla velocità dell'edge: contenuti live in minuti, Core Web Vitals nativi.", tag: 'AEM Sites' },
];

const aemAgents = [
  { name: 'Content Advisor Agent', body: 'Scopre asset, content fragment e form in linguaggio naturale e ne crea varianti pronte per ogni canale.' },
  { name: 'Site Optimization Agent', body: 'Diagnostica automaticamente i problemi del sito e suggerisce varianti di contenuto brand-compliant per acquisire più traffico.' },
  { name: 'Governance Agent', body: 'Presidia integrità di brand e compliance: policy di sicurezza, normative e di brand applicate su tutto AEM.' },
  { name: 'Brand Experience Agent', body: 'Assorbe il lavoro operativo di aggiornamento e modernizzazione delle esperienze — rilasci più rapidi.' },
];

const fireflyLayers = [
  { tag: 'Firefly Services (API)', body: 'API per automatizzare e scalare i workflow creativi — generazione, editing, reframe video — con Content Authenticity integrata.' },
  { tag: 'Firefly Custom Models', body: 'Addestrato sugli asset di brand UniCredit: visual on-brand on demand, coerenti su ogni campagna.' },
  { tag: 'Firefly Foundry', body: 'Modelli proprietari, deeply-tuned da Adobe sui contenuti UniCredit e multimodali: immagine, video, audio, vettoriale, 3D.' },
];
---
<BaseLayout
  title="Contenuti senza limiti"
  description="Con GenStudio e AEM Assets generi 12 varianti di contenuto in 2 minuti, brand-safe e su licenza."
  pageSolutions={['genstudio', 'aem-assets']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/analizza')} prevHref={href(base, '/coinvolgi')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('content-creation')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-secondary)]/82"
      />
      <CoverHero
        eyebrow="05 · CONTENUTI"
        numeral="05"
        title="Contenuti senza limiti"
        lead="12 varianti di campagna, 4 segmenti, 3 lingue, in una frazione del tempo di prima. GenStudio, AEM Sites, AEM Assets e Firefly sono la content supply chain enterprise di UniCredit."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il collo di bottiglia attuale ─────────────────── -->
    <Slide id="slide-problem" bg="primary" align="center">
      <div slot="backdrop" class="uc-bg absolute inset-0"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL PROBLEMA DI SCALA</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-9"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Campagne lente per un mondo veloce
      </h2>

      <div class="w-full max-w-5xl mx-auto" data-reveal data-reveal-delay="0.2">
        <div class="uc-thread mb-5" aria-hidden="true">
          <span class="uc-node uc-node--rosso"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node uc-node--rosso"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node uc-node--rosso"></span>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {bottlenecks.map((b) => (
            <div class="uc-panel uc-panel--rosso text-left">
              <div class="uc-panel-head">
                <span class="uc-tag">Vincolo</span>
              </div>
              <p class="text-[1.05rem] font-semibold text-[var(--color-blu-notte)] mb-2 font-[family-name:var(--font-display)]">{b.problem}</p>
              <p class="uc-panel-body" style="margin-bottom:0;">{b.detail}</p>
            </div>
          ))}
        </div>
      </div>

      <p
        class="text-[clamp(1.1rem,1.6vw,1.5rem)] font-[family-name:var(--font-display)] text-[var(--ink-secondary)] max-w-3xl mt-9"
        data-reveal
        data-reveal-delay="0.35"
      >
        Ora che AJO individua i momenti giusti, il vincolo non è più il dato ma la velocità con cui si producono i contenuti. La prima risposta di AEM sono agenti AI che lavorano accanto al team.
      </p>
    </Slide>

    <!-- ── SLIDE: AI Agents in AEM ────────────────────────────────── -->
    <Slide id="slide-aem-agents" bg="secondary" align="center" data-solution="aem-sites,aem-assets">
      <div slot="backdrop" class="uc-bg-soft absolute inset-0"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>AI AGENTS IN AEM</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-6"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Gli agenti AI dentro AEM
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-3xl mx-auto mb-8 text-base" data-reveal data-reveal-delay="0.15">
        AEM integra agenti AI specializzati che collaborano nel workflow di contenuto, su AEM as a Cloud Service ed Edge Delivery: scoprono e adattano gli asset, ottimizzano le pagine e presidiano il brand, senza rallentare il team.
      </p>
      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-5 mb-7" data-reveal data-reveal-delay="0.2">
        {aemAgents.map((a) => (
          <div class="uc-panel uc-panel--oro text-left">
            <div class="uc-panel-head">
              <span class="uc-tag">Agent</span>
              <span class="uc-node" aria-hidden="true"></span>
            </div>
            <p class="text-[1.05rem] font-semibold text-[var(--color-blu-notte)] mb-2 font-[family-name:var(--font-display)]">{a.name}</p>
            <p class="uc-panel-body" style="margin-bottom:0;">{a.body}</p>
          </div>
        ))}
      </div>
      <p class="text-sm text-[var(--ink-tertiary)] max-w-2xl mx-auto text-center" data-reveal data-reveal-delay="0.3">
        Per UniCredit la content operation passa da coda di richieste a flusso continuo, con la governance di brand sempre attiva.
      </p>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-40">
        Fonte:
        <a href="https://experienceleague.adobe.com/en/docs/experience-manager-cloud-service/content/ai-in-aem/agents/overview" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">Adobe — Agents in AEM (2025)</a>
      </p>
    </Slide>

    <!-- ── SLIDE 2: GenStudio — varianti in 2 minuti ─────────────── -->
    <Slide id="slide-genstudio" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 text-center">
          <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-[17px]" data-reveal>GENSTUDIO FOR PERFORMANCE MARKETING</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-[17px]"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
Da un brief a 12 varianti in minuti
          </h2>
          <p
            class="text-[var(--color-grigio-300)] mb-2 max-w-2xl mx-auto"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.15"
          >
            GenStudio genera copy + layout per ogni segmento, rispettando automaticamente le brand guidelines di UniCredit.
          </p>

          <div
            class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-4"
            data-reveal
            data-reveal-delay="0.2"
          >
            {variants.map((v) => (
              <div class="p-4 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-left">
                <p class="text-sm font-semibold text-[var(--accent-secondary)] uppercase tracking-wide mb-1.5">{v.segment}</p>
                <p class="text-sm font-medium text-[var(--ink-inverse)] mb-1.5 leading-snug">{v.headline}</p>
                <p class="text-sm text-[var(--color-grigio-400)] mb-2.5">Tono: {v.tone}</p>
                <span class="inline-block text-sm font-medium text-[var(--accent-primary)] bg-[var(--accent-primary)]/15 px-2 py-0.5 rounded-full">{v.cta}</span>
              </div>
            ))}
          </div>

          <div class="mt-4 pt-3.5 max-w-3xl mx-auto text-left" style="border-top:1px solid rgba(190,32,39,0.55);" data-reveal data-reveal-delay="0.45">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/10 flex items-center justify-center">
                <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
              </div>
              <div>
                <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-grigio-400)] mb-1">Sofia, in questo momento</p>
                <p class="font-[family-name:var(--font-display)] text-base text-[var(--color-grigio-300)] italic leading-snug">«Il reel ads che l'ha fatta cliccare l'ha generato GenStudio in 4 minuti, non un team creativo di 3 persone in 3 giorni.»</p>
              </div>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="contenuti-genstudio-demo" label="GenStudio — Demo Screenshot/Video" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Brand Concierge ──────────────────────────────── -->
    <Slide id="slide-brand-concierge" bg="secondary" align="center" data-solution="brand-concierge">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 text-center">
          <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-[17px]" data-reveal>ADOBE BRAND CONCIERGE</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-[17px]"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Dal menu alla conversazione
          </h2>
          <p
            class="text-[var(--ink-secondary)] mb-3 max-w-3xl mx-auto"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.15"
          >
            Brand Concierge rende app e sito UniCredit conversazionali: il cliente dialoga in linguaggio naturale, non cerca tra menu e FAQ. Powered by Adobe Experience Platform Agent Orchestrator, con risposte ancorate ai dati first-party.
          </p>

          <div
            class="grid grid-cols-2 gap-4 max-w-3xl mx-auto mb-3"
            data-reveal
            data-reveal-delay="0.2"
          >
            <div class="uc-card text-left">
              <span class="uc-mark" style="margin-bottom:0.6rem;">1</span>
              <p class="uc-card-title" style="font-size:1.05rem;margin-bottom:0.4rem;">Dialogo, non menu</p>
              <p class="uc-card-body" style="font-size:0.9rem;line-height:1.45;">Il cliente chiede "quale mutuo fa per me?" e riceve risposte guidate, non una lista di link.</p>
            </div>
            <div class="uc-card text-left">
              <span class="uc-mark" style="margin-bottom:0.6rem;">2</span>
              <p class="uc-card-title" style="font-size:1.05rem;margin-bottom:0.4rem;">Grounded &amp; brand-safe</p>
              <p class="uc-card-body" style="font-size:0.9rem;line-height:1.45;">Risposte ancorate ai dati first-party e ai contenuti approvati UniCredit: niente allucinazioni, sempre on-brand.</p>
            </div>
            <div class="uc-card text-left">
              <span class="uc-mark" style="margin-bottom:0.6rem;">3</span>
              <p class="uc-card-title" style="font-size:1.05rem;margin-bottom:0.4rem;">Architettura multi-agente</p>
              <p class="uc-card-body" style="font-size:0.9rem;line-height:1.45;">Agenti specializzati — product advisor, site advisory — collaborano dietro le quinte per un'unica esperienza.</p>
            </div>
            <div class="uc-card text-left">
              <span class="uc-mark" style="margin-bottom:0.6rem;">4</span>
              <p class="uc-card-title" style="font-size:1.05rem;margin-bottom:0.4rem;">Esperienza multimodale</p>
              <p class="uc-card-body" style="font-size:0.9rem;line-height:1.45;">Testo, immagini e video insieme: la conversazione mostra prodotti e simulazioni, non solo parole.</p>
            </div>
          </div>

          <div class="uc-quote max-w-3xl mx-auto text-left" data-reveal data-reveal-delay="0.45">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
                <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
              </div>
              <div>
                <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
                <p class="uc-quote-text text-base leading-snug">«Ha chiesto al concierge: "Quanto posso permettermi per la prima casa?" In pochi scambi aveva simulazione, rata e prossimo passo.»</p>
              </div>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="contenuti-brandconcierge-demo" label="Brand Concierge — Demo Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Stack contenuti (Firefly + AEM) ───────────────── -->
    <Slide id="slide-stack" bg="primary" align="center">
      <div slot="backdrop" class="uc-bg absolute inset-0"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL SISTEMA DI CONTENUTO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-9"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Crea, approva, distribuisci
      </h2>

      <div class="w-full max-w-6xl mx-auto" data-reveal data-reveal-delay="0.2">
        <div class="uc-thread mb-5" aria-hidden="true">
          <span class="uc-node"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node uc-node--rosso"></span>
        </div>
        <div class="grid md:grid-cols-4 gap-4">
          {tools.map((t, i) => (
            <div class="uc-panel text-left">
              <div class="uc-panel-head">
                <span class="uc-tag">{t.tag}</span>
                <span class="uc-figure" style="font-size:clamp(1.2rem,1.6vw,1.5rem);">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <p class="text-[1rem] font-semibold text-[var(--color-blu-notte)] mb-2 font-[family-name:var(--font-display)] leading-snug">{t.name}</p>
              <p class="uc-panel-body" style="margin-bottom:0;font-size:0.92rem;">{t.role}</p>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE: Adobe Firefly (enterprise) ──────────────────────── -->
    <Slide id="slide-firefly" bg="inverse" align="center" data-solution="firefly">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-5" data-reveal>ADOBE FIREFLY · ENTERPRISE</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-6"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il generativo diventa il tuo
      </h2>
      <p class="text-[var(--color-grigio-300)] leading-relaxed max-w-3xl mx-auto mb-10 text-base" data-reveal data-reveal-delay="0.15">
        Immagini, video e contenuti generati con un modello commercialmente sicuro, che diventa sempre più quello di UniCredit: dall'API al modello proprietario deeply-tuned.
      </p>
      <div class="w-full max-w-5xl mx-auto mb-10" data-reveal data-reveal-delay="0.2">
        <div class="uc-thread mb-5" aria-hidden="true">
          <span class="uc-node"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node uc-node--rosso"></span>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {fireflyLayers.map((f, i) => (
            <div class="p-6 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-left">
              <div class="flex items-baseline justify-between gap-3 mb-2">
                <p class="text-sm font-semibold text-[var(--accent-secondary)]">{f.tag}</p>
                <span class="font-[family-name:var(--font-display)] text-[var(--color-grigio-400)] leading-none" style="font-size:1.15rem;">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <p class="text-sm text-[var(--color-grigio-300)] leading-relaxed">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
      <div data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/analizza')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-inverse)] text-[var(--ink-primary)] hover:bg-[var(--color-crema)] transition-colors duration-300"
        >
          L'intelligenza dei dati
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/40">
        <span class="opacity-70">Fonte:</span>
        <a href="https://business.adobe.com/products/firefly-business/firefly-foundry.html" target="_blank" rel="noopener noreferrer" class="text-[var(--color-grigio-300)] underline underline-offset-2 hover:text-[var(--ink-inverse)]">Adobe Firefly — Foundry, Custom Models, Firefly Services (2025)</a>
      </p>
    </Slide>

  </DeckContainer>
</BaseLayout>
