---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const bottlenecks = [
  { problem: 'Ciclo creativo lento', detail: '6–8 settimane dal brief alla campagna live. Il momento di rilevanza è già passato.' },
  { problem: 'Varianti insufficienti', detail: 'Una campagna = un formato, una lingua, un tono. I segmenti di Marco e Sofia vedono lo stesso messaggio.' },
  { problem: 'Brand governance fragile', detail: 'Agenzia esterne, versioni non approvate, immagini out-of-brand sui canali regionali.' },
];

const variants = [
  { segment: 'Marco · imprenditore', headline: 'Il mutuo che sostiene la tua crescita', tone: 'Autorevole, concreto', cta: 'Calcola la rata →' },
  { segment: 'Sofia · neolaureata', headline: 'La tua prima casa. Il tuo tasso.', tone: 'Empatico, ottimista', cta: 'Scopri quanto puoi mutuare →' },
  { segment: 'Pensionati 65+', headline: 'Mutuo per donare sicurezza ai tuoi figli', tone: 'Rassicurante, istituzionale', cta: 'Parla con un consulente →' },
  { segment: 'Giovani coppie 30–40', headline: 'Costruite insieme il vostro nido', tone: 'Caldo, visuale', cta: 'Inizia la simulazione →' },
];

const tools = [
  { name: 'GenStudio for Performance Marketing', role: 'Generazione varianti copy + layout in pochi minuti, con brand guidelines integrate.', tag: 'GenStudio' },
  { name: 'Adobe Firefly', role: 'Immagini brand-safe generate su licenza commerciale — zero rischi IP.', tag: 'Firefly' },
  { name: 'AEM Assets', role: 'DAM unificato: ogni asset approvato, versionato e distribuito in automatico su tutti i canali.', tag: 'AEM Assets' },
];
---
<BaseLayout
  title="Contenuti senza limiti"
  description="GenStudio e AEM Assets permettono di generare 12 varianti di contenuto in 2 minuti, brand-safe e su licenza."
  pageSolutions={['genstudio', 'aem-assets']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/analizza')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('content-creation')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-secondary)]/82"
      />
      <CoverHero
        eyebrow="05 · CONTENUTI"
        numeral="05"
        title="Contenuti senza limiti"
        lead="12 varianti di campagna, 4 segmenti, 3 lingue — in meno di due minuti. GenStudio, Brand Concierge e AEM Assets formano il sistema di content supply chain enterprise di UniCredit."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il collo di bottiglia attuale ─────────────────── -->
    <Slide id="slide-problem" bg="primary" align="center">
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>IL PROBLEMA DI SCALA</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-10"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Campagne lente per un mondo veloce
      </h2>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5 mb-10"
        data-reveal
        data-reveal-delay="0.2"
      >
        {bottlenecks.map((b) => (
          <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-sm font-semibold text-[var(--accent-primary)] mb-3">{b.problem}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{b.detail}</p>
          </div>
        ))}
      </div>

      <p
        class="text-[clamp(1.1rem,1.6vw,1.5rem)] font-[family-name:var(--font-display)] text-[var(--ink-secondary)] max-w-3xl"
        data-reveal
        data-reveal-delay="0.35"
      >
        Con AJO che identifica i momenti giusti, il vincolo non è più il dato — è la velocità di produzione dei contenuti.
      </p>
    </Slide>

    <!-- ── SLIDE 2: GenStudio — varianti in 2 minuti ─────────────── -->
    <Slide id="slide-genstudio" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0">
          <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>GENSTUDIO FOR PERFORMANCE MARKETING</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-3"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Un brief. 12 varianti. 2 minuti.
          </h2>
          <p
            class="text-[var(--color-grigio-300)] mb-8 max-w-2xl mx-auto"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.15"
          >
            GenStudio genera copy + layout per ogni segmento, rispettando automaticamente le brand guidelines di UniCredit.
          </p>

          <div
            class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-6"
            data-reveal
            data-reveal-delay="0.2"
          >
            {variants.map((v) => (
              <div class="p-6 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-left">
                <p class="text-sm font-semibold text-[var(--accent-secondary)] uppercase tracking-wide mb-2">{v.segment}</p>
                <p class="text-sm font-medium text-[var(--ink-inverse)] mb-2 leading-snug">{v.headline}</p>
                <p class="text-sm text-[var(--color-grigio-400)] mb-3">Tono: {v.tone}</p>
                <span class="inline-block text-sm font-medium text-[var(--accent-primary)] bg-[var(--accent-primary)]/15 px-2 py-0.5 rounded-full">{v.cta}</span>
              </div>
            ))}
          </div>

          <div class="mt-8 flex items-start gap-4 p-4 bg-[var(--color-grigio-500)]/15 border-l-2 border-[var(--color-oro)] rounded-r-sm max-w-3xl mx-auto" data-reveal data-reveal-delay="0.45">
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/10 flex items-center justify-center">
              <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
            </div>
            <div>
              <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-grigio-400)] mb-1">Sofia, in questo momento</p>
              <p class="font-[family-name:var(--font-display)] text-base text-[var(--color-grigio-300)] italic leading-relaxed">«Il reel che l'ha fatta cliccare era stato generato in 4 minuti da GenStudio. Non da un team creativo di 3 persone che ci lavora 3 giorni.»</p>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="contenuti-genstudio-demo" label="GenStudio — Demo Screenshot/Video" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Brand Concierge ──────────────────────────────── -->
    <Slide id="slide-brand-concierge" bg="secondary" align="center">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0">
          <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>ADOBE BRAND CONCIERGE</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Il guardiano del brand —<br/>alimentato dall'AI
          </h2>
          <p
            class="text-[var(--ink-secondary)] mb-10 max-w-3xl mx-auto"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.15"
          >
            Ogni contenuto generato da GenStudio, ogni variante creata da Firefly, ogni campagna orchestrata da Coworker — Brand Concierge verifica che rispetti le linee guida UniCredit prima di andare live.
          </p>

          <div
            class="grid grid-cols-2 gap-5 max-w-3xl mx-auto mb-10"
            data-reveal
            data-reveal-delay="0.2"
          >
            <div class="p-6 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-sm font-semibold text-[var(--accent-primary)] mb-2">Brand Compliance AI</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Analisi automatica di ogni asset: palette, font, tono di voce, disclaimers — prima del lancio.</p>
            </div>
            <div class="p-6 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-sm font-semibold text-[var(--accent-primary)] mb-2">Guideline Management</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Le linee guida UniCredit sono il training data del sistema. Aggiornate centralmente, applicate ovunque.</p>
            </div>
            <div class="p-6 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-sm font-semibold text-[var(--accent-primary)] mb-2">Approval Workflow</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Workflow di approvazione accelerati: Brand Concierge pre-approva il 70% degli asset. Solo le eccezioni arrivano al team.</p>
            </div>
            <div class="p-6 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-sm font-semibold text-[var(--accent-primary)] mb-2">Audit Trail</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Ogni asset ha un log di compliance: chi ha approvato, quale regola ha verificato, quando.</p>
            </div>
          </div>

          <div class="mt-8 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-3xl mx-auto" data-reveal data-reveal-delay="0.45">
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
              <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
            </div>
            <div>
              <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
              <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«La proposta mutuo era stata generata da AI in 3 minuti. Brand Concierge aveva già verificato che rispettasse il tono ufficiale UniCredit e i disclaimers normativi. Il consulente l'ha inviata — senza modifiche.»</p>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="contenuti-brandconcierge-demo" label="Brand Concierge — Demo Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Stack contenuti (Firefly + AEM) ───────────────── -->
    <Slide id="slide-stack" bg="primary" align="center">
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>IL SISTEMA DI CONTENUTO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-10"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Crea, approva, distribuisci
      </h2>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-6 mb-10"
        data-reveal
        data-reveal-delay="0.2"
      >
        {tools.map((t) => (
          <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <span class="inline-block text-sm font-semibold text-[var(--accent-secondary)] bg-[var(--accent-secondary)]/15 px-2 py-0.5 rounded-full mb-3">{t.tag}</span>
            <p class="text-sm font-semibold text-[var(--ink-primary)] mb-2">{t.name}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{t.role}</p>
          </div>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/analizza')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--accent-primary)] text-[var(--ink-inverse)] hover:opacity-90 transition-opacity duration-300"
        >
          L'intelligenza dei dati
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
