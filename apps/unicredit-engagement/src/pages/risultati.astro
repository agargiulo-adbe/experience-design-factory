---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const topMetrics = [
  { stat: '19×', label: 'aumento conversioni CDP', sub: 'US Bank · campagne personalizzate vs broadcast', data: '19' },
  { stat: '+127%', label: 'nuovi conti aperti', sub: 'con onboarding digitale AJO', data: '127' },
  { stat: '10×', label: 'velocità produzione contenuti', sub: 'GenStudio vs. processo tradizionale', data: '10' },
];

const caseStudies = [
  {
    bank: 'US Bank',
    country: 'Stati Uniti',
    challenge: 'Personalizzazione campagne su 70M di clienti senza aumentare il team creativo.',
    solution: 'Adobe Real-Time CDP + Journey Optimizer + GenStudio',
    result: '19× aumento conversioni · –60% costo per acquisizione · +2700% traffico AI-driven',
    relevance: 'Dimensioni comparabili e stesso obiettivo: scala e rilevanza insieme.',
    pages: 'conosci,acquisisci,contenuti',
  },
  {
    bank: 'Itaú Unibanco',
    country: 'Brasile',
    challenge: 'Unificare i dati di 55M di clienti da 12+ sistemi legacy in un unico profilo azionabile.',
    solution: 'Adobe Experience Platform · Real-Time CDP · Customer Journey Analytics',
    result: '+42% engagement campagne personalizzate · 90% riduzione time-to-market campagne',
    relevance: 'Architettura legacy simile a quella di UniCredit e stesso stack di dati.',
    pages: 'conosci,analizza',
  },
  {
    bank: 'TSB Bank',
    country: 'UK',
    challenge: 'Aumentare la rilevanza dei touchpoint digitali senza aumentare il volume di comunicazioni.',
    solution: 'Adobe Journey Optimizer · Adobe Target · Real-Time CDP',
    result: '+31% NPS digitale · –28% opt-out email · 4× retention su clienti a rischio churn',
    relevance: 'Retail banking europeo, con focus su engagement e churn prevention.',
    pages: 'conosci,acquisisci,coinvolgi',
  },
  {
    bank: 'Deutsche Bank',
    country: 'Germania',
    challenge: "Modernizzare l'acquisizione digitale con SEO AI-driven e ridurre il time-to-market dei contenuti.",
    solution: 'AEM Sites Edge Delivery · Real-Time CDP · Customer Journey Analytics',
    result: '+45% traffico organico · –35% tempo produzione contenuti · 3× velocità go-to-market',
    relevance: 'Stesso contesto regolatorio europeo e percorso di migrazione AEM Sites.',
    pages: 'visibilita,conosci,analizza',
  },
  {
    bank: 'Crédit Agricole Italia',
    country: 'Italia',
    challenge: 'Personalizzare le comunicazioni per 3M+ clienti in un mercato retail e PMI altamente competitivo.',
    solution: 'Adobe Journey Optimizer · GenStudio for Performance Marketing · Real-Time CDP',
    result: '+67% email open rate · +42% conversioni digital lending · –30% costo per lead',
    relevance: 'Competitor diretto in Italia, stesso segmento retail e PMI, framework regolatorio identico.',
    pages: 'acquisisci,contenuti',
  },
];

const unicreditRoi = [
  { label: '€ risparmio operativo annuo', value: '+€45M', sub: 'ottimizzazione campagne + automazione contenuti' },
  { label: 'Riduzione cost per acquisition', value: '–55%', sub: 'grazie a timing e targeting precisi' },
  { label: 'Incremento CLTV medio', value: '+€1.200', sub: 'per cliente attivamente digitale' },
  { label: 'Time-to-market campagne', value: '–85%', sub: 'da 6 settimane a <1 settimana' },
];
---
<BaseLayout
  title="I risultati"
  description="19× conversioni, +127% conti digitali, 10× velocità contenuti. I benchmark banking reali con Adobe Experience Cloud."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/')} prevHref={href(base, '/motore-adobe')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('results-growth')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-inverse)]/85"
      />
      <CoverHero
        eyebrow="BUSINESS IMPACT"
        title="I risultati"
        lead="Banche di tutto il mondo misurano già l'impatto: ecco i benchmark che dicono cosa è possibile per UniCredit."
        size="hero"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 0b: Le storie di Marco e Sofia — i numeri ──────── -->
    <Slide id="slide-storie-roi" bg="primary" align="center">
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>DUE STORIE. UN SISTEMA.</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-8"
        style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        I numeri reali di Marco e Sofia
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-8"
        data-reveal
        data-reveal-delay="0.2"
      >
        <!-- Marco -->
        <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left border-t-2" style="border-top-color: var(--accent-primary);">
          <p class="text-xs font-semibold text-[var(--accent-primary)] uppercase tracking-wide mb-1">Marco Ferretti · Cliente retail · Mutuo prima casa</p>
          <div class="border-t border-[var(--line-subtle)] mt-3 pt-3 flex flex-col gap-3">
            {[
              { stat: "0,3s", label: "pagina mutuo personalizzata (AEM EDS)" },
              { stat: "87/100", label: "propensity mutuo casa al primo click" },
              { stat: "1 touchpoint AI", label: "da ChatGPT a UniCredit" },
              { stat: "0 code", label: "richiesta mutuo 100% digitale" },
              { stat: "12 anni", label: "cliente UniCredit · relazione che continua" },
            ].map((r) => (
              <div class="flex items-baseline gap-3">
                <span class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] flex-shrink-0" style="font-size: clamp(1.1rem, 1.5vw, 1.35rem);">{r.stat}</span>
                <span class="text-xs text-[var(--ink-secondary)]">{r.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Sofia -->
        <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left border-t-2" style="border-top-color: var(--color-oro);">
          <p class="text-xs font-semibold uppercase tracking-wide mb-1" style="color: var(--color-oro);">Sofia Ricci · Digital native · Primo conto</p>
          <div class="border-t border-[var(--line-subtle)] mt-3 pt-3 flex flex-col gap-3">
            {[
              { stat: "22:15", label: "conto aperto da mobile, in metro" },
              { stat: "+34% CTR", label: "funnel ottimizzato da Experimentation" },
              { stat: "6 mesi", label: "da nuovo cliente a relazione attiva" },
              { stat: "3 prodotti", label: "conto, carta, piano di risparmio" },
              { stat: "NPS 78", label: "net promoter score" },
            ].map((r) => (
              <div class="flex items-baseline gap-3">
                <span class="font-[family-name:var(--font-display)] font-light flex-shrink-0" style={`color: var(--color-oro); font-size: clamp(1.1rem, 1.5vw, 1.35rem);`}>{r.stat}</span>
                <span class="text-xs text-[var(--ink-secondary)]">{r.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: 3 metriche chiave ────────────────────────────── -->
    <Slide id="slide-metrics" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-10"
        scrim="bg-[var(--accent-primary)]/82"
      />
      <p class="slide-eyebrow text-[var(--ink-inverse)]/70 mb-8" data-reveal>BENCHMARK SETTORE BANKING</p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-8"
        data-reveal
        data-reveal-delay="0.1"
      >
        {topMetrics.map((m) => (
          <div class="text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-3"
              style="font-size: clamp(3.5rem, 7vw, 6.5rem);"
              data-display
              data-count-up={m.data}
            >
              {m.stat}
            </p>
            <p class="text-base font-medium text-[var(--ink-inverse)] mb-1">{m.label}</p>
            <p class="text-xs text-[var(--ink-inverse)]/60 leading-relaxed">{m.sub}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: US Bank Adobe CDP caso di riferimento (Adobe Summit 2024) · Adobe Experience Cloud benchmark settore bancario · benchmark produzione contenuti</p>
    </Slide>

    <!-- ── SLIDE 2: Case studies ──────────────────────────────────── -->
    <Slide id="slide-cases" bg="primary" align="center">
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>CASE STUDY BANKING</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-8"
        style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Chi ha già fatto il percorso
      </h2>

      <div
        id="case-studies-grid"
        class="w-full max-w-5xl mx-auto flex flex-wrap justify-center gap-5"
        data-reveal
        data-reveal-delay="0.2"
      >
        {caseStudies.map((cs) => (
          <div class="case-study-card p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left flex flex-col md:w-[calc(33.33%-0.84rem)]" data-cs-pages={cs.pages}>
            <div class="flex items-start justify-between gap-2 mb-3">
              <p class="text-sm font-semibold text-[var(--ink-primary)]">{cs.bank}</p>
              <span class="text-sm text-[var(--ink-tertiary)] bg-[var(--surface-secondary)] border border-[var(--line-subtle)] px-1.5 py-0.5 rounded flex-shrink-0">{cs.country}</span>
            </div>
            <p class="text-xs text-[var(--ink-tertiary)] mb-3 leading-relaxed flex-1">{cs.challenge}</p>
            <div class="border-t border-[var(--line-subtle)] pt-3 mb-3">
              <p class="text-xs font-semibold text-[var(--accent-primary)] leading-relaxed">{cs.result}</p>
            </div>
            <p class="text-sm text-[var(--ink-tertiary)] italic">{cs.relevance}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: ROI proiezione UniCredit + CTA ────────────────── -->
    <Slide id="slide-roi" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-inverse)]/85"
      />
      <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>PROIEZIONE UNICREDIT</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-8"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il ROI di Engagement Unlimited
      </h2>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-4 mb-10"
        data-reveal
        data-reveal-delay="0.2"
      >
        {unicreditRoi.map((r) => (
          <div class="flex items-center gap-5 p-5 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-secondary)] leading-none flex-shrink-0"
              style="font-size: clamp(1.75rem, 2.5vw, 2.5rem);"
            >
              {r.value}
            </p>
            <div>
              <p class="text-sm font-medium text-[var(--ink-inverse)]">{r.label}</p>
              <p class="text-xs text-[var(--color-grigio-400)] mt-0.5">{r.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-4 mb-8"
        data-reveal
        data-reveal-delay="0.28"
      >
        {[
          { value: "-68%", label: "tempo di onboarding", sub: "Da 45 minuti a 14 minuti — grazie a JO + AEM EDS" },
          { value: "+40%", label: "conversion rate", sub: "Su pagine AEM EDS vs. pagine legacy" },
          { value: "3×", label: "campagne/mese", sub: "Con lo stesso team — grazie a Coworker Campaigns (illustrativo)" },
        ].map((r) => (
          <div class="flex items-center gap-4 p-4 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm">
            <p class="font-[family-name:var(--font-display)] font-light text-[var(--accent-secondary)] leading-none flex-shrink-0" style="font-size: clamp(1.5rem, 2.2vw, 2rem);">{r.value}</p>
            <div>
              <p class="text-xs font-medium text-[var(--ink-inverse)]">{r.label}</p>
              <p class="text-sm text-[var(--color-grigio-400)] mt-0.5 leading-relaxed">{r.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-xs text-[var(--color-grigio-500)] mb-8" data-reveal data-reveal-delay="0.3">
        Proiezione basata su benchmark settore banking · US Bank, Itaú Unibanco, TSB, Deutsche Bank, Crédit Agricole Italia · adattata per portafoglio UniCredit 14M clienti retail
      </p>

      <div class="mt-8 text-center" data-reveal data-reveal-delay="0.4">
        <p class="text-sm text-[var(--color-grigio-400)] mb-2">Marco e Sofia non sono personaggi di finzione.</p>
        <p class="font-[family-name:var(--font-display)] text-lg italic text-[var(--color-grigio-300)]">«Sono i clienti che UniCredit può servire già da domani.»</p>
      </div>

      <div class="mt-8 flex flex-wrap gap-4 justify-center" data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/')}
          class="inline-flex items-center gap-2 px-5 py-2 text-xs font-medium tracking-widest uppercase border border-[var(--ink-inverse)]/30 text-[var(--ink-inverse)]/50 hover:border-[var(--ink-inverse)]/60 hover:text-[var(--ink-inverse)]/80 transition-colors duration-300 rounded-sm"
        >
          Ricomincia il percorso →
        </a>
        <a
          href={href(base.replace('/unicredit-engagement', ''), '/console/unicredit-engagement')}
          class="inline-flex items-center gap-3 px-8 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide border border-[var(--ink-inverse)]/40 text-[var(--ink-inverse)] hover:border-[var(--ink-inverse)] transition-colors duration-300"
          data-admin-only
        >
          Configura la presentazione
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="5" height="5" rx="0.5"/>
            <rect x="9" y="2" width="5" height="5" rx="0.5"/>
            <rect x="2" y="9" width="5" height="5" rx="0.5"/>
            <rect x="9" y="9" width="5" height="5" rx="0.5"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<script is:inline>
(function () {
  var STORAGE_KEY = 'edf:media-slots:unicredit-engagement';

  function filterCaseStudies() {
    var config;
    try { config = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch (_) { config = {}; }

    var activePages = new Set();
    Object.keys(config).forEach(function (slotId) {
      var cfg = config[slotId];
      if (cfg && cfg.active && cfg.url) {
        var prefix = slotId.split('-')[0];
        activePages.add(prefix);
      }
    });

    var cards = document.querySelectorAll('.case-study-card');
    if (activePages.size === 0) {
      cards.forEach(function (c) { c.style.display = ''; });
      return;
    }

    cards.forEach(function (card) {
      var pages = (card.getAttribute('data-cs-pages') || '').split(',');
      var relevant = pages.some(function (p) { return activePages.has(p.trim()); });
      card.style.display = relevant ? '' : 'none';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', filterCaseStudies);
  } else {
    filterCaseStudies();
  }
  window.addEventListener('storage', function (e) {
    if (e.key === STORAGE_KEY) filterCaseStudies();
  });
  window.addEventListener('edf:slots-updated', filterCaseStudies);
})();
</script>
