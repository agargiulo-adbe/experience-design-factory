---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const topMetrics = [
  { stat: '19×', label: 'aumento conversioni CDP', sub: 'US Bank · campagne personalizzate vs broadcast', data: '19' },
  { stat: '+127%', label: 'nuovi conti aperti', sub: 'con onboarding digitale AJO', data: '127' },
  { stat: '10×', label: 'velocità produzione contenuti', sub: 'GenStudio vs. processo tradizionale', data: '10' },
];

const caseStudies = [
  {
    bank: 'US Bank',
    country: 'Stati Uniti',
    challenge: 'Personalizzare le campagne su 70M di clienti senza ampliare il team creativo.',
    solution: 'Adobe Real-Time CDP + Journey Optimizer + GenStudio',
    result: '19× aumento conversioni · –60% costo per acquisizione · +2700% traffico AI-driven',
    relevance: 'Dimensioni comparabili, stesso obiettivo: scala e rilevanza insieme.',
    pages: 'conosci,acquisisci,contenuti',
  },
  {
    bank: 'Itaú Unibanco',
    country: 'Brasile',
    challenge: 'Unificare i dati di 55M di clienti da 12+ sistemi legacy in un profilo unico.',
    solution: 'Adobe Experience Platform · Real-Time CDP · Customer Journey Analytics',
    result: '+42% engagement campagne personalizzate · 90% riduzione time-to-market campagne',
    relevance: 'Architettura legacy e stack dati simili a UniCredit.',
    pages: 'conosci,analizza',
  },
  {
    bank: 'TSB Bank',
    country: 'UK',
    challenge: 'Aumentare la rilevanza dei touchpoint digitali senza alzare il volume di comunicazioni.',
    solution: 'Adobe Journey Optimizer · Adobe Target · Real-Time CDP',
    result: '+31% NPS digitale · –28% opt-out email · 4× retention su clienti a rischio churn',
    relevance: 'Retail banking europeo, focus su engagement e churn.',
    pages: 'conosci,acquisisci,coinvolgi',
  },
  {
    bank: 'Deutsche Bank',
    country: 'Germania',
    challenge: "Modernizzare l'acquisizione con SEO AI-driven e ridurre il time-to-market dei contenuti.",
    solution: 'AEM Sites Edge Delivery · Real-Time CDP · Customer Journey Analytics',
    result: '+45% traffico organico · –35% tempo produzione contenuti · 3× velocità go-to-market',
    relevance: 'Stesso contesto regolatorio europeo e migrazione AEM Sites.',
    pages: 'visibilita,conosci,analizza',
  },
  {
    bank: 'Crédit Agricole Italia',
    country: 'Italia',
    challenge: 'Personalizzare le comunicazioni per 3M+ clienti in un mercato retail e PMI competitivo.',
    solution: 'Adobe Journey Optimizer · GenStudio for Performance Marketing · Real-Time CDP',
    result: '+67% email open rate · +42% conversioni digital lending · –30% costo per lead',
    relevance: 'Competitor diretto in Italia, stesso segmento retail e PMI.',
    pages: 'acquisisci,contenuti',
  },
];

const unicreditRoi = [
  { label: 'Costi operativi', value: '↓', sub: 'ottimizzazione campagne + automazione contenuti' },
  { label: 'Costo per acquisition', value: '↓', sub: 'timing e targeting più precisi' },
  { label: 'Customer lifetime value', value: '↑', sub: 'per cliente attivamente digitale' },
  { label: 'Time-to-market campagne', value: '↓', sub: 'da settimane a giorni' },
];
---
<BaseLayout
  title="I risultati"
  description="19× conversioni, +127% conti digitali, 10× velocità contenuti. I benchmark banking reali con Adobe Experience Cloud."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/')} prevHref={href(base, '/motore-adobe')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('results-growth')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-inverse)]/85"
      />
      <CoverHero
        eyebrow="BUSINESS IMPACT"
        title="I risultati"
        lead="Banche di tutto il mondo misurano già l'impatto: ecco i benchmark che dicono cosa è possibile per UniCredit."
        size="hero"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 0b: Le storie di Marco e Sofia — i numeri ──────── -->
    <Slide id="slide-storie-roi" bg="primary" align="center">
      <div class="ris-bg" data-slide-bg aria-hidden="true"></div>
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>DUE STORIE. UN SISTEMA.</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-8"
        style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        I numeri reali di Marco e Sofia
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-8"
        data-reveal
        data-reveal-delay="0.2"
      >
        <!-- Marco -->
        <div class="uc-panel uc-panel--rosso text-left">
          <div class="uc-panel-head">
            <span class="uc-tag">Marco Ferretti · Cliente retail</span>
            <span class="ris-persona-note">Mutuo prima casa</span>
          </div>
          <div class="ris-rows">
            {[
              { stat: "0,3s", label: "pagina mutuo personalizzata (AEM EDS)" },
              { stat: "87/100", label: "propensity mutuo casa al primo click" },
              { stat: "1 touchpoint AI", label: "da ChatGPT a UniCredit" },
              { stat: "0 code", label: "richiesta mutuo 100% digitale" },
              { stat: "12 anni", label: "cliente UniCredit · relazione che continua" },
            ].map((r) => (
              <div class="ris-row">
                <span class="ris-row-fig ris-row-fig--rosso">{r.stat}</span>
                <span class="ris-row-label">{r.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Sofia -->
        <div class="uc-panel uc-panel--oro text-left">
          <div class="uc-panel-head">
            <span class="uc-tag ris-tag--oro">Sofia Ricci · Digital native</span>
            <span class="ris-persona-note">Primo conto</span>
          </div>
          <div class="ris-rows">
            {[
              { stat: "22:15", label: "conto aperto da mobile, in metro" },
              { stat: "variante B", label: "vincente, funnel ottimizzato da Experimentation" },
              { stat: "6 mesi", label: "da nuovo cliente a relazione attiva" },
              { stat: "3 prodotti", label: "conto, carta, piano di risparmio" },
              { stat: "promotrice", label: "consiglia UniCredit a chi conosce" },
            ].map((r) => (
              <div class="ris-row">
                <span class="ris-row-fig ris-row-fig--oro">{r.stat}</span>
                <span class="ris-row-label">{r.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: 3 metriche chiave ────────────────────────────── -->
    <Slide id="slide-metrics" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-10"
        scrim="bg-[var(--accent-primary)]/82"
      />
      <p class="slide-eyebrow text-[var(--ink-inverse)]/70 mb-8" data-reveal>BENCHMARK SETTORE BANKING</p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-8"
        data-reveal
        data-reveal-delay="0.1"
      >
        {topMetrics.map((m) => (
          <div class="text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-3"
              style="font-size: clamp(3.5rem, 7vw, 6.5rem);"
              data-display
              data-count-up={m.data}
            >
              {m.stat}
            </p>
            <p class="text-base font-medium text-[var(--ink-inverse)] mb-1">{m.label}</p>
            <p class="text-xs text-[var(--ink-inverse)]/60 leading-relaxed">{m.sub}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: US Bank Adobe CDP caso di riferimento (Adobe Summit 2024) · Adobe Experience Cloud benchmark settore bancario · benchmark produzione contenuti</p>
    </Slide>

    <!-- ── SLIDE 2: Case studies ──────────────────────────────────── -->
    <Slide id="slide-cases" bg="primary" align="center">
      <div class="ris-bg" data-slide-bg aria-hidden="true"></div>
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>CASE STUDY BANKING</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-4"
        style="font-size: clamp(1.85rem, 3vw, 2.85rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Chi ha già fatto il percorso
      </h2>

      <div
        id="case-studies-grid"
        class="w-full max-w-6xl mx-auto flex flex-wrap justify-center gap-4"
        data-reveal
        data-reveal-delay="0.2"
      >
        {caseStudies.map((cs) => (
          <div class="case-study-card uc-panel uc-panel--rosso text-left md:w-[calc(33.33%-0.7rem)]" data-cs-pages={cs.pages}>
            <div class="uc-panel-head ris-case-head">
              <span class="uc-figure ris-case-bank">{cs.bank}</span>
              <span class="ris-case-country">{cs.country}</span>
            </div>
            <p class="ris-case-challenge">{cs.challenge}</p>
            <p class="ris-case-result">{cs.result}</p>
            <p class="ris-case-relevance">{cs.relevance}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: ROI proiezione UniCredit + CTA ────────────────── -->
    <Slide id="slide-roi" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-inverse)]/85"
      />
      <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>PROIEZIONE UNICREDIT</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-4"
        style="font-size: clamp(2rem, 3.2vw, 3rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il ROI di Engagement Unlimited
      </h2>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-3 mb-3"
        data-reveal
        data-reveal-delay="0.2"
      >
        {unicreditRoi.map((r) => (
          <div class="ris-roi-row">
            <p class="ris-roi-arrow">{r.value}</p>
            <div class="min-w-0">
              <p class="ris-roi-label">{r.label}</p>
              <p class="ris-roi-sub">{r.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-3 mb-3"
        data-reveal
        data-reveal-delay="0.28"
      >
        {[
          { value: "↓", label: "tempo di onboarding", sub: "guidato da JO + AEM EDS" },
          { value: "↑", label: "conversion rate", sub: "pagine AEM EDS vs. pagine legacy" },
          { value: "↑", label: "campagne al mese", sub: "con lo stesso team, grazie a Coworker" },
        ].map((r) => (
          <div class="ris-roi-row">
            <p class="ris-roi-arrow ris-roi-arrow--sm">{r.value}</p>
            <div class="min-w-0">
              <p class="ris-roi-label ris-roi-label--sm">{r.label}</p>
              <p class="ris-roi-sub ris-roi-sub--lg">{r.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="ris-roi-note" data-reveal data-reveal-delay="0.3">
        Proiezione basata su benchmark settore banking · US Bank, Itaú Unibanco, TSB, Deutsche Bank, Crédit Agricole Italia · adattata per il portafoglio retail UniCredit
      </p>

      <div class="mt-3 text-center" data-reveal data-reveal-delay="0.4">
        <p class="text-sm text-[var(--color-grigio-400)]">Marco e Sofia non sono personaggi di finzione: <span class="font-[family-name:var(--font-display)] italic text-[var(--color-grigio-300)]">«sono i clienti che UniCredit può servire già da domani.»</span></p>
      </div>

      <div class="mt-4 flex flex-wrap gap-4 justify-center" data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/')}
          class="inline-flex items-center gap-2 px-5 py-2 text-xs font-medium tracking-widest uppercase border border-[var(--ink-inverse)]/30 text-[var(--ink-inverse)]/50 hover:border-[var(--ink-inverse)]/60 hover:text-[var(--ink-inverse)]/80 transition-colors duration-300 rounded-sm"
        >
          Ricomincia il percorso →
        </a>
        <a
          href={href(base.replace('/unicredit-engagement', ''), '/console/unicredit-engagement')}
          class="inline-flex items-center gap-3 px-8 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide border border-[var(--ink-inverse)]/40 text-[var(--ink-inverse)] hover:border-[var(--ink-inverse)] transition-colors duration-300"
          data-admin-only
        >
          Configura la presentazione
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="5" height="5" rx="0.5"/>
            <rect x="9" y="2" width="5" height="5" rx="0.5"/>
            <rect x="2" y="9" width="5" height="5" rx="0.5"/>
            <rect x="9" y="9" width="5" height="5" rx="0.5"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* Depth wash under the light slides (the filo, applied per-slide). */
  .ris-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(120% 75% at 12% 0%, rgba(190,32,39,0.05), transparent 55%),
      radial-gradient(115% 85% at 90% 100%, rgba(201,169,110,0.12), transparent 55%);
  }
  .ris-bg + * { position: relative; z-index: 1; }

  /* Persona panels — rows of designed data figures. */
  .ris-persona-note { font-size: 0.78rem; color: var(--color-grigio-400); letter-spacing: 0.02em; }
  .ris-tag--oro { color: var(--color-oro); }
  .ris-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .ris-row { display: flex; align-items: baseline; gap: 0.75rem; }
  .ris-row-fig {
    font-family: var(--font-display);
    font-weight: 600;
    flex-shrink: 0;
    font-size: clamp(1.15rem, 1.6vw, 1.4rem);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .ris-row-fig--rosso { color: var(--color-rosso); }
  .ris-row-fig--oro { color: var(--color-oro); }
  .ris-row-label { font-size: 0.95rem; line-height: 1.4; color: var(--color-blu-medio); }

  /* Case-study panels — bank as figure, benchmark result in rosso. */
  .ris-case-head { align-items: baseline; }
  .ris-case-bank { font-size: clamp(1.05rem, 1.4vw, 1.3rem); }
  .ris-case-country {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-grigio-400);
    flex-shrink: 0;
  }
  .ris-case-challenge { font-size: 0.95rem; line-height: 1.5; color: var(--color-blu-medio); margin-bottom: 0.7rem; flex: 1; }
  .ris-case-result {
    font-size: 0.98rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--color-rosso);
    padding-top: 0.7rem;
    border-top: 1px solid rgba(190,32,39,0.28);
    margin-bottom: 0.55rem;
  }
  .ris-case-relevance { font-size: 0.9rem; line-height: 1.4; font-style: italic; color: var(--color-grigio-500); }

  /* ROI rows on the dark closing slide — readable greys, oro arrow. */
  .ris-roi-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem;
    min-width: 0;
    background: rgba(107,114,128,0.12);
    border: 1px solid rgba(107,114,128,0.25);
    border-radius: 4px;
  }
  .ris-roi-arrow {
    font-family: var(--font-display);
    font-weight: 300;
    color: var(--color-oro);
    line-height: 1;
    flex-shrink: 0;
    font-size: clamp(1.5rem, 2.1vw, 2.1rem);
  }
  .ris-roi-arrow--sm { font-size: clamp(1.4rem, 1.9vw, 1.85rem); }
  .ris-roi-label { font-size: 0.95rem; font-weight: 500; color: var(--color-crema); }
  .ris-roi-label--sm { font-size: 0.9rem; }
  .ris-roi-sub { font-size: 0.85rem; line-height: 1.4; color: var(--color-grigio-300); margin-top: 0.15rem; }
  .ris-roi-sub--lg { font-size: 0.95rem; }
  .ris-roi-note { font-size: 0.8rem; line-height: 1.45; color: var(--color-grigio-300); max-width: none; }
</style>

<script is:inline>
(function () {
  var STORAGE_KEY = 'edf:media-slots:unicredit-engagement';

  function filterCaseStudies() {
    var config;
    try { config = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch (_) { config = {}; }

    var activePages = new Set();
    Object.keys(config).forEach(function (slotId) {
      var cfg = config[slotId];
      if (cfg && cfg.active && cfg.url) {
        var prefix = slotId.split('-')[0];
        activePages.add(prefix);
      }
    });

    var cards = document.querySelectorAll('.case-study-card');
    if (activePages.size === 0) {
      cards.forEach(function (c) { c.style.display = ''; });
      return;
    }

    cards.forEach(function (card) {
      var pages = (card.getAttribute('data-cs-pages') || '').split(',');
      var relevant = pages.some(function (p) { return activePages.has(p.trim()); });
      card.style.display = relevant ? '' : 'none';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', filterCaseStudies);
  } else {
    filterCaseStudies();
  }
  window.addEventListener('storage', function (e) {
    if (e.key === STORAGE_KEY) filterCaseStudies();
  });
  window.addEventListener('edf:slots-updated', filterCaseStudies);
})();
</script>
