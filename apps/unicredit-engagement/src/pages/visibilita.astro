---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const llmStats = [
  { num: '−25%', desc: 'volume atteso sui motori di ricerca tradizionali entro il 2026, sostituiti dagli assistenti AI', source: 'Gartner, feb 2024', url: 'https://www.gartner.com/en/newsroom/press-releases/2024-02-19-gartner-predicts-search-engine-volume-will-drop-25-percent-by-2026-due-to-ai-chatbots-and-other-virtual-agents' },
  { num: '+1.200%', desc: 'referral traffic proveniente dagli AI Assistant in un anno', source: 'Adobe Analytics, 2025', url: 'https://blog.adobe.com/en/publish/2025/03/17/adobe-analytics-traffic-to-us-retail-websites-from-generative-ai-sources-jumps-1200-percent' },
  { num: '−33%', desc: 'bounce rate dei visitatori che arrivano dagli AI Assistant — restano più a lungo, vedono più pagine', source: 'Adobe Analytics, 2025', url: 'https://blog.adobe.com/en/publish/2025/03/17/adobe-analytics-traffic-to-us-retail-websites-from-generative-ai-sources-jumps-1200-percent' },
];

const brandVisibilityPillars = [
  { title: 'Visibilità AI completa', body: 'Come UniCredit compare su 10 famiglie di LLM — ChatGPT, Perplexity, Gemini, Copilot, Google AI Mode. I log della CDN mostrano cosa leggono gli agenti; le descrizioni sbagliate emergono subito.' },
  { title: 'Intelligence guidata dalla SEO', body: 'Il query fan-out di Semrush trova dove UniCredit ha autorità SEO ma sparisce dalle risposte AI. 289 milioni di prompt reali diventano brief di contenuto già prioritizzati.' },
  { title: 'Ottimizzazioni su ogni superficie', body: 'Modifiche pubblicate in pochi minuti: all’edge della CDN per gli agenti, senza toccare il CMS, oppure alla fonte per il sito. E la presenza si estende anche off-site.' },
  { title: 'Misurazione ad anello chiuso', body: 'Ogni azione collegata a menzioni, citazioni e ricavo. Integrazione nativa con Adobe Analytics e CJA: dalla visibilità AI alla pipeline commerciale.' },
];

const edsMetrics = [
  { num: '100/100', label: 'Lighthouse score', sub: 'su tutti i dispositivi' },
  { num: '0.3s', label: 'First Contentful Paint', sub: 'vs. 3.2s media settore bancario' },
  { num: '+40%', label: 'Conversion rate', sub: 'su pagine EDS vs. pagine legacy' },
];

const optimizerPillars = [
  { title: 'SEO', body: 'Individua keyword mancanti, link rotti e metadati incompleti, insieme ad altre opportunità di ottimizzazione.' },
  { title: 'Contenuti e conversioni', body: 'Valuta la qualità dei contenuti, suggerisce come renderli più efficaci e valida le modifiche con test A/B.' },
  { title: 'Accessibilità', body: 'Verifica automatica della conformità WCAG: segnala criticità come le immagini senza testo alternativo e propone la correzione.' },
  { title: 'Performance', body: 'Monitora di continuo i Core Web Vitals e le prestazioni di pagina, indicando le aree su cui intervenire.' },
];
---
<BaseLayout
  title="Essere trovati — nell'era dell'AI"
  description="Prima ancora che Marco apra il browser. Quando chiede a ChatGPT. Adobe Brand Visibility, AEM EDS, AEM Sites Optimizer."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/conosci')} prevHref={href(base, '/scenario')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="01 · VISIBILITÀ"
        numeral="01"
        title="Essere trovati — nell'era dell'AI"
        lead="Prima ancora che Marco apra il browser. Quando chiede a ChatGPT."
        size="phase"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il dato ───────────────────────────────────────── -->
    <Slide id="slide-data" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL CAMBIAMENTO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-10"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        La ricerca non parte più da Google
      </h2>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-3 gap-6 mb-10" data-reveal data-reveal-delay="0.2">
        {llmStats.map((s) => (
          <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-3"
              style="font-size: clamp(2.5rem, 4.5vw, 4rem);"
            >{s.num}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed mb-2">{s.desc}</p>
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--ink-tertiary)] font-medium underline underline-offset-2 hover:text-[var(--accent-primary)]">{s.source}</a>
          </div>
        ))}
      </div>
      <div class="mt-4 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-2xl mx-auto" data-reveal data-reveal-delay="0.45">
        <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
          <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
        </div>
        <div>
          <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
          <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Ha digitato su ChatGPT: "Miglior banca per il mutuo della prima casa in Italia." UniCredit era la prima risposta. Era lì — non per caso.»</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Marco's moment ───────────────────────────────── -->
    <Slide id="slide-marco-moment" bg="secondary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="flex items-center justify-center">
          <div class="bg-[var(--surface-inverse)] text-[var(--ink-inverse)] rounded-sm p-6 font-mono text-sm leading-relaxed max-w-sm w-full">
            <p class="text-[var(--ink-inverse)]/50 text-xs mb-4">ChatGPT · 09:42</p>
            <p class="text-[var(--ink-inverse)]/80 mb-3">🔍 "miglior banca mutuo prima casa italia"</p>
            <div class="bg-[var(--ink-inverse)]/5 rounded p-3 border border-[var(--ink-inverse)]/10">
              <p class="text-[var(--color-oro)] font-semibold mb-1">UniCredit</p>
              <p class="text-xs text-[var(--ink-inverse)]/70">Ottima scelta per il mutuo prima casa: tassi competitivi, consulenza dedicata e richiesta 100% digitale...</p>
            </div>
          </div>
        </div>
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>LA STORIA DI MARCO · PASSO 1 DI 10</p>
          <p class="slide-eyebrow text-[var(--ink-tertiary)] mb-3 text-xs" data-reveal data-reveal-delay="0.05">ADOBE BRAND VISIBILITY</p>
          <h3
            class="text-[var(--ink-primary)] mb-5"
            style="font-size: clamp(1.6rem, 2.8vw, 2.6rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            UniCredit era lì — per design, non per fortuna
          </h3>
          <ul class="space-y-3" data-reveal data-reveal-delay="0.2">
            <li class="flex items-start gap-3">
              <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Monitoraggio continuo sui principali motori LLM (ChatGPT, Perplexity, Gemini, Copilot e altri)</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Contenuti resi leggibili e citabili dai modelli AI</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Dal primo click AI fino alla conversione, tutto tracciato</p>
            </li>
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Adobe Brand Visibility (Adobe + Semrush) ─────── -->
    <Slide id="slide-brand-visibility" bg="primary" align="split" data-solution="brand-visibility">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-[0.9fr_1.1fr] gap-10 md:gap-14 items-center">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>ADOBE BRAND VISIBILITY · ADOBE + SEMRUSH</p>
          <h2
            class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.9rem, 3vw, 2.9rem); line-height: 1.08;"
            data-reveal
            data-reveal-delay="0.1"
          >
            Non basta misurare la visibilità AI: bisogna cambiarla
          </h2>
          <p class="text-[var(--ink-secondary)] leading-relaxed text-base" data-reveal data-reveal-delay="0.15">
            Adobe e Semrush in un'unica piattaforma, dall'analisi all'azione fino al ricavo: 289 milioni di prompt reali, ottimizzazioni all'edge e alla fonte, ogni intervento legato a un risultato di business.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4" data-reveal data-reveal-delay="0.22">
          {brandVisibilityPillars.map((p) => (
            <div class="p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-[1.05rem] font-bold text-[var(--accent-primary)] mb-1.5">{p.title}</p>
              <p class="text-[0.95rem] text-[var(--ink-secondary)] leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 5: AEM Sites EDS ─────────────────────────────────── -->
    <Slide id="slide-eds" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-data-dark')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 text-center">
          <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-5" data-reveal>AEM SITES EDGE DELIVERY</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-5"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            0.3 secondi. Non 3.2 secondi.
          </h2>
          <p class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/80 max-w-2xl mx-auto mb-10" data-reveal data-reveal-delay="0.15">
            Quando Marco clicca il link di ChatGPT, ha già 3 banche aperte. La velocità decide chi rimane.
          </p>
          <div class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6 mb-8" data-reveal data-reveal-delay="0.2">
            {edsMetrics.map((m) => (
              <div class="p-6 bg-[var(--ink-inverse)]/5 border border-[var(--ink-inverse)]/15 rounded-sm text-center">
                <p
                  class="font-[family-name:var(--font-display)] font-light text-[var(--accent-secondary)] leading-none mb-2"
                  style="font-size: clamp(2rem, 3.5vw, 3rem);"
                >{m.num}</p>
                <p class="text-xs font-semibold text-[var(--ink-inverse)] mb-1">{m.label}</p>
                <p class="text-sm text-[var(--ink-inverse)]/60">{m.sub}</p>
              </div>
            ))}
          </div>
          <p class="text-xs text-center text-[var(--ink-inverse)]/50 tracking-wider" data-reveal data-reveal-delay="0.35">
Contenuti serviti all'edge · CDN gestita da Adobe o propria (BYO) · Sviluppo web su standard aperti (JS/CSS) · Deployment rapidissimi
          </p>
          <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: AEM Edge Delivery Services benchmarks 2024 · Google CrUX, settore banking IT</p>
        </div>
        <MediaDemoSlot id="visibilita-aem-demo" label="AEM Sites EDS — Performance Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 6: AEM Sites Optimizer ──────────────────────────── -->
    <Slide id="slide-optimizer" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-[0.85fr_1.15fr] gap-10 md:gap-14 items-center">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>AEM SITES OPTIMIZER</p>
          <h2
            class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.9rem, 3vw, 2.9rem); line-height: 1.08;"
            data-reveal
            data-reveal-delay="0.1"
          >
            Dove migliorare, pagina per pagina
          </h2>
          <p class="text-[var(--ink-secondary)] leading-relaxed text-base mb-5" data-reveal data-reveal-delay="0.15">
            Analizza ogni pagina e aiuta i team marketing e contenuti a capire dove intervenire, con azioni concrete e già prioritizzate.
          </p>
          <p class="text-sm text-[var(--ink-tertiary)] leading-relaxed mb-6" data-reveal data-reveal-delay="0.2">
            Parte della suite AEM Sites: analisi automatica, continua e integrata nel workflow editoriale.
          </p>
          <div data-reveal data-reveal-delay="0.35">
            <a
              href={href(base, '/conosci')}
              class="text-sm text-[var(--accent-primary)] hover:underline font-medium"
            >
              Prossimo capitolo: UniCredit conosce già Marco →
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-5" data-reveal data-reveal-delay="0.22">
          {optimizerPillars.map((p) => (
            <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-base font-bold text-[var(--accent-primary)] mb-1.5">{p.title}</p>
              <p class="text-[0.95rem] text-[var(--ink-secondary)] leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
