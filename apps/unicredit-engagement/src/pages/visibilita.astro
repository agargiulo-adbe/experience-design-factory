---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const llmStats = [
  { num: '40%', desc: 'delle ricerche finanziarie parte da ChatGPT, Perplexity, Copilot — non da Google', source: 'Gartner, 2025' },
  { num: '2-3×', desc: 'più traffico qualificato per i brand misurabili nei modelli AI', source: 'Adobe Research, 2025' },
  { num: '67%', desc: 'dei consumatori si fida della risposta AI più di quella organica', source: 'Forrester, 2025' },
];

const llmCapabilities = [
  { title: 'AI Brand Monitoring', body: 'Monitora in tempo reale come ChatGPT, Gemini, Copilot, Perplexity descrivono UniCredit. Ogni giorno. Ogni query.' },
  { title: 'Content Optimization', body: 'Ottimizza il contenuto editoriale perché sia citable dai modelli AI — non per i robot, per le persone che li usano.' },
  { title: 'Competitive Intelligence', body: 'Confronta la presenza AI di UniCredit con quella di Intesa, BancoBPM, Fineco. In tempo reale.' },
  { title: 'LLM Attribution', body: 'Traccia il percorso da mention AI a lead a conversione. Marco viene da ChatGPT — ora lo sai.' },
];

const semrushUseCases = [
  { title: 'Keyword tracking PMI/Retail' },
  { title: 'AI Overviews monitoring (Google SGE)' },
  { title: 'Gap analysis competitivo' },
  { title: 'Integrazione diretta in AEM Sites Optimizer' },
];

const edsMetrics = [
  { num: '100/100', label: 'Lighthouse score', sub: 'su tutti i dispositivi' },
  { num: '0.3s', label: 'First Contentful Paint', sub: 'vs. 3.2s media settore bancario' },
  { num: '+40%', label: 'Conversion rate', sub: 'su pagine EDS vs. pagine legacy' },
];

const optimizerPillars = [
  { title: 'SEO Intelligence', body: 'Monitoraggio ranking + gap analysis automatica' },
  { title: 'Conversion Optimization', body: 'A/B insights, CTA scoring, funnel analysis' },
  { title: 'Accessibility Audit', body: 'WCAG 2.2 auto-check su ogni pagina' },
  { title: 'Content Quality Score', body: 'Leggibilità, struttura, intent matching' },
];
---
<BaseLayout
  title="Essere trovati — nell'era dell'AI"
  description="Prima ancora che Marco apra il browser. Quando chiede a ChatGPT. LLM Optimizer, AEM EDS, AEM Sites Optimizer."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/conosci')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="01 · VISIBILITÀ"
        numeral="01"
        title="Essere trovati — nell'era dell'AI"
        lead="Prima ancora che Marco apra il browser. Quando chiede a ChatGPT."
        size="phase"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il dato ───────────────────────────────────────── -->
    <Slide id="slide-data" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL CAMBIAMENTO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-10"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il 40% delle ricerche inizia da un LLM
      </h2>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-3 gap-6 mb-10" data-reveal data-reveal-delay="0.2">
        {llmStats.map((s) => (
          <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-3"
              style="font-size: clamp(2.5rem, 4.5vw, 4rem);"
            >{s.num}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed mb-2">{s.desc}</p>
            <p class="text-sm text-[var(--ink-tertiary)] font-medium">{s.source}</p>
          </div>
        ))}
      </div>
      <div class="mt-4 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-2xl mx-auto" data-reveal data-reveal-delay="0.45">
        <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
          <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
        </div>
        <div>
          <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
          <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Ha digitato su ChatGPT: "Miglior banca per mutuo commerciale PMI Italia 2026." UniCredit era la prima risposta. Era lì — non per caso.»</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Marco's moment ───────────────────────────────── -->
    <Slide id="slide-marco-moment" bg="secondary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="flex items-center justify-center">
          <div class="bg-[var(--surface-inverse)] text-[var(--ink-inverse)] rounded-sm p-6 font-mono text-sm leading-relaxed max-w-sm w-full">
            <p class="text-[var(--ink-inverse)]/50 text-xs mb-4">ChatGPT · 09:42</p>
            <p class="text-[var(--ink-inverse)]/80 mb-3">🔍 "miglior banca mutuo commerciale pmi italia"</p>
            <div class="bg-[var(--ink-inverse)]/5 rounded p-3 border border-[var(--ink-inverse)]/10">
              <p class="text-[var(--color-oro)] font-semibold mb-1">UniCredit</p>
              <p class="text-xs text-[var(--ink-inverse)]/70">Ottima soluzione per mutui PMI: prodotti dedicati, consulenza specializzata, approvazione media 3 giorni...</p>
            </div>
          </div>
        </div>
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>LA STORIA DI MARCO · PASSO 1 DI 10</p>
          <p class="slide-eyebrow text-[var(--ink-tertiary)] mb-3 text-xs" data-reveal data-reveal-delay="0.05">LLM OPTIMIZER</p>
          <h3
            class="text-[var(--ink-primary)] mb-5"
            style="font-size: clamp(1.6rem, 2.8vw, 2.6rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            UniCredit era lì — per design, non per fortuna
          </h3>
          <ul class="space-y-3" data-reveal data-reveal-delay="0.2">
            <li class="flex items-start gap-3">
              <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Monitoraggio continuo su ChatGPT, Copilot, Perplexity, Gemini</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Ottimizzazione contenuti per citabilità dai modelli AI</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Misurazione ROI: da mention AI a conversione</p>
            </li>
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Adobe LLM Optimizer ──────────────────────────── -->
    <Slide id="slide-llm-optimizer" bg="primary" align="center">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 text-center">
          <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>ADOBE LLM OPTIMIZER</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-10"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Essere la risposta — non solo il link
          </h2>
          <div class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-5 mb-10" data-reveal data-reveal-delay="0.2">
            {llmCapabilities.map((cap) => (
              <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
                <p class="text-sm font-bold text-[var(--accent-primary)] mb-2">{cap.title}</p>
                <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{cap.body}</p>
              </div>
            ))}
          </div>
          <div class="mt-4 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-2xl mx-auto" data-reveal data-reveal-delay="0.45">
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
              <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
            </div>
            <div>
              <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
              <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«2 minuti dopo la risposta ChatGPT, Marco clicca su unicredit.it. Il sito si apre in 0.3 secondi. La pagina mutui PMI è personalizzata per lui.»</p>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="visibilita-llm-demo" label="LLM Optimizer — Screenshot prodotto" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: Semrush ───────────────────────────────────────── -->
    <Slide id="slide-semrush" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>SEMRUSH × ADOBE</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-6"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        SEO + AI Overviews + Competitive Intelligence — un'unica visione
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-8 text-base" data-reveal data-reveal-delay="0.15">
        L'integrazione Semrush-Adobe porta l'intelligence SEO direttamente nel workflow editoriale. Da AEM, il team di contenuto vede in tempo reale il gap di visibilità — e lo colma.
      </p>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-2 gap-6 mb-6" data-reveal data-reveal-delay="0.2">
        {semrushUseCases.map((u) => (
          <div class="p-7 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-center">
            <p class="text-base font-semibold text-[var(--ink-primary)] leading-snug">{u.title}</p>
          </div>
        ))}
      </div>
      <p class="text-sm text-[var(--ink-tertiary)] max-w-2xl mx-auto text-center" data-reveal data-reveal-delay="0.3">
        UniCredit recupera visibilità organica perduta nei 6 mesi precedenti — identificata con Semrush, corretta con AEM Sites Optimizer.
      </p>
    </Slide>

    <!-- ── SLIDE 5: AEM Sites EDS ─────────────────────────────────── -->
    <Slide id="slide-eds" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-data-dark')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 text-center">
          <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-5" data-reveal>AEM SITES EDGE DELIVERY</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-5"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            0.3 secondi. Non 3.2 secondi.
          </h2>
          <p class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/80 max-w-2xl mx-auto mb-10" data-reveal data-reveal-delay="0.15">
            Quando Marco clicca il link di ChatGPT, ha già 3 banche aperte. La velocità decide chi rimane.
          </p>
          <div class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6 mb-8" data-reveal data-reveal-delay="0.2">
            {edsMetrics.map((m) => (
              <div class="p-6 bg-[var(--ink-inverse)]/5 border border-[var(--ink-inverse)]/15 rounded-sm text-center">
                <p
                  class="font-[family-name:var(--font-display)] font-light text-[var(--accent-secondary)] leading-none mb-2"
                  style="font-size: clamp(2rem, 3.5vw, 3rem);"
                >{m.num}</p>
                <p class="text-xs font-semibold text-[var(--ink-inverse)] mb-1">{m.label}</p>
                <p class="text-sm text-[var(--ink-inverse)]/60">{m.sub}</p>
              </div>
            ))}
          </div>
          <p class="text-xs text-center text-[var(--ink-inverse)]/50 tracking-wider" data-reveal data-reveal-delay="0.35">
            Content at the edge · Git-based authoring · Zero CMS overhead · Cloudflare CDN
          </p>
          <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: AEM Edge Delivery Services benchmarks 2024 · Google CrUX, settore banking IT · Adobe Commerce benchmark</p>
        </div>
        <MediaDemoSlot id="visibilita-aem-demo" label="AEM Sites EDS — Performance Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 6: AEM Sites Optimizer ──────────────────────────── -->
    <Slide id="slide-optimizer" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>AEM SITES OPTIMIZER</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-6"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il sito che si ottimizza da solo — con l'AI
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-8 text-base" data-reveal data-reveal-delay="0.15">
        Non solo velocità. AEM Sites Optimizer analizza ogni pagina con AI, identifica opportunità di miglioramento per SEO, accessibilità e conversione — e suggerisce correzioni actionable al team editoriale.
      </p>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-6 mb-8" data-reveal data-reveal-delay="0.2">
        {optimizerPillars.map((p) => (
          <div class="p-7 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-sm font-bold text-[var(--accent-primary)] mb-2">{p.title}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-4 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-primary)] rounded-r-sm max-w-2xl mx-auto mb-8" data-reveal data-reveal-delay="0.45">
        <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/10 flex items-center justify-center">
          <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
        </div>
        <div>
          <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Marco, in questo momento</p>
          <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Marco ha compilato il form mutuo. Il sito ha caricato in 0.3s, la pagina PMI era ottimizzata per la sua query — lui non è tornato indietro.»</p>
        </div>
      </div>
      <div data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/conosci')}
          class="text-sm text-[var(--accent-primary)] hover:underline font-medium"
        >
          Prossimo capitolo: UniCredit conosce già Marco →
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
