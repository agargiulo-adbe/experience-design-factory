---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const aiPlatformCapabilities = [
  { label: 'Grounded in customer data', body: 'L\'AI è alimentata dal contesto reale: dati cliente, contenuti approvati, brand guidelines, processi aziendali.' },
  { label: 'Enterprise-grade by design', body: 'Governance, sicurezza e compliance costruite dalla base — non aggiunte. Progettato per settori regolamentati come il banking.' },
  { label: '1st + 3rd party models', body: 'I migliori modelli fondazionali di mercato + modelli proprietari Adobe specializzati per CX, analytics, creative.' },
  { label: 'Purpose-built agents', body: 'Agenti AI che scalano le operazioni CX: orchestrano journeys, generano insight, producono contenuti — in autonomia.' },
];

const stackLayers = [
  {
    layer: 'Brand Visibility',
    products: ['AEM Sites', 'AEM Assets', 'Firefly'],
    color: 'var(--accent-secondary)',
    claim: 'Presenza digitale orchestrata: contenuti web, DAM unificato, immagini AI-generated su licenza commerciale.',
  },
  {
    layer: 'Content Supply Chain',
    products: ['GenStudio', 'AEM Assets', 'Frame.io'],
    color: 'var(--accent-secondary)',
    claim: 'Dalla brief al deployment: varianti di contenuto in minuti, tracciabilità completa, review nativa.',
  },
  {
    layer: 'Customer Engagement',
    products: ['Journey Optimizer B2C', 'Adobe Target', 'Real-Time CDP'],
    color: 'var(--accent-primary)',
    claim: 'Orchestrazione omnicanale in tempo reale — push, email, in-app, SMS, web — con profilo cliente unificato.',
  },
  {
    layer: 'Adobe CX Analytics',
    products: ['Customer Journey Analytics', 'Adobe Analytics', 'Mix Modeler', 'Content Analytics'],
    color: 'var(--accent-primary)',
    claim: 'Intelligence unificata: digital analytics, journey analytics, marketing ROI, content performance.',
  },
];

const dataFoundation = [
  { abbr: 'AEP', name: 'Adobe Experience Platform', sol: 'aep', claim: 'Hub centrale: raccoglie, governa, unifica e attiva ogni dato cliente in tempo reale su tutti i canali.' },
  { abbr: 'CDP', name: 'Real-Time CDP', sol: 'rtcdp', claim: 'Profilo cliente unificato aggiornato in millisecondi — da app, filiale, call center, online.' },
  { abbr: 'DIA', name: 'Data Insights Agent', sol: 'data-insights-agent', claim: 'AI agent che risponde in linguaggio naturale con root cause analysis verificata.' },
  { abbr: 'MCP', name: 'Interfacce MCP', sol: null, claim: 'Interfacce MCP verso AEP e le app Adobe — consentono a client AI (Copilot, ChatGPT, Gemini, tool interni) di interrogare i dati Adobe.' },
];

const contentEngine = [
  { abbr: 'GEN', name: 'GenStudio', sol: 'genstudio', claim: 'Genera copy e layout per ogni segmento in minuti — brand guidelines UniCredit integrate, compliance automatica.' },
  { abbr: 'FF', name: 'Adobe Firefly', sol: 'firefly', claim: 'Immagini generate su licenza commerciale — brand-safe by design, zero rischi IP.' },
  { abbr: 'DAM', name: 'AEM Assets', sol: 'aem-assets', claim: 'Digital Asset Management unificato: ogni asset approvato, versionato e distribuito su tutti i canali.' },
  { abbr: 'EDS', name: 'AEM Sites', sol: 'aem-sites', claim: 'Edge Delivery: il sito UniCredit a 0.3s, authoring git-based, ottimizzazione SEO AI-driven.' },
];

const b2bLayer = [
  { abbr: 'AJO B2B', name: 'Journey Optimizer B2B', sol: 'ajo-b2b', claim: 'Account-based journeys e buying group orchestration per il corporate banking.' },
  { abbr: 'MKT', name: 'Marketo Engage', sol: 'marketo', claim: 'Demand generation e lead nurturing per segmenti business ed enterprise.' },
  { abbr: 'CJA B2B', name: 'CJA B2B Edition', sol: 'cja', claim: 'Analytics dedicato ai journey account-based — misura l\'engagement dei buying group.' },
];

const integrationAdvantages = [
  { stat: '1', label: 'schema dati unificato', body: 'Tutti i prodotti parlano XDM. Zero mapping custom tra soluzioni.' },
  { stat: '0', label: 'integrazioni da costruire', body: 'AEP è il data hub nativo. Ogni prodotto è già connesso.' },
  { stat: '∞', label: 'scalabilità', body: 'Da 14M a 100M di clienti — stessa architettura, stessa governance.' },
];

// Mappa prodotto→soluzione: consente al runtime di gating (data-solution)
// di nascondere i singoli chip/pill nelle slide aggregate quando la relativa
// soluzione viene spenta dalla console. Prodotti senza toggle (Frame.io,
// Adobe Analytics, MCP, Adobe AI Platform) → null = sempre visibili.
const PRODUCT_SOL: Record<string, string | null> = {
  'AEM Sites': 'aem-sites', 'AEM Assets': 'aem-assets', 'Firefly': 'firefly',
  'GenStudio': 'genstudio', 'Frame.io': null,
  'Journey Optimizer B2C': 'ajo-b2c', 'Adobe Target': 'target', 'Real-Time CDP': 'rtcdp',
  'Customer Journey Analytics': 'cja', 'Adobe Analytics': null, 'Mix Modeler': 'mix-modeler',
  'Content Analytics': 'content-analytics',
};

const foundationBand = [
  { name: 'AEP', sol: 'aep' },
  { name: 'Real-Time CDP', sol: 'rtcdp' },
  { name: 'Data Insights Agent', sol: 'data-insights-agent' },
  { name: 'Interfacce MCP', sol: null },
  { name: 'Adobe Experience Platform AI', sol: null },
];

const integrationPills = [
  { name: 'AEP', sol: 'aep' }, { name: 'Real-Time CDP', sol: 'rtcdp' },
  { name: 'CX Analytics', sol: 'cx-analytics' }, { name: 'AJO B2C', sol: 'ajo-b2c' },
  { name: 'Target', sol: 'target' }, { name: 'AEM Sites', sol: 'aem-sites' },
  { name: 'GenStudio', sol: 'genstudio' }, { name: 'Firefly', sol: 'firefly' },
  { name: 'AEM Assets', sol: 'aem-assets' }, { name: 'AJO B2B', sol: 'ajo-b2b' },
  { name: 'Marketo', sol: 'marketo' }, { name: 'Mix Modeler', sol: 'mix-modeler' },
  { name: 'Data Insights Agent', sol: 'data-insights-agent' }, { name: 'MCP', sol: null },
];
---
<BaseLayout
  title="Adobe CX Enterprise — Il Motore"
  description="Il sistema nervoso della CX UniCredit: Adobe Experience Platform come fondazione, CX Analytics come intelligence, AEP come hub dati."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/risultati')} prevHref={href(base, '/b2b')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="IL SISTEMA"
        title="Adobe CX Enterprise"
        lead="Tutto quello che Marco e Sofia hanno vissuto — il sito che caricava in 0,3 secondi, il profilo unificato, il reel ads generato in pochi minuti, il mutuo casa che parte già su misura — è alimentato da questo."
        size="hero"
        tone="inverse"
        primary="UniCredit"
        secondary="Adobe"
      />
    </Slide>

    <!-- ── SLIDE 1: Adobe AI Platform ────────────────────────────── -->
    <Slide id="slide-ai-platform" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('ai-platform')}
        imageClass="opacity-8"
        scrim="bg-[var(--surface-inverse)]/92"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>LA FONDAZIONE</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-3"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Adobe Experience Platform
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        L'AI che alimenta Adobe CX Enterprise non è generica — è radicata nel contesto del cliente: dati, contenuti, brand, processi. Costruita su AEP per enterprise regolamentate come il banking.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.22"
      >
        {aiPlatformCapabilities.map((cap) => (
          <div class="p-5 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-left">
            <p class="text-sm font-semibold text-[var(--accent-secondary)] mb-2">{cap.label}</p>
            <p class="text-sm text-[var(--color-grigio-300)] leading-relaxed">{cap.body}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: Fondazione dati (AEP + CDP + DIA + MCP) ───────── -->
    <Slide id="slide-data-foundation" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>FONDAZIONE DATI</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un hub. Quattro superpoteri.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-secondary)] max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        Adobe Experience Platform centralizza tutti i dati UniCredit. Su questa base si costruiscono il profilo cliente unificato, l'intelligence AI e la connettività universale — la fondazione su cui poggia ogni layer applicativo.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.22"
      >
        {dataFoundation.map((item) => (
          <div class="flex items-start gap-4 p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left" data-solution={item.sol ?? undefined}>
            <span class="w-10 h-10 flex-shrink-0 rounded bg-[var(--accent-primary)]/12 flex items-center justify-center text-sm font-bold text-[var(--accent-primary)]">
              {item.abbr}
            </span>
            <div>
              <p class="text-sm font-semibold text-[var(--ink-primary)] mb-1">{item.name}</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{item.claim}</p>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: Fondazione contenuti (gemella dei dati) ───────── -->
    <Slide id="slide-content-engine" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>FONDAZIONE CONTENUTI</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Una fabbrica. Ogni formato.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-secondary)] max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        Se i dati dicono a chi parlare, i contenuti dicono cosa mostrare. Una content supply chain unica — dalla brief alla pubblicazione, brand-safe e su licenza — con controlli di brand integrati prima del go-live.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.22"
      >
        {contentEngine.map((item) => (
          <div class="flex items-start gap-4 p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left" data-solution={item.sol ?? undefined}>
            <span class="w-10 h-10 flex-shrink-0 rounded bg-[var(--accent-secondary)]/12 flex items-center justify-center text-sm font-bold text-[var(--accent-secondary)]">
              {item.abbr}
            </span>
            <div>
              <p class="text-sm font-semibold text-[var(--ink-primary)] mb-1">{item.name}</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{item.claim}</p>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 4: Stack completo (4 layer) ──────────────────────── -->
    <Slide id="slide-stack" bg="secondary" align="center">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>ADOBE CX ENTERPRISE · STACK COMPLETO</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-8"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
            data-reveal
            data-reveal-delay="0.08"
          >
            Da ogni dato a ogni esperienza
          </h2>

          <div
            class="w-full max-w-5xl mx-auto flex flex-col gap-3"
            data-reveal
            data-reveal-delay="0.15"
          >
            {stackLayers.map((layer, i) => (
              <div class="flex items-center gap-5 p-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
                <div class="w-40 flex-shrink-0 text-left">
                  <p class="text-sm font-semibold uppercase tracking-wider mb-0.5" style={`color: ${layer.color};`}>Layer {i + 1}</p>
                  <p class="text-xs font-semibold text-[var(--ink-primary)]">{layer.layer}</p>
                </div>
                <div class="flex flex-wrap gap-2 flex-1">
                  {layer.products.map((p) => (
                    <span class="px-2.5 py-1 text-sm font-medium border rounded-sm" style={`border-color: ${layer.color}40; color: ${layer.color};`} data-solution={PRODUCT_SOL[p] ?? undefined}>
                      {p}
                    </span>
                  ))}
                </div>
                <p class="text-sm text-[var(--ink-secondary)] leading-relaxed flex-1 text-right max-w-xs hidden md:block">{layer.claim}</p>
              </div>
            ))}

            <div class="flex items-center gap-5 p-4 bg-[var(--accent-primary)]/8 border border-[var(--accent-primary)]/20 rounded-sm">
              <div class="w-40 flex-shrink-0">
                <p class="text-sm font-semibold uppercase tracking-wider text-[var(--accent-secondary)] mb-0.5">Foundation</p>
                <p class="text-xs font-semibold text-[var(--ink-primary)]">Adobe Experience Platform</p>
              </div>
              <p class="foundation-band text-sm text-[var(--ink-secondary)] flex-1">
                {foundationBand.map((f) => (
                  <span class="foundation-item" data-solution={f.sol ?? undefined}>{f.name}</span>
                ))}
              </p>
            </div>
          </div>

          <div class="mt-10 p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm max-w-4xl mx-auto text-center" data-reveal data-reveal-delay="0.5">
            <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-3">Dietro ogni momento di Marco e Sofia</p>
            <p class="font-[family-name:var(--font-display)] text-xl text-[var(--ink-primary)] italic leading-relaxed mb-2">«Ogni tap sull'app. Ogni reel ads che ha convertito. Ogni brief AI-generated. Ogni mutuo casa che parte già su misura.»</p>
            <p class="text-sm text-[var(--ink-secondary)]">Alimentato da Adobe Experience Platform — un unico motore dietro ogni momento della loro relazione con UniCredit.</p>
          </div>
        </div>
        <MediaDemoSlot id="motore-stack-demo" label="Adobe AI Platform — Architecture Diagram" />
      </div>
    </Slide>

    <!-- ── SLIDE 5: B2B Layer ─────────────────────────────────────── -->
    <Slide id="slide-b2b-layer" bg="inverse" align="center" data-solution="ajo-b2b">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-8"
        scrim="bg-[var(--surface-inverse)]/92"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>B2B · CORPORATE BANKING</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Il layer B2B:<br/>account-based intelligence
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        Le stesse fondamenta AEP — estese per il corporate banking: journey orchestrati per account, analytics dei buying group, demand generation automation.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5"
        data-reveal
        data-reveal-delay="0.22"
      >
        {b2bLayer.map((item) => (
          <div class="flex flex-col gap-3 p-5 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm" data-solution={item.sol ?? undefined}>
            <span class="w-9 h-9 rounded bg-[var(--accent-secondary)]/20 flex items-center justify-center text-sm font-bold text-[var(--accent-secondary)] flex-shrink-0">
              {item.abbr}
            </span>
            <div>
              <p class="text-sm font-semibold text-[var(--ink-inverse)] mb-2">{item.name}</p>
              <p class="text-xs text-[var(--color-grigio-300)] leading-relaxed">{item.claim}</p>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 6: Vantaggio integrazione ────────────────────────── -->
    <Slide id="slide-integration" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-8"
        scrim="bg-[var(--accent-primary)]/85"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-5" data-reveal>IL VANTAGGIO ARCHITETTURALE</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un sistema.<br/>Non quattordici soluzioni.
      </h2>
      <p
        class="text-[clamp(1.1rem,1.6vw,1.5rem)] text-[var(--ink-inverse)]/80 max-w-3xl mb-12"
        data-reveal
        data-reveal-delay="0.15"
      >
        AEP come hub centrale significa che ogni dato, ogni journey e ogni contenuto parla la stessa lingua. Zero integrazione custom tra prodotti. Time-to-value in settimane, non anni.
      </p>

      <div
        class="w-full max-w-3xl mx-auto grid grid-cols-3 gap-6 mb-12"
        data-reveal
        data-reveal-delay="0.22"
      >
        {integrationAdvantages.map((adv) => (
          <div class="text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-2"
              style="font-size: clamp(3rem, 6vw, 5.5rem);"
            >
              {adv.stat}
            </p>
            <p class="text-sm font-medium text-[var(--ink-inverse)] mb-1.5">{adv.label}</p>
            <p class="text-xs text-[var(--ink-inverse)]/65 leading-relaxed">{adv.body}</p>
          </div>
        ))}
      </div>

      <div
        class="flex flex-wrap justify-center gap-2.5 mb-12"
        data-reveal
        data-reveal-delay="0.3"
      >
        {integrationPills.map((pill) => (
          <span class="px-3 py-1.5 bg-[var(--ink-inverse)]/12 text-[var(--ink-inverse)] text-xs font-medium border border-[var(--ink-inverse)]/22 rounded-full" data-solution={pill.sol ?? undefined}>
            {pill.name}
          </span>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/risultati')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-inverse)] text-[var(--ink-primary)] hover:bg-[var(--color-crema)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-inverse)] focus-visible:outline-offset-4"
        >
          I risultati
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* Foundation band: middot separators that disappear together with a
     gated item (display:none hides the element AND its ::after). The last
     item — Adobe AI Platform (sol:null) — is never hidden, so no trailing dot. */
  .foundation-band { display: inline; }
  .foundation-item:not(:last-child)::after { content: ' · '; opacity: 0.6; }
</style>
