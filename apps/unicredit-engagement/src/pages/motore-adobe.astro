---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const aiPlatformCapabilities = [
  { label: 'Grounded in customer data', body: 'L\'AI è alimentata dal contesto reale: dati cliente, contenuti approvati, brand guidelines, processi aziendali.' },
  { label: 'Enterprise-grade by design', body: 'Governance, sicurezza e compliance costruite dalla base, non aggiunte dopo. Pensato per settori regolamentati come il banking.' },
  { label: '1st + 3rd party models', body: 'I migliori modelli fondazionali di mercato + modelli proprietari Adobe specializzati per CX, analytics, creative.' },
  { label: 'Purpose-built agents', body: 'Agenti AI che scalano le operazioni CX: orchestrano journeys, generano insight, producono contenuti — in autonomia.' },
];

const stackLayers = [
  {
    layer: 'Brand Visibility',
    products: ['AEM Sites', 'AEM Sites Optimizer', 'AEM Assets', 'Firefly'],
    color: 'var(--accent-secondary)',
    claim: 'Presenza digitale orchestrata: contenuti web, ottimizzazione agentica, DAM unificato, immagini AI su licenza commerciale.',
  },
  {
    layer: 'Content Supply Chain',
    products: ['GenStudio', 'Firefly', 'AEM Assets', 'Frame.io'],
    color: 'var(--accent-secondary)',
    claim: 'Dalla brief al deployment: varianti di contenuto in minuti, tracciabilità completa, review nativa.',
  },
  {
    layer: 'Customer Engagement',
    products: ['Journey Optimizer B2C', 'Adobe Target', 'Real-Time CDP', 'Brand Concierge'],
    color: 'var(--accent-primary)',
    claim: 'Orchestrazione omnicanale in tempo reale (push, email, in-app, SMS, web) e ingaggio conversazionale, con profilo cliente unificato.',
  },
  {
    layer: 'Adobe CX Analytics',
    products: ['Customer Journey Analytics', 'Adobe Analytics', 'Marketing Campaign Analytics', 'Content Analytics'],
    color: 'var(--accent-primary)',
    claim: 'Intelligence unificata: digital + journey analytics, marketing ROI causale, content performance e misura degli LLM.',
  },
];

const dataFoundation = [
  { abbr: 'AEP', name: 'Adobe Experience Platform', sol: 'aep', claim: 'Hub centrale: raccoglie, governa, unifica e attiva ogni dato cliente in tempo reale su tutti i canali.' },
  { abbr: 'CDP', name: 'Real-Time CDP', sol: 'rtcdp', claim: 'Profilo cliente unificato aggiornato in millisecondi, da app, filiale, call center e online.' },
  { abbr: 'AI', name: 'Adobe AI Platform', sol: null, claim: 'Il layer AI (agenti Adobe e di terze parti, agent skill, tool e MCP) su cui girano Data Insights Agent, Brand Concierge e i coworker.' },
  { abbr: 'MCP', name: 'Interfacce MCP', sol: null, claim: 'Interfacce MCP verso AEP e le app Adobe — consentono a client AI (Copilot, ChatGPT, Gemini, tool interni) di interrogare i dati Adobe.' },
];

const contentEngine = [
  { abbr: 'GEN', name: 'GenStudio', sol: 'genstudio', claim: 'Genera copy e layout per ogni segmento in minuti, con brand guidelines UniCredit integrate e compliance automatica.' },
  { abbr: 'FF', name: 'Adobe Firefly', sol: 'firefly', claim: 'Immagini generate su licenza commerciale: brand-safe by design, senza rischi sull\'IP.' },
  { abbr: 'DAM', name: 'AEM Assets', sol: 'aem-assets', claim: 'Digital Asset Management unificato: ogni asset approvato, versionato e distribuito su tutti i canali.' },
  { abbr: 'EDS', name: 'AEM Sites', sol: 'aem-sites', claim: 'Edge Delivery: il sito UniCredit a 0.3s, authoring git-based, ottimizzazione SEO AI-driven.' },
];

const b2bLayer = [
  { abbr: 'AJO B2B', name: 'Journey Optimizer B2B', sol: 'ajo-b2b', claim: 'Account-based journeys e buying group orchestration per il corporate banking.' },
  { abbr: 'MKT', name: 'Marketo Engage', sol: 'marketo', claim: 'Demand generation e lead nurturing per segmenti business ed enterprise.' },
  { abbr: 'CJA B2B', name: 'CJA B2B Edition', sol: 'cja', claim: 'Analytics dedicato ai journey account-based — misura l\'engagement dei buying group.' },
];

const integrationAdvantages = [
  { stat: '1', label: 'schema dati unificato', body: 'Tutti i prodotti parlano XDM. Zero mapping custom tra soluzioni.' },
  { stat: '0', label: 'integrazioni da costruire', body: 'AEP è il data hub nativo. Ogni prodotto è già connesso.' },
  { stat: '∞', label: 'scalabilità', body: 'Dai milioni di clienti di oggi a 100M, con la stessa architettura e la stessa governance.' },
];

// Mappa prodotto→soluzione: consente al runtime di gating (data-solution)
// di nascondere i singoli chip/pill nelle slide aggregate quando la relativa
// soluzione viene spenta dalla console. Prodotti senza toggle (Frame.io,
// Adobe Analytics, MCP, Adobe AI Platform) → null = sempre visibili.
const PRODUCT_SOL: Record<string, string | null> = {
  'AEM Sites': 'aem-sites', 'AEM Sites Optimizer': 'aem-sites', 'AEM Assets': 'aem-assets', 'Firefly': 'firefly',
  'GenStudio': 'genstudio', 'Frame.io': null,
  'Journey Optimizer B2C': 'ajo-b2c', 'Adobe Target': 'target', 'Real-Time CDP': 'rtcdp', 'Brand Concierge': 'brand-concierge',
  'Customer Journey Analytics': 'cja', 'Adobe Analytics': null, 'Marketing Campaign Analytics': 'mix-modeler',
  'Content Analytics': 'content-analytics', 'LLM Insights': null,
};

const foundationBand = [
  { name: 'AEP', sol: 'aep' },
  { name: 'Real-Time CDP', sol: 'rtcdp' },
  { name: 'Adobe AI Platform', sol: null },
  { name: 'Data Insights Agent', sol: 'data-insights-agent' },
  { name: 'Interfacce MCP', sol: null },
];

const integrationPills = [
  { name: 'Real-Time CDP', sol: 'rtcdp' }, { name: 'CX Analytics', sol: 'cx-analytics' },
  { name: 'CJA', sol: 'cja' }, { name: 'Marketing Campaign Analytics', sol: 'mix-modeler' },
  { name: 'Content Analytics', sol: 'content-analytics' }, { name: 'AJO B2C', sol: 'ajo-b2c' },
  { name: 'Target', sol: 'target' }, { name: 'Brand Concierge', sol: 'brand-concierge' },
  { name: 'AEM Sites', sol: 'aem-sites' }, { name: 'AEM Sites Optimizer', sol: 'aem-sites' },
  { name: 'GenStudio', sol: 'genstudio' }, { name: 'Firefly', sol: 'firefly' },
  { name: 'AEM Assets', sol: 'aem-assets' }, { name: 'Frame.io', sol: null },
  { name: 'AJO B2B', sol: 'ajo-b2b' }, { name: 'Marketo', sol: 'marketo' },
];
---
<BaseLayout
  title="Adobe CX Enterprise — Il Motore"
  description="Il sistema nervoso della CX UniCredit: Adobe Experience Platform come fondazione e hub dati, CX Analytics come intelligence."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/risultati')} prevHref={href(base, '/b2b')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="IL SISTEMA"
        title="Adobe CX Enterprise"
        lead="Tutto quello che Marco e Sofia hanno vissuto (il sito a 0,3 secondi, il profilo unificato, il reel ads generato in pochi minuti, il mutuo casa già su misura) nasce da qui."
        size="hero"
        tone="inverse"
        primary="UniCredit"
        secondary="Adobe"
      />
    </Slide>

    <!-- ── SLIDE 1: Adobe AI Platform ────────────────────────────── -->
    <Slide id="slide-ai-platform" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('ai-platform')}
        imageClass="opacity-8"
        scrim="bg-[var(--surface-inverse)]/92"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>LA FONDAZIONE</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-3"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Adobe Experience Platform
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-8"
        data-reveal
        data-reveal-delay="0.15"
      >
        L'AI che alimenta Adobe CX Enterprise non è generica: è radicata nel contesto del cliente, tra dati, contenuti, brand e processi. Costruita su AEP per enterprise regolamentate come il banking.
      </p>

      <!-- filo motif: il motore tiene i quattro capi -->
      <div class="uc-thread w-full max-w-4xl mx-auto mb-6" data-reveal data-reveal-delay="0.18" aria-hidden="true">
        <span class="uc-node uc-node--rosso"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node uc-node--rosso"></span>
      </div>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {aiPlatformCapabilities.map((cap) => (
          <div class="uc-panel uc-panel--oro text-left">
            <p class="uc-tag" style="color: var(--color-oro);">{cap.label}</p>
            <p class="uc-panel-body" style="margin-top:0.55rem; margin-bottom:0;">{cap.body}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: Fondazione dati (AEP + CDP + DIA + MCP) ───────── -->
    <Slide id="slide-data-foundation" bg="primary" align="center">
      <div class="uc-bg absolute inset-0 -z-10" aria-hidden="true"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>FONDAZIONE DATI</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-4"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un hub. Quattro superpoteri.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-secondary)] max-w-2xl mb-8"
        data-reveal
        data-reveal-delay="0.15"
      >
        Adobe Experience Platform centralizza tutti i dati UniCredit. Su questa base nascono il profilo cliente unificato, l'intelligence AI e la connettività universale: è la fondazione su cui poggia ogni layer applicativo.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {dataFoundation.map((item) => (
          <div class="uc-panel uc-panel--rosso motore-node text-left" data-solution={item.sol ?? undefined}>
            <div class="motore-node-head">
              <span class="motore-abbr">{item.abbr}</span>
              <p class="motore-name">{item.name}</p>
            </div>
            <p class="uc-panel-body" style="margin-bottom:0;">{item.claim}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: Fondazione contenuti (gemella dei dati) ───────── -->
    <Slide id="slide-content-engine" bg="secondary" align="center">
      <div class="uc-bg-soft absolute inset-0 -z-10" aria-hidden="true"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>FONDAZIONE CONTENUTI</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-4"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Una fabbrica. Ogni formato.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-secondary)] max-w-2xl mb-8"
        data-reveal
        data-reveal-delay="0.15"
      >
        Se i dati dicono a chi parlare, i contenuti dicono cosa mostrare. Una content supply chain unica — dalla brief alla pubblicazione, brand-safe e su licenza — con controlli di brand integrati prima del go-live.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {contentEngine.map((item) => (
          <div class="uc-panel uc-panel--oro motore-node text-left" data-solution={item.sol ?? undefined}>
            <div class="motore-node-head">
              <span class="motore-abbr motore-abbr--oro">{item.abbr}</span>
              <p class="motore-name">{item.name}</p>
            </div>
            <p class="uc-panel-body" style="margin-bottom:0;">{item.claim}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 4: Stack completo (4 layer) ──────────────────────── -->
    <Slide id="slide-stack" bg="secondary" align="center">
      <div class="uc-bg-soft absolute inset-0 -z-10" aria-hidden="true"></div>
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>ADOBE CX ENTERPRISE · STACK COMPLETO</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-4"
            style="font-size: clamp(2rem, 3.4vw, 3rem);"
            data-reveal
            data-reveal-delay="0.08"
          >
            Da ogni dato a ogni esperienza
          </h2>

          <div
            class="w-full max-w-5xl mx-auto flex flex-col gap-1.5 motore-stack"
            data-reveal
            data-reveal-delay="0.15"
          >
            {stackLayers.map((layer, i) => (
              <div class="motore-layer">
                <span class="motore-layer-thread" aria-hidden="true"></span>
                <div class="w-40 flex-shrink-0 text-left">
                  <p class="text-sm font-semibold uppercase tracking-wider mb-0.5" style={`color: ${layer.color};`}>Layer {i + 1}</p>
                  <p class="text-xs font-semibold text-[var(--ink-primary)]">{layer.layer}</p>
                </div>
                <div class="flex flex-wrap gap-2 flex-1">
                  {layer.products.map((p) => (
                    <span class="motore-pill" style={`border-color: ${layer.color}59; color: ${layer.color};`} data-solution={PRODUCT_SOL[p] ?? undefined}>
                      {p}
                    </span>
                  ))}
                </div>
                <p class="text-sm text-[var(--ink-secondary)] leading-relaxed flex-1 text-right max-w-xs hidden md:block">{layer.claim}</p>
              </div>
            ))}

            <div class="motore-layer motore-layer--foundation">
              <span class="motore-layer-thread motore-layer-thread--oro" aria-hidden="true"></span>
              <div class="w-40 flex-shrink-0">
                <p class="text-sm font-semibold uppercase tracking-wider text-[var(--accent-secondary)] mb-0.5">Foundation</p>
                <p class="text-xs font-semibold text-[var(--ink-primary)]">Adobe Experience Platform</p>
              </div>
              <p class="foundation-band text-sm text-[var(--ink-secondary)] flex-1">
                {foundationBand.map((f) => (
                  <span class="foundation-item" data-solution={f.sol ?? undefined}>{f.name}</span>
                ))}
              </p>
            </div>
          </div>

          <div class="uc-quote mt-4 max-w-4xl mx-auto text-center" data-reveal data-reveal-delay="0.5">
            <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-2">Dietro ogni momento di Marco e Sofia</p>
            <p class="uc-quote-text" style="margin-inline:auto;">«Ogni tap sull'app, ogni reel ads che ha convertito, ogni brief AI-generated, ogni mutuo casa già su misura: dietro c'è un solo motore, Adobe Experience Platform.»</p>
          </div>
        </div>
        <MediaDemoSlot id="motore-stack-demo" label="Adobe AI Platform — Architecture Diagram" />
      </div>
    </Slide>

    <!-- ── SLIDE 5: B2B Layer ─────────────────────────────────────── -->
    <Slide id="slide-b2b-layer" bg="inverse" align="center" data-solution="ajo-b2b">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-8"
        scrim="bg-[var(--surface-inverse)]/92"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>B2B · CORPORATE BANKING</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Il layer B2B:<br/>account-based intelligence
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-8"
        data-reveal
        data-reveal-delay="0.15"
      >
        Le stesse fondamenta AEP, estese al corporate banking: journey orchestrati per account, analytics dei buying group, demand generation automation.
      </p>

      <!-- filo motif: lo stesso motore, esteso -->
      <div class="uc-thread w-full max-w-3xl mx-auto mb-6" data-reveal data-reveal-delay="0.18" aria-hidden="true">
        <span class="uc-node"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node"></span>
      </div>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {b2bLayer.map((item) => (
          <div class="uc-panel uc-panel--oro motore-node motore-node--b2b" data-solution={item.sol ?? undefined}>
            <span class="motore-abbr motore-abbr--oro">{item.abbr}</span>
            <p class="motore-name" style="margin-top:0.7rem;">{item.name}</p>
            <p class="uc-panel-body" style="font-size:0.9rem; margin-bottom:0; margin-top:0.4rem;">{item.claim}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 6: Vantaggio integrazione ────────────────────────── -->
    <Slide id="slide-integration" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-8"
        scrim="bg-[var(--accent-primary)]/85"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-5" data-reveal>IL VANTAGGIO ARCHITETTURALE</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un sistema.<br/>Non quattordici soluzioni.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.35rem)] text-[var(--ink-inverse)]/80 max-w-3xl mb-6"
        data-reveal
        data-reveal-delay="0.15"
      >
        Con AEP come hub centrale, ogni dato, journey e contenuto parla la stessa lingua. Nessuna integrazione custom tra prodotti, e time-to-value in settimane invece che in anni.
      </p>

      <div
        class="w-full max-w-3xl mx-auto grid grid-cols-3 gap-6 mb-6"
        data-reveal
        data-reveal-delay="0.22"
      >
        {integrationAdvantages.map((adv) => (
          <div class="text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-2"
              style="font-size: clamp(2.75rem, 5vw, 4.5rem);"
            >
              {adv.stat}
            </p>
            <p class="text-sm font-medium text-[var(--ink-inverse)] mb-1.5">{adv.label}</p>
            <p class="text-xs text-[var(--ink-inverse)]/65 leading-relaxed">{adv.body}</p>
          </div>
        ))}
      </div>

      <!-- filo motif: tutti i prodotti sullo stesso filo -->
      <div class="uc-thread w-full max-w-4xl mx-auto mb-4" data-reveal data-reveal-delay="0.26" aria-hidden="true">
        <span class="uc-node motore-node-light"></span>
        <span class="motore-thread-light"></span>
        <span class="uc-node motore-node-light"></span>
        <span class="motore-thread-light"></span>
        <span class="uc-node motore-node-light"></span>
      </div>

      <div
        class="flex flex-wrap justify-center gap-2 mb-6 max-w-4xl mx-auto"
        data-reveal
        data-reveal-delay="0.3"
      >
        {integrationPills.map((pill) => (
          <span class="px-3 py-1.5 bg-[var(--ink-inverse)]/12 text-[var(--ink-inverse)] text-xs font-medium border border-[var(--ink-inverse)]/22 rounded-full" data-solution={pill.sol ?? undefined}>
            {pill.name}
          </span>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/risultati')}
          class="inline-flex items-center gap-3 px-10 py-4 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-inverse)] text-[var(--ink-primary)] hover:bg-[var(--color-crema)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-inverse)] focus-visible:outline-offset-4"
        >
          I risultati
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* Foundation band: middot separators that disappear together with a
     gated item (display:none hides the element AND its ::after). The last
     item — Adobe AI Platform (sol:null) — is never hidden, so no trailing dot. */
  .foundation-band { display: inline; }
  .foundation-item:not(:last-child)::after { content: ' · '; opacity: 0.6; }

  /* ── Motore Adobe: the engine that weaves the ORO filo ───────────
     Each product = a node connected on/around the gold thread. Explicit
     rgba only (rosso/oro/blu-notte); no oklab/color-mix on text bgs. */

  /* Node panel: abbr disc + name, sitting on the thread. */
  .motore-node-head { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.6rem; }
  .motore-abbr {
    flex-shrink: 0; width: 2.4rem; height: 2.4rem; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.02em;
    color: var(--color-rosso); background: rgba(190,32,39,0.10);
