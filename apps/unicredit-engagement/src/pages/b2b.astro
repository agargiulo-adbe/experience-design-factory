---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const rmInsights = [
  { label: 'Fatturato aziendale', value: '€4.2M · crescita +11% YoY', source: 'Open Banking' },
  { label: 'Flussi di cassa', value: 'Stagionalità agosto–settembre', source: 'Conto corrente business' },
  { label: 'Propensity leasing', value: 'Score 79/100 · flotta auto', source: 'AEP + CJA' },
  { label: 'Evento triggering', value: 'Ha visitato "/finanziamenti-aziendali" × 4', source: 'CDP real-time' },
  { label: 'Prossima scadenza', value: 'Mutuo sede operativa: 18 mesi', source: 'Core banking' },
];

const ajoB2bFeatures = [
  { label: 'Buying group orchestration', body: "AJO B2B identifica tutti i decision-maker dell'azienda (CEO, CFO, RM) e orchestra touchpoint coerenti per ognuno." },
  { label: 'Account-based journeys', body: 'Campagne e sequenze dedicate per ogni azienda cliente, con contenuti personalizzati per settore e dimensione.' },
  { label: 'RM enablement', body: "Il Relationship Manager riceve suggerimenti AI in tempo reale prima di ogni interazione, con next-best-experience calcolata." },
  { label: 'Marketo integration', body: 'Pipeline B2B corporate integrata con Marketo: lead scoring, nurturing, handoff automatico al team Sales Enterprise.' },
];

const b2bKpis = [
  { stat: '↑', label: 'deal velocity per PMI', sub: 'con account-based journeys' },
  { stat: '↑', label: 'penetrazione prodotti per azienda', sub: 'grazie al cross-sell intelligente' },
  { stat: '↓', label: 'tempo preparazione meeting RM', sub: 'con AI insights automatici' },
];
---
<BaseLayout
  title="Banking per le imprese"
  description="AJO B2B e Marketo portano la personalizzazione enterprise al livello del business banking UniCredit."
  pageSolutions={['ajo-b2b', 'marketo']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/motore-adobe')} prevHref={href(base, '/coworker')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('business-meeting')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-secondary)]/82"
      />
      <CoverHero
        eyebrow="08 · B2B"
        numeral="08"
        title="Banking per le imprese"
        lead="Adriana guida la tesoreria di una PMI manifatturiera. Vuole una banca che anticipi i bisogni della sua azienda, non che aspetti la sua chiamata. Qui la relazione B2B diventa un vantaggio."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Adriana + esigenze B2B ───────────────────────── -->
    <Slide id="slide-adriana" bg="primary" align="split">
      <div class="uc-b2b-bg" aria-hidden="true"></div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-14 items-center relative">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>IL CLIENTE BUSINESS</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-5"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
Adriana cerca un partner,<br/>non solo una banca
          </h2>

          <div class="uc-thread mb-5" data-reveal data-reveal-delay="0.16">
            <span class="uc-node"></span>
            <span class="uc-thread-line"></span>
            <span class="uc-node uc-node--rosso"></span>
          </div>

          <div class="uc-panel uc-panel--oro mb-4" data-reveal data-reveal-delay="0.2">
            <div class="uc-panel-head">
              <span class="uc-figure">Adriana Conti</span>
              <span class="uc-tag">CFO · 8 anni</span>
            </div>
            <p class="uc-panel-body">CFO di una PMI manifatturiera con 45 dipendenti. Cliente UniCredit Business da 8 anni. Gestisce liquidità, finanziamenti e pagamenti internazionali. Vuole proattività: il suo RM dovrebbe anticipare i suoi bisogni, non aspettare che lei chiami.</p>
            <p class="uc-src">PMI manifatturiera · 45 dipendenti</p>
          </div>

          <p class="text-[var(--ink-secondary)] leading-relaxed" style="font-size:0.98rem;" data-reveal data-reveal-delay="0.3">
            Con 250.000 aziende clienti, la sfida di UniCredit è dare a ognuna il servizio su misura di un private banker, <strong class="text-[var(--ink-primary)]">in modo scalabile</strong>.
          </p>

          <div class="uc-quote" data-reveal data-reveal-delay="0.45">
            <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-2">Adriana, in questo momento</p>
            <p class="uc-quote-text">«Il suo Relationship Manager — preparato da Coworker AI — la chiama prima della scadenza del mutuo di sede: ha già pronte tre opzioni di rifinanziamento e un piano di tesoreria. Adriana non aveva ancora chiesto nulla.»</p>
          </div>
        </div>

        <div class="uc-panel uc-panel--rosso" data-reveal data-reveal-delay="0.35">
          <p class="uc-tag mb-3">Profilo aziendale · AI Insights per il RM</p>
          <div class="flex flex-col gap-2">
            {rmInsights.map((ins) => (
              <div class="uc-b2b-insight">
                <div class="flex-1 min-w-0">
                  <p class="uc-b2b-insight-label">{ins.label}</p>
                  <p class="uc-b2b-insight-value">{ins.value}</p>
                </div>
                <span class="uc-b2b-insight-src">{ins.source}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: AJO B2B features ─────────────────────────────── -->
    <Slide id="slide-ajo-b2b" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-5" data-reveal>JOURNEY OPTIMIZER B2B + MARKETO</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-6"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il consulente aumentato dall'AI
      </h2>

      <div class="uc-thread mb-8 max-w-5xl mx-auto w-full" data-reveal data-reveal-delay="0.16">
        <span class="uc-node uc-node--rosso"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node"></span>
      </div>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.2"
      >
        {ajoB2bFeatures.map((f) => (
          <div class="uc-panel uc-panel--oro text-left">
            <p class="uc-b2b-feature-label">{f.label}</p>
            <p class="uc-panel-body" style="margin-bottom:0;">{f.body}</p>
          </div>
        ))}
      </div>

      <div class="uc-quote max-w-3xl mx-auto text-left" data-reveal data-reveal-delay="0.45">
        <p class="text-xs font-semibold tracking-wider uppercase text-[var(--color-grigio-300)] mb-2">Adriana, in questo momento</p>
        <p class="uc-quote-text" style="color: var(--color-crema);">«AJO B2B ha mappato il buying group dell'azienda di Adriana: lei come CFO, il CEO e il responsabile acquisti. Ognuno ha ricevuto comunicazioni diverse, calibrate sul suo ruolo nella decisione.»</p>
      </div>
    </Slide>

    <!-- ── SLIDE 3: KPI risultati B2B ─────────────────────────────── -->
    <Slide id="slide-kpi-b2b" bg="primary" align="center">
      <div class="uc-b2b-bg" aria-hidden="true"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5 relative" data-reveal>IMPATTO BUSINESS</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-6 relative"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
Il bancario di relazione<br/>torna a fare la differenza
      </h2>

      <div class="uc-thread mb-8 max-w-3xl mx-auto w-full relative" data-reveal data-reveal-delay="0.16">
        <span class="uc-node"></span>
        <span class="uc-thread-line"></span>
        <span class="uc-node uc-node--rosso"></span>
      </div>

      <div
        class="w-full max-w-3xl mx-auto grid md:grid-cols-3 gap-6 mb-10 relative"
        data-reveal
        data-reveal-delay="0.2"
      >
        {b2bKpis.map((k) => (
          <div class="uc-panel uc-panel--oro text-center" style="align-items:center;">
            <p class="uc-b2b-kpi-stat">{k.stat}</p>
            <p class="uc-b2b-kpi-label">{k.label}</p>
            <p class="uc-b2b-kpi-sub">{k.sub}</p>
          </div>
        ))}
      </div>

      <div class="relative" data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/motore-adobe')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--accent-primary)] text-[var(--ink-inverse)] hover:opacity-90 transition-opacity duration-300"
        >
          Il motore Adobe
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-30 relative">Fonte: Adobe Journey Optimizer B2B Edition benchmark · banking europeo, Forrester TEI, Adobe Experience Cloud, 2023</p>
    </Slide>

  </DeckContainer>

<style>
  /* B2B — gold-thread depth background scoped to this page's light slides */
  .uc-b2b-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(120% 75% at 12% 0%, rgba(190,32,39,0.05), transparent 55%),
      radial-gradient(115% 85% at 90% 100%, rgba(201,169,110,0.12), transparent 55%);
  }

  /* Insight rows inside the rosso profile panel */
  .uc-b2b-insight {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.7rem 0.85rem;
    background: rgba(26,26,46,0.03);
    border: 1px solid rgba(26,26,46,0.1);
    border-radius: 4px;
  }
  .uc-b2b-insight-label { font-size: 0.82rem; font-weight: 600; color: var(--color-blu-notte); line-height: 1.3; }
  .uc-b2b-insight-value { font-size: 0.95rem; color: var(--color-blu-medio); line-height: 1.4; margin-top: 0.15rem; }
  .uc-b2b-insight-src {
    flex-shrink: 0;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--color-grigio-400);
    background: rgba(201,169,110,0.12);
    border: 1px solid rgba(201,169,110,0.3);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    margin-top: 0.1rem;
  }

  /* AJO feature label — gold accent lead-in */
  .uc-b2b-feature-label { font-size: 1.02rem; font-weight: 700; color: var(--color-blu-notte); margin-bottom: 0.5rem; }

  /* KPI stat within the oro panel */
  .uc-b2b-kpi-stat {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-rosso);
    line-height: 1;
    margin-bottom: 0.6rem;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
  }
  .uc-b2b-kpi-label { font-size: 0.98rem; font-weight: 600; color: var(--color-blu-notte); line-height: 1.3; margin-bottom: 0.4rem; }
  .uc-b2b-kpi-sub { font-size: 0.82rem; color: var(--color-blu-medio); line-height: 1.4; }
</style>
</BaseLayout>
