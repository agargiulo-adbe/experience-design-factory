---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const sources = [
  { label: 'App mobile', icon: '📱', count: '4M+ eventi/giorno' },
  { label: 'Online banking', icon: '💻', count: '3M+ sessioni' },
  { label: 'Filiali', icon: '🏛️', count: '3.800 sportelli' },
  { label: 'Call center', icon: '📞', count: '65K chiamate/g' },
  { label: 'ATM / POS', icon: '💳', count: '7.500 ATM' },
  { label: 'Open Banking', icon: '🔗', count: 'dati terze parti' },
];

const profileAttribs = [
  { label: 'Profilo unificato', value: 'Marco Ferretti · 38a · Brescia' },
  { label: 'Propensity score mutuo casa', value: '87/100 ↑' },
  { label: 'Next-Best-Experience', value: 'Mutuo prima casa 20Y · offerta personalizzata' },
  { label: 'Canale preferito', value: 'App · mercoledì mattina' },
  { label: 'Segmento', value: 'Cliente retail alto-valore · in-market mutuo casa' },
  { label: 'Ultimo evento', value: 'Ricerca "mutuo casa" in-app 14:23' },
];

const capabilities = [
  { label: 'Segmentazione real-time', body: 'Segmenti che si aggiornano quando cambia il comportamento, senza attendere i batch notturni.', color: 'var(--accent-primary)' },
  { label: 'Propensity scoring', body: 'Un punteggio di propensione per ogni prodotto, ricalcolato live a ogni evento.', color: 'var(--accent-secondary)' },
  { label: 'Next-Best-Experience', body: "L'offerta giusta arriva nel momento giusto, sul canale che il cliente preferisce.", color: 'var(--accent-primary)' },
  { label: 'Privacy by design', body: 'Governance GDPR integrata: consensi, data residency europea e audit trail.', color: 'var(--accent-secondary)' },
];
---
<BaseLayout
  title="Conosci ogni cliente"
  description="Real-Time CDP unifica i dati di milioni di clienti in profili azionabili in tempo reale."
  pageSolutions={['rtcdp']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/acquisisci')} prevHref={href(base, '/visibilita')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-secondary)]/80"
      />
      <CoverHero
        eyebrow="02 · DATI"
        numeral="02"
        title="Conosci ogni cliente"
        lead="Milioni di clienti, con dati sparsi tra app, filiale e call center. Real-Time CDP li raccoglie in un profilo per cliente, aggiornato in millisecondi."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Storia di Marco ─────────────────────────────── -->
    <Slide id="slide-storia-conosci" bg="secondary" align="split">
      <div class="uc-bg-soft w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center rounded-sm">
        <div class="flex items-center justify-center" data-reveal>
          <div class="relative overflow-hidden rounded-sm" style="width:100%; height:min(500px,65dvh);">
            <MediaSlot {...mediaProps('persona-marco')} fill objectPosition="top" />
          </div>
        </div>

        <div class="text-left">
          <div class="uc-thread mb-5" data-reveal aria-hidden="true">
            <span class="uc-node"></span>
            <span class="uc-thread-line"></span>
            <span class="uc-node uc-node--rosso"></span>
          </div>
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal data-reveal-delay="0.06">STORIA DI MARCO · PASSO 2 DI 10</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            RT-CDP: UniCredit sapeva già chi era Marco
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed mb-6"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.2"
          >
            Marco non era nemmeno loggato. Dal click anonimo, in 200ms il Real-Time CDP ha ricomposto la sua identità e unito 2 anni di storico transazionale, il comportamento nell'app, la visita in filiale a novembre e la ricerca "mutuo casa" di 3 giorni fa. Propensione: 87/100. È lo stesso motore che serve i clienti storici e che, in acquisition, intercetta chi la banca ancora non conosce.
          </p>
          <div class="uc-quote" data-reveal data-reveal-delay="0.45">
            <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-2">Marco, in questo momento</p>
            <p class="uc-quote-text">«Il sistema non ha visto un cliente qualsiasi: ha visto Marco, con la sua storia, il suo obiettivo e un momento preciso di vita.»</p>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Marco + dati frammentati ─────────────────────── -->
    <Slide id="slide-persona" bg="primary" align="split">
      <div class="uc-bg w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center rounded-sm">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>IL PROBLEMA</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Marco usa 6 canali.<br/>La banca non lo sa.
          </h2>
          <div class="uc-panel uc-panel--oro mb-5" data-reveal data-reveal-delay="0.2">
            <div class="uc-panel-head">
              <span class="uc-tag">Il cliente</span>
              <span class="uc-src">Cliente da 12 anni</span>
            </div>
            <p class="text-sm font-semibold text-[var(--ink-primary)] mb-1">Marco Ferretti · 38 anni · Brescia</p>
            <p class="uc-panel-body">Cliente UniCredit da 12 anni, una famiglia e una casa da comprare. Usa l'app tutti i giorni e ha cercato "mutuo casa" tre volte questa settimana, ma la banca non ha collegato i punti.</p>
          </div>
          <p class="text-[var(--ink-secondary)] text-sm leading-relaxed" data-reveal data-reveal-delay="0.3">
            Il problema non è la mancanza di dati: <strong class="text-[var(--ink-primary)]">ogni sistema parla da solo</strong>. Il profilo completo di Marco non esiste ancora in nessun posto.
          </p>
        </div>

        <div class="flex flex-col gap-3" data-reveal data-reveal-delay="0.35">
          {sources.map((s) => (
            <div class="uc-panel flex-row items-center gap-4" style="padding:0.85rem 1rem;">
              <span class="text-2xl flex-shrink-0" aria-hidden="true">{s.icon}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-[var(--ink-primary)]">{s.label}</p>
                <p class="text-xs text-[var(--ink-tertiary)]">{s.count}</p>
              </div>
              <span class="text-sm font-semibold uppercase tracking-wide flex-shrink-0" style="color: rgba(190,32,39,1); background: rgba(190,32,39,0.1); padding: 0.1rem 0.55rem; border-radius: 9999px;">isolato</span>
            </div>
          ))}
          <p class="uc-src mt-1">Canali e volumi · scenario illustrativo</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Real-Time CDP — unificazione ─────────────────── -->
    <Slide id="slide-cdp" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-inverse)]/87"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>ADOBE REAL-TIME CDP</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-10"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Un profilo. In tempo reale.
          </h2>

          <div
            class="w-full max-w-5xl mx-auto grid grid-cols-[1fr_72px_1fr] gap-4 items-center"
            data-reveal
            data-reveal-delay="0.2"
          >
            <!-- Sorgenti -->
            <div class="flex flex-col gap-2">
              {sources.map((s) => (
                <div class="flex items-center gap-3 p-3 border rounded-sm text-sm" style="background: rgba(107,114,128,0.15); border-color: rgba(107,114,128,0.25); color: var(--color-grigio-300);">
                  <span aria-hidden="true">{s.icon}</span>
                  <span>{s.label}</span>
                </div>
              ))}
            </div>

            <!-- CDP hub — il filo oro converge sull'hub rosso -->
            <div class="flex flex-col items-center gap-2">
              <div class="w-px flex-1" style="background: linear-gradient(to bottom, transparent, var(--color-oro));" aria-hidden="true"></div>
              <div class="w-14 h-14 rounded-full flex items-center justify-center text-white text-sm font-semibold text-center leading-tight px-1 flex-shrink-0" style="background: var(--color-rosso);">
                Real-Time CDP
              </div>
              <div class="w-px flex-1" style="background: linear-gradient(to bottom, var(--color-oro), transparent);" aria-hidden="true"></div>
            </div>

            <!-- Profilo unificato -->
            <div class="p-5 border rounded-sm h-full flex flex-col justify-center" style="background: rgba(190,32,39,0.1); border-color: rgba(190,32,39,0.35);">
              <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: rgba(190,32,39,1);">Profilo unificato</p>
              {profileAttribs.map((a) => (
                <div class="mb-3 last:mb-0">
                  <span class="block text-sm text-[var(--color-grigio-400)] uppercase tracking-wide mb-0.5">{a.label}</span>
                  <span class="text-xs text-[var(--ink-inverse)] leading-snug">{a.value}</span>
                </div>
              ))}
            </div>
          </div>
          <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: Adobe Real-Time CDP · benchmark settore bancario, Forrester TEI, Adobe AEP, 2023</p>
        </div>
        <MediaDemoSlot id="conosci-rtcdp-demo" label="RT-CDP — Unified Profile Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: RT-CDP Collaboration for Brands ─────────────── -->
    <Slide id="slide-data-collab" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>RT-CDP COLLABORATION FOR BRANDS</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-5"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.08"
          >
I milioni di profili di UniCredit<br/>incontrano il mondo esterno
          </h2>
          <p
            class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-2xl mb-10"
            data-reveal
            data-reveal-delay="0.15"
          >
            Privacy-safe, zero data movement. Collabora con publisher, retail media e partner per acquisire nuovi clienti e misurare l'impatto, senza mai esporre i dati proprietari UniCredit.
          </p>

          <div
            class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-5 mb-8"
            data-reveal
            data-reveal-delay="0.22"
          >
            {[
              { label: 'Acquisizione', body: 'Raggiunge prospect che la banca ancora non conosce: lookalike dei clienti alto-valore sui media network partner, senza mai condividere i profili RT-CDP.' },
              { label: 'Arricchimento', body: 'Integra segnali comportamentali di partner retail e open banking per completare il profilo cliente, nel rispetto del GDPR.' },
              { label: 'Misurazione', body: 'Close-loop measurement: dalla campagna su media network alla firma del mutuo, senza cross-brand tracking.' },
            ].map((item) => (
              <div class="p-5 border rounded-sm text-left" style="background: rgba(107,114,128,0.12); border-color: rgba(107,114,128,0.25);">
                <p class="text-sm font-semibold uppercase tracking-wide mb-2" style="color: rgba(201,169,110,1);">{item.label}</p>
                <p class="text-sm text-[var(--color-grigio-300)] leading-relaxed">{item.body}</p>
              </div>
            ))}
          </div>

          <div
            class="w-full max-w-5xl mx-auto grid md:grid-cols-4 gap-4"
            data-reveal
            data-reveal-delay="0.3"
          >
            {[
              { partner: 'Retail Media Network', example: 'Esselunga, Carrefour' },
              { partner: 'Open Banking', example: 'API PSD2/3 consensuate' },
              { partner: 'Publisher Digitali', example: 'news, editorial, finance' },
              { partner: 'Co-marketing', example: 'partner assicurativi' },
            ].map((p) => (
              <div class="p-3 border rounded-sm text-center" style="background: rgba(107,114,128,0.08); border-color: rgba(107,114,128,0.2);">
                <p class="text-xs font-semibold text-[var(--ink-inverse)] mb-0.5">{p.partner}</p>
                <p class="text-xs text-[var(--color-grigio-400)]">{p.example}</p>
              </div>
            ))}
          </div>
          <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: Forrester, State of Data Collaboration, 2024 · 51% agenzie e brand usa o pianifica data collaboration con publisher e media network</p>
        </div>
        <MediaDemoSlot id="conosci-data-collab-demo" label="RT-CDP Collaboration — Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: Capabilities → next-best-experience ───────────── -->
    <Slide id="slide-nba" bg="primary" align="center">
      <div class="uc-bg w-full flex-1 min-h-0 flex flex-col items-center justify-center rounded-sm">
        <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>COSA DIVENTA POSSIBILE</p>
        <h2
          class="slide-title text-[var(--ink-primary)] mb-10"
          style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
          data-reveal
          data-reveal-delay="0.1"
        >
          Dal dato all'azione,<br/>in millisecondi
        </h2>

        <div
          class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-5 mb-10"
          data-reveal
          data-reveal-delay="0.2"
        >
          {capabilities.map((cap, i) => (
            <div class="uc-card">
              <span class="uc-mark">{i + 1}</span>
              <p class="uc-card-title" style={`color: ${cap.color};`}>{cap.label}</p>
              <p class="uc-card-body">{cap.body}</p>
            </div>
          ))}
        </div>

        <div data-reveal data-reveal-delay="0.4">
          <a
            href={href(base, '/acquisisci')}
            class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--accent-primary)] text-[var(--ink-inverse)] hover:opacity-90 transition-opacity duration-300"
          >
            Acquisisci digitale
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
