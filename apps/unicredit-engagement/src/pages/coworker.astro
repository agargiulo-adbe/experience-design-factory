---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const painPoints = [
  { num: '40%', label: 'del tempo dei team CX su task manuali, handoff, approvazioni, report' },
  { num: '6 settimane', label: 'dalla brief di campagna al go-live, quando il momento buono è già passato.' },
  { num: '1 campagna / mese', label: 'la velocità media di un team CX senza automazione AI' },
];

// Capacità di Coworker (Adobe CX Enterprise Coworker, annunciato Adobe Summit).
const modules = [
  {
    name: 'Task in linguaggio naturale',
    desc: "Automatizza i task CX descritti a parole: dall'idea all'azione in minuti, con skill personalizzabili e planning flessibile.",
    variant: 'rosso',
  },
  {
    name: 'Campagne agili',
    desc: 'Dalla brief al lancio in ore invece di settimane, con contenuti e approvazioni orchestrati.',
    variant: 'oro',
  },
  {
    name: 'Workflow end-to-end',
    desc: 'Task, approvazioni ed esecuzione CX in un unico posto, con governance e supervisione umana.',
    variant: 'neutro',
  },
];

const governancePillars = [
  { title: 'Brand policy enforcement', body: 'Conformità di brand verificata su ogni output' },
  { title: 'Progettato per DORA / PSD3 / GDPR', body: 'Human-in-the-loop e audit trail supportano i requisiti regolatori (validazione legale necessaria)' },
  { title: 'Human-in-the-loop', body: 'Ogni azione critica richiede approvazione' },
  { title: 'Audit trail completo', body: 'Ogni decisione AI è tracciata e spiegabile' },
];

const finalMetrics = [
  { num: '↑', label: 'più campagne con lo stesso team' },
  { num: '↓', label: 'tempo di approvazione più breve' },
  { num: '✓', label: 'conformità di brand verificata su ogni output' },
];

const campaignTimeline = [
  { time: '08:00', label: 'Brief → AI' },
  { time: '08:20', label: 'Contenuti GenStudio' },
  { time: '08:45', label: 'Approvazione 1-click' },
  { time: '09:00', label: 'Live su Meta' },
];
---
<BaseLayout
  title="Il Coworker AI — da intenzione a esecuzione"
  description="CX Enterprise Coworker: il team marketing rende tre volte tanto, senza lavorare tre volte di più."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/b2b')} prevHref={href(base, '/analizza')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-data-dark')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="07 · COWORKER AI"
        numeral="07"
        title="Il Coworker AI — da intenzione a esecuzione"
        lead="Il team marketing rende tre volte tanto, senza lavorare tre volte di più."
        size="phase"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il problema ───────────────────────────────────── -->
    <Slide id="slide-problem" bg="primary" align="center">
      <div class="uc-bg absolute inset-0 -z-10"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL PROBLEMA DI OGNI CMO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-10"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il tempo del team non dovrebbe andare qui
      </h2>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-3 gap-6 mb-10" data-reveal data-reveal-delay="0.2">
        {painPoints.map((p) => (
          <div class="uc-panel uc-panel--rosso items-center text-center">
            <p class="uc-figure mb-3 break-words">{p.num}</p>
            <p class="uc-panel-body" style="margin-bottom: 0;">{p.label}</p>
          </div>
        ))}
      </div>
      <div class="w-full max-w-2xl mx-auto uc-quote text-center" data-reveal data-reveal-delay="0.35" style="margin-top: 0;">
        <p class="uc-quote-text mx-auto">Il CMO può scegliere: strumenti che assistono, o un sistema che esegue.</p>
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-30">Fonte: Adobe Content Supply Chain Benchmark Report, 2024 · settore banking</p>
    </Slide>

    <!-- ── SLIDE 2: Cos'è Coworker ────────────────────────────────── -->
    <Slide id="slide-coworker-intro" bg="secondary" align="center">
      <div class="uc-bg-soft absolute inset-0 -z-10"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>ADOBE CX ENTERPRISE · COWORKER</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Non un assistente. Un collega AI.
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-10 text-base" data-reveal data-reveal-delay="0.15">
        Coworker è l'engine AI di Adobe CX Enterprise per automatizzare i processi CX. Trasforma obiettivi di alto livello in esecuzione coordinata end-to-end, con governance, supervisione umana e contesto enterprise.
      </p>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-3 gap-6" data-reveal data-reveal-delay="0.2">
        {modules.map((m) => (
          <div class:list={["uc-panel text-left", m.variant === 'rosso' && 'uc-panel--rosso', m.variant === 'oro' && 'uc-panel--oro']}>
            <p class="uc-card-title" style="font-size: 1.05rem; margin-bottom: 0.5rem;">{m.name}</p>
            <p class="uc-panel-body" style="margin-bottom: 0;">{m.desc}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: Marco's account manager ──────────────────────── -->
    <Slide id="slide-marco-brief" bg="primary" align="split">
      <div class="uc-bg absolute inset-0 -z-10"></div>
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
          <div class="flex items-center justify-center">
            <div class="uc-panel uc-panel--rosso max-w-sm w-full">
              <div class="uc-panel-head">
                <span class="uc-tag">Coworker · 10:05</span>
              </div>
              <div class="bg-[var(--surface-primary)] rounded p-3 mb-3">
                <p class="uc-panel-body" style="margin-bottom: 0;">Prepara il brief per Marco Ferretti, appuntamento ore 14:00</p>
              </div>
              <div class="bg-[var(--accent-primary)]/8 rounded p-3" style="margin-bottom: 0; border-top: 1px solid rgba(190,32,39,0.45);">
                <p class="uc-tag mb-2">Coworker · Brief generato</p>
                <p class="uc-panel-body" style="margin-bottom: 0;">Marco Ferretti · Propensity mutuo casa 87/100 · cliente retail alto-valore · 3 interazioni nell'ultima settimana · Proposta personalizzata: mutuo prima casa 20Y, tasso dedicato ai clienti storici...</p>
              </div>
            </div>
          </div>
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>COWORKER · STORIA DI MARCO</p>
            <h3
              class="text-[var(--ink-primary)] mb-5"
              style="font-size: clamp(1.6rem, 2.8vw, 2.6rem);"
              data-reveal
              data-reveal-delay="0.1"
            >
              Il consulente arriva preparato
            </h3>
            <p class="text-[var(--ink-secondary)] leading-relaxed mb-6 text-base" data-reveal data-reveal-delay="0.15">
              Coworker ha letto il profilo RT-CDP di Marco, analizzato il suo storico e preparato la proposta, tutto prima che il consulente aprisse il laptop.
            </p>
            <div class="cw-thread" data-reveal data-reveal-delay="0.2">
              <div class="uc-thread">
                <span class="uc-node uc-node--rosso"></span>
                <p class="cw-thread-item">Brief AI-generated in 30 secondi</p>
              </div>
              <div class="uc-thread">
                <span class="uc-node uc-node--rosso"></span>
                <p class="cw-thread-item">Proposta personalizzata allegata</p>
              </div>
              <div class="uc-thread">
                <span class="uc-node uc-node--rosso"></span>
                <p class="cw-thread-item">Storico cross-canale incluso</p>
              </div>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="coworker-chat-demo" label="Coworker — Demo Video" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: Coworker Campaigns / Sofia ────────────────────── -->
    <Slide id="slide-campaigns-sofia" bg="secondary" align="split">
      <div class="uc-bg-soft absolute inset-0 -z-10"></div>
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--color-oro)] mb-5" data-reveal>COWORKER · STORIA DI SOFIA</p>
            <h3
              class="text-[var(--ink-primary)] mb-5"
              style="font-size: clamp(1.5rem, 2.6vw, 2.4rem);"
              data-reveal
              data-reveal-delay="0.1"
            >
              La campagna era live alle 9:00. Sofia ha visto il reel ads alle 19:30.
            </h3>
            <p class="text-[var(--ink-secondary)] leading-relaxed mb-6 text-sm" data-reveal data-reveal-delay="0.15">
              Il team di digital marketing ha usato Coworker per gestire l'intera campagna Instagram: dalla brief al lancio in 2 ore invece di 6 settimane.
            </p>
            <div class="cw-timeline mb-6" data-reveal data-reveal-delay="0.2">
              {campaignTimeline.map((t) => (
                <div class="uc-thread">
                  <span class="text-sm font-mono text-[var(--ink-tertiary)] w-12 flex-shrink-0">{t.time}</span>
                  <span class="uc-node flex-shrink-0"></span>
                  <span class="text-[var(--ink-secondary)]" style="font-size: 0.95rem;">{t.label}</span>
                </div>
              ))}
            </div>
            <div class="uc-quote" data-reveal data-reveal-delay="0.45" style="border-top-color: rgba(201,169,110,0.5);">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/10 flex items-center justify-center">
                  <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
                </div>
                <div>
                  <p class="uc-src mb-1">Sofia, in questo momento</p>
                  <p class="uc-quote-text" style="font-size: clamp(1rem, 1.2vw, 1.15rem);">«Ha visto il reel ads alle 19:30. Alle 22:15, in metro, aveva già aperto il conto.»</p>
                </div>
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-4">
            <div class="uc-panel uc-panel--oro">
              <p class="uc-card-title" style="font-size: 1.05rem; margin-bottom: 0.3rem;">2 ore</p>
              <p class="uc-panel-body" style="margin-bottom: 0; font-size: 0.9rem;">dal brief al live (vs. 6 settimane)</p>
            </div>
            <div class="uc-panel uc-panel--oro">
              <p class="uc-card-title" style="font-size: 1.05rem; margin-bottom: 0.3rem;">12 varianti creative</p>
              <p class="uc-panel-body" style="margin-bottom: 0; font-size: 0.9rem;">testate (Experimentation Accelerator)</p>
            </div>
            <div class="uc-panel uc-panel--oro">
              <p class="uc-card-title" style="font-size: 1.05rem; margin-bottom: 0.3rem;">CTR in crescita</p>
              <p class="uc-panel-body" style="margin-bottom: 0; font-size: 0.9rem;">rispetto alla versione manuale</p>
            </div>
            <div class="uc-panel uc-panel--oro">
              <p class="uc-card-title" style="font-size: 1.05rem; margin-bottom: 0.3rem;">Sofia ha aperto il conto alle 22:15</p>
              <p class="uc-panel-body" style="margin-bottom: 0; font-size: 0.9rem;">la sera stessa · 3 prodotti in 6 mesi</p>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="coworker-campaigns-demo" label="Coworker — Demo Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 5: Governance ────────────────────────────────────── -->
    <Slide id="slide-governance" bg="primary" align="center">
      <div class="uc-bg absolute inset-0 -z-10"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>ENTERPRISE GOVERNANCE</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Velocità senza perdere il controllo
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-10 text-base" data-reveal data-reveal-delay="0.15">
        Coworker non agisce mai senza contesto aziendale, policy di brand e supervisione umana: il responsabile può approvare o bloccare prima del lancio.
      </p>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-6 mb-8" data-reveal data-reveal-delay="0.2">
        {governancePillars.map((p) => (
          <div class="uc-panel uc-panel--rosso text-left">
            <p class="uc-card-title" style="font-size: 1.1rem; margin-bottom: 0.5rem;">{p.title}</p>
            <p class="uc-panel-body" style="margin-bottom: 0;">{p.body}</p>
          </div>
        ))}
      </div>
      <p class="text-xs text-[var(--ink-tertiary)] text-center" data-reveal data-reveal-delay="0.35">
        Interface-agnostic: MCP + A2A — Coworker si integra con i sistemi già in uso da UniCredit. · La conformità ai requisiti regolatori specifici (DORA, PSD3, GDPR) richiede validazione legale per ogni implementazione.
      </p>
    </Slide>

    <!-- ── SLIDE 6: Risultato del Team ──────────────────────────── -->
    <Slide id="slide-coworker-result" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-unlimited')}
        imageClass="opacity-12"
        scrim="bg-[var(--accent-primary)]/85"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-5" data-reveal>IL VALORE PER IL TEAM</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Più campagne, senza più ore
      </h2>
      <p class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/80 max-w-2xl mb-10" data-reveal data-reveal-delay="0.15">
        Il team non lavora di più: Coworker si prende il lavoro ripetitivo che ne divora le giornate.
      </p>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6 mb-10" data-reveal data-reveal-delay="0.22">
        {finalMetrics.map((m) => (
          <div class="p-6 bg-[var(--ink-inverse)]/10 border border-[var(--ink-inverse)]/20 rounded-sm text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-2"
              style="font-size: clamp(2rem, 3.5vw, 3.25rem);"
            >{m.num}</p>
            <p class="text-xs text-[var(--ink-inverse)]/70">{m.label}</p>
          </div>
        ))}
      </div>
      <div data-reveal data-reveal-delay="0.3">
        <a
          href={href(base, '/b2b')}
          class="inline-flex items-center gap-3 px-10 py-5 bg-[var(--ink-inverse)] text-[var(--ink-primary)] text-lg font-medium tracking-wide hover:bg-[var(--color-crema)] transition-colors"
        >
          Prossimo: B2B →
        </a>
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: Adobe GenStudio for Performance Marketing (GA) · proiezione illustrativa su benchmark campagne bancarie</p>
    </Slide>

  </DeckContainer>

  <style>
    /* Il filo interno → cliente: la squadra che tiene la relazione. */
    .cw-thread { display: flex; flex-direction: column; gap: 0.85rem; }
    .cw-thread .uc-thread { align-items: flex-start; gap: 0.75rem; }
    .cw-thread .uc-node { margin-top: 0.5rem; }
    .cw-thread-item {
      color: var(--color-blu-medio);
      font-size: 0.96rem;
      line-height: 1.5;
      max-width: none;
      margin: 0;
    }
    .cw-timeline { display: flex; flex-direction: column; gap: 0.6rem; }
    .cw-timeline .uc-thread { align-items: center; }
  </style>
</BaseLayout>
