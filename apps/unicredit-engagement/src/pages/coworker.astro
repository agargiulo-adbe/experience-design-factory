---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const painPoints = [
  { num: '40%', label: 'del tempo dei team CX su task manuali, handoff, approvazioni, report' },
  { num: '3 settimane', label: 'dalla brief di campagna al go-live. Il momento rilevante è già passato.' },
  { num: '1 campagna / mese', label: 'la velocità media di un team CX senza automazione AI' },
];

const modules = [
  {
    name: 'Coworker Chat',
    status: 'Disponibile ora',
    desc: 'Automazione di task CX in linguaggio naturale. Idee → azioni in minuti. Skills personalizzabili, planning flessibile.',
    borderColor: 'var(--accent-primary)',
  },
  {
    name: 'Coworker Campaigns',
    status: 'Disponibile ora',
    desc: 'Template per campagne agile: dalla brief al lancio in 2 ore invece di 2 settimane. (ex Project Halo)',
    borderColor: 'var(--color-oro)',
  },
  {
    name: 'Coworker Projects',
    status: 'Coming H2 2026',
    desc: 'Workspace unificato per workflow CX end-to-end: task, approvazioni, esecuzione in un unico posto.',
    borderColor: 'var(--ink-tertiary)',
  },
];

const governancePillars = [
  { title: 'Brand policy enforcement', body: 'Ogni output rispetta le linee guida UniCredit' },
  { title: 'Regulatory compliance', body: 'DORA, PSD3, GDPR — built-in' },
  { title: 'Human-in-the-loop', body: 'Ogni azione critica richiede approvazione' },
  { title: 'Audit trail completo', body: 'Ogni decisione AI è tracciata e spiegabile' },
];

const finalMetrics = [
  { num: '3×', label: 'più campagne con stesso team' },
  { num: '−72%', label: 'riduzione del tempo di approvazione' },
  { num: '100%', label: 'brand compliance garantita' },
];

const campaignTimeline = [
  { time: '08:00', label: 'Brief → AI' },
  { time: '08:20', label: 'Contenuti GenStudio' },
  { time: '08:45', label: 'Approvazione 1-click' },
  { time: '09:00', label: 'Live su Meta' },
];
---
<BaseLayout
  title="Il Coworker AI — da intenzione a esecuzione"
  description="CX Enterprise Coworker: il team di Cristina lavora tre volte di più. Non lavora tre volte di più."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/b2b')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-data-dark')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="07 · COWORKER AI"
        numeral="07"
        title="Il Coworker AI — da intenzione a esecuzione"
        lead="Il team di Cristina lavora tre volte di più. Non lavora tre volte di più."
        size="phase"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il problema ───────────────────────────────────── -->
    <Slide id="slide-problem" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL PROBLEMA DI OGNI CMO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-10"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il tempo del team non dovrebbe andare qui
      </h2>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6 mb-10" data-reveal data-reveal-delay="0.2">
        {painPoints.map((p) => (
          <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-3"
              style="font-size: clamp(2rem, 3.5vw, 3.25rem);"
            >{p.num}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{p.label}</p>
          </div>
        ))}
      </div>
      <p class="text-base text-[var(--ink-secondary)] max-w-xl mx-auto text-center" data-reveal data-reveal-delay="0.35">
        Cristina può scegliere: strumenti che assistono, o un sistema che esegue.
      </p>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-30">Fonte: Adobe Content Supply Chain Benchmark Report, 2024 · settore banking</p>
    </Slide>

    <!-- ── SLIDE 2: Cos'è Coworker ────────────────────────────────── -->
    <Slide id="slide-coworker-intro" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>ADOBE CX ENTERPRISE COWORKER — GA</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Non un assistente. Un collega AI.
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-10 text-base" data-reveal data-reveal-delay="0.15">
        CX Enterprise Coworker è l'engine AI per l'automazione dei processi CX. Trasforma obiettivi di alto livello in esecuzione coordinata end-to-end — con governance, supervisione umana e contesto enterprise.
      </p>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6" data-reveal data-reveal-delay="0.2">
        {modules.map((m) => (
          <div class="p-6 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left" style={`border-top: 2px solid ${m.borderColor};`}>
            <p class="text-sm font-bold text-[var(--ink-primary)] mb-1">{m.name}</p>
            <p class="text-sm font-semibold uppercase tracking-wider text-[var(--ink-tertiary)] mb-3">{m.status}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: Marco's account manager ──────────────────────── -->
    <Slide id="slide-marco-brief" bg="primary" align="split">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
          <div class="flex items-center justify-center">
            <div class="bg-[var(--surface-secondary)] rounded-sm p-5 border border-[var(--line-subtle)] max-w-sm w-full text-sm">
              <p class="text-xs text-[var(--ink-tertiary)] mb-4 font-semibold tracking-wide uppercase">Coworker Chat · 10:05</p>
              <div class="bg-[var(--surface-primary)] rounded p-3 mb-3">
                <p class="text-[var(--ink-secondary)]">Prepara il brief per Marco Ferretti, appuntamento ore 14:00</p>
              </div>
              <div class="bg-[var(--accent-primary)]/8 rounded p-3 border-l-2 border-[var(--accent-primary)]">
                <p class="text-xs text-[var(--accent-primary)] font-semibold mb-2">Coworker · Brief generato</p>
                <p class="text-xs text-[var(--ink-secondary)]">Marco Ferretti · Propensity mutuo 87/100 · PMI metalmeccanica · 3 interazioni nell'ultima settimana · Proposta personalizzata: mutuo comm. 20Y €800K, tasso agevolato PMI...</p>
              </div>
            </div>
          </div>
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>COWORKER CHAT · STORIA DI MARCO</p>
            <h3
              class="text-[var(--ink-primary)] mb-5"
              style="font-size: clamp(1.6rem, 2.8vw, 2.6rem);"
              data-reveal
              data-reveal-delay="0.1"
            >
              Il consulente arriva preparato
            </h3>
            <p class="text-[var(--ink-secondary)] leading-relaxed mb-6 text-base" data-reveal data-reveal-delay="0.15">
              Coworker ha letto il profilo RT-CDP di Marco, analizzato il suo storico, e preparato la proposta — prima che il consulente aprisse il laptop.
            </p>
            <ul class="space-y-3" data-reveal data-reveal-delay="0.2">
              <li class="flex items-start gap-3">
                <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
                <p class="text-sm text-[var(--ink-secondary)]">Brief AI-generated in 30 secondi</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
                <p class="text-sm text-[var(--ink-secondary)]">Proposta personalizzata allegata</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 size-1.5 rounded-full bg-[var(--accent-primary)] flex-shrink-0"></span>
                <p class="text-sm text-[var(--ink-secondary)]">Storico cross-canale incluso</p>
              </li>
            </ul>
          </div>
        </div>
        <MediaDemoSlot id="coworker-chat-demo" label="Coworker Chat — Demo Video" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: Coworker Campaigns / Sofia ────────────────────── -->
    <Slide id="slide-campaigns-sofia" bg="secondary" align="split">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--color-oro)] mb-5" data-reveal>COWORKER CAMPAIGNS · STORIA DI SOFIA</p>
            <h3
              class="text-[var(--ink-primary)] mb-5"
              style="font-size: clamp(1.5rem, 2.6vw, 2.4rem);"
              data-reveal
              data-reveal-delay="0.1"
            >
              Sofia ha visto il reel alle 7:45. La campagna era live alle 7:00.
            </h3>
            <p class="text-[var(--ink-secondary)] leading-relaxed mb-6 text-sm" data-reveal data-reveal-delay="0.15">
              Il team di digital marketing ha usato Coworker Campaigns per orchestrare l'intera campagna Instagram — dalla brief al lancio in 2 ore invece di 2 settimane.
            </p>
            <div class="flex flex-col gap-2 mb-6" data-reveal data-reveal-delay="0.2">
              {campaignTimeline.map((t, i) => (
                <div class="flex items-center gap-4">
                  <span class="text-sm font-mono text-[var(--ink-tertiary)] w-12 flex-shrink-0">{t.time}</span>
                  <span class="w-2 h-2 rounded-full bg-[var(--color-oro)] flex-shrink-0"></span>
                  <span class="text-xs text-[var(--ink-secondary)]">{t.label}</span>
                </div>
              ))}
            </div>
            <div class="mt-6 flex items-start gap-4 p-4 bg-[var(--surface-primary)] border-l-2 border-[var(--color-oro)] rounded-r-sm" data-reveal data-reveal-delay="0.45">
              <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/10 flex items-center justify-center">
                <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
              </div>
              <div>
                <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Sofia, in questo momento</p>
                <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Ha visto il reel mentre aspettava il caffè. 15 minuti dopo era sul sito UniCredit.»</p>
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-4">
            <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
              <p class="text-sm font-bold text-[var(--color-oro)] mb-1">2 ore</p>
              <p class="text-xs text-[var(--ink-secondary)]">dal brief al live (vs. 3 settimane)</p>
            </div>
            <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
              <p class="text-sm font-bold text-[var(--color-oro)] mb-1">12 varianti creative</p>
              <p class="text-xs text-[var(--ink-secondary)]">testate (Experimentation Accelerator)</p>
            </div>
            <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
              <p class="text-sm font-bold text-[var(--color-oro)] mb-1">+34% CTR</p>
              <p class="text-xs text-[var(--ink-secondary)]">rispetto alla versione manuale</p>
            </div>
            <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
              <p class="text-sm font-bold text-[var(--color-oro)] mb-1">Sofia ha aperto il conto quella sera</p>
              <p class="text-xs text-[var(--ink-secondary)]">8 minuti · NPS 78 · 3 prodotti in 6 mesi</p>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="coworker-campaigns-demo" label="Coworker Campaigns — Demo Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 5: Governance ────────────────────────────────────── -->
    <Slide id="slide-governance" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>ENTERPRISE GOVERNANCE</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Velocità senza perdere il controllo
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-10 text-base" data-reveal data-reveal-delay="0.15">
        CX Enterprise Coworker non agisce mai senza contesto aziendale, policy di brand e supervisione umana. Cristina può approvare o bloccare prima del lancio.
      </p>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-6 mb-8" data-reveal data-reveal-delay="0.2">
        {governancePillars.map((p) => (
          <div class="p-7 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-sm font-bold text-[var(--accent-primary)] mb-2">{p.title}</p>
            <p class="text-base text-[var(--ink-secondary)] leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
      <p class="text-xs text-[var(--ink-tertiary)] text-center" data-reveal data-reveal-delay="0.35">
        Interface-agnostic: MCP + A2A — Coworker si integra con i sistemi già in uso da UniCredit.
      </p>
    </Slide>

    <!-- ── SLIDE 6: Risultato Cristina ────────────────────────────── -->
    <Slide id="slide-cristina-result" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-unlimited')}
        imageClass="opacity-12"
        scrim="bg-[var(--accent-primary)]/85"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-5" data-reveal>IL VALORE PER CRISTINA</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        3 campagne questa settimana invece di 1
      </h2>
      <p class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/80 max-w-2xl mb-10" data-reveal data-reveal-delay="0.15">
        Non perché il team lavora di più. Perché CX Enterprise Coworker gestisce il 40% del lavoro ripetitivo.
      </p>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6 mb-10" data-reveal data-reveal-delay="0.22">
        {finalMetrics.map((m) => (
          <div class="p-6 bg-[var(--ink-inverse)]/10 border border-[var(--ink-inverse)]/20 rounded-sm text-center">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--ink-inverse)] leading-none mb-2"
              style="font-size: clamp(2rem, 3.5vw, 3.25rem);"
            >{m.num}</p>
            <p class="text-xs text-[var(--ink-inverse)]/70">{m.label}</p>
          </div>
        ))}
      </div>
      <div data-reveal data-reveal-delay="0.3">
        <a
          href={href(base, '/b2b')}
          class="inline-flex items-center gap-3 px-10 py-5 bg-[var(--ink-inverse)] text-[var(--ink-primary)] text-lg font-medium tracking-wide hover:bg-[var(--color-crema)] transition-colors"
        >
          Prossimo: B2B →
        </a>
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-inverse)]/30">Fonte: Adobe GenStudio for Performance Marketing, Early Access 2025 · benchmark campagne bancarie</p>
    </Slide>

  </DeckContainer>
</BaseLayout>
