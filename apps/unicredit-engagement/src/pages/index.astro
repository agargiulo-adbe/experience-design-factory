---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const pillars = [
  { label: 'Conosci', sublabel: 'Real-Time CDP', solution: 'rtcdp', color: '#BE2027' },
  { label: 'Acquisisci', sublabel: 'Journey Optimizer', solution: 'ajo-b2c', color: '#C9A96E' },
  { label: 'Coinvolgi', sublabel: 'Personalization', solution: 'ajo-b2c', color: '#BE2027' },
  { label: 'Scala', sublabel: 'GenStudio', solution: 'genstudio', color: '#C9A96E' },
  { label: 'Analizza', sublabel: 'CJA', solution: 'cja', color: '#BE2027' },
  { label: 'B2B', sublabel: 'AJO B2B', solution: 'ajo-b2b', color: '#C9A96E' },
];
---
<BaseLayout
  title="Engagement Unlimited"
  description="Come Adobe trasforma ogni interazione in una relazione per UniCredit."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/scenario')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-inverse)]/82"
      />
      <CoverHero
        eyebrow="UniCredit × Adobe"
        title="Engagement Unlimited"
        lead="Trasformare ogni interazione digitale in una relazione che crea valore — per ogni cliente, in ogni momento."
        size="hero"
        tone="inverse"
        primary="UniCredit"
        secondary="Adobe"
      />
    </Slide>

    <!-- ── SLIDE 1: Piano strategico UniCredit Unlimited ─────────── -->
    <Slide id="slide-strategy" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-marble')}
        imageClass="opacity-30"
        scrim="bg-[var(--surface-primary)]/80"
      />
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>IL CONTESTO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-6"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        UniCredit Unlimited
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-14"
        style="font-size: clamp(1.15rem, 1.5vw, 1.45rem);"
        data-reveal
        data-reveal-delay="0.2"
      >
        Il piano strategico 2026–2028 punta su tecnologia e AI come abilitatori chiave.
        L'obiettivo: diventare la banca di riferimento per la relazione digitale con i clienti.
      </p>

      <div class="relative w-full max-w-4xl mx-auto grid grid-cols-3 gap-6" data-reveal data-reveal-delay="0.3">
        {[
          { value: '7M', label: 'clienti UniCredit', sub: '4M attivamente digitali' },
          { value: '60%+', label: 'transazioni online', sub: 'target 80% entro 2026' },
          { value: '€13B', label: 'utile netto 2028', sub: 'dal piano Unlimited' },
        ].map((m) => (
          <div class="text-center p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-2"
              style="font-size: clamp(2.25rem, 4vw, 3.5rem);"
            >
              {m.value}
            </p>
            <p class="text-sm font-medium text-[var(--ink-primary)] mb-0.5">{m.label}</p>
            <p class="text-xs text-[var(--ink-tertiary)]">{m.sub}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: La sfida + il percorso ───────────────────────── -->
    <Slide id="slide-journey" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-15"
        scrim="bg-[var(--accent-primary)]/82"
      />
      <p
        data-display
        class="font-[family-name:var(--font-display)] font-light leading-none text-[var(--ink-inverse)] mb-7"
        style="font-size: clamp(4rem, 10vw, 9rem);"
      >
        <span data-count-up="60">0</span>%
      </p>
      <p
        class="text-[clamp(1.5rem,2.4vw,2.25rem)] font-[family-name:var(--font-display)] font-normal text-[var(--ink-inverse)] leading-snug mb-5 max-w-3xl"
        data-reveal
        data-reveal-delay="0.2"
      >
        Il 60% delle transazioni è già digitale. Ma digital non significa ancora personale.
        Adobe trasforma la scala in rilevanza.
      </p>
      <p
        class="text-[clamp(1rem,1.3vw,1.2rem)] text-[var(--ink-inverse)]/65 mb-12"
        data-reveal
        data-reveal-delay="0.28"
      >
        UniCredit Investor Day 2024 · UCX Programme
      </p>

      <div
        class="flex flex-wrap justify-center gap-3 mb-12"
        data-reveal
        data-reveal-delay="0.35"
      >
        {pillars.map((p) => (
          <span
            data-nav-solution={p.solution}
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-[var(--ink-inverse)]/15 text-[var(--ink-inverse)] text-sm font-medium tracking-wide border border-[var(--ink-inverse)]/30 rounded-full"
          >
            {p.label}
          </span>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/scenario')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-inverse)] text-[var(--ink-primary)] hover:bg-[var(--color-crema)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-inverse)] focus-visible:outline-offset-4"
        >
          Inizia il percorso
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
