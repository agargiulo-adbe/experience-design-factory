---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const journey = [
  { num: '00', label: 'Scenario', sub: 'I protagonisti', href: '/scenario' },
  { num: '01', label: 'Visibilità', sub: 'Brand Visibility · AEM EDS', href: '/visibilita' },
  { num: '02', label: 'Conosci', sub: 'Real-Time CDP', href: '/conosci', solution: 'rtcdp' },
  { num: '03', label: 'Acquisisci', sub: 'Journey Optimizer', href: '/acquisisci', solution: 'ajo-b2c,aem-sites' },
  { num: '04', label: 'Coinvolgi', sub: 'Personalizzazione', href: '/coinvolgi', solution: 'ajo-b2c,target' },
  { num: '05', label: 'Contenuti', sub: 'GenStudio · Brand Concierge', href: '/contenuti', solution: 'genstudio,aem-assets' },
  { num: '06', label: 'Analizza', sub: 'CX Analytics · DIA', href: '/analizza', solution: 'cja' },
  { num: '07', label: 'Coworker AI', sub: 'Coworker', href: '/coworker' },
  { num: '08', label: 'B2B', sub: 'AJO B2B + Marketo', href: '/b2b', solution: 'ajo-b2b' },
  { num: '09', label: 'Il Motore', sub: 'Adobe AI Platform', href: '/motore-adobe' },
  { num: '10', label: 'Risultati', sub: 'ROI & business case', href: '/risultati' },
];

const unicreditStats = [
  { value: '€5,5B+', label: 'in tecnologia, digitale e dati', sub: 'investimento di piano entro il 2027' },
  { value: '€11B+', label: 'ambizione di utile netto', sub: 'obiettivo di piano al 2027' },
  { value: '>20%', label: 'RoTE obiettivo', sub: 'return on tangible equity al 2027' },
];
---
<BaseLayout
  title="Engagement Unlimited"
  description="Come Adobe trasforma ogni interazione digitale in una relazione che crea valore — per UniCredit."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/scenario')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="UniCredit × Adobe"
        title="Engagement Unlimited"
        lead="Due clienti reali. Un'unica piattaforma. Ogni sezione, un momento di valore."
        size="hero"
        tone="inverse"
        primary="UniCredit"
        secondary="Adobe"
      />
      <p class="mt-5 text-center text-[0.58rem] tracking-widest uppercase text-[var(--ink-inverse)]/40 max-w-2xl mx-auto">
        Demo concettuale — scenario illustrativo non commissionato da UniCredit · Dati pubblici e illustrativi citati alle fonti
      </p>
      <div class="flex gap-8 mt-6 justify-center flex-wrap" data-reveal data-reveal-delay="0.3">
        <div class="flex items-center gap-2.5 text-[var(--ink-inverse)]/70">
          <div class="size-7 rounded-full bg-[var(--accent-primary)]/20 flex items-center justify-center text-sm font-bold text-[var(--accent-primary)]">M</div>
          <p class="text-sm font-[family-name:var(--font-display)] italic">Marco — dal preventivo AI al mutuo casa</p>
        </div>
        <div class="flex items-center gap-2.5 text-[var(--ink-inverse)]/70">
          <div class="size-7 rounded-full bg-[var(--color-oro)]/20 flex items-center justify-center text-sm font-bold text-[var(--color-oro)]">S</div>
          <p class="text-sm font-[family-name:var(--font-display)] italic">Sofia — dal reel ads al primo conto</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: Piano strategico UniCredit ────────────────────── -->
    <Slide id="slide-strategy" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-marble')}
        imageClass="opacity-25"
        scrim="bg-[var(--surface-primary)]/82"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>IL CONTESTO STRATEGICO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        UniCredit Unlocked
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-10"
        style="font-size: clamp(1.1rem, 1.45vw, 1.4rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Con "UniCredit Unlimited" il Gruppo destina oltre €5,5B a tecnologia, digitale e dati entro il 2027: tecnologia e AI sono gli abilitatori chiave per raggiungere gli obiettivi di piano ed essere la banca di riferimento nella relazione digitale con i clienti italiani.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6"
        data-reveal
        data-reveal-delay="0.22"
      >
        {unicreditStats.map((m) => (
          <div class="text-center p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-2"
              style="font-size: clamp(2.25rem, 4vw, 3.5rem);"
            >
              {m.value}
            </p>
            <p class="text-sm font-medium text-[var(--ink-primary)] mb-0.5">{m.label}</p>
            <p class="text-xs text-[var(--ink-tertiary)]">{m.sub}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-40">
        Fonte:
        <a href="https://www.unicreditgroup.eu/en/one-unicredit/articles/2026/february/unicredit-unpacked-welcome-to-unicredit-unlimited-outperforming-the-old-and-the-new.html" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">UniCredit — piano UniCredit Unlimited (feb 2026)</a>
      </p>
    </Slide>

    <!-- ── SLIDE 2: Roadmap del percorso ──────────────────────────── -->
    <Slide id="slide-journey" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-unlimited')}
        imageClass="opacity-12"
        scrim="bg-[var(--accent-primary)]/83"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-5" data-reveal>IL PERCORSO</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-4"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
        data-edf-chapters
      >
        Undici capitoli. Due storie. Una relazione.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/78 max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        Una piattaforma unificata. Dalla visibilità AI al ROI — la storia di Marco e Sofia.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid grid-cols-3 md:grid-cols-4 gap-4 mb-10"
        data-reveal
        data-reveal-delay="0.22"
      >
        {journey.map((step) => (
          <a
            href={href(base, step.href)}
            data-nav-solution={step.solution ?? undefined}
            data-edf-journey-card
            class="p-5 bg-[var(--ink-inverse)]/10 border border-[var(--ink-inverse)]/20 rounded-sm text-left hover:bg-[var(--ink-inverse)]/18 transition-colors no-underline group"
          >
            <p class="text-sm font-semibold text-[var(--ink-inverse)]/55 mb-1" data-edf-cardnum>{step.num}</p>
            <p class="text-base font-semibold text-[var(--ink-inverse)] mb-0.5 group-hover:text-[var(--ink-inverse)]">{step.label}</p>
            <p class="text-sm text-[var(--ink-inverse)]/60">{step.sub}</p>
          </a>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.35">
        <a
          href={href(base, '/scenario')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-inverse)] text-[var(--ink-primary)] hover:bg-[var(--color-crema)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-inverse)] focus-visible:outline-offset-4"
        >
          Inizia il percorso
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>

  <!--
    Dynamic chapter count: "Undici capitoli" reflects the sections actually
    active in the Admin Console (solution gating). Gates mirror the home
    roadmap cards' data-nav-solution so the number matches the visible cards.
  -->
  <script is:inline>
  (function () {
    var KEY = 'edf-solutions-unicredit-engagement';
    // Per-section gate, in section order — matches the home roadmap cards.
    var GATES = [
      null, null, ['rtcdp'], ['ajo-b2c', 'aem-sites'], ['ajo-b2c', 'target'],
      ['genstudio', 'aem-assets'], ['cja'], null, ['ajo-b2b'], null, null,
    ];
    var WORDS = ['zero', 'una', 'due', 'tre', 'quattro', 'cinque', 'sei', 'sette', 'otto', 'nove', 'dieci', 'undici'];

    function activeIds() {
      var p = new URLSearchParams(location.search).get('s');
      if (p) return p.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
      try { var st = localStorage.getItem(KEY); if (st) return JSON.parse(st); } catch (_) {}
      return null;
    }
    function count() {
      var ids = activeIds();
      if (!ids) return GATES.length; // no restriction → every section active
      var n = 0;
      GATES.forEach(function (g) {
        if (!g || g.some(function (id) { return ids.indexOf(id) !== -1; })) n++;
      });
      return n;
    }
    function label(n) {
      if (n === 1) return 'Un capitolo';
      var w = WORDS[n] || String(n);
      return w.charAt(0).toUpperCase() + w.slice(1) + ' capitoli';
    }
    function renumber() {
      // Renumber visible roadmap cards consecutively so a gated-off section
      // never leaves a gap in the numbering (00, 01, 02 …).
      var n = 0;
      document.querySelectorAll('[data-edf-journey-card]').forEach(function (card) {
        var hidden = card.offsetParent === null || getComputedStyle(card).display === 'none';
        if (hidden) return;
        var numEl = card.querySelector('[data-edf-cardnum]');
        if (numEl) numEl.textContent = ('0' + n).slice(-2);
        n++;
      });
    }
    function apply() {
      var txt = label(count()) + '. Due storie. Una relazione.';
      document.querySelectorAll('[data-edf-chapters]').forEach(function (el) { el.textContent = txt; });
      renumber();
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply); else apply();
    document.addEventListener('astro:page-load', apply);
    window.addEventListener('storage', function (e) { if (e.key === KEY) apply(); });
  })();
  </script>
</BaseLayout>
