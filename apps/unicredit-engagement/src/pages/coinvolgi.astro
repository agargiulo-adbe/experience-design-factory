---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const nbaSignals = [
  { icon: '🔍', label: 'Ricerca in-app', detail: '"mutuo casa" × 3 in 7 giorni' },
  { icon: '💳', label: 'Comportamento', detail: 'Accrediti +18% ultimi 3 mesi' },
  { icon: '📊', label: 'Propensity CDP', detail: 'Score mutuo: 87/100' },
  { icon: '📅', label: 'Momento di vita', detail: 'Età media acquisto casa: 36-40a' },
];

const channels = [
  { label: 'Push notification', timing: 'sabato mattina', message: 'Hai pensato al mutuo? Scopri il tasso dedicato a te.' },
  { label: 'In-app banner', timing: 'accesso successivo', message: 'Offerta con rata stimata per Marco.' },
  { label: 'Social Ads', timing: 'in parallelo', message: 'Retargeting su Meta e Instagram, sincronizzato via RT-CDP.' },
  { label: 'Email personalizzata', timing: '+2 giorni se non apre', message: 'Contenuto GenStudio: tono professionale, dati reali.' },
  { label: 'Consulente proattivo', timing: '+5 giorni', message: 'Il RM riceve il segnale AJO e richiama con offerta pronta.' },
];

const results = [
  { stat: '↑', label: 'tasso di conversione sui mutui', sub: 'offerta rilevante vs. campagne broadcast' },
  { stat: '↓', label: 'costo di acquisizione prodotto', sub: 'grazie al timing preciso' },
  { stat: '↑', label: 'NPS post-offerta personalizzata', sub: 'vs. offerta generica' },
];
---
<BaseLayout
  title="Coinvolgi in tempo reale"
  description="AJO B2C intercetta il momento giusto di ogni cliente con il messaggio giusto, sul canale giusto."
  pageSolutions={['ajo-b2c', 'target']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/contenuti')} prevHref={href(base, '/acquisisci')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-secondary)]/82"
      />
      <CoverHero
        eyebrow="04 · ENGAGEMENT"
        numeral="04"
        title="Coinvolgi in tempo reale"
        lead="Il mutuo giusto proprio quando Marco ci sta pensando, non settimane più tardi."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il momento di Marco ──────────────────────────── -->
    <Slide id="slide-momento" bg="primary" align="split">
      <div class="cnv-momento uc-bg-inline w-full">
        <div class="w-full grid md:grid-cols-2 gap-8 md:gap-14 items-center">
          <div class="text-left">
            <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>IL MOMENTO DI VITA</p>
            <h2
              class="slide-title text-[var(--ink-primary)] mb-6"
              style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
              data-reveal
              data-reveal-delay="0.1"
            >
              Marco pensa a comprare casa
            </h2>
            <p
              class="text-[var(--ink-secondary)] leading-relaxed mb-6"
              style="font-size: clamp(1.05rem, 1.5vw, 1.3rem);"
              data-reveal
              data-reveal-delay="0.2"
            >
              38 anni, cliente UniCredit da 12 anni, con una famiglia in crescita. Questa settimana ha cercato "mutuo casa" tre volte nell'app e il suo profilo Real-Time CDP segna un propensity score di 87/100. La banca lo sa già, ma finora non ha agito.
            </p>
            <p class="text-[var(--ink-secondary)] text-sm leading-relaxed" data-reveal data-reveal-delay="0.3">
              <strong class="text-[var(--ink-primary)]">Journey Optimizer B2C</strong> coglie questi segnali e mette in campo l'azione omnicanale nel momento in cui conta di più.
            </p>
          </div>

          <div class="uc-panel uc-panel--oro" data-reveal data-reveal-delay="0.35">
            <div class="uc-panel-head">
              <span class="uc-tag">Segnali rilevati da Real-Time CDP</span>
            </div>
            <div class="flex flex-col gap-2.5">
              {nbaSignals.map((s, i) => (
                <div class="cnv-signal">
                  <span class="cnv-signal-thread" aria-hidden="true">
                    <span class={i === 0 ? 'uc-node uc-node--rosso' : 'uc-node'}></span>
                    {i < nbaSignals.length - 1 && <span class="cnv-signal-drop"></span>}
                  </span>
                  <span class="text-2xl flex-shrink-0 leading-none" aria-hidden="true">{s.icon}</span>
                  <div class="min-w-0">
                    <p class="text-[0.98rem] font-semibold text-[var(--color-blu-notte)] leading-tight">{s.label}</p>
                    <p class="text-[0.9rem] text-[var(--color-blu-medio)] leading-snug">{s.detail}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="cnv-nbx">
              <span class="uc-node" aria-hidden="true"></span>
              <div class="min-w-0">
                <p class="text-[0.95rem] font-semibold text-[var(--color-oro)] mb-1">Next-Best-Experience calcolata</p>
                <p class="text-[0.95rem] text-[var(--color-blu-medio)] leading-snug">Proposta mutuo 20 anni · tasso personalizzato · canale: app push + email</p>
              </div>
            </div>
          </div>
        </div>

        <div class="uc-panel mt-6" data-reveal data-reveal-delay="0.45">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/15 flex items-center justify-center">
              <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
            </div>
            <div>
              <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-grigio-500)] mb-1">Sofia, in questo momento</p>
              <p class="uc-quote-text">«Tre mesi dopo aver aperto il conto, l'app le propone: "Sofia, hai messo da parte €1.240, vuoi farli crescere con un piano di risparmio?" Il momento l'aveva scelto Target.»</p>
            </div>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Orchestrazione omnicanale ────────────────────── -->
    <Slide id="slide-orch" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-data-dark')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-inverse)]/88"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>JOURNEY OPTIMIZER B2C</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-10"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Il messaggio giusto,<br/>sul canale giusto
          </h2>

          <div
            class="cnv-channels w-full max-w-6xl mx-auto"
            data-reveal
            data-reveal-delay="0.2"
          >
            <div class="uc-thread cnv-channel-thread" aria-hidden="true">
              <span class="uc-node uc-node--rosso"></span>
              <span class="uc-thread-line"></span>
              <span class="uc-node"></span>
            </div>
            <div class="grid md:grid-cols-5 gap-4">
              {channels.map((ch, i) => (
                <div class="uc-panel cnv-channel">
                  <span class="cnv-channel-dot" aria-hidden="true"></span>
                  <p class="uc-tag mb-2">{ch.label}</p>
                  <p class="text-[0.9rem] text-[var(--color-grigio-500)] mb-3 leading-snug">{ch.timing}</p>
                  <p class="text-[0.92rem] text-[var(--color-blu-medio)] leading-relaxed italic">"{ch.message}"</p>
                </div>
              ))}
            </div>
          </div>

          <p
            class="mt-8 text-[var(--color-grigio-300)] text-[0.98rem] leading-relaxed max-w-2xl"
            data-reveal
            data-reveal-delay="0.4"
          >
            Adobe Target personalizza ogni touchpoint in tempo reale, dalla headline all'immagine all'offerta, in base al profilo CDP di Marco.
          </p>

          <div class="uc-panel uc-panel--rosso mt-8 max-w-3xl mx-auto" data-reveal data-reveal-delay="0.5">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-primary)]/12 flex items-center justify-center">
                <span class="text-xs font-bold text-[var(--accent-primary)]">M</span>
              </div>
              <div>
                <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-grigio-500)] mb-1">Marco, in questo momento</p>
                <p class="uc-quote-text">«La email è arrivata un mercoledì mattina, l'orario in cui Marco apre più spesso le comunicazioni della banca. A sceglierlo è stata la send-time optimization di Journey Optimizer, non il caso.»</p>
              </div>
            </div>
          </div>
        </div>
        <MediaDemoSlot id="coinvolgi-target-demo" label="Journey Optimizer + Adobe Target — Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Risultati ─────────────────────────────────────── -->
    <Slide id="slide-results" bg="primary" align="center">
      <div class="cnv-results uc-bg-inline w-full">
        <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IMPATTO BUSINESS</p>
        <h2
          class="slide-title text-[var(--ink-primary)] mb-8"
          style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
          data-reveal
          data-reveal-delay="0.1"
        >
          Scala + rilevanza = risultati
        </h2>

        <div class="uc-thread cnv-results-thread" data-reveal data-reveal-delay="0.15" aria-hidden="true">
          <span class="uc-node uc-node--rosso"></span>
          <span class="uc-thread-line"></span>
          <span class="uc-node"></span>
        </div>

        <div
          class="cnv-results-grid w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-6 mb-8"
          data-reveal
          data-reveal-delay="0.2"
        >
          {results.map((r) => (
            <div class="uc-panel uc-panel--oro text-center items-center">
              <p
                class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-3"
                style="font-size: clamp(2.25rem, 4vw, 3.5rem);"
              >
                {r.stat}
              </p>
              <p class="text-[0.98rem] font-medium text-[var(--color-blu-notte)] mb-1.5 leading-snug">{r.label}</p>
              <p class="text-[0.85rem] text-[var(--color-grigio-500)] leading-snug">{r.sub}</p>
            </div>
          ))}
        </div>
        <p class="mb-6 text-center text-[0.62rem] tracking-widest uppercase opacity-30">Fonte: Basato su Adobe Real-Time CDP impact study, settore bancario europeo · Forrester TEI, Adobe Experience Cloud, 2023</p>

        <div class="text-center" data-reveal data-reveal-delay="0.4">
          <a
            href={href(base, '/contenuti')}
            class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--accent-primary)] text-[var(--ink-inverse)] hover:opacity-90 transition-opacity duration-300"
          >
            Contenuti senza limiti
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* Coinvolgi (engage) — il filo DEEPENS: engagement come connessione
     sostenuta lungo il thread ORO. Piccolo override di pagina; solo rgba
     esplicito su qualsiasi fondo di testo (mai oklab/color-mix). */

  /* Depth di fondo sotto i pannelli chiari, scoped alla pagina */
  .uc-bg-inline {
    background:
      radial-gradient(120% 75% at 12% 0%, rgba(190, 32, 39, 0.05), transparent 55%),
      radial-gradient(115% 85% at 90% 100%, rgba(201, 169, 110, 0.12), transparent 55%);
    border-radius: 6px;
    padding: 1.4rem 1.4rem 1.5rem;
  }

  /* Segnali RT-CDP: ogni riga è un nodo sul filo che scende (relazione che si approfondisce) */
  .cnv-signal {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    position: relative;
  }
  .cnv-signal-thread {
    position: relative;
    flex: 0 0 auto;
    width: 9px;
    display: flex;
    justify-content: center;
    align-self: stretch;
    align-items: flex-start;
    padding-top: 0.35rem;
  }
  .cnv-signal-drop {
    position: absolute;
    top: 0.75rem;
    bottom: -0.9rem;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: linear-gradient(to bottom, rgba(201, 169, 110, 0.55), rgba(201, 169, 110, 0.2));
    border-radius: 2px;
  }

  /* Il nodo terminale del filo: la Next-Best-Experience calcolata */
  .cnv-nbx {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-top: 0.9rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(201, 169, 110, 0.45);
  }
  .cnv-nbx .uc-node {
    margin-top: 0.4rem;
  }

  /* Canali: il filo ORO collega i touchpoint in sequenza */
  .cnv-channel-thread {
    margin-bottom: 1rem;
  }
  .cnv-channel {
    position: relative;
    text-align: left;
    padding-top: 1.35rem;
    background: rgba(255, 255, 255, 0.96);
  }
  .cnv-channel-dot {
    position: absolute;
    top: -5px;
    left: 1.4rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-oro);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.18);
  }

  /* Il filo continuo sopra le tre metriche di risultato */
  .cnv-results-thread {
    max-width: 56rem;
    margin: 0 auto 1.4rem;
  }

  @media (max-width: 767px) {
    .cnv-channel-thread {
      display: none;
    }
    .cnv-channel {
      padding-top: 1.35rem;
    }
  }
</style>
