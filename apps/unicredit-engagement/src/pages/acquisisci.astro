---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const journeySteps = [
  {
    phase: '1',
    label: 'Scoperta',
    channel: 'App / Web',
    action: 'Sofia cerca "aprire conto corrente". AEM Sites mostra una landing personalizzata; Adobe Target sceglie in tempo reale la variante migliore per lei.',
    product: 'AEM Sites + Adobe Target',
  },
  {
    phase: '2',
    label: 'Richiesta',
    channel: 'App mobile',
    action: 'Modulo compilato in-app, documento d\'identità letto con AI OCR. Niente filiale, niente carta.',
    product: 'AJO B2C',
  },
  {
    phase: '3',
    label: 'Verifica',
    channel: 'Digital',
    action: 'Verifica identità e firma digitale in-app. AJO orchestra il follow-up se il flusso si interrompe.',
    product: 'AJO B2C',
  },
  {
    phase: '4',
    label: 'Attivazione',
    channel: 'App + Email',
    action: 'Conto attivo. Sequenza onboarding personalizzata: prima transazione, carta digitale, Apple Pay.',
    product: 'AJO B2C',
  },
];

const kpis = [
  { stat: '↓', label: 'tempo di apertura conto', sub: 'da giorni a minuti · 100% digitale' },
  { stat: '↑', label: 'tasso di completamento', sub: 'vs. modulo cartaceo in filiale' },
  { stat: '↓', label: 'abbandoni nel funnel', sub: 'con journey orchestrati vs. form statico' },
];
---
<BaseLayout
  title="Acquisisci digitale"
  description="AJO B2C e AEM Sites orchestrano un onboarding 100% digitale che riduce i tempi da giorni a ore."
  pageSolutions={['ajo-b2c', 'aem-sites']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/coinvolgi')} prevHref={href(base, '/conosci')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-secondary)]/80"
      />
      <CoverHero
        eyebrow="03 · ACQUISIZIONE"
        numeral="03"
        title="Acquisisci digitale"
        lead="Sofia apre il suo primo conto interamente da mobile, senza mai entrare in filiale. È così che si fa onboarding nel 2026."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Storia Sofia ─────────────────────────────────── -->
    <Slide id="slide-storia-acquisisci" bg="secondary" align="split">
      <div class="uc-bg-soft absolute inset-0 -z-10" aria-hidden="true"></div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="uc-thread mb-5" data-reveal aria-hidden="true">
            <span class="uc-node"></span>
            <span class="uc-thread-line"></span>
            <span class="uc-node uc-node--rosso"></span>
          </div>
          <p class="slide-eyebrow text-[var(--color-oro)] mb-4" data-reveal data-reveal-delay="0.06">STORIA DI SOFIA · PASSO 3 DI 10</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
Sono le 22:15. In metro,<br/>non allo sportello.
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed mb-6"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.2"
          >
            Sofia ha visto il reel ads alle 19:30 e alle 22:15 ha aperto l'app UniCredit, in metro. Journey Optimizer aveva già pronta la sequenza di onboarding: push notification → landing page personalizzata → form semplificato → firma digitale → conferma.
          </p>
          <div class="uc-quote" data-reveal data-reveal-delay="0.45">
            <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-2">Sofia, in questo momento</p>
            <p class="uc-quote-text">«Le tre banche con cui stava confrontando richiedevano appuntamento in filiale. UniCredit le ha detto: fallo ora, da qui.»</p>
          </div>
        </div>

        <div class="flex items-center justify-center" data-reveal data-reveal-delay="0.3">
          <div class="relative overflow-hidden rounded-sm" style="width:100%; height:min(500px,65dvh);">
            <MediaSlot {...mediaProps('persona-sara')} fill objectPosition="top" />
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Sofia persona ─────────────────────────────────── -->
    <Slide id="slide-sara" bg="primary" align="split">
      <div class="uc-bg absolute inset-0 -z-10" aria-hidden="true"></div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="uc-thread mb-5" data-reveal aria-hidden="true">
            <span class="uc-node uc-node--rosso"></span>
            <span class="uc-thread-line"></span>
            <span class="uc-node"></span>
          </div>
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal data-reveal-delay="0.06">IL CLIENTE DI DOMANI</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Sofia non verrà mai in filiale
          </h2>
          <div class="uc-panel uc-panel--rosso mb-5" data-reveal data-reveal-delay="0.2">
            <p class="text-sm font-semibold text-[var(--color-blu-notte)] mb-1">Sofia Ricci · 27 anni · Milano</p>
            <p class="uc-panel-body" style="margin-bottom:0;">UX Designer freelance, primo conto corrente. Si aspetta un processo 100% digitale, da mobile, senza filiale. Se l'esperienza è lenta o macchinosa, in pochi minuti passa alla concorrenza.</p>
          </div>
          <p class="text-[var(--ink-secondary)] text-sm leading-relaxed" data-reveal data-reveal-delay="0.3">
            Sofia è il <strong class="text-[var(--ink-primary)]">canale di acquisizione primario</strong> di UniCredit per i prossimi dieci anni. La qualità dell'onboarding decide la relazione di lungo periodo.
          </p>
        </div>

        <div class="flex flex-col gap-4" data-reveal data-reveal-delay="0.35">
          <div class="uc-panel uc-panel--oro">
            <p class="uc-tag" style="color:var(--color-oro);">Aspettative Gen Z/Millennial</p>
            <div class="mt-3">
              {[
                ['Apertura conto', 'senza appuntamento'],
                ['Tutto da mobile', 'no PDF, no stampe'],
                ['Firma digitale', 'no filiale obbligatoria'],
                ['Supporto', 'chat in-app, non call center'],
              ].map(([k, v]) => (
                <div class="flex justify-between items-center gap-4 py-2 border-b border-[rgba(26,26,46,0.1)] last:border-0">
                  <span class="text-sm text-[var(--color-blu-medio)]">{k}</span>
                  <span class="text-sm font-medium text-[var(--color-blu-notte)] text-right">{v}</span>
                </div>
              ))}
            </div>
          </div>
          <p class="uc-src">Aspettative Gen Z/Millennial · scenario illustrativo</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Journey steps ─────────────────────────────────── -->
    <Slide id="slide-journey" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('onboarding-digital')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-inverse)]/90"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--color-oro)] mb-5" data-reveal>IL PERCORSO ORCHESTRATO DA AJO</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-8"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Da lead a cliente attivo, in un solo flusso
          </h2>

          <!-- il filo: 4 nodi ORO uniti dal thread, uno per fase -->
          <div class="w-full max-w-5xl mx-auto mb-6 px-8" data-reveal data-reveal-delay="0.15" aria-hidden="true">
            <div class="uc-thread">
              <span class="uc-node"></span>
              <span class="uc-thread-line"></span>
              <span class="uc-node"></span>
              <span class="uc-thread-line"></span>
              <span class="uc-node"></span>
              <span class="uc-thread-line"></span>
              <span class="uc-node uc-node--rosso"></span>
            </div>
          </div>

          <div
            class="w-full max-w-5xl mx-auto grid md:grid-cols-4 gap-5"
            data-reveal
            data-reveal-delay="0.2"
          >
            {journeySteps.map((step, i) => (
              <div class="uc-step text-left flex flex-col h-full">
                {i < journeySteps.length - 1 && (
                  <div class="hidden md:block absolute top-8 -right-3 text-[var(--color-oro)] z-10 text-lg" aria-hidden="true">→</div>
                )}
                <div class="flex items-center gap-2 mb-3">
                  <span class="uc-step-mark">{step.phase}</span>
                  <span class="text-xs font-semibold text-[var(--color-oro)] uppercase tracking-wide">{step.label}</span>
                </div>
                <p class="text-sm text-[var(--color-grigio-300)] uppercase tracking-wide mb-2">{step.channel}</p>
                <p class="text-sm text-[var(--color-grigio-200)] leading-relaxed mb-3">{step.action}</p>
                <span class="uc-step-tag mt-auto self-start">{step.product}</span>
              </div>
            ))}
          </div>
        </div>
        <MediaDemoSlot id="acquisisci-jo-demo" label="Journey Optimizer — Orchestrazione Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: Experimentation Accelerator ─────────────────── -->
    <Slide id="slide-experimentation" bg="primary" align="center">
      <div class="uc-bg absolute inset-0 -z-10" aria-hidden="true"></div>
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>ADOBE EXPERIMENTATION ACCELERATOR</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            12 varianti. 1 vincitore.
          </h2>
          <p
            class="text-[var(--ink-secondary)] mb-9 max-w-3xl"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.15"
          >
            Il team non tira più a indovinare: testa. Con Experimentation Accelerator lancia 5× più esperimenti a parità di persone, dal CTA alla landing page all'offerta.
          </p>

          <div
            class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-6 mb-9"
            data-reveal
            data-reveal-delay="0.2"
          >
            <div class="uc-card">
              <span class="uc-figure mb-2">5×</span>
              <p class="uc-card-title" style="font-size:1.05rem; margin-bottom:0.4rem;">più esperimenti</p>
              <p class="uc-card-body">Con lo stesso team. Automazione AI suggerisce ipotesi e configura i test.</p>
            </div>
            <div class="uc-card">
              <span class="uc-figure mb-2">CTR ↑</span>
              <p class="uc-card-title" style="font-size:1.05rem; margin-bottom:0.4rem;">sulla variante vincente</p>
              <p class="uc-card-body">Il test sulla CTA "Apri il tuo primo conto" per Sofia: 12 varianti in 48 ore.</p>
            </div>
            <div class="uc-card">
              <span class="uc-figure mb-2">3 giorni</span>
              <p class="uc-card-title" style="font-size:1.05rem; margin-bottom:0.4rem;">→ live</p>
              <p class="uc-card-body">Dal setup del test ai risultati statisticamente significativi. Non 3 settimane.</p>
            </div>
          </div>

          <div class="uc-panel uc-panel--oro max-w-3xl mx-auto text-left" data-reveal data-reveal-delay="0.45">
            <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-2">Sofia, in questo momento</p>
            <p class="font-[family-name:var(--font-display)] text-base text-[var(--color-blu-notte)] italic leading-relaxed" style="max-width:none;">«Ha cliccato "Apri il conto" sulla variante B, senza sapere che aveva battuto altre 11 versioni e che la conversione era appena salita.»</p>
          </div>
          <p class="mt-5 text-center text-[0.7rem] tracking-widest uppercase text-[var(--color-grigio-400)]">Adobe Experimentation Accelerator · schema illustrativo · A/B test su campagna acquisizione conto</p>
        </div>
        <MediaDemoSlot id="acquisisci-experimentation-demo" label="Experimentation Accelerator — Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 5: KPI risultati ─────────────────────────────────── -->
    <Slide id="slide-kpi" bg="primary" align="center">
      <div class="uc-bg absolute inset-0 -z-10" aria-hidden="true"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>RISULTATI ATTESI</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        L'onboarding diventa un vantaggio competitivo
      </h2>

      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-3xl mx-auto mb-9 text-[clamp(0.95rem,1.15vw,1.1rem)]"
        data-reveal
        data-reveal-delay="0.15"
      >
        UniCredit può già avere un onboarding digitale end-to-end. La differenza la fanno <strong class="text-[var(--ink-primary)]">AEM Sites</strong> (landing veloce e personalizzata), <strong class="text-[var(--ink-primary)]">Adobe Target</strong> (la variante giusta in tempo reale) e <strong class="text-[var(--ink-primary)]">AJO</strong> (che guida ogni passo e recupera chi abbandona). Il risultato è un processo che converte di più a ogni iterazione.
      </p>

      <div
        class="w-full max-w-3xl mx-auto grid md:grid-cols-3 gap-6 mb-9"
        data-reveal
        data-reveal-delay="0.2"
      >
        {kpis.map((k) => (
          <div class="uc-card items-center text-center">
            <p class="uc-stat-value" style="font-size:clamp(2.25rem,4vw,3.5rem);">{k.stat}</p>
            <p class="text-sm font-medium text-[var(--color-blu-notte)] mb-1">{k.label}</p>
            <p class="uc-stat-src">{k.sub}</p>
          </div>
        ))}
      </div>
      <p class="mb-6 text-center text-[0.7rem] tracking-widest uppercase text-[var(--color-grigio-400)]">Proiezione illustrativa · modello su benchmark Adobe Experience Cloud · non sono risultati ufficiali UniCredit</p>

      <div data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/coinvolgi')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--accent-primary)] text-[var(--ink-inverse)] hover:opacity-90 transition-opacity duration-300"
        >
          Coinvolgi in tempo reale
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>

  <style>
    /* Acquisisci — il filo dell'acquisizione: nodo/momento in cui il prospect
       entra nella relazione. Piccole classi di pagina, colori rgba espliciti. */
    #slide-journey .uc-step {
      position: relative;
      background: rgba(201, 169, 110, 0.08);
      border: 1px solid rgba(201, 169, 110, 0.28);
      border-radius: 4px;
      padding: 1.4rem 1.35rem 1.2rem;
      min-width: 0;
    }
    #slide-journey .uc-step-mark {
      width: 1.6rem;
      height: 1.6rem;
      border-radius: 50%;
      background: var(--color-oro);
      color: var(--color-blu-notte);
      font-weight: 700;
      font-size: 0.85rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    #slide-journey .uc-step-tag {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-oro);
      background: rgba(201, 169, 110, 0.15);
      padding: 0.15rem 0.6rem;
      border-radius: 9999px;
    }
  </style>
</BaseLayout>
