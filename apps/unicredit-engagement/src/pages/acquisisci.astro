---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const journeySteps = [
  {
    phase: '1',
    label: 'Scoperta',
    channel: 'App / Web',
    action: 'Sofia cerca "aprire conto corrente". AEM Sites mostra una landing personalizzata; Adobe Target sceglie in tempo reale la variante migliore per lei.',
    product: 'AEM Sites + Adobe Target',
  },
  {
    phase: '2',
    label: 'Richiesta',
    channel: 'App mobile',
    action: 'Modulo compilato in-app, documento d\'identità letto con AI OCR. Niente filiale, niente carta.',
    product: 'AJO B2C',
  },
  {
    phase: '3',
    label: 'Verifica',
    channel: 'Digital',
    action: 'Verifica identità e firma digitale in-app. AJO orchestra il follow-up se il flusso si interrompe.',
    product: 'AJO B2C',
  },
  {
    phase: '4',
    label: 'Attivazione',
    channel: 'App + Email',
    action: 'Conto attivo. Sequenza onboarding personalizzata: prima transazione, carta digitale, Apple Pay.',
    product: 'AJO B2C',
  },
];

const kpis = [
  { stat: '↓', label: 'tempo di apertura conto', sub: 'da giorni a minuti · 100% digitale' },
  { stat: '↑', label: 'tasso di completamento', sub: 'vs. modulo cartaceo in filiale' },
  { stat: '↓', label: 'abbandoni nel funnel', sub: 'con journey orchestrati vs. form statico' },
];
---
<BaseLayout
  title="Acquisisci digitale"
  description="AJO B2C e AEM Sites orchestrano un onboarding 100% digitale che riduce i tempi da giorni a ore."
  pageSolutions={['ajo-b2c', 'aem-sites']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/coinvolgi')} prevHref={href(base, '/conosci')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-secondary)]/80"
      />
      <CoverHero
        eyebrow="03 · ACQUISIZIONE"
        numeral="03"
        title="Acquisisci digitale"
        lead="Sofia apre il suo primo conto interamente da mobile, senza mai entrare in filiale. È così che si fa onboarding nel 2026."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Storia Sofia ─────────────────────────────────── -->
    <Slide id="slide-storia-acquisisci" bg="secondary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--color-oro)] mb-5" data-reveal>STORIA DI SOFIA · PASSO 3 DI 10</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
Sono le 22:15. In metro,<br/>non allo sportello.
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed mb-6"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.2"
          >
            Sofia ha visto il reel ads alle 19:30 e alle 22:15 ha aperto l'app UniCredit, in metro. Journey Optimizer aveva già pronta la sequenza di onboarding: push notification → landing page personalizzata → form semplificato → firma digitale → conferma.
          </p>
          <div class="mt-8 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--color-oro)] rounded-r-sm" data-reveal data-reveal-delay="0.45">
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/10 flex items-center justify-center">
              <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
            </div>
            <div>
              <p class="text-sm font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Sofia, in questo momento</p>
              <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Le tre banche con cui stava confrontando richiedevano appuntamento in filiale. UniCredit le ha detto: fallo ora, da qui.»</p>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-center" data-reveal data-reveal-delay="0.3">
          <div class="relative overflow-hidden rounded-sm" style="width:100%; height:min(500px,65dvh);">
            <MediaSlot {...mediaProps('persona-sara')} fill objectPosition="top" />
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Sofia persona ─────────────────────────────────── -->
    <Slide id="slide-sara" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>IL CLIENTE DI DOMANI</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Sofia non verrà mai in filiale
          </h2>
          <div
            class="p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm mb-5"
            data-reveal
            data-reveal-delay="0.2"
          >
            <p class="text-sm font-semibold text-[var(--ink-primary)] mb-1">Sofia Ricci · 27 anni · Milano</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">UX Designer freelance, primo conto corrente. Si aspetta un processo 100% digitale, da mobile, senza filiale. Se l'esperienza è lenta o macchinosa, in pochi minuti passa alla concorrenza.</p>
          </div>
          <p class="text-[var(--ink-secondary)] text-sm leading-relaxed" data-reveal data-reveal-delay="0.3">
            Sofia è il <strong class="text-[var(--ink-primary)]">canale di acquisizione primario</strong> di UniCredit per i prossimi dieci anni. La qualità dell'onboarding decide la relazione di lungo periodo.
          </p>
        </div>

        <div class="flex flex-col gap-4" data-reveal data-reveal-delay="0.35">
          <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <p class="text-xs font-semibold text-[var(--accent-primary)] uppercase tracking-wide mb-3">Aspettative Gen Z/Millennial</p>
            {[
              ['Apertura conto', 'senza appuntamento'],
              ['Tutto da mobile', 'no PDF, no stampe'],
              ['Firma digitale', 'no filiale obbligatoria'],
              ['Supporto', 'chat in-app, non call center'],
            ].map(([k, v]) => (
              <div class="flex justify-between items-center py-2 border-b border-[var(--line-subtle)] last:border-0">
                <span class="text-sm text-[var(--ink-secondary)]">{k}</span>
                <span class="text-sm font-medium text-[var(--ink-primary)]">{v}</span>
              </div>
            ))}
          </div>
          <p class="text-xs text-[var(--ink-tertiary)]">Aspettative Gen Z/Millennial · scenario illustrativo</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Journey steps ─────────────────────────────────── -->
    <Slide id="slide-journey" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('onboarding-digital')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-inverse)]/90"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>IL PERCORSO ORCHESTRATO DA AJO</p>
          <h2
            class="slide-title text-[var(--ink-inverse)] mb-10"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Da lead a cliente attivo, in un solo flusso
          </h2>

          <div
            class="w-full max-w-5xl mx-auto grid md:grid-cols-4 gap-5"
            data-reveal
            data-reveal-delay="0.2"
          >
            {journeySteps.map((step, i) => (
              <div class="relative p-6 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-left flex flex-col h-full">
                {i < journeySteps.length - 1 && (
                  <div class="hidden md:block absolute top-9 right-1 text-[var(--accent-primary)] z-10" aria-hidden="true">→</div>
                )}
                <div class="flex items-center gap-2 mb-3">
                  <span class="w-6 h-6 rounded-full bg-[var(--accent-primary)] flex items-center justify-center text-white text-xs font-semibold flex-shrink-0">{step.phase}</span>
                  <span class="text-xs font-semibold text-[var(--accent-primary)] uppercase tracking-wide">{step.label}</span>
                </div>
                <p class="text-sm text-[var(--color-grigio-400)] uppercase tracking-wide mb-2">{step.channel}</p>
                <p class="text-sm text-[var(--color-grigio-300)] leading-relaxed mb-3">{step.action}</p>
                <span class="mt-auto self-start inline-block text-sm font-medium text-[var(--accent-secondary)] bg-[var(--accent-secondary)]/15 px-2 py-0.5 rounded-full">{step.product}</span>
              </div>
            ))}
          </div>
        </div>
        <MediaDemoSlot id="acquisisci-jo-demo" label="Journey Optimizer — Orchestrazione Screenshot" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: Experimentation Accelerator ─────────────────── -->
    <Slide id="slide-experimentation" bg="primary" align="center">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>ADOBE EXPERIMENTATION ACCELERATOR</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-6"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            12 varianti. 1 vincitore.
          </h2>
          <p
            class="text-[var(--ink-secondary)] mb-10 max-w-3xl"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.15"
          >
            Il team non tira più a indovinare: testa. Con Experimentation Accelerator lancia 5× più esperimenti a parità di persone, dal CTA alla landing page all'offerta.
          </p>

          <div
            class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-6 mb-10"
            data-reveal
            data-reveal-delay="0.2"
          >
            <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-2xl font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] mb-2">5×</p>
              <p class="text-sm font-semibold text-[var(--ink-primary)] mb-2">più esperimenti</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Con lo stesso team. Automazione AI suggerisce ipotesi e configura i test.</p>
            </div>
            <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-2xl font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] mb-2">CTR ↑</p>
              <p class="text-sm font-semibold text-[var(--ink-primary)] mb-2">sulla variante vincente</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Il test sulla CTA "Apri il tuo primo conto" per Sofia: 12 varianti in 48 ore.</p>
            </div>
            <div class="p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
              <p class="text-2xl font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] mb-2">3 giorni</p>
              <p class="text-sm font-semibold text-[var(--ink-primary)] mb-2">→ live</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">Dal setup del test ai risultati statisticamente significativi. Non 3 settimane.</p>
            </div>
          </div>

          <div class="mt-8 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--color-oro)] rounded-r-sm max-w-3xl mx-auto" data-reveal data-reveal-delay="0.45">
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--color-oro)]/10 flex items-center justify-center">
              <span class="text-xs font-bold text-[var(--color-oro)]">S</span>
            </div>
            <div>
              <p class="text-xs font-semibold tracking-wider uppercase text-[var(--ink-tertiary)] mb-1">Sofia, in questo momento</p>
              <p class="font-[family-name:var(--font-display)] text-base text-[var(--ink-secondary)] italic leading-relaxed">«Ha cliccato "Apri il conto" sulla variante B, senza sapere che aveva battuto altre 11 versioni e che la conversione era appena salita.»</p>
            </div>
          </div>
          <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-30">Adobe Experimentation Accelerator · schema illustrativo · A/B test su campagna acquisizione conto</p>
        </div>
        <MediaDemoSlot id="acquisisci-experimentation-demo" label="Experimentation Accelerator — Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 5: KPI risultati ─────────────────────────────────── -->
    <Slide id="slide-kpi" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>RISULTATI ATTESI</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        L'onboarding diventa un vantaggio competitivo
      </h2>

      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-3xl mx-auto mb-9 text-[clamp(0.95rem,1.15vw,1.1rem)]"
        data-reveal
        data-reveal-delay="0.15"
      >
        UniCredit può già avere un onboarding digitale end-to-end. La differenza la fanno <strong class="text-[var(--ink-primary)]">AEM Sites</strong> (landing veloce e personalizzata), <strong class="text-[var(--ink-primary)]">Adobe Target</strong> (la variante giusta in tempo reale) e <strong class="text-[var(--ink-primary)]">AJO</strong> (che guida ogni passo e recupera chi abbandona). Il risultato è un processo che converte di più a ogni iterazione.
      </p>

      <div
        class="w-full max-w-3xl mx-auto grid md:grid-cols-3 gap-6 mb-10"
        data-reveal
        data-reveal-delay="0.2"
      >
        {kpis.map((k) => (
          <div class="text-center p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-2"
              style="font-size: clamp(2.25rem, 4vw, 3.5rem);"
            >
              {k.stat}
            </p>
            <p class="text-sm font-medium text-[var(--ink-primary)] mb-1">{k.label}</p>
            <p class="text-xs text-[var(--ink-tertiary)]">{k.sub}</p>
          </div>
        ))}
      </div>
      <p class="mb-6 text-center text-[0.62rem] tracking-widest uppercase opacity-40">Proiezione illustrativa · modello su benchmark Adobe Experience Cloud · non sono risultati ufficiali UniCredit</p>

      <div data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/coinvolgi')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--accent-primary)] text-[var(--ink-inverse)] hover:opacity-90 transition-opacity duration-300"
        >
          Coinvolgi in tempo reale
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
