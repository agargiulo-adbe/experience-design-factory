---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const macroTrends = [
  {
    trend: 'AI Search',
    desc: 'Le ricerche passano dai motori agli assistenti AI: Gartner stima −25% di volume sui motori tradizionali entro il 2026. Se ChatGPT, Gemini o Perplexity non ti citano, per il cliente non ci sei.',
  },
  {
    trend: 'Hyper-personalizzazione',
    desc: 'Le FinTech offrono esperienze su misura con pochi dati. Le banche hanno dati infiniti ma faticano a usarli in tempo reale.',
  },
  {
    trend: 'Zero-latency intelligence',
    desc: 'Il churn non si previene guardando indietro: servono segnali precoci e azioni automatiche in pochi minuti, non in giorni.',
  },
];

const gaps = [
  { problem: 'Dati frammentati', desc: 'Milioni di clienti e dati sparsi tra sistemi che si parlano poco. Il profilo che mette insieme app, filiale e call center spesso resta parziale.' },
  { problem: 'Interazioni generiche', desc: "L'app risponde alla transazione, ma non sa a che punto è il cliente: un figlio che nasce, una casa da comprare, la pensione che si avvicina." },
  { problem: 'Intelligence silenziosa', desc: 'I dati ci sono, ma trasformarli in decisioni richiede giorni, non minuti. E i segnali di churn si notano solo quando è tardi.' },
  { problem: 'Contenuti lenti', desc: "Le campagne arrivano tre settimane dopo l'evento che le ha ispirate, quando il momento è ormai passato." },
];

const marcoPills = ['Adobe Brand Visibility: UniCredit GEO', 'AEM EDS: 0,3s', 'RT-CDP: profilo unico', 'Mutuo prima casa'];
const sofiaPills = ['Instagram → Reel ads GenStudio', 'Conto aperto da mobile', 'Funnel ottimizzato', '3 prodotti in 6 mesi'];
---
<BaseLayout
  title="Il cliente del futuro è già qui"
  description="Due storie vere e una sola piattaforma: il viaggio che UniCredit può già offrire a ogni cliente italiano."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/visibilita')} prevHref={href(base, '/')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-inverse)]/84"
      />
      <CoverHero
        eyebrow="00 · SCENARIO"
        title="Il cliente del futuro è già qui"
        lead="Due storie vere e una sola piattaforma: il viaggio che UniCredit può già offrire a ogni cliente italiano."
        size="phase"
        tone="inverse"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Macro trends ──────────────────────────────────── -->
    <Slide id="slide-trends" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-unlimited')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-primary)]/86"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL CONTESTO</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-9"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il banking sta cambiando. Di nuovo.
      </h2>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-3 gap-6" data-reveal data-reveal-delay="0.2">
        {macroTrends.map((t) => (
          <div class="p-6 bg-[var(--surface-secondary)] border-t-2 border-[var(--accent-primary)] text-left">
            <p class="text-sm font-bold text-[var(--ink-primary)] mb-3">{t.trend}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-40">
        Fonte:
        <a href="https://www.gartner.com/en/newsroom/press-releases/2024-02-19-gartner-predicts-search-engine-volume-will-drop-25-percent-by-2026-due-to-ai-chatbots-and-other-virtual-agents" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">Gartner, feb 2024</a>
        ·
        <a href="https://blog.adobe.com/en/publish/2025/03/17/adobe-analytics-traffic-to-us-retail-websites-from-generative-ai-sources-jumps-1200-percent" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">Adobe Analytics, 2025</a>
      </p>
    </Slide>

    <!-- ── SLIDE 2: Il gap oggi ───────────────────────────────────── -->
    <Slide id="slide-gap" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>IL GAP ATTUALE</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-9"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Quattro problemi che ogni giorno costano relazione
      </h2>
      <div class="w-full max-w-5xl mx-auto grid grid-cols-2 gap-5" data-reveal data-reveal-delay="0.2">
        {gaps.map((g) => (
          <div class="p-6 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-sm font-bold text-[var(--accent-primary)] mb-3">{g.problem}</p>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{g.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase opacity-40">Sfide ricorrenti del retail banking · scenario illustrativo</p>
    </Slide>

    <!-- ── SLIDE 3: Marco Ferretti ────────────────────────────────── -->
    <Slide id="slide-marco" bg="primary" align="split">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('banking-branch')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div>
          <div class="relative overflow-hidden rounded-sm" style="aspect-ratio:4/5; max-height:480px;">
            <MediaSlot {...mediaProps('persona-marco')} fill objectPosition="top" />
          </div>
        </div>
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>PROTAGONISTA 01</p>
          <h2
            class="text-[var(--ink-primary)] mb-1 font-[family-name:var(--font-display)]"
            style="font-size: clamp(2rem, 3.5vw, 3.25rem);"
            data-reveal
            data-reveal-delay="0.08"
          >Marco Ferretti</h2>
          <p class="text-sm text-[var(--ink-tertiary)] mb-5" data-reveal data-reveal-delay="0.12">38 anni · cliente UniCredit da 12 anni · Brescia</p>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed mb-4 font-[family-name:var(--font-display)] italic"
            style="font-size: clamp(1.05rem, 1.4vw, 1.3rem);"
            data-reveal
            data-reveal-delay="0.18"
          >
            Ha appena chiesto a ChatGPT quale banca scegliere per il mutuo della prima casa.
          </p>
          <p class="text-sm text-[var(--ink-secondary)] leading-relaxed mb-6" data-reveal data-reveal-delay="0.22">
            UniCredit è il primo risultato. Il sito carica in 0,3 secondi. Il profilo RT-CDP lo riconosce come cliente storico con alta propensione al mutuo casa e gli apre un percorso già su misura, non un modulo qualsiasi.
          </p>
          <div class="flex gap-2 flex-wrap" data-reveal data-reveal-delay="0.28">
            {marcoPills.map((p) => (
              <span class="text-[11px] font-medium px-3 py-1.5 bg-[var(--accent-primary)]/10 text-[var(--accent-primary)] border border-[var(--accent-primary)]/20 rounded-full">{p}</span>
            ))}
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Sofia Ricci ───────────────────────────────────── -->
    <Slide id="slide-sofia" bg="secondary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--color-oro)] mb-4" data-reveal>PROTAGONISTA 02</p>
          <h2
            class="text-[var(--ink-primary)] mb-1 font-[family-name:var(--font-display)]"
            style="font-size: clamp(2rem, 3.5vw, 3.25rem);"
            data-reveal
            data-reveal-delay="0.08"
          >Sofia Ricci</h2>
          <p class="text-sm text-[var(--ink-tertiary)] mb-5" data-reveal data-reveal-delay="0.12">27 anni · UX Designer freelance · Milano</p>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed mb-4 font-[family-name:var(--font-display)] italic"
            style="font-size: clamp(1.05rem, 1.4vw, 1.3rem);"
            data-reveal
            data-reveal-delay="0.18"
          >
            Ha visto un reel ads UniCredit su Instagram. Stasera apre il suo primo conto, direttamente da iPhone.
          </p>
          <p class="text-sm text-[var(--ink-secondary)] leading-relaxed mb-6" data-reveal data-reveal-delay="0.22">
            GenStudio ha creato il reel ads che l'ha catturata, Journey Optimizer ha guidato l'onboarding e Experimentation Accelerator ha affinato il funnel che l'ha convinta ad attivare anche carta e piano di risparmio. In 6 mesi: 3 prodotti e una relazione appena iniziata.
          </p>
          <div class="flex gap-2 flex-wrap" data-reveal data-reveal-delay="0.28">
            {sofiaPills.map((p) => (
              <span class="text-[11px] font-medium px-3 py-1.5 bg-[var(--color-oro)]/10 text-[var(--color-oro)] border border-[var(--color-oro)]/20 rounded-full">{p}</span>
            ))}
          </div>
        </div>
        <div>
          <div class="relative overflow-hidden rounded-sm" style="aspect-ratio:4/5; max-height:480px;">
            <MediaSlot {...mediaProps('persona-sara')} fill objectPosition="top" />
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Promessa ──────────────────────────────────────── -->
    <Slide id="slide-promise" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-unlimited')}
        imageClass="opacity-12"
        scrim="bg-[var(--accent-primary)]/85"
      />
      <p class="slide-eyebrow text-center text-[var(--ink-inverse)]/70 mb-5" data-reveal>IL PERCORSO</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-5"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        Per Marco e Sofia, ogni capitolo è un momento che conta
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/80 max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        La loro storia continua sezione dopo sezione, dalla scoperta al ROI.
      </p>
      <div data-reveal data-reveal-delay="0.25">
        <a
          href={href(base, '/visibilita')}
          class="inline-flex items-center gap-3 px-10 py-5 bg-[var(--ink-inverse)] text-[var(--ink-primary)] text-lg font-medium tracking-wide hover:bg-[var(--color-crema)] transition-colors"
        >
          Dalla storia alla tecnologia →
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
