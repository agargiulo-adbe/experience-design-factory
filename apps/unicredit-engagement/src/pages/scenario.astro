---
import BaseLayout from '../layouts/BaseLayout.astro';
import UniNavigation from '../components/UniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const digitalStats = [
  { stat: '4M', label: 'clienti UniCredit attivamente digitali', sub: 'Annual Report 2024' },
  { stat: '60%+', label: 'transazioni via online/mobile', sub: 'target 80% entro 2026 · UCX Programme' },
  { stat: '1 su 3', label: 'interagisce SOLO via app negli ultimi 90 giorni', sub: 'pattern Digital Banking IT' },
  { stat: '+15%', label: 'crescita YoY transazioni digitali', sub: 'trend 2023–2024' },
];

const gaps = [
  {
    problem: 'Dati frammentati',
    detail: '7M di clienti, 6+ sistemi separati. Il profilo completo — che unisce app, filiale, call center — non esiste ancora.',
    solution: 'Real-Time CDP',
    color: 'var(--accent-primary)',
  },
  {
    problem: 'Interazioni generiche',
    detail: "L'app risponde alla transazione. Non conosce il momento di vita del cliente — figlio che nasce, casa da comprare, pensione che si avvicina.",
    solution: 'Journey Optimizer',
    color: 'var(--accent-primary)',
  },
  {
    problem: 'Intelligence silenziosa',
    detail: 'I dati ci sono. Ma trasformarli in decisioni richiede giorni, non minuti. E i segnali di churn si vedono solo dopo.',
    solution: 'CX Analytics + Data Insights Agent',
    color: 'var(--accent-primary)',
  },
  {
    problem: 'Contenuti lenti',
    detail: "Campagne che arrivano 3 settimane dopo l'evento che le ha ispirate. Il momento è già passato.",
    solution: 'GenStudio',
    color: 'var(--accent-secondary)',
  },
];

const unlimitedPillars = [
  { label: 'Relazione digitale', sub: 'Essere la banca di riferimento per ogni cliente in ogni momento di vita.' },
  { label: 'AI & Data', sub: 'Decisioni basate su dati unificati. Personalizzazione at scale.' },
  { label: 'Digital first', sub: 'App come canale principale. Filiale come canale di consulenza ad alto valore.' },
  { label: 'Engagement Unlimited', sub: 'Ogni interazione digitale diventa opportunità di rafforzare la relazione.' },
];

const bankingMacroTrends = [
  {
    trend: 'AI Conversazionale',
    impact: 'I clienti iniziano il loro percorso finanziario chiedendo a ChatGPT o Gemini. Chi non è misurabile in quei contesti, non esiste.',
    urgency: 'Alta',
  },
  {
    trend: 'Hyper-personalizzazione',
    impact: 'Le FinTech offrono esperienze su misura con pochi dati. Le banche hanno dati infiniti ma faticano a usarli in tempo reale.',
    urgency: 'Alta',
  },
  {
    trend: 'Zero-latency intelligence',
    impact: 'Il churn non si previene a posteriori. Servono segnali precoci e azioni automatiche entro pochi minuti, non giorni.',
    urgency: 'Media',
  },
];
---
<BaseLayout
  title="Il momento del banking"
  description="Il contesto digitale del mercato bancario italiano, le sfide UniCredit e il piano strategico Unlimited."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <UniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/conosci')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-banking-city')}
        imageClass="opacity-22"
        scrim="bg-[var(--surface-secondary)]/75"
      />
      <CoverHero
        eyebrow="00 · IL CONTESTO"
        numeral="00"
        title="Il momento del banking"
        lead="Il mercato bancario si trasforma in tempo reale. Chi personalizza vince. Chi aspetta, perde quota ai fintech."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Dati digitali UniCredit ───────────────────────── -->
    <Slide id="slide-digital-data" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>IL CLIENTE DIGITALE OGGI</p>
          <h2
            class="slide-title text-[var(--ink-primary)] mb-7"
            style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
            data-reveal
            data-reveal-delay="0.1"
          >
            Digitale di default,<br/>non di necessità
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed"
            style="font-size: clamp(1.05rem, 1.4vw, 1.3rem);"
            data-reveal
            data-reveal-delay="0.2"
          >
            Il cliente bancario italiano del 2026 non sceglie il digitale perché non ha alternativa — lo sceglie perché è più veloce, più comodo, più suo. Ma si aspetta che la banca lo conosca davvero.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4" data-reveal data-reveal-delay="0.3">
          {digitalStats.map((item) => (
            <div class="p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-center">
              <p
                class="font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-2"
                style="font-size: clamp(1.75rem, 3vw, 2.75rem);"
              >
                {item.stat}
              </p>
              <p class="text-xs font-medium text-[var(--ink-primary)] mb-0.5 leading-snug">{item.label}</p>
              <p class="text-[10px] text-[var(--ink-tertiary)]">{item.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: I 4 gap da colmare ───────────────────────────── -->
    <Slide id="slide-gaps" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-20"
        scrim="bg-[var(--surface-inverse)]/80"
      />
      <p class="slide-eyebrow text-[var(--color-grigio-300)] mb-5" data-reveal>LA SFIDA</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-9"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Essere grandi non basta più
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.2"
      >
        {gaps.map((g) => (
          <div class="p-5 bg-[var(--color-grigio-500)]/12 border border-[var(--color-grigio-500)]/25 rounded-sm text-left">
            <div class="flex items-start justify-between gap-3 mb-3">
              <p class="text-sm font-semibold text-[var(--accent-secondary)]">{g.problem}</p>
              <span class="text-[9px] font-semibold uppercase tracking-wider text-[var(--color-grigio-400)] bg-[var(--color-grigio-500)]/20 px-2 py-1 rounded flex-shrink-0">
                → {g.solution}
              </span>
            </div>
            <p class="text-sm text-[var(--color-grigio-300)] leading-relaxed">{g.detail}</p>
          </div>
        ))}
      </div>

      <p
        class="text-[clamp(1.05rem,1.4vw,1.25rem)] font-[family-name:var(--font-display)] text-[var(--ink-inverse)] leading-snug max-w-3xl mt-8"
        data-reveal
        data-reveal-delay="0.4"
      >
        Adobe colma tutti e quattro i gap — con una piattaforma unificata, non quattro soluzioni separate.
      </p>
    </Slide>

    <!-- ── SLIDE 3: Macro trend banking ──────────────────────────── -->
    <Slide id="slide-trends" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('banking-branch')}
        imageClass="opacity-8"
        scrim="bg-[var(--surface-primary)]/88"
      />
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>MACRO TREND 2026</p>
      <h2
        class="slide-title text-[var(--ink-primary)] mb-9"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.1"
      >
        Il contesto che non aspetta
      </h2>

      <div
        class="w-full max-w-4xl mx-auto flex flex-col gap-4"
        data-reveal
        data-reveal-delay="0.2"
      >
        {bankingMacroTrends.map((t) => (
          <div class="flex items-start gap-6 p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <div class="w-32 flex-shrink-0">
              <p class="text-xs font-semibold text-[var(--accent-primary)] mb-1">{t.trend}</p>
              <span class="text-[9px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full"
                style={`background: ${t.urgency === 'Alta' ? 'var(--accent-primary)' : 'var(--accent-secondary)'}20; color: ${t.urgency === 'Alta' ? 'var(--accent-primary)' : 'var(--accent-secondary)'};`}>
                {t.urgency}
              </span>
            </div>
            <p class="text-sm text-[var(--ink-secondary)] leading-relaxed flex-1">{t.impact}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 4: Piano Unlimited + bridge → soluzione ─────────── -->
    <Slide id="slide-unlimited" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-digital-blue')}
        imageClass="opacity-10"
        scrim="bg-[var(--accent-primary)]/82"
      />
      <p class="slide-eyebrow text-[var(--ink-inverse)]/70 mb-4" data-reveal>PIANO STRATEGICO UNICREDIT</p>
      <h2
        class="slide-title text-[var(--ink-inverse)] mb-4"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.08"
      >
        UniCredit Unlimited
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)]/80 max-w-2xl mb-9"
        data-reveal
        data-reveal-delay="0.15"
      >
        Il piano strategico 2026–2028 identifica tecnologia e AI come abilitatori chiave per diventare la banca di riferimento nella relazione digitale con i clienti.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-4 gap-4 mb-10"
        data-reveal
        data-reveal-delay="0.22"
      >
        {unlimitedPillars.map((p) => (
          <div class="p-4 bg-[var(--ink-inverse)]/10 border border-[var(--ink-inverse)]/20 rounded-sm text-left">
            <p class="text-xs font-semibold text-[var(--ink-inverse)] mb-1.5">{p.label}</p>
            <p class="text-[11px] text-[var(--ink-inverse)]/70 leading-relaxed">{p.sub}</p>
          </div>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.3">
        <a
          href={href(base, '/conosci')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-inverse)] text-[var(--ink-primary)] hover:bg-[var(--color-crema)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-inverse)] focus-visible:outline-offset-4"
        >
          Come Adobe lo rende possibile
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
