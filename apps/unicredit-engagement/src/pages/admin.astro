<script is:inline define:vars={{ deckHref, SUPABASE_URL, SUPABASE_ANON_KEY, allSolutionIds }}>
(function() {
  var STORAGE_KEY = 'edf:media-slots:unicredit-engagement';
  var SOL_STORAGE_KEY = 'edf-solutions-unicredit-engagement';
  var PROJECT_SLUG = 'unicredit-engagement';
  var EXPERIENCE_URL = location.origin + deckHref;

  // ── Solutions (section on/off) ────────────────────────────────
  function loadSolutions() {
    try {
      var raw = localStorage.getItem(SOL_STORAGE_KEY);
      if (raw) return JSON.parse(raw);
    } catch(e) {}
    return null; // null = all active (no restriction)
  }

  function activeSolutionIds() {
    var out = [];
    document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
      if (t.checked) out.push(t.getAttribute('data-solution-toggle'));
    });
    return out;
  }

  function updateSolutionRows() {
    document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
      var row = t.closest('[data-solution-row]');
      if (!row) return;
      if (t.checked) row.removeAttribute('data-inactive');
      else row.setAttribute('data-inactive', '');
    });
  }

  function updateSolutionCount() {
    var badge = document.querySelector('[data-count-sezioni]');
    if (badge) badge.textContent = activeSolutionIds().length + '/' + allSolutionIds.length;
  }

  function saveSolutions() {
    var active = activeSolutionIds();
    try { localStorage.setItem(SOL_STORAGE_KEY, JSON.stringify(active)); } catch(e) {}

    // Shareable ?s= link (omit when all active)
    var input = document.getElementById('sol-share-url');
    if (input) {
      input.value = active.length < allSolutionIds.length
        ? EXPERIENCE_URL + '?s=' + active.join(',')
        : '';
    }

    // Live broadcast to any open deck (same-origin, cross-tab)
    var msg = { type: 'edf:solutions-changed', project: PROJECT_SLUG, activeIds: active };
    try { new BroadcastChannel('edf-console').postMessage(msg); } catch(e) {}

    updateSolutionRows();
    updateSolutionCount();
  }

  function loadConfig() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    } catch(e) { return {}; }
  }

  function saveConfig(config) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(config));
    window.dispatchEvent(new CustomEvent('edf:slots-updated'));
  }

  async function generateShareableLink() {
    var config = loadConfig();
    var hasActive = Object.keys(config).some(function(k) {
      return config[k] && config[k].active && config[k].url;
    });

    var genBtn = document.getElementById('generate-link-btn');
    var urlRow = document.getElementById('share-url-row');
    var shareInput = document.getElementById('share-url-input');
    var note = document.getElementById('share-note');

    if (!hasActive) {
      if (note) { note.textContent = 'Attiva e salva almeno uno slot prima di generare il link.'; note.style.color = '#BE2027'; }
      return;
    }

    if (genBtn) { genBtn.disabled = true; genBtn.textContent = 'Generazione…'; }
    if (note) { note.textContent = ''; note.style.color = ''; }

    try {
      var res = await fetch(SUPABASE_URL + '/rest/v1/media_configs', {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
          'Content-Type': 'application/json',
          'Prefer': 'return=representation'
        },
        body: JSON.stringify({ project_slug: 'unicredit-engagement', config: config })
      });
      var rows = await res.json();
      var id = rows && rows[0] && rows[0].id;
      if (!id) throw new Error('no id');

      var shareUrl = EXPERIENCE_URL + '?cfg=' + id;
      if (shareInput) shareInput.value = shareUrl;
      if (urlRow) urlRow.style.display = 'flex';
      if (note) { note.textContent = 'Link generato. Rigenera dopo ogni modifica per aggiornare la configurazione condivisa.'; note.style.color = '#16a34a'; }
    } catch(e) {
      if (note) { note.textContent = 'Errore nella generazione del link. Controlla la connessione e riprova.'; note.style.color = '#BE2027'; }
    } finally {
      if (genBtn) {
        genBtn.disabled = false;
        genBtn.innerHTML = '<svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M8 3v10M3 8h10"/></svg> Genera link condivisibile';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    try { sessionStorage.setItem('edf:console', '1'); } catch(e) {}
    var config = loadConfig();

    // ── Tab switching ──────────────────────────────────────────
    document.querySelectorAll('.admin-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var name = tab.getAttribute('data-tab');
        document.querySelectorAll('.admin-tab').forEach(function(t) {
          var on = t === tab;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        document.querySelectorAll('[data-tabpanel]').forEach(function(p) {
          if (p.getAttribute('data-tabpanel') === name) p.removeAttribute('hidden');
          else p.setAttribute('hidden', '');
        });
      });
    });

    // ── Solutions init ─────────────────────────────────────────
    var savedSolutions = loadSolutions();
    if (savedSolutions) {
      document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
        t.checked = savedSolutions.indexOf(t.getAttribute('data-solution-toggle')) !== -1;
      });
    }
    updateSolutionRows();
    updateSolutionCount();
    // Sync share URL to current state (without forcing a write if untouched)
    (function() {
      var input = document.getElementById('sol-share-url');
      var active = activeSolutionIds();
      if (input) input.value = active.length < allSolutionIds.length ? EXPERIENCE_URL + '?s=' + active.join(',') : '';
    })();

    document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
      t.addEventListener('change', saveSolutions);
    });

    var solEnableAll = document.getElementById('sol-enable-all');
    if (solEnableAll) solEnableAll.addEventListener('click', function() {
      document.querySelectorAll('[data-solution-toggle]').forEach(function(t) { t.checked = true; });
      saveSolutions();
    });
    var solDisableAll = document.getElementById('sol-disable-all');
    if (solDisableAll) solDisableAll.addEventListener('click', function() {
      document.querySelectorAll('[data-solution-toggle]').forEach(function(t) { t.checked = false; });
      saveSolutions();
    });

    var solCopyBtn = document.getElementById('sol-copy-url');
    var solShareInput = document.getElementById('sol-share-url');
    if (solCopyBtn && solShareInput) {
      solCopyBtn.addEventListener('click', function() {
        var url = solShareInput.value || EXPERIENCE_URL;
        navigator.clipboard.writeText(url).then(function() {
          var orig = solCopyBtn.innerHTML;
          solCopyBtn.textContent = '✓ Copiato!';
          setTimeout(function() { solCopyBtn.innerHTML = orig; }, 2000);
        }).catch(function() { solShareInput.select(); document.execCommand('copy'); });
      });
    }

    // Accordion toggle logic
    document.querySelectorAll('[data-page-toggle]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var slug = btn.getAttribute('data-page-toggle');
        var panel = document.querySelector('[data-slides-panel="' + slug + '"]');
        if (!panel) return;
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        if (expanded) {
          panel.setAttribute('hidden', '');
        } else {
          panel.removeAttribute('hidden');
        }
      });
    });

    // Auto-expand sections that have active slots
    Object.keys(config).forEach(function(slotKey) {
      if (config[slotKey] && config[slotKey].active && config[slotKey].url) {
        var parts = slotKey.split(':');
        if (parts.length >= 2) {
          var slug = parts[0];
          var btn = document.querySelector('[data-page-toggle="' + slug + '"]');
          var panel = document.querySelector('[data-slides-panel="' + slug + '"]');
          if (btn && panel) {
            btn.setAttribute('aria-expanded', 'true');
            panel.removeAttribute('hidden');
          }
        }
      }
    });

    // Populate each slot form from stored config
    document.querySelectorAll('[data-slot-toggle]').forEach(function(toggle) {
      var id = toggle.getAttribute('data-slot-toggle');
      var cfg = config[id] || {};

      toggle.checked = !!cfg.active;

      var urlInput = document.querySelector('[data-slot-url="' + id + '"]');
      if (urlInput && cfg.url) urlInput.value = cfg.url;

      var typeInputs = document.querySelectorAll('[data-slot-type="' + id + '"]');
      var savedType = cfg.type || 'image';
      typeInputs.forEach(function(r) { r.checked = r.value === savedType; });

      var autoplayInputs = document.querySelectorAll('[data-slot-autoplay="' + id + '"]');
      var savedAutoplay = cfg.autoplay || 'auto';
      autoplayInputs.forEach(function(r) { r.checked = r.value === savedAutoplay; });

      var delayInput = document.querySelector('[data-slot-delay="' + id + '"]');
      if (delayInput && cfg.autoplayDelay) delayInput.value = cfg.autoplayDelay;

      var autoplayRow = document.querySelector('[data-autoplay-row="' + id + '"]');
      if (autoplayRow) autoplayRow.style.display = savedType === 'video' ? '' : 'none';

      var delayRow = document.querySelector('[data-delay-row="' + id + '"]');
      if (delayRow) delayRow.style.display = (savedType === 'video' && savedAutoplay === 'delayed') ? '' : 'none';
    });

    // Save buttons
    document.querySelectorAll('[data-slot-save]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-slot-save');
        var currentConfig = loadConfig();

        var urlInput = document.querySelector('[data-slot-url="' + id + '"]');
        var toggleInput = document.querySelector('[data-slot-toggle="' + id + '"]');
        var typeInput = document.querySelector('[data-slot-type="' + id + '"]:checked');
        var autoplayInput = document.querySelector('[data-slot-autoplay="' + id + '"]:checked');
        var delayInput2 = document.querySelector('[data-slot-delay="' + id + '"]');

        currentConfig[id] = {
          active: toggleInput ? toggleInput.checked : false,
          url: urlInput ? urlInput.value.trim() : '',
          type: typeInput ? typeInput.value : 'image',
          autoplay: autoplayInput ? autoplayInput.value : 'auto',
          autoplayDelay: delayInput2 ? (parseInt(delayInput2.value, 10) || 3) : 3,
        };

        saveConfig(currentConfig);

        // Visual feedback
        var feedback = document.querySelector('[data-slot-feedback="' + id + '"]');
        if (feedback) {
          feedback.textContent = '✓ Salvato';
          feedback.classList.add('visible');
          setTimeout(function() { feedback.classList.remove('visible'); }, 2000);
        }
      });
    });

    // Type change → show/hide autoplay row
    document.querySelectorAll('[data-slot-type]').forEach(function(r) {
      r.addEventListener('change', function() {
        var sid = r.getAttribute('data-slot-type');
        var aRow = document.querySelector('[data-autoplay-row="' + sid + '"]');
        if (aRow) aRow.style.display = r.value === 'video' ? '' : 'none';
        if (r.value !== 'video') {
          var dRow = document.querySelector('[data-delay-row="' + sid + '"]');
          if (dRow) dRow.style.display = 'none';
        }
      });
    });

    // Autoplay mode change → show/hide delay row
    document.querySelectorAll('[data-slot-autoplay]').forEach(function(r) {
      r.addEventListener('change', function() {
        var sid = r.getAttribute('data-slot-autoplay');
        var dRow = document.querySelector('[data-delay-row="' + sid + '"]');
        if (dRow) dRow.style.display = r.value === 'delayed' ? '' : 'none';
      });
    });

    // Generate link button
    var genBtn = document.getElementById('generate-link-btn');
    if (genBtn) genBtn.addEventListener('click', generateShareableLink);

    // Copy share URL button
    var copyBtn = document.getElementById('copy-share-url');
    var shareInput = document.getElementById('share-url-input');
    if (copyBtn && shareInput) {
      copyBtn.addEventListener('click', function() {
        var url = shareInput.value;
        if (!url) return;
        navigator.clipboard.writeText(url).then(function() {
          var origHtml = copyBtn.innerHTML;
          copyBtn.textContent = '✓ Copiato!';
          setTimeout(function() { copyBtn.innerHTML = origHtml; }, 2000);
        }).catch(function() {
          shareInput.select();
          document.execCommand('copy');
        });
      });
    }

    // Reset all button
    var resetBtn = document.getElementById('reset-all-slots');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        if (confirm('Eliminare tutte le configurazioni demo slot?')) {
          localStorage.removeItem(STORAGE_KEY);
          window.dispatchEvent(new CustomEvent('edf:slots-updated'));
          location.reload();
        }
      });
    }
  });
})();
</script>
