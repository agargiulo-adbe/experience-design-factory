// Registry delle soluzioni Adobe — controllano l'accensione/spegnimento
// delle sezioni dell'experience (data-solution / pageSolutions).
// `gate` = sezioni per cui questo prodotto è NECESSARIO (spente tutte → sezione via).
// `appearsIn` = tutte le sezioni in cui il prodotto compare (chip/slide gated),
//   così l'utente sa dove agisce il toggle anche se compare in più sezioni.
interface SolutionEntry { id: string; name: string; shortName: string; pillar: string; description: string; appearsIn: string[]; }

const SOLUTIONS: SolutionEntry[] = [
  { id: 'aep', name: 'Adobe Experience Platform', shortName: 'AEP', pillar: 'foundation', description: 'Foundation: unifica tutti i dati cliente in real-time.', appearsIn: ['Motore'] },
  { id: 'rtcdp', name: 'Real-Time CDP', shortName: 'RT-CDP', pillar: 'data', description: 'Profili unificati e audience segmentation in tempo reale.', appearsIn: ['Conosci', 'Motore'] },
  { id: 'cja', name: 'Customer Journey Analytics', shortName: 'CJA', pillar: 'analytics', description: 'Cross-channel analytics: dal branch al mobile in una vista.', appearsIn: ['Analizza', 'B2B', 'Motore'] },
  { id: 'ajo-b2c', name: 'Journey Optimizer B2C', shortName: 'AJO B2C', pillar: 'journeys', description: 'Orchestrazione omnicanale per acquisizione e engagement.', appearsIn: ['Acquisisci', 'Coinvolgi', 'Motore'] },
  { id: 'aem-sites', name: 'AEM Sites & Edge Delivery', shortName: 'AEM Sites', pillar: 'content', description: 'Gestione canali digitali con velocità editoriale enterprise.', appearsIn: ['Acquisisci', 'Motore'] },
  { id: 'aem-assets', name: 'AEM Assets + Dynamic Media', shortName: 'AEM Assets', pillar: 'content', description: 'DAM enterprise per contenuti multicanale a scala.', appearsIn: ['Contenuti', 'Motore'] },
  { id: 'genstudio', name: 'GenStudio for Performance Marketing', shortName: 'GenStudio', pillar: 'content', description: 'Varianti di contenuto on-brand in pochi minuti.', appearsIn: ['Contenuti', 'Motore'] },
  { id: 'firefly', name: 'Adobe Firefly', shortName: 'Firefly', pillar: 'content', description: 'AI image generation sicura per uso commerciale.', appearsIn: ['Motore'] },
  { id: 'target', name: 'Adobe Target', shortName: 'Target', pillar: 'personalization', description: 'A/B testing e personalizzazione su ogni touchpoint digitale.', appearsIn: ['Coinvolgi', 'Motore'] },
  { id: 'ajo-b2b', name: 'Journey Optimizer B2B Edition', shortName: 'AJO B2B', pillar: 'b2b', description: 'Account-based journeys per PMI e corporate banking.', appearsIn: ['B2B', 'Motore'] },
  { id: 'marketo', name: 'Marketo Engage', shortName: 'Marketo', pillar: 'b2b', description: 'Marketing automation B2B per lead generation corporate.', appearsIn: ['B2B', 'Motore'] },
  { id: 'cx-analytics', name: 'Adobe CX Analytics', shortName: 'CX Analytics', pillar: 'intelligence', description: 'Umbrella: CJA + Content Analytics + Adobe Analytics — intelligence unificata.', appearsIn: ['Analizza', 'Motore'] },
  { id: 'data-insights-agent', name: 'Data Insights Agent', shortName: 'DIA', pillar: 'intelligence', description: 'AI agent per root cause analysis in linguaggio naturale.', appearsIn: ['Analizza', 'Motore'] },
  { id: 'content-analytics', name: 'Adobe Content Analytics', shortName: 'Content Analytics', pillar: 'intelligence', description: 'Misura quale contenuto porta a risultati — per segmento e canale.', appearsIn: ['Contenuti', 'Analizza', 'Motore'] },
  { id: 'mix-modeler', name: 'Adobe Mix Modeler', shortName: 'Mix Modeler', pillar: 'intelligence', description: 'Causal AI — full-funnel attribution e budget optimization.', appearsIn: ['Analizza', 'Motore'] },
];

const PILLAR_LABELS: Record<string, string> = {
  foundation: 'Foundation', data: 'Data & Profiles', journeys: 'Journeys',
  content: 'Content', analytics: 'Analytics', intelligence: 'CX Analytics & AI',
  personalization: 'Personalization', b2b: 'B2B',
};
const PILLAR_ORDER = ['foundation', 'data', 'journeys', 'content', 'analytics', 'intelligence', 'personalization', 'b2b'];
const PILLAR_COLORS: Record<string, string> = {
  foundation: '#BE2027', data: '#2563eb', journeys: '#7c3aed', content: '#ea580c',
  analytics: '#0891b2', intelligence: '#0d9488', personalization: '#db2777', b2b: '#4f46e5',
};

const solutionGroups = PILLAR_ORDER
  .map((pillar) => ({
    pillar,
    label: PILLAR_LABELS[pillar],
    color: PILLAR_COLORS[pillar],
    solutions: SOLUTIONS.filter((s) => s.pillar === pillar),
  }))
  .filter((g) => g.solutions.length > 0);

const allSolutionIds = SOLUTIONS.map((s) => s.id);

const deckHref = href(base, '/');
---

<BaseLayout title="Console di configurazione — Engagement Unlimited">
  <AdminConsole
    projectSlug="unicredit-engagement"
    projectName="Engagement Unlimited"
    clientLabel="UniCredit × Adobe"
    deckHref={deckHref}
    pages={PAGE_REGISTRY}
    solutionGroups={solutionGroups}
    allSolutionIds={allSolutionIds}
    supabaseUrl={SUPABASE_URL}
    supabaseAnonKey={SUPABASE_ANON_KEY}
  />
</BaseLayout>
