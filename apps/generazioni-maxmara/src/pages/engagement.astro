---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import HowItWorks from '@edf/core/blocks/HowItWorks.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

// Generic catalogue tiles — the matched ones are relevant to Giulia.
const contenuti = [
  { label: 'Teddy Bear Coat', tag: 'Editoriale', match: true },
  { label: 'Materiali & artigianato', tag: 'Storia', match: true },
  { label: 'Runway FW25', tag: 'Sfilata', match: false },
  { label: 'Profumi', tag: 'Beauty', match: false },
  { label: 'Cappotto 101801', tag: 'Icona', match: false },
  { label: 'Saldi stagione', tag: 'Promo', match: false },
];

const adobe = [
  { code: 'AEM', name: 'AEM Sites', claim: 'Ogni pagina si adatta al profilo della visitatrice e le mostra i contenuti più rilevanti per lei' },
  { code: 'Tgt', name: 'Adobe Target', claim: 'Test A/B e personalizzazione in tempo reale: il sito impara cosa funziona per ogni segmento e si affina' },
  { code: 'Com', name: 'Adobe Commerce', claim: 'Un acquisto senza intoppi, dove contenuto editoriale e catalogo prodotto si fondono' },
];
---
<BaseLayout title="Engagement" description="Dalla scoperta alla relazione: come nutrire il legame con le clienti Max Mara.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <DeckContainer nextHref={href(base, '/conversione')} prevHref={href(base, '/acquisizione')}>

    <!-- ── SLIDE 0: Apertura fase ────────────────────────────────── -->
    <Slide id="slide-apertura" bg="secondary" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-linen')} imageClass="opacity-25" scrim="bg-[var(--surface-secondary)]/70" />
      <div slot="backdrop" class="mm-weave" aria-hidden="true"></div>

      <div class="flex flex-col items-center">
        <CoverHero eyebrow="FASE 2 · ENGAGEMENT" numeral="02" title="Dalla scoperta alla relazione" lead="La prima visita non basta. Trasformare la curiosità in familiarità è il momento più delicato." signature={false} />

        <!-- il filo di seta: secondo nodo del percorso, "Conoscersi" -->
        <div class="mm-thread relative w-full max-w-3xl mt-12 flex items-center justify-between px-2" data-reveal data-reveal-delay="0.4" aria-hidden="true">
          <span class="mm-thread-line left-0 right-0 top-1/2"></span>
          <div class="relative flex flex-col items-center gap-3 px-5 bg-[var(--surface-secondary)]">
            <span class="mm-node">1</span>
            <span class="mm-node-label">Acquisizione</span>
          </div>
          <div class="relative flex flex-col items-center gap-3 px-5 bg-[var(--surface-secondary)]">
            <span class="mm-node" data-active>2</span>
            <span class="mm-node-label">Conoscersi</span>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: Personalizzazione (il meccanismo) ────────────── -->
    <Slide id="slide-personalize" bg="primary" align="center">
      <div slot="backdrop" class="mm-bg-soft" aria-hidden="true"></div>

      <div class="w-full max-w-5xl mx-auto flex flex-col items-center">
        <p class="mm-panel-tag mb-4" data-reveal>SITO MAX MARA · HOMEPAGE, AL RITORNO DI GIULIA</p>
        <h2 class="mm-panel-head text-[var(--ink-primary)] mb-10" style="font-size: clamp(2rem, 3.6vw, 3.4rem); line-height:1.08;" data-reveal data-reveal-delay="0.1">
          Lo stesso brand, il volto giusto per lei
        </h2>

        <!-- Personalize: generic tiles resolve to Giulia's matches (deck-animated) -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 w-full" data-personalize>
          {contenuti.map((c) => (
            <div class:list={["perso-item mm-card text-left transition-colors duration-500", c.match ? "border-[var(--accent-primary)]/70 bg-[var(--accent-primary)]/8" : ""]} data-match={c.match ? '' : undefined}>
              <span class="mm-panel-tag block mb-2">{c.tag}</span>
              <span class="mm-card-title" style="font-size: clamp(1rem,1.3vw,1.25rem);">{c.label}</span>
            </div>
          ))}
        </div>

        <div class="mm-quote max-w-2xl mx-auto mt-9" data-reveal data-reveal-delay="0.4">
          <p class="mm-quote-text" style="font-size: clamp(1.2rem,1.8vw,1.6rem); font-style: normal;">
            La homepage non è generica: tra tutti i contenuti, emergono quelli che parlano a Giulia.
          </p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Front stage — contenuto editoriale (mockup reale) ── -->
    <Slide id="slide-frontstage" bg="primary" align="split">
      <div slot="backdrop" class="mm-bg" aria-hidden="true"></div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="mm-panel max-w-xl" data-reveal data-reveal-delay="0.15">
            <p class="mm-panel-tag" data-reveal>Ciò che vede la cliente</p>
            <h2 class="mm-panel-head text-[var(--ink-primary)] mb-6 mt-2" style="font-size: clamp(2.25rem, 4.2vw, 3.75rem); line-height:1.06;" data-reveal data-reveal-delay="0.1">Un'esperienza che parla a lei</h2>
            <p class="mm-panel-body" style="font-size: clamp(1.05rem,1.35vw,1.3rem);" data-reveal data-reveal-delay="0.2">
              Giulia torna sul sito. L'homepage le mostra contenuti editoriali sul Teddy Bear Coat e la invita a scoprire la storia dei materiali. Ogni touchpoint rafforza la familiarità, senza forzare la vendita.
            </p>
          </div>
        </div>

        <!-- phone with a REAL editorial photo of the coat -->
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.3">
          <div class="ig-phone relative mx-auto w-full max-w-[300px] max-h-[calc(100dvh-200px)] flex flex-col overflow-hidden rounded-[2.2rem] border-[5px] border-[var(--surface-inverse)] bg-[var(--surface-inverse)] shadow-2xl">
            <div class="flex flex-col min-h-0 bg-[var(--surface-primary)] rounded-[1.7rem] overflow-hidden">
              <div class="flex items-center justify-center pt-2 pb-1.5">
                <span class="w-16 h-1.5 rounded-full bg-[var(--ink-tertiary)]/25"></span>
              </div>
              <div class="relative w-full aspect-[4/5] overflow-hidden bg-[var(--surface-secondary)] flex-shrink-0">
                <MediaSlot {...mediaProps('engagement-editoriale')} fill noText="0,0,0,0" />
              </div>
              <div class="px-4 py-4 text-left">
                <p class="text-[0.7rem] tracking-[0.12em] uppercase text-[var(--accent-primary)] mb-1.5">Editoriale</p>
                <p class="text-[0.98rem] font-medium text-[var(--ink-primary)] leading-snug">La storia del Teddy Bear Coat</p>
                <p class="text-[0.8rem] text-[var(--ink-tertiary)] mt-2 inline-flex items-center gap-1.5">Scopri i materiali <span class="text-[var(--accent-primary)]">→</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Front→Back impulse (l'aha) ───────────────────── -->
    <Slide id="slide-impulse" bg="secondary" align="center">
      <div slot="backdrop" class="mm-weave" aria-hidden="true"></div>

      <h2 class="mm-panel-head text-[var(--ink-primary)] mb-10 max-w-4xl mx-auto" style="font-size: clamp(2rem, 3.8vw, 3.4rem); line-height:1.08;" data-reveal>
        Ogni contenuto rilevante è una decisione della piattaforma
      </h2>

      <div class="relative w-full max-w-[1100px] mx-auto grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-0 items-stretch min-h-[30vh]" data-pulse-line>
        <div class="mm-panel flex flex-col justify-between text-left" data-reveal>
          <p class="mm-panel-tag mb-3">In scena</p>
          <p class="mm-panel-figure" style="font-size: clamp(1.3rem,1.9vw,1.85rem);">La cliente esplora</p>
          <p class="mm-panel-body mt-2" style="font-size: clamp(1.05rem,1.3vw,1.3rem);">Legge, sfoglia, torna a trovarci</p>
        </div>

        <div class="hidden md:flex items-center justify-center px-6">
          <svg width="180" height="60" viewBox="0 0 180 60" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 0 30 L 150 30" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="166" cy="30" r="9" fill="currentColor" opacity="0"/>
          </svg>
        </div>
        <div class="flex md:hidden items-center justify-center py-1">
          <svg width="60" height="46" viewBox="0 0 60 46" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 30 0 L 30 34" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="30" cy="40" r="6" fill="currentColor" opacity="0"/>
          </svg>
        </div>

        <div class="relative rounded-[3px] p-8 md:p-10 bg-[rgba(28,20,15,0.92)] border border-[rgba(245,240,230,0.14)] text-[rgba(245,240,230,0.96)] flex flex-col justify-between text-left overflow-hidden" data-reveal data-reveal-delay="0.3">
          <span class="absolute left-0 top-8 bottom-8 w-[2px] bg-[rgba(193,154,107,0.85)] rounded-full" aria-hidden="true"></span>
          <p class="mm-panel-tag mb-3" style="color: rgba(193,154,107,0.95);">Dietro le quinte</p>
          <p class="font-[family-name:var(--font-display)] font-medium leading-tight" style="font-size: clamp(1.3rem,1.9vw,1.85rem);">La piattaforma adatta</p>
          <p class="mt-2 leading-[1.6] text-[rgba(245,240,230,0.8)]" style="font-size: clamp(1.05rem,1.3vw,1.3rem);">Sceglie i contenuti, testa, ottimizza</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Back stage — i prodotti Adobe in "Scopri come" ── -->
    <Slide id="slide-backstage" bg="inverse" align="center">
      <div slot="backdrop" class="mm-bg" aria-hidden="true"></div>

      <div class="w-full max-w-3xl mx-auto flex flex-col items-center">
        <p class="mm-panel-tag mb-4" data-reveal style="color: rgba(193,154,107,0.95);">CIÒ CHE FA LA PIATTAFORMA</p>
        <h2 class="mm-panel-head text-[var(--ink-inverse)] mb-8" style="font-size: clamp(2.25rem, 4.2vw, 3.75rem); line-height:1.06;" data-reveal data-reveal-delay="0.1">
          Personalizzazione, su ogni canale
        </h2>

        <div class="w-full flex flex-col gap-5 text-left" data-stagger="0.25">
          <p class="font-[family-name:var(--font-display)] leading-[1.35] text-[rgba(245,240,230,0.96)] border-l-2 border-[rgba(193,154,107,0.85)] pl-6" style="font-size: clamp(1.35rem,2vw,2rem);">
            Ogni pagina si adatta al profilo della visitatrice, mostrando i contenuti più rilevanti.
          </p>
          <p class="font-[family-name:var(--font-display)] leading-[1.35] text-[rgba(245,240,230,0.96)] border-l-2 border-[rgba(193,154,107,0.85)] pl-6" style="font-size: clamp(1.35rem,2vw,2rem);">
            Il sito impara cosa funziona per ogni segmento e si ottimizza, in tempo reale.
          </p>
        </div>

        <div class="mt-9 w-full" data-reveal data-reveal-delay="0.5">
          <HowItWorks title="Personalizzazione su ogni canale" tone="onDark">
            {adobe.map((p) => (
              <p class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)] leading-snug"><strong class="text-[var(--accent-secondary)] font-semibold">{p.name}</strong> — {p.claim}.</p>
            ))}
          </HowItWorks>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Payoff — metrica + CTA ───────────────────────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />
      <div slot="backdrop" class="mm-weave" aria-hidden="true"></div>

      <div class="flex flex-col items-center max-w-3xl mx-auto">
        <p data-display class="font-[family-name:var(--font-display)] font-light leading-none text-[var(--ink-primary)] mb-5" style="font-size: clamp(4.5rem, 12vw, 11rem);">
          <span data-count-up="15" data-count-prefix="+" data-count-suffix="%">+0%</span>
        </p>
        <p class="font-[family-name:var(--font-display)] font-normal text-[var(--ink-primary)] leading-snug mb-4" style="font-size: clamp(1.5rem,2.4vw,2.25rem);" data-reveal data-reveal-delay="0.2">
          di ricavi in più quando l'esperienza è personalizzata in modo coerente
        </p>
        <p class="tracking-[0.02em] text-[var(--ink-primary)]/70 mb-9" style="font-size: clamp(0.9rem,1.1vw,1.05rem);" data-reveal data-reveal-delay="0.28">
          Fonte: McKinsey &amp; Company
        </p>

        <div class="mm-quote mx-auto mb-10" data-reveal data-reveal-delay="0.36">
          <p class="mm-quote-text text-[var(--ink-primary)]" style="font-size: clamp(1.3rem,2vw,1.75rem);">
            La stessa cura che accoglie Giulia oggi è ciò che, nel tempo, ha tenuto Francesca.
          </p>
        </div>
      </div>

      <div data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/conversione')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
        >
          Continua · Conversione
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
