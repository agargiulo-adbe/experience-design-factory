---
import BaseLayout from '../layouts/BaseLayout.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import HowItWorks from '@edf/core/blocks/HowItWorks.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;

// Generic catalogue tiles — the matched ones are relevant to Giulia.
const contenuti = [
  { label: 'Teddy Bear Coat', tag: 'Editoriale', match: true },
  { label: 'Materiali & artigianato', tag: 'Storia', match: true },
  { label: 'Runway FW25', tag: 'Sfilata', match: false },
  { label: 'Profumi', tag: 'Beauty', match: false },
  { label: 'Cappotto 101801', tag: 'Icona', match: false },
  { label: 'Saldi stagione', tag: 'Promo', match: false },
];

const adobe = [
  { code: 'AEM', name: 'AEM Sites', claim: 'Storytelling digitale personalizzato: ogni pagina si adatta al profilo della visitatrice, mostrando i contenuti più rilevanti' },
  { code: 'Tgt', name: 'Adobe Target', claim: 'Test A/B e personalizzazione in tempo reale — il sito impara cosa funziona per ogni segmento e si ottimizza' },
  { code: 'Com', name: 'Adobe Commerce', claim: 'Esperienze d\'acquisto seamless che fondono contenuto editoriale e catalogo prodotto' },
];
---
<BaseLayout title="Engagement" description="Dalla scoperta alla relazione: come nutrire il legame con le clienti Max Mara.">
  <DeckContainer nextHref={href(base, '/conversione')}>

    <!-- ── SLIDE 0: Apertura fase ────────────────────────────────── -->
    <Slide id="slide-apertura" bg="secondary" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-linen')} imageClass="opacity-25" scrim="bg-[var(--surface-secondary)]/70" />
      <CoverHero eyebrow="FASE 2 · ENGAGEMENT" numeral="02" title="Dalla scoperta alla relazione" lead="La prima visita non basta. Trasformare la curiosità in familiarità è il momento più delicato." />
    </Slide>

    <!-- ── SLIDE 1: Personalizzazione (il meccanismo) ────────────── -->
    <Slide id="slide-personalize" bg="primary" align="center">
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-4" data-reveal>IL MECCANISMO</p>
      <h2 class="slide-title text-[var(--ink-primary)] mb-7" style="font-size: clamp(2rem, 3.6vw, 3.4rem);" data-reveal data-reveal-delay="0.1">
        Lo stesso brand, il volto giusto per lei
      </h2>

      <!-- Personalize: generic tiles resolve to Giulia's matches (deck-animated) -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3.5 max-w-3xl mx-auto w-full" data-personalize>
        {contenuti.map((c) => (
          <div class:list={["perso-item px-5 py-4 rounded-md border text-left", c.match ? "border-[var(--accent-primary)] bg-[var(--accent-primary)]/8" : "border-[var(--line-subtle)] bg-[var(--surface-secondary)]"]} data-match={c.match ? '' : undefined}>
            <span class="block text-[0.72rem] tracking-[0.1em] uppercase text-[var(--ink-tertiary)] mb-1.5">{c.tag}</span>
            <span class="text-[clamp(1rem,1.3vw,1.25rem)] font-medium text-[var(--ink-primary)]">{c.label}</span>
          </div>
        ))}
      </div>

      <p class="text-[clamp(1.05rem,1.4vw,1.35rem)] text-[var(--ink-tertiary)] mt-5 max-w-xl mx-auto" data-reveal data-reveal-delay="0.4">
        La homepage non è generica: tra tutti i contenuti, emergono quelli che parlano a Giulia.
      </p>
    </Slide>

    <!-- ── SLIDE 2: Front stage — contenuto editoriale (mockup reale) ── -->
    <Slide id="slide-frontstage" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="flex items-center gap-3 mb-5" data-reveal>
            <span class="w-3.5 h-3.5 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
            <span class="slide-eyebrow text-[var(--ink-tertiary)]">Ciò che vede la cliente</span>
          </div>
          <h2 class="slide-title text-[var(--ink-primary)] mb-7" style="font-size: clamp(2.25rem, 4.2vw, 3.75rem);" data-reveal data-reveal-delay="0.1">Un'esperienza che parla a lei</h2>
          <p class="slide-lead text-[var(--ink-secondary)] max-w-xl" data-reveal data-reveal-delay="0.2">
            Giulia torna sul sito. L'homepage le mostra contenuti editoriali sul Teddy Bear Coat e la invita a scoprire la storia dei materiali. Ogni touchpoint rafforza la familiarità, senza forzare la vendita.
          </p>
        </div>

        <!-- phone with a REAL editorial photo of the coat -->
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.3">
          <div class="ig-phone relative mx-auto w-full max-w-[300px] max-h-[calc(100dvh-200px)] flex flex-col overflow-hidden rounded-[2.2rem] border-[5px] border-[var(--surface-inverse)] bg-[var(--surface-inverse)] shadow-2xl">
            <div class="flex flex-col min-h-0 bg-[var(--surface-primary)] rounded-[1.7rem] overflow-hidden">
              <div class="flex items-center justify-center pt-2 pb-1.5">
                <span class="w-16 h-1.5 rounded-full bg-[var(--ink-tertiary)]/25"></span>
              </div>
              <div class="relative w-full aspect-[4/5] overflow-hidden bg-[var(--surface-secondary)] flex-shrink-0">
                <MediaSlot {...mediaProps('engagement-editoriale')} fill noText="0,0,0,0" />
              </div>
              <div class="px-4 py-4 text-left">
                <p class="text-[0.7rem] tracking-[0.12em] uppercase text-[var(--accent-primary)] mb-1.5">Editoriale</p>
                <p class="text-[0.98rem] font-medium text-[var(--ink-primary)] leading-snug">La storia del Teddy Bear Coat</p>
                <p class="text-[0.8rem] text-[var(--ink-tertiary)] mt-2 inline-flex items-center gap-1.5">Scopri i materiali <span class="text-[var(--accent-primary)]">→</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Front→Back impulse (l'aha) ───────────────────── -->
    <Slide id="slide-impulse" bg="secondary" align="center">
      <h2 class="slide-title text-[var(--ink-primary)] mb-10" style="font-size: clamp(2rem, 3.8vw, 3.4rem);" data-reveal>
        Ogni contenuto rilevante è una decisione della piattaforma
      </h2>

      <div class="relative w-full max-w-[1100px] mx-auto grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-0 items-stretch min-h-[30vh]" data-pulse-line>
        <div class="bg-[var(--surface-primary)] rounded-lg p-8 md:p-10 border border-[var(--line-subtle)] flex flex-col justify-between" data-reveal>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
            <span class="text-[0.75rem] font-medium tracking-[0.1em] uppercase text-[var(--ink-tertiary)]">In scena</span>
          </div>
          <p class="text-[clamp(1.3rem,1.9vw,1.85rem)] text-[var(--ink-primary)] font-medium leading-tight">La cliente esplora</p>
          <p class="text-[clamp(1.05rem,1.3vw,1.3rem)] text-[var(--ink-secondary)] mt-1.5">Legge, sfoglia, torna a trovarci</p>
        </div>

        <div class="hidden md:flex items-center justify-center px-6">
          <svg width="180" height="60" viewBox="0 0 180 60" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 0 30 L 150 30" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="166" cy="30" r="9" fill="currentColor" opacity="0"/>
          </svg>
        </div>
        <div class="flex md:hidden items-center justify-center py-1">
          <svg width="60" height="46" viewBox="0 0 60 46" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 30 0 L 30 34" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="30" cy="40" r="6" fill="currentColor" opacity="0"/>
          </svg>
        </div>

        <div class="bg-[var(--surface-inverse)] rounded-lg p-8 md:p-10 text-[var(--ink-inverse)] flex flex-col justify-between" data-reveal data-reveal-delay="0.3">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
            <span class="text-[0.75rem] font-medium tracking-[0.1em] uppercase text-[var(--color-grigio-300)]">Dietro le quinte</span>
          </div>
          <p class="text-[clamp(1.3rem,1.9vw,1.85rem)] font-medium leading-tight">La piattaforma adatta</p>
          <p class="text-[clamp(1.05rem,1.3vw,1.3rem)] text-[var(--color-grigio-300)] mt-1.5">Sceglie i contenuti, testa, ottimizza</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Back stage — i prodotti Adobe in "Scopri come" ── -->
    <Slide id="slide-backstage" bg="inverse" align="center">
      <div class="flex items-center gap-3 mb-4" data-reveal>
        <span class="w-3.5 h-3.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
        <span class="slide-eyebrow text-[var(--color-grigio-300)]">CIÒ CHE FA LA PIATTAFORMA</span>
      </div>
      <h2 class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(2.25rem, 4.2vw, 3.75rem);" data-reveal data-reveal-delay="0.1">
        Personalizzazione, su ogni canale
      </h2>

      <div class="w-full max-w-3xl mx-auto flex flex-col gap-6 text-left" data-stagger="0.25">
        <p class="text-[clamp(1.35rem,2vw,2rem)] text-[var(--ink-inverse)] leading-snug border-l-2 border-[var(--accent-secondary)] pl-6">
          Ogni pagina si adatta al profilo della visitatrice, mostrando i contenuti più rilevanti.
        </p>
        <p class="text-[clamp(1.35rem,2vw,2rem)] text-[var(--ink-inverse)] leading-snug border-l-2 border-[var(--accent-secondary)] pl-6">
          Il sito impara cosa funziona per ogni segmento e si ottimizza, in tempo reale.
        </p>
      </div>

      <div class="mt-9" data-reveal data-reveal-delay="0.5">
        <HowItWorks title="Personalizzazione su ogni canale" tone="onDark">
          {adobe.map((p) => (
            <p class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-inverse)] leading-snug"><strong class="text-[var(--accent-secondary)] font-semibold">{p.name}</strong> — {p.claim}.</p>
          ))}
        </HowItWorks>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Payoff — metrica + CTA ───────────────────────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />
      <p data-display class="font-[family-name:var(--font-display)] font-light leading-none text-[var(--ink-primary)] mb-6" style="font-size: clamp(4.5rem, 12vw, 11rem);">
        <span data-count-up="15" data-count-prefix="+" data-count-suffix="%">+0%</span>
      </p>
      <p class="text-[clamp(1.5rem,2.4vw,2.25rem)] font-[family-name:var(--font-display)] font-normal text-[var(--ink-primary)] leading-snug mb-5 max-w-3xl" data-reveal data-reveal-delay="0.2">
        di ricavi in più quando l'esperienza è personalizzata in modo coerente
      </p>
      <p class="text-[clamp(1.1rem,1.35vw,1.3rem)] text-[var(--ink-primary)]/70 mb-12" data-reveal data-reveal-delay="0.28">
        Fonte: McKinsey &amp; Company
      </p>

      <div data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/conversione')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
        >
          Continua · Conversione
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
