---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import JourneyPhase from '@edf/core/blocks/JourneyPhase.astro';
import NarrativeSection from '@edf/core/blocks/NarrativeSection.astro';
import FrontBackStageSplit from '@edf/core/blocks/FrontBackStageSplit.astro';
---
<BaseLayout title="Engagement" description="Dalla scoperta alla relazione: come nutrire il legame con le clienti Max Mara.">
  <PageLayout title="Engagement">
    <JourneyPhase
      phaseNumber={2}
      phaseId="engagement"
      title="Dalla scoperta alla relazione"
      subtitle="Fase 2 — Engagement"
      body="<p>La prima visita non basta. Dopo la scoperta, inizia il momento più delicato: trasformare la curiosità in interesse, l'interesse in familiarità. Qui il brand deve raccontare la propria storia — il heritage, la qualità, il mondo valoriale — in modo che risuoni con chi è appena arrivata, senza alienare chi c'è da sempre.</p><p>Il segreto è la personalizzazione: mostrare a ciascuna cliente il volto del brand più rilevante per lei, nel momento giusto, sul canale giusto.</p>"
    />

    <NarrativeSection
      eyebrow="Heritage"
      title="Settant'anni di stile senza tempo"
      body="<p>Dal 1951, Max Mara ha costruito un linguaggio fatto di qualità sartoriale, linee pulite e materiali eccellenti. Il cappotto cammello non è solo un capo: è un gesto culturale, un codice condiviso tra generazioni di donne che scelgono la sostanza sull'apparenza.</p><p>Raccontare questo heritage alla nuova generazione non significa ripetere il passato — significa mostrare perché quei valori sono più attuali che mai in un mondo saturo di fast fashion e tendenze effimere.</p>"
    />

    <FrontBackStageSplit
      phaseId="engagement"
      phaseLabel="Engagement — Front stage / Back stage"
      customerTitle="Un'esperienza che parla a lei"
      customerBody="<p>La stessa cliente che ha scoperto la borsa Monogram torna sul sito. Questa volta l'homepage non è generica: le mostra contenuti editoriali sul Teddy Bear Coat — un pezzo iconico che incontra il suo gusto — e la invita a esplorare la storia dei materiali Max Mara. Ogni touchpoint rafforza la familiarità senza forzare la vendita.</p>"
      adobeStack={[
        { id: 'aem-sites', name: 'AEM Sites', claim: 'Storytelling digitale personalizzato: ogni pagina si adatta al profilo della visitatrice, mostrando i contenuti più rilevanti' },
        { id: 'target', name: 'Adobe Target', claim: 'Test A/B e personalizzazione in tempo reale — il sito impara cosa funziona per ogni segmento e si ottimizza' },
        { id: 'commerce', name: 'Adobe Commerce', claim: 'Esperienze d\'acquisto seamless che fondono contenuto editoriale e catalogo prodotto' },
      ]}
      reversed={true}
    />
  </PageLayout>
</BaseLayout>
