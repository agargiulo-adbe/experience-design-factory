---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import JourneyPhase from '@edf/core/blocks/JourneyPhase.astro';
import FrontBackStageSplit from '@edf/core/blocks/FrontBackStageSplit.astro';
import MetricCallout from '@edf/core/blocks/MetricCallout.astro';
import NarrativeSection from '@edf/core/blocks/NarrativeSection.astro';
---
<BaseLayout title="Loyalty" description="Dalla prima transazione al valore nel tempo: costruire fedeltà che dura generazioni.">
  <PageLayout title="Loyalty">
    <JourneyPhase
      phaseNumber={4}
      phaseId="loyalty"
      title="Dal primo acquisto al valore nel tempo"
      subtitle="Fase 4 — Loyalty"
      body="<p>Il primo acquisto non è un traguardo — è un inizio. Il vero valore di una cliente si costruisce nel tempo: nella seconda visita, nel terzo acquisto, nel momento in cui smette di confrontare e inizia a fidarsi. La loyalty nel luxury non si compra con i punti: si costruisce con esperienze che fanno sentire riconosciute e speciali.</p><p>Qui la tecnologia gioca il ruolo più sottile: ricordare senza essere intrusiva, anticipare senza presumere, personalizzare ogni momento — dal messaggio digitale al sorriso della store advisor che sa già come ti chiami.</p>"
    />

    <FrontBackStageSplit
      phaseId="loyalty"
      phaseLabel="Loyalty — Front stage / Back stage"
      customerTitle="Essere riconosciute, ovunque"
      customerBody="<p>Giulia entra nel negozio Max Mara di Via Montenapoleone. La store advisor l'accoglie per nome, sa che ha acquistato online il mese scorso, conosce le sue preferenze di stile. Non è magia — è un profilo unificato che attraversa i canali. Le propone un cappotto che completa il suo guardaroba, e le anticipa un invito esclusivo per il trunk show della prossima stagione.</p>"
      adobeStack={[
        { id: 'journey-optimizer', name: 'Journey Optimizer', claim: 'Journey lifecycle personalizzati: dal welcome post-acquisto al re-engagement, ogni comunicazione è rilevante e tempestiva' },
        { id: 'rtcdp', name: 'Real-Time CDP', claim: 'Profilo unificato real-time: il negozio vede il browsing online, l\'e-commerce vede gli acquisti in store — una vista unica della cliente' },
        { id: 'cja', name: 'Customer Journey Analytics', claim: 'Analisi LTV per coorti, predizione del churn, segmentazione RFM — per intervenire prima che la cliente si allontani' },
      ]}
      reversed={true}
    />

    <NarrativeSection
      eyebrow="Clienteling"
      title="Il digitale che potenzia l'umano"
      body="<p>Il clienteling in store è il momento più alto della luxury experience. Non si tratta di sostituire la relazione umana con la tecnologia — si tratta di dare alla store advisor le informazioni giuste per rendere ogni interazione memorabile.</p><p>Quando la tecnologia funziona, diventa invisibile: il cliente sente solo che qualcuno la conosce davvero. E questo è il tipo di esperienza che genera fedeltà duratura — il tipo che si racconta alle amiche, che passa da una generazione all'altra.</p>"
      mediaPosition="right"
    />

    <MetricCallout
      value="+306%"
      label="LTV delle clienti emotivamente connesse vs. clienti soddisfatte"
      context="Nel luxury, la soddisfazione è il minimo. La connessione emotiva è ciò che moltiplica il valore."
      source="Harvard Business Review"
      variant="large"
    />
  </PageLayout>
</BaseLayout>
