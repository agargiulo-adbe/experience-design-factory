---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import StepContainer from '@edf/core/blocks/immersive/StepContainer.astro';
import Step from '@edf/core/blocks/immersive/Step.astro';
import { href } from '@edf/core/utils/url.js';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

const adobe = [
  { code: 'JO', name: 'Journey Optimizer', claim: 'Journey lifecycle personalizzati: dal welcome post-acquisto al re-engagement, ogni comunicazione è rilevante e tempestiva' },
  { code: 'RC', name: 'Real-Time CDP', claim: 'Profilo unificato real-time: il negozio vede il browsing online, l\'e-commerce vede gli acquisti in store — una vista unica' },
  { code: 'CJ', name: 'Customer Journey Analytics', claim: 'Analisi LTV per coorti, predizione del churn, segmentazione RFM — per intervenire prima che la cliente si allontani' },
];
---
<BaseLayout title="Loyalty" description="Dalla prima transazione al valore nel tempo: costruire fedeltà che dura generazioni.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <StepContainer>
    <!-- ── STEP 1: Apertura ──────────────────────────────────────── -->
    <Step id="step-apertura" bg="secondary" align="center">
      <div class="max-w-3xl mx-auto">
        <span class="block text-[clamp(5rem,12vw,10rem)] font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] opacity-20 leading-none mb-6" data-reveal aria-hidden="true">04</span>
        <p class="text-xs font-medium tracking-[0.12em] uppercase text-[var(--accent-primary)] mb-4" data-reveal data-reveal-delay="0.1">Fase 4 — Loyalty</p>
        <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw+1rem,4.5rem)] font-light leading-[1.05] tracking-tight text-[var(--ink-primary)] mb-6" data-reveal data-reveal-delay="0.2">
          Dal primo acquisto al valore nel tempo
        </h1>
        <p class="text-[clamp(1.125rem,1vw+0.875rem,1.375rem)] text-[var(--ink-secondary)] leading-relaxed max-w-xl mx-auto" data-reveal data-reveal-delay="0.3">
          La loyalty nel luxury non si compra con i punti: si costruisce con esperienze che fanno sentire riconosciute.
        </p>
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--ink-tertiary)] opacity-60 scroll-hint" data-reveal data-reveal-delay="0.6">
        <span class="text-[0.65rem] tracking-[0.15em] uppercase">Scorri</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="animate-bounce-subtle" aria-hidden="true">
          <path d="M10 4v12M5 11l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </Step>

    <!-- ── STEP 2: Lifecycle (the value animation) ───────────────── -->
    <Step id="step-lifecycle" bg="primary" align="center">
      <div class="max-w-3xl mx-auto w-full">
        <p class="text-xs font-medium tracking-[0.12em] uppercase text-[var(--accent-primary)] mb-6" data-reveal>Il meccanismo</p>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw+0.5rem,3rem)] font-light leading-[1.15] text-[var(--ink-primary)] mb-12" data-reveal data-reveal-delay="0.1">
          Non una linea, ma un ciclo che continua
        </h2>

        <!-- Lifecycle ring -->
        <div class="relative w-full max-w-xs mx-auto aspect-square" data-lifecycle>
          <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 200 200" fill="none" aria-hidden="true">
            <circle cx="100" cy="100" r="70" stroke="var(--line-subtle)" stroke-width="1"/>
            <path class="cycle-track" d="M100,30 a70,70 0 1,1 -0.1,0" stroke="var(--accent-primary)" stroke-width="2" stroke-linecap="round"/>
            <circle class="cycle-dot" cx="100" cy="30" r="5" fill="var(--accent-primary)" data-cx="100" data-cy="100"/>
          </svg>
          <!-- Nodes around the ring -->
          <div class="cycle-node absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
            <span class="w-3 h-3 rounded-full bg-[var(--accent-primary)]"></span>
            <span class="text-[0.65rem] font-medium text-[var(--ink-secondary)] mt-1 whitespace-nowrap">1 · Acquisto</span>
          </div>
          <div class="cycle-node absolute top-1/2 right-0 translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
            <span class="w-3 h-3 rounded-full bg-[var(--accent-primary)]"></span>
            <span class="text-[0.65rem] font-medium text-[var(--ink-secondary)] mt-1 whitespace-nowrap">2 · Welcome</span>
          </div>
          <div class="cycle-node absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 flex flex-col items-center">
            <span class="w-3 h-3 rounded-full bg-[var(--accent-primary)]"></span>
            <span class="text-[0.65rem] font-medium text-[var(--ink-secondary)] mt-1 whitespace-nowrap">3 · Riconoscimento</span>
          </div>
          <div class="cycle-node absolute top-1/2 left-0 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
            <span class="w-3 h-3 rounded-full bg-[var(--accent-primary)]"></span>
            <span class="text-[0.65rem] font-medium text-[var(--ink-secondary)] mt-1 whitespace-nowrap">4 · Invito</span>
          </div>
        </div>

        <p class="text-sm text-[var(--ink-tertiary)] mt-12 max-w-md mx-auto" data-reveal data-reveal-delay="0.2">
          Ogni giro aumenta il valore: la seconda visita, il terzo acquisto, il momento in cui smette di confrontare.
        </p>
      </div>
    </Step>

    <!-- ── STEP 3: Front stage — clienteling (recognition) ───────── -->
    <Step id="step-frontstage" bg="primary" align="center">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-3 mb-6" data-reveal>
          <span class="w-3 h-3 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-[var(--ink-tertiary)]">Ciò che vive la cliente</span>
        </div>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw+0.5rem,3.5rem)] font-light leading-[1.1] text-[var(--ink-primary)] mb-8" data-reveal data-reveal-delay="0.1">
          Essere riconosciute, ovunque
        </h2>

        <!-- Clienteling: recognition card populates under a scan sweep -->
        <div class="relative max-w-sm mx-auto p-6 rounded-sm border border-[var(--line-default)] bg-[var(--surface-secondary)] overflow-hidden text-left" data-clienteling>
          <div class="scan-line absolute left-0 right-0 h-12 pointer-events-none" style="background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--accent-primary) 22%, transparent), transparent); opacity: 0;"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 rounded-full bg-[var(--accent-primary)] flex items-center justify-center flex-shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--surface-primary)" stroke-width="1.5" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-[var(--ink-primary)]">Giulia M.</p>
              <p class="text-xs text-[var(--ink-tertiary)]">Via Montenapoleone, ore 16:20</p>
            </div>
          </div>
          <ul class="space-y-2.5 text-sm text-[var(--ink-secondary)]">
            <li class="reveal-attr flex items-center gap-2"><span class="text-[var(--accent-primary)]">›</span> Cliente dal 2024 · 3 acquisti</li>
            <li class="reveal-attr flex items-center gap-2"><span class="text-[var(--accent-primary)]">›</span> Ultimo: Whitney Bag, online</li>
            <li class="reveal-attr flex items-center gap-2"><span class="text-[var(--accent-primary)]">›</span> Stile: minimal, materiali pregiati</li>
            <li class="reveal-attr flex items-center gap-2"><span class="text-[var(--accent-primary)]">›</span> Invito trunk show: da proporre</li>
          </ul>
        </div>

        <p class="text-sm text-[var(--ink-tertiary)] mt-8 max-w-md mx-auto" data-reveal data-reveal-delay="0.2">
          La store advisor l'accoglie per nome. Non è magia: è un profilo unificato che attraversa i canali.
        </p>
      </div>
    </Step>

    <!-- ── STEP 4: Front→Back impulse (the aha) ──────────────────── -->
    <Step id="step-impulse" bg="secondary" align="center">
      <div class="max-w-4xl mx-auto w-full">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.5rem,2.5vw+0.5rem,2.5rem)] font-light leading-[1.15] text-[var(--ink-primary)] mb-10 text-center" data-reveal>
          Il digitale che potenzia l'umano
        </h2>

        <div class="relative grid md:grid-cols-[1fr_auto_1fr] gap-4 md:gap-0 items-center" data-pulse-line>
          <div class="bg-[var(--surface-primary)] rounded-sm p-6 md:p-8 border border-[var(--line-subtle)]" data-reveal>
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2 h-2 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
              <span class="text-[0.65rem] font-medium tracking-[0.1em] uppercase text-[var(--ink-tertiary)]">Front stage</span>
            </div>
            <p class="text-sm text-[var(--ink-primary)] font-medium">La store advisor la conosce</p>
            <p class="text-xs text-[var(--ink-tertiary)] mt-1">Per nome, gusto, storia d'acquisto</p>
          </div>

          <div class="hidden md:flex items-center justify-center px-4">
            <svg width="120" height="40" viewBox="0 0 120 40" class="text-[var(--accent-primary)]">
              <path class="pulse-path" d="M 0 20 L 100 20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
              <circle class="pulse-dot" cx="110" cy="20" r="6" fill="currentColor" opacity="0"/>
            </svg>
          </div>
          <div class="flex md:hidden items-center justify-center py-2">
            <svg width="40" height="40" viewBox="0 0 40 40" class="text-[var(--accent-primary)]">
              <path class="pulse-path" d="M 20 0 L 20 30" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
              <circle class="pulse-dot" cx="20" cy="36" r="4" fill="currentColor" opacity="0"/>
            </svg>
          </div>

          <div class="bg-[var(--surface-inverse)] rounded-sm p-6 md:p-8 text-[var(--ink-inverse)]" data-reveal data-reveal-delay="0.3">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2 h-2 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
              <span class="text-[0.65rem] font-medium tracking-[0.1em] uppercase text-[var(--color-grigio-400)]">Back stage</span>
            </div>
            <p class="text-sm font-medium">La piattaforma ricorda</p>
            <p class="text-xs text-[var(--color-grigio-400)] mt-1">Profilo unificato, online e in store</p>
          </div>
        </div>
      </div>
    </Step>

    <!-- ── STEP 5: Back stage — prodotti Adobe uno alla volta ────── -->
    <Step id="step-backstage" bg="inverse" align="center">
      <div class="max-w-3xl mx-auto w-full text-[var(--ink-inverse)]">
        <div class="flex items-center gap-3 mb-6" data-reveal>
          <span class="w-3 h-3 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-[var(--color-grigio-400)]">Ciò che fa la piattaforma</span>
        </div>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,3.5vw+0.5rem,3rem)] font-light leading-[1.1] mb-10" data-reveal data-reveal-delay="0.1">
          Ricordare, anticipare, intervenire
        </h2>

        <div class="space-y-4" data-stagger="0.2">
          {adobe.map((p) => (
            <div class="flex items-center gap-4 p-4 md:p-5 rounded-sm border border-[var(--color-grigio-500)]/30 bg-[var(--color-grigio-500)]/5 hover:border-[var(--accent-secondary)]/60 transition-colors">
              <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-[var(--accent-secondary)]/20 flex items-center justify-center">
                <span class="text-[0.6rem] font-bold text-[var(--accent-secondary)]">{p.code}</span>
              </div>
              <div>
                <p class="text-sm font-medium">{p.name}</p>
                <p class="text-xs text-[var(--color-grigio-400)] mt-0.5">{p.claim}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Step>

    <!-- ── STEP 6: Payoff — metrica + CTA ────────────────────────── -->
    <Step id="step-payoff" bg="brand" align="center">
      <div class="max-w-3xl mx-auto text-center">
        <p class="font-[family-name:var(--font-display)] font-light leading-none text-white mb-6" style="font-size: clamp(5rem, 15vw, 12rem);">
          <span data-count-up="306" data-count-prefix="+" data-count-suffix="%">+0%</span>
        </p>
        <p class="text-xl md:text-2xl font-[family-name:var(--font-display)] font-light text-white/90 leading-snug mb-4" data-reveal data-reveal-delay="0.2">
          il Lifetime Value delle clienti emotivamente connesse rispetto a quelle soddisfatte
        </p>
        <p class="text-sm text-white/60" data-reveal data-reveal-delay="0.3">
          Fonte: Harvard Business Review
        </p>

        <div class="mt-16" data-reveal data-reveal-delay="0.5">
          <a
            href={href(base, '/motore-adobe')}
            class="inline-flex items-center gap-3 px-8 py-3.5 text-sm font-medium tracking-wide uppercase border border-white/40 text-white hover:bg-white hover:text-[var(--accent-primary)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
          >
            Scopri il motore Adobe
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Step>
  </StepContainer>
</BaseLayout>

<style>
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
  .animate-bounce-subtle { animation: bounce-subtle 2s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) {
    .animate-bounce-subtle { animation: none; }
    .scroll-hint { display: none; }
  }
</style>

<script>
  import { initAllAnimations } from '@edf/core/blocks/immersive/animations';
  function setup() {
    const container = document.querySelector<HTMLElement>('[data-step-container]');
    if (container) initAllAnimations(container);
  }
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
