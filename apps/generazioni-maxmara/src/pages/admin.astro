// Solutions registry — derived from the Adobe products actually featured in the
// Generazioni content (verified per page). appearsIn uses the page labels above.
interface SolutionEntry { id: string; name: string; shortName: string; pillar: string; description: string; appearsIn: string[]; }
const SOLUTIONS: SolutionEntry[] = [
  { id: 'aep', name: 'Adobe Experience Platform', shortName: 'AEP', pillar: 'foundation', description: 'La fondazione dati: raccoglie, normalizza e attiva i profili in tempo reale.', appearsIn: ['Il Motore Adobe'] },
  { id: 'rtcdp', name: 'Real-Time CDP', shortName: 'RT-CDP', pillar: 'data', description: 'Unifica i dati in un profilo unico e costruisce pubblici simili per la scoperta.', appearsIn: ['Acquisizione', 'Loyalty', 'Il Motore Adobe'] },
  { id: 'aem-sites', name: 'Adobe Experience Manager Sites', shortName: 'AEM Sites', pillar: 'content', description: 'Storytelling digitale personalizzato su ogni touchpoint editoriale.', appearsIn: ['Engagement', 'Il Motore Adobe'] },
  { id: 'genstudio', name: 'GenStudio for Performance Marketing', shortName: 'GenStudio', pillar: 'content', description: 'I team interni creano e declinano varianti on-brand in minuti, senza attendere l’agenzia.', appearsIn: ['Acquisizione', 'Il Motore Adobe'] },
  { id: 'firefly', name: 'Adobe Firefly', shortName: 'Firefly', pillar: 'content', description: 'Generazione creativa AI brand-safe per ampliare gli asset di campagna.', appearsIn: ['Acquisizione', 'Il Motore Adobe'] },
  { id: 'express', name: 'Adobe Express', shortName: 'Express', pillar: 'content', description: 'Editing rapido e template brand-safe per i team marketing.', appearsIn: ['Il Motore Adobe'] },
  { id: 'target', name: 'Adobe Target', shortName: 'Target', pillar: 'engagement', description: 'Test A/B, raccomandazioni e personalizzazione in tempo reale.', appearsIn: ['Engagement', 'Conversione', 'Il Motore Adobe'] },
  { id: 'ajo', name: 'Adobe Journey Optimizer', shortName: 'AJO', pillar: 'engagement', description: 'Orchestrazione dei journey lifecycle personalizzati, in tempo reale e cross-canale.', appearsIn: ['Conversione', 'Loyalty', 'Il Motore Adobe'] },
  { id: 'brand-concierge', name: 'Brand Concierge', shortName: 'Brand Concierge', pillar: 'engagement', description: 'L’assistente conversazionale AI di Adobe (Product Advisor Agent su Agent Orchestrator).', appearsIn: ['Conversione', 'Il Motore Adobe'] },
  { id: 'commerce', name: 'Adobe Commerce', shortName: 'Commerce', pillar: 'commerce', description: 'Checkout seamless cross-device ed esperienze d’acquisto senza attrito.', appearsIn: ['Engagement', 'Conversione', 'Il Motore Adobe'] },
  { id: 'cja', name: 'Customer Journey Analytics', shortName: 'CJA', pillar: 'analytics', description: 'Analisi LTV per coorti e predizione del churn su tutti i touchpoint.', appearsIn: ['Loyalty', 'Il Motore Adobe'] },
  { id: 'workfront', name: 'Adobe Workfront', shortName: 'Workfront', pillar: 'operations', description: 'Coordina flussi e team che alimentano il motore di esperienza.', appearsIn: ['Il Motore Adobe'] },
];

const PILLAR_LABELS: Record<string, string> = { foundation: 'Foundation', data: 'Data', content: 'Content', engagement: 'Engagement', commerce: 'Commerce', analytics: 'Analytics', operations: 'Operations' };
const PILLAR_ORDER = ['foundation', 'data', 'content', 'engagement', 'commerce', 'analytics', 'operations'];
const PILLAR_COLORS: Record<string, string> = { foundation: '#C19A6B', data: '#6B4F3A', content: '#B8975A', engagement: '#3E2C20', commerce: '#9B7B4F', analytics: '#736B61', operations: '#C4BDB3' };

const solutionGroups = PILLAR_ORDER
  .map((pillar) => ({ pillar, label: PILLAR_LABELS[pillar], color: PILLAR_COLORS[pillar], solutions: SOLUTIONS.filter((s) => s.pillar === pillar) }))
  .filter((g) => g.solutions.length > 0);
const allSolutionIds = SOLUTIONS.map((s) => s.id);
const deckHref = href(base, '/');
---
<BaseLayout title="Console di configurazione — Generazioni">
  <AdminConsole
    projectSlug="generazioni-maxmara"
    projectName="Generazioni — Max Mara"
    clientLabel="Max Mara"
    deckHref={deckHref}
    pages={PAGE_REGISTRY}
    solutionGroups={solutionGroups}
    allSolutionIds={allSolutionIds}
    supabaseUrl={SUPABASE_URL}
    supabaseAnonKey={SUPABASE_ANON_KEY}
  />
</BaseLayout>
