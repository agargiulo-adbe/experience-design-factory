---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Generazioni">
  <main>
    <section class="min-h-screen flex items-center justify-center bg-[var(--surface-primary)]">
      <div class="max-w-4xl mx-auto px-6 py-24 text-center">
        <p class="text-sm font-medium tracking-[0.1em] uppercase text-[var(--ink-tertiary)] mb-6">Max Mara × Adobe</p>
        <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw+1rem,5rem)] font-light leading-[1.1] tracking-tight text-[var(--ink-primary)] mb-8">
          Generazioni
        </h1>
        <p class="text-[clamp(1.125rem,1vw+0.875rem,1.5rem)] text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto">
          Ringiovanire il target, allungare il ciclo di vita, accrescere il valore di ogni cliente.
          Un ponte tra generazioni di donne — con Adobe come tessuto connettivo.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
