---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import Hero from '@edf/core/blocks/Hero.astro';
import NarrativeSection from '@edf/core/blocks/NarrativeSection.astro';
import MetricCallout from '@edf/core/blocks/MetricCallout.astro';
import Timeline from '@edf/core/blocks/Timeline.astro';
import { href } from '@edf/core/utils/url.js';

const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Generazioni" description="Ringiovanire il target, allungare il ciclo di vita, accrescere il valore. Un ponte tra generazioni di donne — con Adobe come tessuto connettivo.">
  <PageLayout title="Generazioni">
    <Hero
      label="Max Mara × Adobe"
      title="Generazioni"
      subtitle="Ringiovanire il target, allungare il ciclo di vita, accrescere il valore di ogni cliente. Un ponte tra generazioni di donne — con Adobe come tessuto connettivo invisibile."
      ctaLabel="Scopri il percorso"
      ctaHref={href(base, '/acquisizione')}
    />

    <NarrativeSection
      eyebrow="La tesi"
      title="Dal data lake alle relazioni"
      body="<p>Max Mara possiede un patrimonio di dati — ma oggi quel patrimonio è un data lake silente, non un motore di relazioni. La sfida è trasformare dati frammentati in profili conosciuti e azionabili: acquisire una nuova generazione di clienti, riconoscerle al primo tocco, personalizzare ogni momento del percorso, farle crescere in valore nel tempo.</p><p>Servono due cose: un tessuto connettivo tecnologico che oggi manca — e una visione che unisca acquisition, engagement, conversione e loyalty in un unico flusso. Adobe è quel tessuto. Questo progetto mostra come.</p>"
    />

    <MetricCallout
      value="+306%"
      label="Lifetime Value delle clienti emotivamente connesse rispetto a quelle semplicemente soddisfatte"
      context="Le connessioni emotive guidano la fedeltà nel luxury: non basta soddisfare, bisogna ispirare."
      source="Harvard Business Review"
      variant="large"
    />

    <NarrativeSection
      eyebrow="La visione"
      title="Due generazioni, un solo filo"
      body="<p>«Generazioni» non è solo un nome. È la strategia: costruire un ponte tra la cliente che scopre Max Mara per la prima volta — attratta da un accessorio, un profumo, un momento digitale — e la cliente che da decenni sceglie il cappotto cammello come gesto d'identità.</p><p>Il filo che le unisce è il valore nel tempo. Acquisire giovani è necessario; farle restare è ciò che cambia il business. E la tecnologia giusta rende possibile ciò che l'intuizione da sola non può: riconoscere, personalizzare, anticipare — su ogni canale, in ogni momento.</p>"
      mediaPosition="left"
    />

    <Timeline
      title="Una storia che continua"
      entries={[
        { year: '1951', title: 'Achille Maramotti fonda Max Mara a Reggio Emilia', body: 'L\'idea rivoluzionaria: alta moda prêt-à-porter, qualità sartoriale accessibile.', highlight: false },
        { year: '1981', title: 'Il cappotto 101801 diventa icona', body: 'Design senza tempo che attraversa le generazioni — il capo più longevo della moda italiana.', highlight: false },
        { year: '2013', title: 'Nasce il Teddy Bear Coat', body: 'Un nuovo classico che cattura una generazione più giovane.', highlight: true },
        { year: '2024', title: 'Max Mara entra in Roblox', body: 'Un segnale chiaro: il brand parla anche alla Gen Z, nei loro spazi.', highlight: true },
        { year: '2025', title: '"Untamed Heroine" — la forza interiore femminile', body: 'La campagna FW25 celebra donne che non chiedono permesso.', highlight: true },
        { year: 'Domani', title: 'Generazioni — il ponte', body: 'Dalla prima scoperta alla fedeltà profonda. Un ciclo di vita che si allunga, un valore che cresce.', highlight: true },
      ]}
    />
  </PageLayout>
</BaseLayout>
