---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

// Slide-manifesto: i quattro momenti come archi di un'unica relazione.
const tappe = [
  { label: 'Acquisizione', essence: 'Incontrare' },
  { label: 'Engagement', essence: 'Conoscersi' },
  { label: 'Conversione', essence: 'Scegliere' },
  { label: 'Loyalty', essence: 'Restare' },
];
---
<BaseLayout title="Generazioni" description="Incontrare una nuova generazione, onorare chi sceglie Max Mara da sempre. Una relazione che attraversa il tempo.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <DeckContainer nextHref={href(base, '/acquisizione')}>

    <!-- ── SLIDE 0: Copertina ────────────────────────────────────── -->
    <Slide id="slide-cover" bg="secondary" align="center">
      <div slot="backdrop" class="absolute inset-0">
        <SlideBackdrop {...mediaProps('bg-linen')} imageClass="opacity-25" scrim="bg-[var(--surface-secondary)]/70" />
        <div class="mm-bg" aria-hidden="true"></div>
        <div class="mm-weave" aria-hidden="true"></div>
        <!-- il filo di seta: un'unica linea sottile, ben sotto il titolo -->
        <div class="mm-thread-line" style="top: 82%; left: 0; right: 0;" aria-hidden="true"></div>
      </div>
      <CoverHero
        size="hero"
        eyebrow="Max Mara × Adobe"
        title="Generazioni"
        lead="Incontrare una nuova generazione, onorare chi sceglie Max Mara da sempre. Una relazione che attraversa il tempo."
      />
    </Slide>

    <!-- ── SLIDE 1: Manifesto — l'intero percorso in una schermata ── -->
    <Slide id="slide-manifesto" bg="primary" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-15" scrim="bg-[var(--surface-primary)]/82" />
      <div class="mm-weave" aria-hidden="true"></div>

      <div class="w-full max-w-6xl mx-auto flex flex-col items-center text-center">
        <p class="mm-panel-tag mb-4" data-reveal>IL PERCORSO</p>
        <h2 class="font-[family-name:var(--font-display)] font-medium text-[var(--ink-primary)] mb-5" style="font-size: clamp(2rem, 3.6vw, 3.4rem); line-height: 1.08;" data-reveal data-reveal-delay="0.1">
          Una sola relazione, quattro momenti
        </h2>
        <p class="mm-panel-body max-w-2xl mx-auto mb-16" style="font-size: clamp(1.05rem, 1.4vw, 1.3rem); line-height: 1.6;" data-reveal data-reveal-delay="0.2">
          Accogliere una nuova generazione e onorare chi sceglie Max Mara da sempre, dall'incontro alla fedeltà, lungo un solo filo che attraversa il tempo.
        </p>

        <!-- Il filo di seta: da Giulia (la nuova) attraverso le quattro fasi, fino a Francesca (chi resta) -->
        <div class="mm-thread w-full max-w-5xl mx-auto" data-reveal data-reveal-delay="0.3">
          <div class="mm-thread-line hidden md:block" style="top: 2.2rem; left: 9%; right: 9%;" aria-hidden="true"></div>
          <div class="relative grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-y-9 gap-x-4 items-start justify-items-center">
            <div class="flex flex-col items-center gap-2 text-center">
              <div class="relative w-[3.6rem] h-[3.6rem] rounded-full overflow-hidden flex-shrink-0 bg-[var(--accent-primary)] ring-1 ring-[rgba(193,154,107,0.7)] shadow-[0_2px_10px_-4px_rgba(62,44,32,0.5)]">
                <MediaSlot {...mediaProps('persona-giulia')} fill noText="0,0,0,0" />
              </div>
              <span class="font-[family-name:var(--font-display)] text-[clamp(1rem,1.15vw,1.2rem)] text-[var(--ink-primary)] mt-1">Giulia, 29</span>
              <span class="mm-node-label">la nuova cliente</span>
            </div>

            {tappe.map((t, i) => (
              <div class="flex flex-col items-center gap-2 text-center">
                <span class="mm-node text-[0.95rem]" data-active={i === 0 ? '' : undefined} aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="font-[family-name:var(--font-display)] text-[clamp(1rem,1.15vw,1.2rem)] text-[var(--ink-primary)] mt-1">{t.label}</span>
                <span class="mm-node-label">{t.essence}</span>
              </div>
            ))}

            <div class="flex flex-col items-center gap-2 text-center">
              <div class="relative w-[3.6rem] h-[3.6rem] rounded-full overflow-hidden flex-shrink-0 bg-[var(--accent-secondary)] ring-1 ring-[rgba(193,154,107,0.7)] shadow-[0_2px_10px_-4px_rgba(62,44,32,0.5)]">
                <MediaSlot {...mediaProps('francesca-volto')} fill noText="0,0,0,0" />
              </div>
              <span class="font-[family-name:var(--font-display)] text-[clamp(1rem,1.15vw,1.2rem)] text-[var(--ink-primary)] mt-1">Francesca, 52</span>
              <span class="mm-node-label">la cliente storica</span>
            </div>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Invito — il valore + entra nel percorso ──────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />

      <div class="w-full max-w-6xl mx-auto grid md:grid-cols-[auto_1fr] gap-x-14 gap-y-8 items-center">
        <p data-display class="font-[family-name:var(--font-display)] font-light leading-none text-[var(--ink-primary)] text-center md:text-left" style="font-size: clamp(4.5rem, 12vw, 11rem);">
          <span data-count-up="2.4">0</span>
        </p>

        <div class="mm-panel text-left" data-reveal data-reveal-delay="0.15">
          <p class="mm-panel-tag">L'EQUILIBRIO DELLA FIDUCIA</p>
          <p class="mm-panel-head mt-3" style="font-size: clamp(1.5rem, 2.4vw, 2.25rem); line-height: 1.16;">
            Bastano 2.4 esperienze negative per perdere una cliente. Ne servono 6.7 positive per conquistarla.
          </p>
          <p class="mm-panel-src mt-5">
            Fonti: McKinsey · Deloitte · Adobe &amp; Incisiv, ricerca sulla loyalty nel retail, 2026
          </p>
        </div>
      </div>

      <div class="mt-12" data-reveal data-reveal-delay="0.4">
        <a
          href={href(base, '/acquisizione')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
        >
          Inizia il percorso · Acquisizione
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
