---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import JourneyPhase from '@edf/core/blocks/JourneyPhase.astro';
import FrontBackStageSplit from '@edf/core/blocks/FrontBackStageSplit.astro';
import ProductGateway from '@edf/core/blocks/ProductGateway.astro';
import MetricCallout from '@edf/core/blocks/MetricCallout.astro';
---
<BaseLayout title="Acquisizione" description="Ringiovanire il target: come attrarre una nuova generazione di clienti Max Mara.">
  <PageLayout title="Acquisizione">
    <JourneyPhase
      phaseNumber={1}
      phaseId="acquisizione"
      title="Ringiovanire il target"
      subtitle="Fase 1 — Acquisizione"
      body="<p>Millennial e Gen Z rappresentano circa tre quarti della spesa luxury entro fine 2025. Max Mara ha un vantaggio naturale: il quiet luxury risuona con queste generazioni, che cercano qualità duratura, non ostentazione. Ma raggiungerle richiede nuovi linguaggi, nuovi canali e la capacità di creare contenuti on-brand a una velocità che le agenzie tradizionali, da sole, non possono garantire.</p><p>La risposta non è sostituire le agenzie — è potenziarle. Con strumenti che permettono ai team interni di produrre varianti creative a scala, mantenendo il controllo del brand, mentre le agenzie si concentrano sulla visione strategica.</p>"
    />

    <FrontBackStageSplit
      phaseId="acquisizione"
      phaseLabel="Acquisizione — Front stage / Back stage"
      customerTitle="Scoprire Max Mara per la prima volta"
      customerBody="<p>Una ventottenne milanese scopre una borsa Monogram su Instagram. Il contenuto è perfetto: parla il suo linguaggio, mostra il prodotto nel suo mondo — non in una vetrina distante. Clicca, atterra su una pagina che la riconosce come nuova visitatrice e le mostra un percorso pensato per chi sta scoprendo il brand.</p>"
      adobeStack={[
        { id: 'genstudio', name: 'GenStudio for Performance Marketing', claim: 'Creatività on-brand a scala con AI generativa — il team interno produce varianti senza dipendere da tempi d\'agenzia' },
        { id: 'firefly', name: 'Adobe Firefly', claim: 'Immagini e contenuti generati con AI, sicuri per uso commerciale e coerenti con l\'identità visiva del brand' },
        { id: 'rtcdp', name: 'Real-Time CDP', claim: 'Audience lookalike per raggiungere profili simili alle migliori clienti — anche chi non conosce ancora il brand' },
        { id: 'cja', name: 'Customer Journey Analytics', claim: 'Analisi cross-channel per capire quali touchpoint convertono le nuove clienti, e ottimizzare il mix' },
        { id: 'mix-modeler', name: 'Mix Modeler', claim: 'Ottimizzazione del media mix con AI: più budget sui canali che funzionano, meno spreco' },
      ]}
    />

    <ProductGateway
      title="I pezzi d'ingresso"
      body="Accessori, Monogram, fragranze: prodotti più accessibili che aprono la porta al mondo Max Mara. Ogni pezzo d'ingresso è un'opportunità per iniziare una relazione."
      products={[
        { name: 'Monogram', description: 'La firma riconoscibile che costruisce appartenenza — borse, accessori, piccola pelletteria.' },
        { name: 'Accessori', description: 'Sciarpe, cinture, gioielli: oggetti che entrano nella quotidianità e creano familiarità col brand.' },
        { name: 'Fragranze', description: 'Il punto d\'ingresso più accessibile — un gesto quotidiano che porta Max Mara nella vita delle nuove clienti.' },
      ]}
    />

    <MetricCallout
      value="¾"
      label="della spesa luxury entro il 2025 sarà guidata da Millennial e Gen Z"
      context="Intercettarle oggi significa costruire il business di domani."
      source="Bain & Company / Altagamma"
    />
  </PageLayout>
</BaseLayout>
