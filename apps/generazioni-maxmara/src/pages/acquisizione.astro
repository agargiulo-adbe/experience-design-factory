---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverSlide from '@edf/core/blocks/CoverSlide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import InstagramPost from '@edf/core/blocks/InstagramPost.astro';
import HowItWorks from '@edf/core/blocks/HowItWorks.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

// Faint persistent "data lake" field behind the profiles (visible in every state,
// so the data → people metaphor reads even when the convergence isn't playing).
const field = Array.from({ length: 46 }).map((_, i) => ({
  x: Math.round(6 + (((i * 53) % 88))),
  y: Math.round(8 + (((i * 37) % 84))),
}));

// Data-lake dots — scattered, converging to centre (kept compact to fit the frame).
const dots = Array.from({ length: 56 }).map((_, i) => {
  const angle = (i / 56) * Math.PI * 2 + (i % 3);
  const radius = 120 + Math.floor(Math.abs(Math.sin(i * 2.6698) * 200));
  return {
    dx: Math.round(Math.cos(angle) * radius),
    dy: Math.round(Math.sin(angle) * radius * 0.55),
  };
});
---
<BaseLayout title="Acquisizione" description="Una relazione che attraversa il tempo: come Max Mara incontra Giulia, la nuova generazione di clienti.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <DeckContainer nextHref={href(base, '/engagement')} prevHref={href(base, '/')}>

    <!-- ── SLIDE 0: Cover cinematografica ────────────────────────── -->
    <CoverSlide tagline="Una relazione che attraversa il tempo" bgMedia={mediaProps('bg-cashmere').media} bgSrc={mediaProps('bg-cashmere').src} />

    <!-- ── SLIDE 1: Apertura fase ────────────────────────────────── -->
    <Slide id="slide-apertura" bg="secondary" align="center">
      <MediaSlot slot="backdrop" {...mediaProps('acquisizione-atmosfera')} fill loading="eager" class="opacity-30" />
      <div slot="backdrop" data-scrim class="absolute inset-0 bg-[var(--surface-secondary)]/55" aria-hidden="true"></div>
      <div slot="backdrop" class="mm-weave" aria-hidden="true"></div>

      <div class="flex flex-col items-center">
        <CoverHero eyebrow="FASE 1 · ACQUISIZIONE" numeral="01" title="Incontrare chi ancora non ci conosce" />

        <!-- il filo di seta: primo nodo del percorso -->
        <div class="mm-thread relative w-full max-w-3xl mt-12 flex items-center justify-center" data-reveal data-reveal-delay="0.4" aria-hidden="true">
          <span class="mm-thread-line left-0 right-0 top-1/2"></span>
          <div class="relative flex flex-col items-center gap-3 px-6 bg-[var(--surface-secondary)]">
            <span class="mm-node" data-active>1</span>
            <span class="mm-node-label">Acquisizione</span>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Giulia, il volto ─────────────────────────────── -->
    <Slide id="slide-giulia" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-[0.85fr_1fr] gap-10 md:gap-16 items-center">
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.15">
          <div class="relative h-full max-h-[70vh] aspect-[4/5] rounded-lg overflow-hidden shadow-xl bg-[var(--accent-primary)] mx-auto">
            <MediaSlot {...mediaProps('persona-giulia')} fill loading="eager" noText="4,12,76,64" />
          </div>
        </div>
        <div class="text-left">
          <div class="mm-panel max-w-xl" data-reveal data-reveal-delay="0.2">
            <p class="mm-panel-tag" data-reveal>Lei</p>
            <h2 class="mm-panel-head text-[var(--ink-primary)] mb-5" style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height:1.05;" data-reveal data-reveal-delay="0.1">Giulia, 29 anni</h2>
            <p class="mm-panel-body" style="font-size: clamp(1.05rem, 1.35vw, 1.3rem);">
              Conosce Max Mara di nome. Non l'ha mai scelto. Per lei il guardaroba è racconto di sé, non status — e decide su Instagram molto prima di entrare in una boutique.
            </p>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Il problema → profili (split: testo + viz) ───── -->
    <Slide id="slide-datalake" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="mm-panel" data-reveal data-reveal-delay="0.15">
            <p class="mm-panel-tag" data-reveal>Il punto di partenza</p>
            <h2 class="mm-panel-head text-[var(--ink-primary)] mb-4" style="font-size: clamp(2rem, 3.4vw, 3.25rem); line-height:1.1;" data-reveal data-reveal-delay="0.1">
              Max Mara ha i dati. Non ancora le persone.
            </h2>
            <p class="mm-panel-body mb-4" style="font-size: clamp(1.15rem, 1.6vw, 1.5rem);" data-reveal data-reveal-delay="0.2">
              I dati vivono in un lago silenzioso, slegati. Real-Time CDP li ricompone in profili vivi: Giulia smette di essere un numero e diventa qualcuno da incontrare.
            </p>
            <p class="mm-panel-src" style="font-size: clamp(1.05rem,1.3vw,1.25rem); color: rgba(62,44,32,0.7);" data-reveal data-reveal-delay="0.28">Il CRM e i sistemi di oggi restano al loro posto: basta collegarli.</p>
          </div>
          <div class="mt-5" data-reveal data-reveal-delay="0.34">
          <HowItWorks title="Dal data lake ai profili">
          <p class="text-[clamp(0.95rem,1.05vw,1.1rem)] text-[var(--ink-secondary)] leading-snug">Oggi i dati di Max Mara vivono separati: e-commerce, CRM, punto vendita, campagne. <strong class="text-[var(--ink-primary)] font-semibold">Real-Time CDP</strong> li unifica in un unico profilo vivo per ogni cliente.</p>
          <p class="text-[clamp(0.95rem,1.05vw,1.1rem)] text-[var(--ink-secondary)] leading-snug">Non sostituisce i sistemi esistenti: li mette in dialogo, in tempo reale.</p>
          <p class="text-[clamp(0.95rem,1.05vw,1.1rem)] text-[var(--ink-secondary)] leading-snug">E permette di trovare nuove clienti simili a Giulia nel rispetto della privacy, collaborando con i dati dei partner in ambienti protetti.</p>
          </HowItWorks>
          </div>
        </div>

        <div class="relative h-full min-h-0 flex items-center justify-center" data-datalake>
          <!-- faint persistent data field (the silent lake) -->
          <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            {field.map((f) => (
              <span class="absolute w-1.5 h-1.5 rounded-full bg-[var(--accent-primary)]/20" style={`left:${f.x}%; top:${f.y}%;`} />
            ))}
          </div>
          <!-- converging dots (animate into the profiles) -->
          {dots.map((d) => (
            <div class="data-dot absolute left-1/2 top-1/2 w-3 h-3 md:w-3.5 md:h-3.5 rounded-full bg-[var(--accent-primary)]" data-dx={d.dx} data-dy={d.dy} />
          ))}
          <!-- emerged profiles -->
          <div class="relative flex flex-col items-center gap-8">
            <div class="flex items-center justify-center gap-10 md:gap-14">
              <div class="profile-circle flex flex-col items-center gap-3">
                <div class="w-28 h-28 md:w-40 md:h-40 rounded-full overflow-hidden relative bg-[var(--accent-primary)] shadow-xl ring-4 ring-[var(--surface-primary)]">
                  <MediaSlot {...mediaProps('persona-giulia')} fill noText="6,14,72,58" />
                </div>
                <span class="text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium text-[var(--ink-secondary)]">Giulia, 29</span>
              </div>
              <div class="profile-circle flex flex-col items-center gap-3">
                <div class="w-28 h-28 md:w-40 md:h-40 rounded-full overflow-hidden relative bg-[var(--accent-secondary)] shadow-xl ring-4 ring-[var(--surface-primary)]">
                  <MediaSlot {...mediaProps('francesca-volto')} fill noText="6,14,72,58" />
                </div>
                <span class="text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium text-[var(--ink-secondary)]">Francesca, 52</span>
              </div>
            </div>
            <span class="text-[clamp(1rem,1.2vw,1.2rem)] text-[var(--ink-tertiary)] tracking-wide">Profili unificati, in tempo reale</span>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Front stage — la scoperta ────────────────────── -->
    <Slide id="slide-frontstage" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left order-2 md:order-1">
          <div class="mm-panel max-w-xl" data-reveal data-reveal-delay="0.15">
            <div class="flex items-center gap-3" data-reveal>
              <span class="mm-node" style="width:2rem;height:2rem;font-size:0.95rem;" data-active>1</span>
              <span class="mm-panel-tag" style="letter-spacing:0.14em;">Ciò che vede Giulia</span>
            </div>
            <h2 class="mm-panel-head text-[var(--ink-primary)] mb-5" style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height:1.05;" data-reveal data-reveal-delay="0.1">La incontra dove già vive</h2>
            <p class="mm-panel-body" style="font-size: clamp(1.05rem, 1.35vw, 1.3rem);" data-reveal data-reveal-delay="0.2">
              La Whitney Bag appare nel suo feed. Per Giulia non è pubblicità: è il suo mondo, la sua estetica, la sua lingua. Si ferma. Tocca.
            </p>
          </div>
        </div>
        <div class="order-1 md:order-2 h-full flex items-center justify-center" data-reveal data-reveal-delay="0.3">
          <InstagramPost {...mediaProps('whitney-post')} caption="Whitney Bag. Dieci anni, senza tempo." />
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Front→back — l'aha ───────────────────────────── -->
    <Slide id="slide-impulse" bg="secondary" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-linen')} imageClass="opacity-20" scrim="bg-[var(--surface-secondary)]/78" />
      <p class="mm-panel-tag mb-5" style="letter-spacing:0.18em;" data-reveal>Dietro le quinte</p>
      <h2 class="slide-title text-[var(--ink-primary)] mb-7" style="font-size: clamp(2.25rem, 4.4vw, 4rem);" data-reveal data-reveal-delay="0.1">
        Quel tocco non si perde
      </h2>

      <div class="relative w-full max-w-[1200px] mx-auto grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-0 items-stretch" data-pulse-line>
        <div class="mm-panel flex flex-col justify-center" data-reveal>
          <p class="mm-panel-head text-[var(--ink-primary)]" style="font-size:clamp(1.3rem,1.9vw,1.9rem); line-height:1.15;">Giulia apre il post</p>
          <p class="mm-panel-body mt-1.5" style="font-size:clamp(1.15rem,1.4vw,1.4rem);">scopre la Whitney Bag</p>
        </div>

        <div class="hidden md:flex items-center justify-center px-6">
          <svg width="180" height="60" viewBox="0 0 180 60" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 0 30 L 150 30" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="166" cy="30" r="9" fill="currentColor" opacity="0"/>
          </svg>
        </div>
        <div class="flex md:hidden items-center justify-center py-1">
          <svg width="60" height="46" viewBox="0 0 60 46" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 30 0 L 30 34" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="30" cy="40" r="6" fill="currentColor" opacity="0"/>
          </svg>
        </div>

        <div class="rounded-[3px] p-7 md:p-9 text-[var(--ink-inverse)] flex flex-col justify-center" style="background:rgba(28,20,15,0.92); border:1px solid rgba(193,154,107,0.35); box-shadow:0 20px 48px -34px rgba(62,44,32,0.5);" data-reveal data-reveal-delay="0.3">
          <p class="font-[family-name:var(--font-display)] font-medium leading-tight" style="font-size:clamp(1.3rem,1.9vw,1.9rem); color:rgba(245,240,230,0.98);">La piattaforma risponde</p>
          <p class="mt-1.5" style="font-size:clamp(1.15rem,1.4vw,1.4rem); color:rgba(193,154,107,0.95);">la riconosce e adatta tutto</p>
        </div>
      </div>

      <div class="mm-panel max-w-4xl mx-auto mt-8 text-left" data-reveal data-reveal-delay="0.4">
        <p class="mm-panel-body" style="font-size: clamp(1.1rem, 1.5vw, 1.4rem);">
          Quando Giulia tocca la Whitney Bag, la piattaforma la riconosce come nuova visitatrice, capisce cosa la incuriosisce e ricompone l'esperienza intorno a lei: immagini, suggerimenti, tono. Succede in tempo reale, senza che se ne accorga, e quel gesto di curiosità diventa l'inizio di una relazione.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 6: Come — prodotti in contesto (non lista) ──────── -->
    <Slide id="slide-come" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-wool')} imageClass="opacity-35" scrim="bg-[var(--surface-inverse)]/72" />
      <div class="flex items-center gap-3 mb-5" data-reveal>
        <span class="mm-node" style="width:2rem;height:2rem;font-size:0.95rem;background:rgba(193,154,107,0.2);border-color:rgba(193,154,107,0.6);color:rgba(245,240,230,0.95);" data-active>1</span>
        <span class="slide-eyebrow text-[var(--color-grigio-300)]">CIÒ CHE FA LA PIATTAFORMA</span>
      </div>
      <h2 class="slide-title text-[var(--ink-inverse)] mb-9" style="font-size: clamp(2.25rem, 4.4vw, 4rem);" data-reveal data-reveal-delay="0.1">
        Parlarle la sua lingua
      </h2>

      <div class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-6 text-left" data-stagger="0.25">
        <div class="mm-panel">
          <p class="mm-panel-body" style="font-size:clamp(1.2rem,1.7vw,1.65rem); line-height:1.4; color:rgba(245,240,230,0.92);">
            Contenuti su misura, alla velocità dei social: i team interni li creano e li declinano con <strong class="font-semibold text-[var(--accent-secondary)]">GenStudio</strong> e <strong class="font-semibold text-[var(--accent-secondary)]">Firefly</strong>, senza attendere l'agenzia.
          </p>
        </div>
        <div class="mm-panel">
          <p class="mm-panel-body" style="font-size:clamp(1.2rem,1.7vw,1.65rem); line-height:1.4; color:rgba(245,240,230,0.92);">
            E ogni nuova cliente come Giulia diventa una traccia: <strong class="font-semibold text-[var(--accent-secondary)]">Real-Time CDP</strong> costruisce pubblici simili alle migliori, nel rispetto della privacy.
          </p>
        </div>
      </div>

      <div class="mt-9" data-reveal data-reveal-delay="0.5">
        <HowItWorks title="Contenuti on-brand, sempre" tone="onDark">
          <p class="text-[clamp(1rem,1.25vw,1.2rem)] text-[var(--ink-inverse)] leading-snug">I social chiedono contenuti continui. <strong class="text-[var(--accent-secondary)] font-semibold">GenStudio</strong> permette ai team interni di creare e declinare campagne fedeli al brand, senza i tempi dell'agenzia.</p>
          <p class="text-[clamp(1rem,1.25vw,1.2rem)] text-[var(--ink-inverse)] leading-snug"><strong class="text-[var(--accent-secondary)] font-semibold">Firefly</strong> genera immagini sicure per l'uso commerciale, addestrato su contenuti licenziati: nessun rischio di copyright.</p>
          <p class="text-[clamp(1rem,1.25vw,1.2rem)] text-[var(--ink-inverse)] leading-snug">Insieme formano una linea di produzione dei contenuti: dal brief alla pubblicazione, senza che il brand perda il controllo.</p>
        </HowItWorks>
      </div>
    </Slide>

    <!-- ── SLIDE 6b: Nel frattempo — Francesca (il filo) ─────────── -->
    <Slide id="slide-francesca" bg="secondary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-[1fr_0.85fr] gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="mm-panel max-w-xl" data-reveal data-reveal-delay="0.15">
            <p class="mm-panel-tag" data-reveal>Nel frattempo</p>
            <h2 class="mm-panel-head text-[var(--ink-primary)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem); line-height:1.08;" data-reveal data-reveal-delay="0.1">Francesca sceglie Max Mara da vent'anni</h2>
            <p class="mm-panel-body" style="font-size: clamp(1.05rem, 1.35vw, 1.3rem);" data-reveal data-reveal-delay="0.2">
              La stessa attenzione che conquista Giulia oggi è ciò che ha tenuto Francesca vicina nel tempo. Acquisire e fidelizzare sono la stessa relazione, in due momenti diversi.
            </p>
          </div>
        </div>
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.25">
          <div class="relative h-full max-h-[70vh] aspect-[4/5] rounded-lg overflow-hidden shadow-xl bg-[var(--accent-secondary)] mx-auto">
            <MediaSlot {...mediaProps('francesca-ritratto')} fill noText="6,24,52,40" />
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 7: Payoff + filo ────────────────────────────────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />
      <p data-display class="font-[family-name:var(--font-display)] font-light leading-none text-[var(--ink-primary)] mb-8" style="font-size: clamp(3.5rem, 8vw, 7.5rem); letter-spacing:-0.01em;">tre quarti</p>
      <p class="text-[clamp(1.5rem,2.4vw,2.25rem)] font-[family-name:var(--font-display)] font-normal text-[var(--ink-primary)] leading-snug mb-6 max-w-3xl" data-reveal data-reveal-delay="0.2">
        Oggi i Millennial sono già quasi metà del mercato del lusso. Entro il 2030, con la Gen Z, ne guideranno oltre tre quarti.
      </p>
      <p class="text-[clamp(1.1rem,1.35vw,1.3rem)] text-[var(--ink-primary)]/70 mb-14" data-reveal data-reveal-delay="0.28">
        Fonte: Bain &amp; Company · Altagamma, Luxury Goods Worldwide Market Study
      </p>

      <div class="mm-quote max-w-3xl mx-auto text-center [&::before]:left-1/2 [&::before]:-translate-x-1/2 pt-9" data-reveal data-reveal-delay="0.36">
        <p class="mm-quote-text" style="font-style:normal; color:rgba(62,44,32,0.95); font-size:clamp(1.3rem,1.9vw,1.75rem); line-height:1.3;">
          Giulia è entrata nel mondo Max Mara. Adesso l'obiettivo non è venderle qualcosa: è iniziare una relazione.
        </p>
      </div>

      <div class="mt-12" data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/engagement')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
        >
          Segue · L'incontro
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
