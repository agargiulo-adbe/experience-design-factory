---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import NarrativeSection from '@edf/core/blocks/NarrativeSection.astro';
import AdobeStackReveal from '@edf/core/blocks/AdobeStackReveal.astro';
---
<BaseLayout title="Il Motore Adobe" description="L'architettura Adobe che trasforma un data lake silente in relazioni conosciute e durature.">
  <PageLayout title="Il Motore Adobe">
    <NarrativeSection
      eyebrow="L'architettura"
      title="Da data lake a relazioni"
      body="<p>Max Mara possiede dati — ma non ancora un tessuto connettivo che li renda azionabili. Adobe Experience Platform è quel tessuto: unifica i dati da ogni fonte (e-commerce, CRM, punto vendita, campagne, app) in profili real-time che i team possono usare immediatamente.</p><p>Non si tratta di sostituire ciò che funziona — CRM, ERP, le competenze delle agenzie — ma di completare il quadro. Real-Time CDP trasforma il data lake in audience pronte all'azione; Journey Optimizer orchestra le comunicazioni; Customer Journey Analytics misura tutto, cross-channel. Adobe potenzia l'ecosistema esistente, non lo sostituisce.</p>"
    />

    <AdobeStackReveal
      title="La piattaforma, fase per fase"
      body="Ogni fase del percorso cliente è supportata da prodotti Adobe specifici. Al centro, Adobe Experience Platform e Real-Time CDP unificano i dati e abilitano l'azione in tempo reale."
      phases={[
        {
          phaseId: 'core',
          label: 'Cuore — Trasversale',
          products: [
            { id: 'aep', name: 'Adobe Experience Platform', claim: 'La base dati unificata: raccoglie, normalizza e attiva i dati da ogni fonte in profili real-time' },
            { id: 'rtcdp', name: 'Real-Time CDP', claim: 'Profili cliente unificati e audience azionabili — dal data lake ai canali, in tempo reale' },
            { id: 'ai-assistant', name: 'AI Assistant', claim: 'Intelligenza artificiale integrata per analisi conversazionali, automazione e insight immediati' },
            { id: 'agent-orchestrator', name: 'Agent Orchestrator', claim: 'Orchestrazione di agenti AI per automatizzare workflow complessi end-to-end' },
          ],
        },
        {
          phaseId: 'acquisizione',
          label: 'Acquisizione',
          products: [
            { id: 'genstudio', name: 'GenStudio for Performance Marketing', claim: 'Creatività on-brand a scala — i team interni producono varianti senza dipendere dai tempi d\'agenzia' },
            { id: 'firefly', name: 'Adobe Firefly', claim: 'Generazione di immagini e contenuti con AI, sicuri per uso commerciale' },
            { id: 'express', name: 'Adobe Express', claim: 'Creazione rapida di contenuti on-brand per ogni team, senza necessità di designer' },
            { id: 'cja', name: 'Customer Journey Analytics', claim: 'Analisi cross-channel per ottimizzare il mix di acquisizione' },
            { id: 'mix-modeler', name: 'Mix Modeler', claim: 'Ottimizzazione del media mix con AI per massimizzare il ROI' },
          ],
        },
        {
          phaseId: 'engagement',
          label: 'Engagement',
          products: [
            { id: 'aem-sites', name: 'AEM Sites', claim: 'Storytelling digitale personalizzato su ogni canale' },
            { id: 'target', name: 'Adobe Target', claim: 'Personalizzazione e test A/B in tempo reale' },
            { id: 'commerce', name: 'Adobe Commerce', claim: 'Commercio digitale seamless, dal contenuto al carrello' },
          ],
        },
        {
          phaseId: 'conversione',
          label: 'Conversione',
          products: [
            { id: 'journey-optimizer', name: 'Journey Optimizer', claim: 'Orchestrazione multicanale real-time — dal trigger all\'azione' },
            { id: 'brand-concierge', name: 'Brand Concierge', claim: 'Assistenza conversazionale AI per scoperta prodotto e shopping personalizzato' },
          ],
        },
        {
          phaseId: 'loyalty',
          label: 'Loyalty & LTV',
          products: [
            { id: 'journey-optimizer', name: 'Journey Optimizer', claim: 'Journey lifecycle: dal welcome al re-engagement, orchestrazione continua' },
            { id: 'rtcdp', name: 'Real-Time CDP', claim: 'Segmentazione RFM, predizione churn, profilo unificato cross-canale' },
            { id: 'cja', name: 'Customer Journey Analytics', claim: 'Analisi LTV, coorti, attribuzione — per misurare il valore reale di ogni relazione' },
          ],
        },
        {
          phaseId: 'operations',
          label: 'Operations & Content Supply Chain',
          products: [
            { id: 'workfront', name: 'Workfront', claim: 'Gestione del lavoro e orchestrazione della content supply chain — potenzia le agenzie, non le sostituisce' },
            { id: 'genstudio', name: 'GenStudio for Performance Marketing', claim: 'Il ponte tra creatività e performance: dal brief alla pubblicazione, con governance del brand' },
          ],
        },
      ]}
    />
  </PageLayout>
</BaseLayout>
