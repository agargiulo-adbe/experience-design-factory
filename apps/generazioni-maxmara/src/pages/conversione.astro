---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import JourneyPhase from '@edf/core/blocks/JourneyPhase.astro';
import FrontBackStageSplit from '@edf/core/blocks/FrontBackStageSplit.astro';
import MetricCallout from '@edf/core/blocks/MetricCallout.astro';
---
<BaseLayout title="Conversione" description="Dal desiderio all'acquisto: rimuovere ogni attrito nel percorso verso la prima transazione.">
  <PageLayout title="Conversione">
    <JourneyPhase
      phaseNumber={3}
      phaseId="conversione"
      title="Dal desiderio all'acquisto"
      subtitle="Fase 3 — Conversione"
      body="<p>Il momento della conversione non è un punto — è un percorso. Una cliente che ha esplorato, sfogliato, aggiunto al carrello, ma non ha ancora comprato. Il rischio più grande non è il prezzo: è l'attrito. Un'esperienza frammentata, un messaggio sbagliato, un canale che non riconosce ciò che è successo sull'altro.</p><p>La conversione nel luxury richiede un equilibrio sottile: accompagnare senza pressare, essere presenti senza essere invadenti, personalizzare senza risultare inquietanti.</p>"
    />

    <FrontBackStageSplit
      phaseId="conversione"
      phaseLabel="Conversione — Front stage / Back stage"
      customerTitle="Un accompagnamento discreto"
      customerBody="<p>Giulia ha aggiunto una Whitney Bag al carrello tre giorni fa. Non riceve un'email aggressiva con un countdown — riceve un messaggio curato che le racconta la storia della borsa, i materiali, l'artigianato. Pochi giorni dopo, visitando il negozio in Corso Venezia, la store advisor sa già cosa le interessa e può completare l'esperienza.</p>"
      adobeStack={[
        { id: 'journey-optimizer', name: 'Journey Optimizer', claim: 'Orchestrazione in tempo reale: il messaggio giusto, nel momento giusto, sul canale giusto — trigger automatici da browse e carrello abbandonato' },
        { id: 'target', name: 'Adobe Target', claim: 'Raccomandazioni personalizzate basate sul comportamento reale, non su regole statiche' },
        { id: 'commerce', name: 'Adobe Commerce', claim: 'Checkout seamless cross-device: il carrello la segue dal mobile al desktop al negozio' },
        { id: 'brand-concierge', name: 'Brand Concierge', claim: 'Assistenza conversazionale AI: la cliente può chiedere consigli, taglie, abbinamenti — come avere una personal shopper sempre disponibile' },
      ]}
    />

    <MetricCallout
      value="3×"
      label="Il tasso di conversione quando l'esperienza è coerente tra canali digitali e punto vendita"
      context="L'omnicanalità non è un lusso tecnologico — è il modo naturale in cui le clienti si muovono."
    />
  </PageLayout>
</BaseLayout>
