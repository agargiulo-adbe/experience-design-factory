---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import HowItWorks from '@edf/core/blocks/HowItWorks.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

// The four journey moments — node 3 (Scegliere) is active on this stage.
const moments = [
  { n: '1', label: 'Incontrare' },
  { n: '2', label: 'Conoscere' },
  { n: '3', label: 'Scegliere' },
  { n: '4', label: 'Restare' },
];

// Conversational discovery — the Brand Concierge is the Adobe AI assistant (not a human).
const chat = [
  { side: 'in', who: 'Giulia', ai: false, text: 'Ho messo nel carrello la Whitney Bag, ma sto ancora pensando…' },
  { side: 'out', who: 'Assistente Max Mara', ai: true, text: 'Pelle martellata, lavorata a mano. Se ti va, ti racconto la storia del modello.' },
  { side: 'in', who: 'Giulia', ai: false, text: 'Sì. E sta bene con un look da ufficio?' },
  { side: 'out', who: 'Assistente Max Mara', ai: true, text: 'Dal lunedì al weekend. Se vuoi, in Corso Venezia te la tengono da parte.' },
];

const adobe = [
  { code: 'JO', name: 'Journey Optimizer', claim: 'Orchestrazione in tempo reale: il messaggio giusto, nel momento giusto, sul canale giusto, con trigger da browse e carrello abbandonato' },
  { code: 'Tgt', name: 'Adobe Target', claim: 'Raccomandazioni personalizzate che seguono il comportamento reale, non regole statiche' },
  { code: 'Com', name: 'Adobe Commerce', claim: 'Checkout continuo tra dispositivi: il carrello la segue dal mobile al desktop al negozio' },
  { code: 'BC', name: 'Brand Concierge', claim: 'L\'assistente non è un umano: è l\'AI conversazionale di Adobe (Product Advisor Agent su Agent Orchestrator), addestrata sul catalogo e sulla voce del brand, e dà consigli, taglie e abbinamenti sul canale, in quel momento' },
];
---
<BaseLayout title="Conversione" description="Dal desiderio all'acquisto: rimuovere ogni attrito nel percorso verso la prima transazione.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <DeckContainer nextHref={href(base, '/loyalty')} prevHref={href(base, '/engagement')}>

    <!-- ── SLIDE 0: Apertura fase ────────────────────────────────── -->
    <Slide id="slide-apertura" bg="secondary" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-25" scrim="bg-[var(--surface-secondary)]/70" />
      <div slot="backdrop" class="mm-weave" aria-hidden="true"></div>

      <div class="flex flex-col items-center">
        <CoverHero eyebrow="FASE 3 · CONVERSIONE" numeral="03" title="Dal desiderio all'acquisto" lead="Il rischio più grande non è il prezzo: è l'attrito. Accompagnare senza pressare." signature={false} />

        <!-- il filo di seta: terzo nodo del percorso (Scegliere) -->
        <div class="mm-thread relative w-full max-w-3xl mt-12" data-reveal data-reveal-delay="0.4" aria-hidden="true">
          <span class="mm-thread-line left-[8%] right-[8%] top-[1.375rem]"></span>
          <div class="grid grid-cols-4 gap-2">
            {moments.map((m) => (
              <div class="relative flex flex-col items-center gap-3">
                <span class="mm-node" data-active={m.n === '3' ? '' : undefined}>{m.n}</span>
                <span class:list={["mm-node-label", m.n === '3' && "text-[var(--ink-primary)]"]}>{m.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: Scoperta conversazionale (il meccanismo) ─────── -->
    <Slide id="slide-converse" bg="primary" align="center">
      <div slot="backdrop" class="mm-bg-soft" aria-hidden="true"></div>

      <div class="w-full max-w-3xl mx-auto flex flex-col items-center">
        <p class="mm-panel-tag mb-3" data-reveal>IL MECCANISMO</p>
        <h2 class="mm-panel-head text-[var(--ink-primary)] mb-5 text-center" style="font-size: clamp(2rem, 3.6vw, 3.4rem); line-height:1.08;" data-reveal data-reveal-delay="0.1">
          Una conversazione, non una pressione
        </h2>

        <!-- Context: canale · momento + natura AI esplicita -->
        <div class="w-full mb-5 flex items-center justify-center gap-2.5 flex-wrap" data-reveal data-reveal-delay="0.15">
          <span class="inline-flex items-center gap-2 text-[0.82rem] text-[var(--ink-secondary)] px-3.5 py-1 rounded-full bg-[var(--surface-secondary)] border border-[var(--line-subtle)]">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="6" y="2" width="12" height="20" rx="3"/><path d="M11 19h2"/></svg>
            App Max Mara · mentre Giulia esita sul carrello
          </span>
          <span class="inline-flex items-center gap-1.5 text-[0.8rem] font-medium text-[var(--accent-primary)] px-3 py-1 rounded-full bg-[var(--accent-primary)]/12">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.6 5.4L19 9l-5.4 1.6L12 16l-1.6-5.4L5 9l5.4-1.6z"/></svg>
            Assistente AI, non un umano
          </span>
        </div>

        <!-- Converse: chat bubbles appear one by one (deck-animated) -->
        <div class="mm-panel w-full" data-reveal data-reveal-delay="0.2">
          <div class="flex flex-col gap-2.5 w-full" data-converse>
            {chat.map((m) => (
              <div
                class:list={[
                  "chat-bubble max-w-[80%] px-5 py-2.5 rounded-2xl text-left",
                  m.side === 'in'
                    ? "self-end bg-[var(--accent-primary)] text-white rounded-br-sm shadow-sm"
                    : "self-start bg-[var(--surface-secondary)] text-[var(--ink-primary)] border border-[var(--line-subtle)] rounded-bl-sm",
                ]}
                data-side={m.side}
              >
                <span class:list={["flex items-center gap-1.5 text-[0.64rem] tracking-[0.08em] uppercase mb-0.5", m.side === 'in' ? "text-white/70" : "text-[var(--ink-tertiary)]"]}>
                  {m.who}
                  {m.ai && (
                    <span class="inline-flex items-center gap-1 normal-case tracking-normal text-[var(--accent-primary)] font-semibold">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.6 5.4L19 9l-5.4 1.6L12 16l-1.6-5.4L5 9l5.4-1.6z"/></svg>AI
                    </span>
                  )}
                </span>
                <p class="text-[clamp(0.95rem,0.98vw,1.08rem)] leading-relaxed">{m.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Front stage — il carrello (mockup reale) ─────── -->
    <Slide id="slide-frontstage" bg="primary" align="split">
      <div slot="backdrop" class="mm-bg" aria-hidden="true"></div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="text-left">
          <div class="mm-panel max-w-xl" data-reveal data-reveal-delay="0.1">
            <p class="mm-panel-tag" data-reveal>Ciò che vive la cliente</p>
            <h2 class="mm-panel-head text-[var(--ink-primary)] mb-6" style="font-size: clamp(2.25rem, 4.2vw, 3.75rem); line-height:1.06;" data-reveal data-reveal-delay="0.1">Un accompagnamento discreto</h2>
            <p class="mm-panel-body" style="font-size: clamp(1.05rem, 1.35vw, 1.3rem);" data-reveal data-reveal-delay="0.2">
              Niente email aggressive con countdown. Giulia riceve un messaggio curato sulla storia della borsa. Pochi giorni dopo, in Corso Venezia, la store advisor sa già cosa le interessa.
            </p>
          </div>
        </div>

        <!-- phone with a REAL leather photo -->
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.3">
          <div class="ig-phone relative mx-auto w-full max-w-[300px] max-h-[calc(100dvh-200px)] flex flex-col overflow-hidden rounded-[2.2rem] border-[5px] border-[var(--surface-inverse)] bg-[var(--surface-inverse)] shadow-2xl">
            <div class="flex flex-col min-h-0 bg-[var(--surface-primary)] rounded-[1.7rem] overflow-hidden">
              <div class="flex items-center justify-center pt-2 pb-1.5">
                <span class="w-16 h-1.5 rounded-full bg-[var(--ink-tertiary)]/25"></span>
              </div>
              <div class="relative w-full aspect-[4/5] overflow-hidden bg-[var(--surface-secondary)] flex-shrink-0">
                <MediaSlot {...mediaProps('conversione-pelle')} fill noText="0,0,0,0" />
              </div>
              <div class="px-4 py-4 text-left">
                <p class="text-[0.7rem] tracking-[0.12em] uppercase text-[var(--accent-primary)] mb-1.5">Nel carrello</p>
                <p class="text-[0.98rem] font-medium text-[var(--ink-primary)] leading-snug">Whitney Bag — pelle martellata</p>
                <p class="text-[0.8rem] text-[var(--ink-tertiary)] mt-2 inline-flex items-center gap-1.5">La storia del modello <span class="text-[var(--accent-primary)]">→</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Front→Back impulse (l'aha) ───────────────────── -->
    <Slide id="slide-impulse" bg="secondary" align="center">
      <div slot="backdrop" class="mm-weave" aria-hidden="true"></div>

      <h2 class="mm-panel-head text-[var(--ink-primary)] mb-10 text-center" style="font-size: clamp(2rem, 3.8vw, 3.4rem); line-height:1.08;" data-reveal>
        Dal carrello al negozio, senza salti
      </h2>

      <div class="relative w-full max-w-[1100px] mx-auto grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-0 items-stretch min-h-[30vh]" data-pulse-line>
        <div class="mm-panel flex flex-col justify-between text-left" data-reveal>
          <p class="mm-panel-tag flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
            In scena
          </p>
          <div>
            <p class="mm-panel-figure" style="font-size: clamp(1.3rem,1.9vw,1.85rem);">La cliente esita</p>
            <p class="mm-panel-body mt-2" style="font-size: clamp(1.05rem,1.3vw,1.3rem);">Aggiunge al carrello, non conclude</p>
          </div>
        </div>

        <div class="hidden md:flex items-center justify-center px-6">
          <svg width="180" height="60" viewBox="0 0 180 60" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 0 30 L 150 30" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="166" cy="30" r="9" fill="currentColor" opacity="0"/>
          </svg>
        </div>
        <div class="flex md:hidden items-center justify-center py-1">
          <svg width="60" height="46" viewBox="0 0 60 46" class="text-[var(--accent-primary)]">
            <path class="pulse-path" d="M 30 0 L 30 34" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle class="pulse-dot" cx="30" cy="40" r="6" fill="currentColor" opacity="0"/>
          </svg>
        </div>

        <div class="mm-panel mm-panel--acqua flex flex-col justify-between text-left" style="background: rgba(28,20,15,0.92); border-color: rgba(245,240,230,0.16);" data-reveal data-reveal-delay="0.3">
          <p class="mm-panel-tag flex items-center gap-2 mb-3" style="color: rgba(245,240,230,0.6);">
            <span class="w-2 h-2 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
            Dietro le quinte
          </p>
          <div>
            <p class="mm-panel-figure" style="font-size: clamp(1.3rem,1.9vw,1.85rem); color: rgba(245,240,230,0.98);">La piattaforma accompagna</p>
            <p class="mm-panel-body mt-2" style="font-size: clamp(1.05rem,1.3vw,1.3rem); color: rgba(245,240,230,0.82);">Trigger curato, carrello che segue, advisor informata</p>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Back stage — i prodotti Adobe in "Scopri come" ── -->
    <Slide id="slide-backstage" bg="inverse" align="center">
      <div slot="backdrop" class="mm-bg" aria-hidden="true"></div>

      <div class="flex items-center gap-3 mb-5" data-reveal>
        <span class="w-3.5 h-3.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
        <span class="mm-panel-tag" style="color: rgba(245,240,230,0.7);">CIÒ CHE FA LA PIATTAFORMA</span>
      </div>
      <h2 class="mm-panel-head text-[var(--ink-inverse)] mb-9 text-center" style="font-size: clamp(2.25rem, 4.2vw, 3.75rem); line-height:1.06;" data-reveal data-reveal-delay="0.1">
        Quattro prodotti, zero attrito
      </h2>

      <div class="w-full max-w-3xl mx-auto flex flex-col gap-5 text-left" data-stagger="0.25">
        <div class="mm-quote">
          <p class="mm-quote-text" style="font-size: clamp(1.35rem,2vw,2rem);">
            Il messaggio giusto, nel momento giusto, sul canale giusto: dal browse al carrello abbandonato.
          </p>
        </div>
        <div class="mm-quote">
          <p class="mm-quote-text" style="font-size: clamp(1.35rem,2vw,2rem);">
            L'assistente che risponde è AI, non un umano: parla la lingua del brand, addestrato sul catalogo.
          </p>
        </div>
      </div>

      <div class="mt-9" data-reveal data-reveal-delay="0.5">
        <HowItWorks title="Quattro prodotti, zero attrito" tone="onDark">
          {adobe.map((p) => (
            <p class="text-[clamp(0.98rem,1.25vw,1.2rem)] text-[var(--ink-inverse)] leading-snug"><strong class="text-[var(--accent-secondary)] font-semibold">{p.name}</strong> — {p.claim}.</p>
          ))}
        </HowItWorks>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Payoff — metrica + CTA ───────────────────────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />
      <p data-display class="mm-stat-value font-light text-[var(--ink-primary)] mb-6" style="font-size: clamp(4.5rem, 12vw, 11rem); line-height:0.95;">
        <span data-count-up="3" data-count-suffix="×">0×</span>
      </p>
      <p class="mm-quote-text not-italic text-[var(--ink-primary)] mb-5 max-w-3xl" style="font-size: clamp(1.5rem,2.4vw,2.25rem); line-height:1.3;" data-reveal data-reveal-delay="0.2">
        il tasso di conversione quando l'esperienza è coerente tra digitale e punto vendita
      </p>
      <p class="mm-panel-body text-[var(--ink-primary)]/70 mb-8" style="font-size: clamp(1.1rem,1.35vw,1.3rem);" data-reveal data-reveal-delay="0.28">
        L'omnicanalità è il modo naturale in cui le clienti si muovono
      </p>

      <p class="mm-quote-text not-italic text-[var(--ink-primary)] max-w-3xl border-t border-[var(--ink-primary)]/25 pt-7 mb-10" style="font-size: clamp(1.15rem,1.6vw,1.5rem); line-height:1.4;" data-reveal data-reveal-delay="0.36">
        Senza attrito per Giulia oggi, come lo è stato per Francesca in vent'anni.
      </p>

      <div data-reveal data-reveal-delay="0.5">
        <a
          href={href(base, '/loyalty')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
        >
          Continua · Loyalty
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
