---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import PersonaCard from '@edf/core/blocks/PersonaCard.astro';
import NarrativeSection from '@edf/core/blocks/NarrativeSection.astro';
---
<BaseLayout title="La Persona" description="Giulia e Francesca: due generazioni, un solo brand. Il percorso dalla scoperta alla fedeltà.">
  <PageLayout title="La Persona">
    <NarrativeSection
      eyebrow="Le protagoniste"
      title="Due donne, un filo che le unisce"
      body="<p>Ogni strategia ha bisogno di volti. Giulia e Francesca non sono statistiche — sono le due generazioni che Max Mara deve unire in un unico disegno. La prima scopre il brand dai pezzi d'ingresso; la seconda è il brand. Insieme, raccontano perché allungare il ciclo di vita è la strategia più potente che esista.</p>"
    />

    <PersonaCard
      name="Giulia"
      age={29}
      location="Milano"
      title="La nuova generazione"
      story="<p>Giulia è una product manager in una tech company milanese. Non segue i trend — cerca pezzi che durino. Ha scoperto Max Mara attraverso una borsa Monogram vista su Instagram, non attraverso il cappotto cammello delle sue colleghe più senior.</p><p>Per Giulia, il lusso è qualità senza ostentazione. Non cerca il logo grande — cerca il materiale perfetto, il taglio che funziona dal lunedì alla domenica. Si informa online, confronta, legge recensioni. Compra quando è convinta, non quando è pressata.</p><p>Il suo percorso ideale: scoprire il brand dai pezzi d'ingresso, sentirsi riconosciuta e non trattata come un numero, scoprire gradualmente il mondo Max Mara — fino al giorno in cui il cappotto cammello diventa il suo.</p>"
      variant="primary"
    />

    <PersonaCard
      name="Francesca"
      age={52}
      location="Bologna"
      title="La cliente storica"
      story="<p>Francesca è avvocata, madre di due figlie. Il suo primo Max Mara l'ha comprato a trent'anni — un Manuela che porta ancora oggi. Da allora, il brand è parte del suo guardaroba e della sua identità.</p><p>Francesca non ha bisogno di essere convinta: ha bisogno di sentirsi speciale. Vuole che il negozio la conosca, che le proposte siano pensate per lei, che le novità le arrivino prima degli altri. Il suo valore per il brand è enorme — ma solo se il brand continua a meritare la sua fedeltà.</p><p>Il suo percorso ideale: essere riconosciuta ovunque — online e in negozio —, ricevere inviti esclusivi, vivere il brand come una relazione, non come una transazione. E forse, un giorno, portare sua figlia in boutique.</p>"
      variant="secondary"
    />
  </PageLayout>
</BaseLayout>
