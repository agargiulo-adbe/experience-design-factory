---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

const recognition = [
  'Giulia · scopre da social, compra online',
  'Francesca · fedele da 20 anni, acquista in store',
  'Stessa vista: preferenze, storia, valore nel tempo',
  'Ogni canale parla la lingua giusta per ciascuna',
];
---
<BaseLayout title="La Persona" description="Giulia e Francesca: due generazioni, un solo brand. Il percorso dalla scoperta alla fedeltà.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <DeckContainer nextHref={href(base, '/chiusura')} prevHref={href(base, '/motore-adobe')}>

    <!-- ── SLIDE 0: Apertura ─────────────────────────────────────── -->
    <Slide id="slide-apertura" bg="secondary" align="center">
      <div slot="backdrop" class="absolute inset-0">
        <SlideBackdrop {...mediaProps('bg-linen')} imageClass="opacity-20" scrim="bg-[var(--surface-secondary)]/74" />
        <div class="mm-bg" aria-hidden="true"></div>
        <div class="mm-weave" aria-hidden="true"></div>
      </div>
      <CoverHero eyebrow="LE PROTAGONISTE" title="Due donne, un filo che le unisce" lead="Giulia e Francesca non sono statistiche: sono le due generazioni che Max Mara deve tenere insieme." />
    </Slide>

    <!-- ── SLIDE 1: Il filo (thread) ─────────────────────────────── -->
    <Slide id="slide-filo" bg="primary" align="center">
      <div slot="backdrop" class="absolute inset-0">
        <div class="mm-bg" aria-hidden="true"></div>
        <div class="mm-weave" aria-hidden="true"></div>
      </div>

      <div class="w-full max-w-4xl mx-auto text-center">
        <p class="mm-panel-tag mb-4" data-reveal>Il legame</p>
        <h2 class="text-[var(--ink-primary)] font-[family-name:var(--font-display)] font-normal mb-14" style="font-size: clamp(2rem, 3.6vw, 3.4rem); line-height: 1.1;" data-reveal data-reveal-delay="0.1">
          Dalla prima scoperta alla fedeltà di una vita
        </h2>

        <div class="mm-thread relative w-full" data-thread>
          <svg class="absolute inset-0 w-full h-full overflow-visible" viewBox="0 0 400 100" fill="none" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
            <path class="thread-path" d="M60 50 C 160 8, 240 92, 340 50" stroke="rgba(193,154,107,0.85)" stroke-width="1" stroke-linecap="round"/>
          </svg>
          <div class="relative flex items-center justify-between px-2 md:px-12 py-4">
            <div class="thread-node flex flex-col items-center gap-3">
              <div class="w-24 h-24 md:w-28 md:h-28 rounded-full overflow-hidden relative bg-[var(--accent-primary)] ring-1 ring-[rgba(193,154,107,0.6)] shadow-[0_18px_40px_-28px_rgba(62,44,32,0.6)]">
                <MediaSlot {...mediaProps('persona-giulia')} fill noText="0,0,0,0" />
              </div>
              <span class="font-[family-name:var(--font-display)] text-[clamp(1.1rem,1.3vw,1.35rem)] text-[var(--ink-primary)]">Giulia, 29</span>
              <span class="mm-node-label">Milano</span>
            </div>
            <div class="thread-node flex flex-col items-center gap-3">
              <div class="w-24 h-24 md:w-28 md:h-28 rounded-full overflow-hidden relative bg-[var(--accent-secondary)] ring-1 ring-[rgba(193,154,107,0.6)] shadow-[0_18px_40px_-28px_rgba(62,44,32,0.6)]">
                <MediaSlot {...mediaProps('francesca-volto')} fill noText="0,0,0,0" />
              </div>
              <span class="font-[family-name:var(--font-display)] text-[clamp(1.1rem,1.3vw,1.35rem)] text-[var(--ink-primary)]">Francesca, 52</span>
              <span class="mm-node-label">Bologna</span>
            </div>
          </div>
        </div>

        <p class="mm-card-body mx-auto max-w-2xl mt-14 text-[1.02rem]" data-reveal data-reveal-delay="0.3">
          La prima scopre il brand dai pezzi d'ingresso; la seconda è il brand. Il valore che cresce nel tempo le unisce.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Giulia — la nuova generazione ────────────────── -->
    <Slide id="slide-giulia" bg="primary" align="split">
      <div slot="backdrop" class="absolute inset-0">
        <div class="mm-bg-soft" aria-hidden="true"></div>
      </div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-[0.82fr_1fr] gap-10 md:gap-16 items-center">
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.15">
          <div class="relative h-full max-h-[64vh] aspect-[4/5] overflow-hidden rounded-[2px] shadow-[0_30px_70px_-40px_rgba(62,44,32,0.6)] bg-[var(--accent-primary)] mx-auto ring-1 ring-[rgba(62,44,32,0.08)]">
            <MediaSlot {...mediaProps('persona-giulia')} fill noText="4,12,76,64" />
          </div>
        </div>
        <div class="mm-panel text-left">
          <p class="mm-panel-tag" data-reveal>La nuova generazione</p>
          <h2 class="mm-panel-head mt-1.5" style="font-size: clamp(2.1rem, 4vw, 3.2rem);" data-reveal data-reveal-delay="0.1">Giulia, 29</h2>
          <p class="mm-panel-src mt-2 mb-6 text-[0.95rem] tracking-[0.02em]" data-reveal data-reveal-delay="0.16">Product manager · Milano</p>
          <p class="mm-panel-body text-[1.05rem] mb-4" data-reveal data-reveal-delay="0.2">
            Non segue i trend: cerca pezzi che durino. Ha scoperto Max Mara da una borsa Monogram su Instagram, non dal cappotto cammello delle colleghe più senior.
          </p>
          <p class="mm-panel-body text-[1.05rem]" data-reveal data-reveal-delay="0.28">
            Per lei il lusso è qualità senza ostentazione. Si informa, confronta e compra quando è convinta, non quando è pressata.
          </p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Francesca — la cliente storica ───────────────── -->
    <Slide id="slide-francesca" bg="secondary" align="split">
      <div slot="backdrop" class="absolute inset-0">
        <div class="mm-bg-soft" aria-hidden="true"></div>
      </div>
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-[1fr_0.82fr] gap-10 md:gap-16 items-center">
        <div class="mm-panel mm-panel--acqua text-left">
          <p class="mm-panel-tag" data-reveal>La cliente storica</p>
          <h2 class="mm-panel-head mt-1.5" style="font-size: clamp(2.1rem, 4vw, 3.2rem);" data-reveal data-reveal-delay="0.1">Francesca, 52</h2>
          <p class="mm-panel-src mt-2 mb-6 text-[0.95rem] tracking-[0.02em]" data-reveal data-reveal-delay="0.16">Avvocata · Bologna</p>
          <p class="mm-panel-body text-[1.05rem] mb-4" data-reveal data-reveal-delay="0.2">
            Il suo primo Max Mara l'ha comprato a trent'anni, un Manuela che porta ancora oggi. Da allora il brand è parte della sua identità.
          </p>
          <p class="mm-panel-body text-[1.05rem]" data-reveal data-reveal-delay="0.28">
            Non va convinta: va fatta sentire speciale. Vuole essere riconosciuta, ricevere le novità prima degli altri, vivere il brand come una relazione.
          </p>
        </div>
        <div class="h-full flex items-center justify-center" data-reveal data-reveal-delay="0.15">
          <div class="relative h-full max-h-[64vh] aspect-[4/5] overflow-hidden rounded-[2px] shadow-[0_30px_70px_-40px_rgba(62,44,32,0.6)] bg-[var(--accent-secondary)] mx-auto ring-1 ring-[rgba(62,44,32,0.08)]">
            <MediaSlot {...mediaProps('francesca-ritratto')} fill noText="6,24,52,40" />
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Riconoscere entrambe (clienteling) ───────────── -->
    <Slide id="slide-recognition" bg="primary" align="center">
      <div slot="backdrop" class="absolute inset-0">
        <div class="mm-bg" aria-hidden="true"></div>
        <div class="mm-weave" aria-hidden="true"></div>
      </div>

      <div class="w-full max-w-4xl mx-auto text-center">
        <h2 class="text-[var(--ink-primary)] font-[family-name:var(--font-display)] font-normal mb-10" style="font-size: clamp(2.1rem, 4vw, 3.6rem); line-height: 1.1;" data-reveal>
          Un'unica piattaforma le conosce entrambe
        </h2>

        <div class="mm-panel relative w-full max-w-xl mx-auto flex-shrink-0 overflow-hidden text-left" data-clienteling data-reveal data-reveal-delay="0.2">
          <div class="scan-line absolute left-0 right-0 h-12 pointer-events-none" style="background: linear-gradient(180deg, transparent, rgba(193,154,107,0.22), transparent); opacity: 0;"></div>
          <p class="mm-panel-tag mb-5">Profilo unificato — cross-canale</p>
          <ul class="space-y-3 mm-panel-body text-[1.02rem]">
            {recognition.map((r) => (
              <li class="reveal-attr flex items-baseline gap-3"><span class="text-[rgba(193,154,107,0.95)] font-[family-name:var(--font-display)]">·</span> {r}</li>
            ))}
          </ul>
        </div>

        <p class="mm-card-body mx-auto max-w-2xl mt-8 text-[1.02rem]" data-reveal data-reveal-delay="0.4">
          Acquisire giovani è necessario; far crescere il loro valore nel tempo è ciò che cambia il business.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Payoff — metrica + CTA ───────────────────────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />
      <div class="w-full max-w-3xl mx-auto text-center flex flex-col items-center">
        <p data-display class="mm-stat-value font-light mb-6" style="font-size: clamp(4.5rem, 12vw, 11rem); line-height: 0.92;">
          <span data-count-up="64" data-count-suffix="%">0%</span>
        </p>
        <p class="mm-quote-text not-italic mb-6 max-w-3xl" style="font-size: clamp(1.5rem,2.4vw,2.25rem); line-height: 1.28;" data-reveal data-reveal-delay="0.2">
          La relazione che fa tornare una cliente è la stessa, a 29 come a 52 anni: la ragione per cui unire le generazioni conta.
        </p>
        <p class="mm-panel-src mb-12 max-w-2xl text-[0.8rem]" style="color: rgba(245,240,230,0.72);" data-reveal data-reveal-delay="0.28">
          Fonte: BCG – Altagamma, «True-Luxury Global Consumer Insight», 2024
        </p>

        <div data-reveal data-reveal-delay="0.5">
          <a
            href={href(base, '/chiusura')}
            class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
          >
            Il prossimo passo
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
