---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '@edf/core/layouts/PageLayout.astro';
import Hero from '@edf/core/blocks/Hero.astro';
import MetricCallout from '@edf/core/blocks/MetricCallout.astro';
import NarrativeSection from '@edf/core/blocks/NarrativeSection.astro';
---
<BaseLayout title="Il prossimo passo" description="Dalla visione all'azione: il prossimo passo per Max Mara con Adobe.">
  <PageLayout title="Il prossimo passo">
    <Hero
      label="Il prossimo passo"
      title="Dalla visione all'azione"
      subtitle="Il data lake diventa profili. I profili diventano relazioni. Le relazioni diventano valore che dura generazioni. Il tessuto connettivo è pronto — serve solo il primo passo."
      variant="centered"
    />

    <NarrativeSection
      eyebrow="La sintesi"
      title="Cosa abbiamo visto"
      body="<p>Un percorso end-to-end — dall'acquisizione di una nuova generazione alla loyalty che dura decenni — supportato da un'unica piattaforma. Non una collezione di strumenti separati, ma un tessuto connettivo che unisce dati, contenuti, decisioni e azioni in un flusso continuo.</p><p><strong>Acquisizione:</strong> raggiungere le nuove generazioni con contenuti on-brand a scala, potenziando (non sostituendo) le agenzie.<br/><strong>Engagement:</strong> personalizzare ogni touchpoint per trasformare curiosità in familiarità.<br/><strong>Conversione:</strong> accompagnare con discrezione, dall'online al negozio, senza attrito.<br/><strong>Loyalty:</strong> riconoscere ogni cliente ovunque, anticipare i suoi desideri, costruire valore nel tempo.</p><p>Al centro di tutto: Adobe Experience Platform e Real-Time CDP che trasformano un data lake silente in intelligence azionabile.</p>"
    />

    <div class="py-8 md:py-12 bg-[var(--surface-secondary)]">
      <div class="max-w-4xl mx-auto px-6 md:px-12 grid sm:grid-cols-3 gap-8">
        <MetricCallout
          value="+306%"
          label="LTV clienti connesse emotivamente"
          variant="default"
        />
        <MetricCallout
          value="¾"
          label="Spesa luxury da Millennial + Gen Z"
          variant="default"
        />
        <MetricCallout
          value="3×"
          label="Conversione con esperienza omnicanale coerente"
          variant="default"
        />
      </div>
    </div>

    <section class="py-20 md:py-32 bg-[var(--surface-primary)] text-center">
      <div class="max-w-3xl mx-auto px-6 md:px-12">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw+0.5rem,3rem)] font-light leading-[1.15] text-[var(--ink-primary)] mb-6">
          Costruiamo insieme il prossimo capitolo
        </h2>
        <p class="text-lg text-[var(--ink-secondary)] leading-relaxed mb-10">
          Ogni generazione merita un'esperienza che la riconosca. Ogni relazione merita la tecnologia giusta per durare. Il momento di iniziare è adesso.
        </p>
        <a
          href="mailto:experience-design@adobe.com"
          class="inline-flex items-center gap-2 px-10 py-4 text-sm font-medium tracking-wide uppercase bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--accent-hover)] transition-colors duration-[var(--duration-normal)] focus-visible:outline-2 focus-visible:outline-[var(--focus-ring)] focus-visible:outline-offset-2"
        >
          Parliamone
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </section>
  </PageLayout>
</BaseLayout>
