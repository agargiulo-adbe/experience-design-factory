---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '@edf/core/layouts/Navigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Acquisizione', href: '/acquisizione' },
  { label: 'Engagement', href: '/engagement' },
  { label: 'Conversione', href: '/conversione' },
  { label: 'Loyalty', href: '/loyalty' },
  { label: 'Il Motore', href: '/motore-adobe' },
  { label: 'Persona', href: '/persona' },
];

const fasi = [
  { n: '01', label: 'Acquisizione', desc: 'Raggiungere le nuove generazioni con contenuti on-brand', path: '/acquisizione' },
  { n: '02', label: 'Engagement', desc: 'Personalizzare ogni touchpoint: da curiosità a familiarità', path: '/engagement' },
  { n: '03', label: 'Conversione', desc: 'Accompagnare con discrezione, dall\'online al negozio, senza attrito', path: '/conversione' },
  { n: '04', label: 'Loyalty', desc: 'Riconoscere ovunque, anticipare, costruire valore nel tempo', path: '/loyalty' },
];

const numeri = [
  { value: '2.4', prefix: '', suffix: '', label: 'esperienze negative per perdere una cliente; 6.7 positive per conquistarla' },
  { value: '75', prefix: '', suffix: '%', label: 'della spesa luxury da Millennial e Gen Z' },
  { value: '3', prefix: '', suffix: '×', label: 'conversione con esperienza omnicanale coerente' },
];
---
<BaseLayout title="Il prossimo passo" description="Dalla visione all'azione: il prossimo passo per Max Mara con Adobe.">
  <div class="fixed top-0 left-0 right-0 z-50">
    <Navigation items={navItems} currentPath={currentPath} base={base.replace(/\/$/, '')} />
  </div>

  <DeckContainer nextHref={href(base, '/')} prevHref={href(base, '/persona')}>

    <!-- ── SLIDE 0: Apertura ─────────────────────────────────────── -->
    <Slide id="slide-apertura" bg="secondary" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--surface-secondary)]/72" />
      <CoverHero eyebrow="IL PROSSIMO PASSO" title="Dalla visione all'azione" lead="Il data lake diventa profili. I profili diventano relazioni. Le relazioni diventano valore che dura generazioni." />
    </Slide>

    <!-- ── SLIDE 1: La sintesi — le quattro fasi ─────────────────── -->
    <Slide id="slide-sintesi" bg="primary" align="center">
      <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>LA SINTESI</p>
      <h2 class="slide-title text-[var(--ink-primary)] mb-10" style="font-size: clamp(2rem, 3.6vw, 3.4rem);" data-reveal data-reveal-delay="0.1">
        Un percorso end-to-end, un unico tessuto
      </h2>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 text-left w-full max-w-5xl mx-auto" data-stagger="0.12">
        {fasi.map((f) => (
          <a href={href(base, f.path)} class="group flex flex-col gap-2 p-5 rounded-lg border border-[var(--line-subtle)] bg-[var(--surface-secondary)] hover:border-[var(--accent-primary)] transition-colors">
            <span class="font-[family-name:var(--font-display)] text-[clamp(1.6rem,2vw,2.1rem)] font-light text-[var(--accent-primary)]">{f.n}</span>
            <span class="text-[clamp(1.05rem,1.3vw,1.25rem)] font-medium text-[var(--ink-primary)]">{f.label}</span>
            <span class="text-[clamp(0.92rem,1.05vw,1.05rem)] text-[var(--ink-tertiary)] leading-snug">{f.desc}</span>
          </a>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: I numeri che contano ─────────────────────────── -->
    <Slide id="slide-numeri" bg="inverse" align="center">
      <h2 class="slide-title text-[var(--ink-inverse)] mb-24" style="font-size: clamp(2rem, 3.6vw, 3.4rem);" data-reveal>
        Tre numeri, una direzione
      </h2>
      <div class="grid sm:grid-cols-3 gap-10 md:gap-8 text-center w-full max-w-5xl mx-auto">
        {numeri.map((n) => (
          <div>
            <p class="font-[family-name:var(--font-display)] font-light leading-none text-[var(--accent-secondary)] mb-4" style="font-size: clamp(4rem, 9vw, 7.5rem);">
              <span data-count-up={n.value} data-count-prefix={n.prefix} data-count-suffix={n.suffix}>{n.prefix}0{n.suffix}</span>
            </p>
            <p class="text-[clamp(1rem,1.2vw,1.2rem)] text-[var(--color-grigio-300)] leading-snug">{n.label}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: La promessa ──────────────────────────────────── -->
    <Slide id="slide-promessa" bg="primary" align="center">
      <p class="font-[family-name:var(--font-display)] font-light leading-[1.25] text-[var(--ink-primary)] max-w-4xl mx-auto" style="font-size: clamp(2.2rem, 4.2vw, 4rem);">
        <span class="block" data-reveal>Ogni generazione merita un'esperienza che la riconosca.</span>
        <span class="block text-[var(--accent-primary)] mt-6" data-reveal data-reveal-delay="0.25">Ogni relazione merita la tecnologia giusta per durare.</span>
      </p>
    </Slide>

    <!-- ── SLIDE 4: Payoff — CTA finale ──────────────────────────── -->
    <Slide id="slide-payoff" bg="brand" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-cashmere')} imageClass="opacity-20" scrim="bg-[var(--accent-primary)]/78" />
      <h2 class="slide-title text-[var(--ink-primary)] mb-6 max-w-4xl" style="font-size: clamp(2.25rem, 4.5vw, 4rem);" data-reveal>
        Costruiamo insieme il prossimo capitolo
      </h2>
      <p class="text-[clamp(1.2rem,1.7vw,1.65rem)] text-[var(--ink-primary)]/85 leading-relaxed mb-12 max-w-2xl mx-auto" data-reveal data-reveal-delay="0.2">
        Il tessuto connettivo è pronto. Serve solo il primo passo. Il momento di iniziare è adesso.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="0.4">
        <a
          href="mailto:experience-design@adobe.com"
          class="inline-flex items-center gap-2 px-10 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-medium tracking-wide bg-[var(--ink-primary)] text-[var(--ink-inverse)] hover:bg-[var(--surface-inverse)] transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-4"
        >
          Parliamone
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href={href(base, '/')}
          class="inline-flex items-center gap-2 px-8 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-medium tracking-wide border border-[var(--ink-primary)]/40 text-[var(--ink-primary)] hover:bg-[var(--ink-primary)]/10 transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--ink-primary)] focus-visible:outline-offset-2"
        >
          Rivedi il percorso
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
