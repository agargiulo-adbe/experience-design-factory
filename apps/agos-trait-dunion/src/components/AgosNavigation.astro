---
import { href } from '@edf/core/utils/url.js';

interface Props {
  currentPath: string;
  base: string;
}

const { currentPath, base } = Astro.props;

const sections = [
  { slug: '',             label: 'Cover',          solution: null },
  { slug: 'scenario',     label: 'Scenario',       solution: null },
  { slug: 'fondamenta',   label: 'Fondamenta',     solution: null },
  { slug: 'evoluzione',   label: 'Evoluzione',     solution: 'ajo,target,genstudio' },
  { slug: 'trait-dunion', label: "Trait d'union",  solution: 'cja' },
  { slug: 'orizzonti',    label: 'Orizzonti',      solution: 'rtcdp,data-collab' },
  { slug: 'valore',       label: 'Valore',         solution: null },
  { slug: 'roadmap',      label: 'Roadmap',        solution: null },
];

function isActive(slug: string) {
  const norm = currentPath.replace(/\/+$/, '');
  if (slug === '') return norm.endsWith('/agos-trait-dunion') || norm.endsWith('/index');
  return norm.endsWith('/' + slug);
}
---
<nav
  class="flex items-center justify-between px-6 py-3 bg-[var(--color-abisso)]/95 backdrop-blur-sm border-b border-[var(--color-alga)]"
  aria-label="Navigazione esperienza"
>
  <a
    href={href(base, '/')}
    class="flex items-center gap-2.5 no-underline group"
    aria-label="Home — Trait d'Union"
  >
    <span class="inline-flex items-center justify-center w-7 h-7 rounded bg-[var(--color-petrolio)] flex-shrink-0" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
        <circle cx="9" cy="16" r="4" fill="#06ABB8"/>
        <rect x="12" y="15" width="8" height="2" rx="1" fill="white"/>
        <circle cx="23" cy="16" r="4" fill="#F57C00"/>
      </svg>
    </span>
    <span class="text-sm font-semibold text-[var(--color-perla)] group-hover:text-white transition-colors font-[family-name:var(--font-display)]">
      Trait d'Union
    </span>
    <span class="hidden sm:inline text-[0.6rem] font-bold tracking-widest uppercase text-[var(--color-perla)]/40 ml-1">
      Agos × Adobe
    </span>
  </a>

  <ol class="hidden md:flex flex-nowrap items-center gap-0.5 min-w-0 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden" role="list">
    {sections.filter(s => s.slug !== '').map((s, i) => (
      <li
        data-nav-solution={s.solution ?? undefined}
        role="listitem"
        class="flex-shrink-0"
      >
        <a
          href={href(base, s.slug ? '/' + s.slug : '/')}
          class={[
            'block whitespace-nowrap px-2.5 py-1.5 text-xs font-medium rounded-sm transition-colors no-underline',
            isActive(s.slug)
              ? 'bg-[var(--accent-primary)]/15 text-[var(--accent-primary)] border border-[var(--accent-primary)]/30'
              : 'text-[var(--color-grigio-300)] hover:text-[var(--color-perla)] hover:bg-[var(--color-alga)]',
          ].join(' ')}
          aria-current={isActive(s.slug) ? 'page' : undefined}
        >
          <span class="text-[var(--color-grigio-500)] mr-1 tabular-nums">
            {String(i + 1).padStart(2, '0')}
          </span>
          {s.label}
        </a>
      </li>
    ))}
  </ol>

  <div class="flex items-center gap-3">
    <span class="hidden sm:inline text-[0.65rem] tracking-widest uppercase text-[var(--color-grigio-500)]">
      Live Pitch
    </span>
    <a
      href={href(base, '/admin')}
      class="text-[0.7rem] font-semibold tracking-wider uppercase px-3 py-1.5 border border-[var(--color-alga)] text-[var(--color-grigio-400)] hover:text-[var(--color-perla)] hover:border-[var(--color-grigio-500)] rounded-sm transition-colors no-underline"
      data-admin-only
    >
      Admin
    </a>
  </div>
</nav>
