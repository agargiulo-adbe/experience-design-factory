---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const journey = [
  { num: '01', label: 'Scenario',      sub: 'Il paradosso dei due mondi',           href: '/scenario',     solution: null },
  { num: '02', label: 'Fondamenta',    sub: 'Quello che avete già · AgosX',         href: '/fondamenta',   solution: null },
  { num: '03', label: 'Evoluzione',    sub: 'I vostri use case, evoluti',           href: '/evoluzione',   solution: 'ajo,target,genstudio' },
  { num: '04', label: "Trait d'union", sub: 'CJA — i due mondi, una vista',         href: '/trait-dunion', solution: 'cja' },
  { num: '05', label: 'Orizzonti',     sub: 'Nuovi casi d\'uso dal playbook FSI',    href: '/orizzonti',    solution: 'rtcdp,data-collab' },
  { num: '06', label: 'Valore',        sub: 'Evidence-based, alla vostra maniera',  href: '/valore',       solution: null },
  { num: '07', label: 'Roadmap',       sub: 'Sequenziata con la trasformazione',    href: '/roadmap',      solution: null },
];

const agosStats = [
  { value: '>€8 mld', label: 'erogato 2024', sub: 'record degli ultimi 10 anni' },
  { value: '9,4M+',   label: 'clienti in Italia', sub: '200 filiali · migliaia di partner' },
  { value: 'ACT 2028', label: 'piano di gruppo CA', sub: 'Italia secondo mercato domestico' },
];
---
<BaseLayout
  title="Trait d'Union"
  description="Due mondi — digitale e fisico, acquisition e customer base — connessi in un'unica intelligenza del cliente. Agos × Adobe."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/scenario')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-due-mondi')}
        imageClass="opacity-20"
        scrim="bg-[var(--color-abisso)]/90"
      />
      <CoverHero
        eyebrow="100% digitale · 100% umano · 100% connesso"
        title="Trait d'Union"
        lead="Il vostro cliente vive in due mondi: quello digitale dei click e quello umano delle filiali. Oggi si parlano poco. Connetterli — con la tecnologia Adobe che già usate — è il prossimo vantaggio competitivo."
        size="hero"
        tone="ink"
        primary="Agos"
        secondary="Adobe"
      />
      <p class="mt-5 text-center text-[0.75rem] tracking-widest uppercase text-[var(--color-grigio-300)] max-w-2xl mx-auto">
        Scenario evolutivo · dati pubblici e illustrativi citati alle fonti · preparato dal team Adobe Italia
      </p>
      <div class="flex gap-8 mt-6 justify-center flex-wrap" data-reveal data-reveal-delay="0.3">
        <div class="flex items-center gap-2.5">
          <div class="size-7 rounded-full bg-[var(--accent-primary)]/20 flex items-center justify-center text-sm font-bold text-[var(--accent-primary)] font-[family-name:var(--font-display)]">E</div>
          <p class="text-sm font-medium text-[var(--color-perla)]/65">Elisa — da prospect anonima a cliente fidelizzata</p>
        </div>
        <div class="flex items-center gap-2.5">
          <div class="size-7 rounded-full bg-[var(--accent-secondary)]/20 flex items-center justify-center text-sm font-bold text-[var(--accent-secondary)] font-[family-name:var(--font-display)]">7</div>
          <p class="text-sm font-medium text-[var(--color-perla)]/65">Sette capitoli — dai casi d'uso di oggi ai nuovi orizzonti</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: Contesto Agos ─────────────────────────────────── -->
    <Slide id="slide-contesto" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-citta')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        IL CONTESTO STRATEGICO
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
        style="font-size: clamp(2rem, 3.6vw, 3.4rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un leader in piena accelerazione
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-2xl mx-auto mb-5"
        style="font-size: clamp(1rem, 1.25vw, 1.25rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Erogato record, un piano di gruppo che punta sull'Italia, un mercato in cui il 19%
        dei prestiti personali si colloca ormai 100% online. La trasformazione tecnologica
        è già in corsa — e l'esperienza cliente è il terreno dove si vince.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-5"
        data-reveal
        data-reveal-delay="0.22"
      >
        {agosStats.map((m) => (
          <div class="text-center p-4 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-2"
              style="font-size: clamp(1.7rem, 3.2vw, 2.7rem);"
            >
              {m.value}
            </p>
            <p class="text-[1rem] font-medium text-[var(--ink-primary)] mb-1">{m.label}</p>
            <p class="text-[0.82rem] text-[var(--color-grigio-300)]">{m.sub}</p>
          </div>
        ))}
      </div>
      <p class="mt-5 text-center text-[0.75rem] tracking-widest uppercase text-[var(--color-grigio-300)]">
        Fonti:&nbsp;
        <a href="https://www.agoscorporate.it/allegati/2025/3/cs-agosrisultatify2024_27650.pdf" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
          Agos, risultati FY2024 (mar 2025)
        </a>
        &nbsp;·&nbsp;
        <a href="https://www.credit-agricole.com/en/pdfPreview/208134" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
          Crédit Agricole, piano ACT 2028 (nov 2025)
        </a>
        &nbsp;·&nbsp;
        <a href="https://www.crif.it/ricerche-e-academy/ricerche/osservatorio-credito-al-dettaglio/" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
          Osservatorio Assofin–CRIF–Prometeia (giu 2026)
        </a>
      </p>
    </Slide>

    <!-- ── SLIDE 2: Il percorso ───────────────────────────────────── -->
    <Slide id="slide-journey" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--color-petrolio)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--color-perla)]/70 mb-4" data-reveal>
        IL PERCORSO
      </p>
      <h2
        class="font-[family-name:var(--font-display)] text-[var(--color-perla)] mb-4 max-w-3xl"
        style="font-size: clamp(1.9rem, 3vw, 2.6rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
        data-edf-chapters
      >
        Sette capitoli. Due mondi. Un trait d'union.
      </h2>
      <p
        class="text-[clamp(0.9rem,1.05vw,1.05rem)] text-[var(--color-perla)]/75 max-w-2xl mb-3"
        data-reveal
        data-reveal-delay="0.15"
      >
        Da quello che funziona già oggi a un'esperienza cliente connessa,
        misurabile e pronta per la trasformazione.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-2 mb-2.5"
        data-reveal
        data-reveal-delay="0.22"
      >
        {journey.map((step) => (
          <a
            href={href(base, step.href)}
            data-nav-solution={step.solution ?? undefined}
            data-edf-journey-card
            class="journey-card px-4 py-1.5 border border-[var(--color-perla)]/25 rounded-sm text-left text-[var(--color-perla)] transition-colors no-underline group"
          >
            <p class="text-xs font-semibold text-[var(--color-perla)]/50 mb-0.5 font-[family-name:var(--font-display)] tabular-nums" data-edf-cardnum>
              {step.num}
            </p>
            <p class="text-[1.02rem] font-semibold text-[var(--color-perla)] mb-0.5 font-[family-name:var(--font-display)]">
              {step.label}
            </p>
            <p class="text-[0.82rem] text-[var(--color-perla)]/70">{step.sub}</p>
          </a>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.35">
        <a
          href={href(base, '/scenario')}
          class="inline-flex items-center gap-3 px-9 py-2 text-[clamp(1rem,1.2vw,1.15rem)] font-semibold tracking-wide bg-[var(--color-perla)] text-[var(--color-abisso)] hover:bg-white transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--color-perla)] focus-visible:outline-offset-4 font-[family-name:var(--font-display)]"
        >
          Inizia il percorso
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>

  <script is:inline>
  (function () {
    var KEY = 'edf-solutions-agos-trait-dunion';
    var GATES = [null, null, ['ajo', 'target', 'genstudio'], ['cja'], ['rtcdp', 'data-collab'], null, null];
    var WORDS = ['zero', 'uno', 'due', 'tre', 'quattro', 'cinque', 'sei', 'sette'];

    function activeIds() {
      var p = new URLSearchParams(location.search).get('s');
      if (p) return p.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
      try { var st = localStorage.getItem(KEY); if (st) return JSON.parse(st); } catch (_) {}
      return null;
    }
    function count() {
      var ids = activeIds();
      if (!ids) return GATES.length;
      var n = 0;
      GATES.forEach(function(g) {
        if (!g || g.some(function(id) { return ids.indexOf(id) !== -1; })) n++;
      });
      return n;
    }
    function label(n) {
      var w = WORDS[n] || String(n);
      return w.charAt(0).toUpperCase() + w.slice(1) + ' capitoli';
    }
    function renumber() {
      var n = 1;
      document.querySelectorAll('[data-edf-journey-card]').forEach(function(card) {
        var hidden = card.offsetParent === null || getComputedStyle(card).display === 'none';
        if (hidden) return;
        var numEl = card.querySelector('[data-edf-cardnum]');
        if (numEl) numEl.textContent = ('0' + n).slice(-2);
        n++;
      });
    }
    function apply() {
      var txt = label(count()) + ". Due mondi. Un trait d'union.";
      document.querySelectorAll('[data-edf-chapters]').forEach(function(el) { el.textContent = txt; });
      renumber();
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply); else apply();
    document.addEventListener('astro:page-load', apply);
    window.addEventListener('storage', function(e) { if (e.key === KEY) apply(); });
  })();
  </script>
</BaseLayout>
