---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

interface Evo {
  id: string;
  solution: string;
  eyebrow: string;
  product: string;
  title: string;
  oggi: string[];
  domani: string[];
  nota: string;
}

const evoluzioni: Evo[] = [
  {
    id: 'slide-form-abbandonato',
    solution: 'ajo',
    eyebrow: 'USE CASE 1 · GIÀ VOSTRO',
    product: 'Adobe Journey Optimizer',
    title: 'Il form abbandonato diventa un journey',
    oggi: [
      'Il log tecnico intercetta l\'abbandono, parte un recall entro la finestra consentita',
      'Prima comunicazione uguale per tutti: solo dopo si può insistere sui già clienti',
      'Nessuna vista su cosa succede dopo: risposta, pratica, canale',
    ],
    domani: [
      'L\'evento di abbandono attiva in tempo reale un journey multicanale su email, SMS e push',
      'Chi è già cliente viene riconosciuto e arricchito: tono, offerta e canale su misura',
      'Il journey ascolta: se la pratica riparte si ferma da solo, se converte genera il follow-up',
    ],
    nota: 'Stesso trigger di oggi, il vostro log tecnico, ingerito nativamente: nessun nuovo tracciamento richiesto.',
  },
  {
    id: 'slide-use-case-orchestrati',
    solution: 'ajo',
    eyebrow: 'USE CASE 2 · GIÀ VOSTRO',
    product: 'AJO · Orchestrated Campaigns',
    title: 'Gli use case si parlano tra loro',
    oggi: [
      'Ogni use case è un blocco a sé: filtri + canale, esclusioni impostate a mano',
      'Capping «chi prima arriva»: può fermarsi la campagna di maggior valore',
      'Le simulazioni non lasciano traccia: ogni run riparte da zero',
    ],
    domani: [
      'Le campagne batch restano batch — stessa logica operativa, query on-demand in secondi',
      'Capping + priorità di journey: la pressione si governa per valore, non per ordine di arrivo',
      'Un profilo unico decide la next best experience tra tutti gli use case attivi',
    ],
    nota: 'Orchestrated Campaigns è l\'ambiente più vicino a come già lavorate: chi opera resta a suo agio, chi decide guadagna un salto.',
  },
  {
    id: 'slide-conversione',
    solution: 'ajo,cja',
    eyebrow: 'USE CASE 3 · IL PIÙ ATTESO',
    product: 'AJO + Customer Journey Analytics',
    title: 'Il dato di ritorno entra in piattaforma',
    oggi: [
      'Delivery e click si vedono; caricata e liquidata arrivano dopo, da report esterni',
      'Il venduto è in piattaforma solo come filtro di esclusione',
      'Migliorare una campagna richiede settimane di andata e ritorno tra uffici',
    ],
    domani: [
      'Due colonne bastano per cominciare, codice cliente ed esito, e il loop si chiude',
      'Fallout completo in un\'unica vista: aperture → click → pratica → liquidata',
      'L\'AI suggerisce dove intervenire: «open rate alto, cadute al caricamento: ecco perché»',
    ],
    nota: 'Approccio a onde: si parte minimale, si arricchisce quando il valore è dimostrato. Evidence-based, come piace a voi.',
  },
  {
    id: 'slide-experimentation',
    solution: 'target',
    eyebrow: 'USE CASE 4 · DA RIACCENDERE',
    product: 'Adobe Target · Experimentation',
    title: 'L\'A/B test oltre lo split del webmaster',
    oggi: [
      'Split 50/50 fatto a mano su due atterraggi alternativi',
      'Misura sul log di sistema, esperimenti lenti da montare e smontare',
      'Form completo vs form leggero: un dilemma mai chiuso per canale',
    ],
    domani: [
      'Esperimenti attivabili dal marketing: varianti, segmenti, stop automatico al vincitore',
      'La misura si riconcilia col log tecnico, ingerito come fonte anziché ignorato',
      'Test per canale: il social vede la variante leggera, il search quella completa',
    ],
    nota: 'Experimentation, non iper-personalizzazione: un\'ipotesi, un test controllato, una decisione. Il vostro metodo, reso industriale.',
  },
  {
    id: 'slide-genai',
    solution: 'genstudio',
    eyebrow: 'USE CASE 5 · IL PIÙ VELOCE',
    product: 'GenStudio + AI Assistant',
    title: 'Contenuti on-brand, con la compliance già dentro',
    oggi: [
      'DEM costruite a mano, tempi lunghi tra brief, grafica e controlli',
      'Il copy di un prodotto creditizio ha vincoli precisi: ogni parola va pesata',
      'Centinaia di campagne l\'anno, una manutenzione che non scala',
    ],
    domani: [
      'La DEM nasce da un prompt, dentro i template e i colori del brand',
      'Brand score anche semantico: le guideline di compliance diventano una knowledge base che valuta il copy',
      'Varianti per segmento generate in minuti, e misurate sul risultato storico',
    ],
    nota: 'Il controllo resta umano: l\'AI propone dentro i vincoli e il team approva. Si guadagna velocità senza cedere responsabilità.',
  },
];
---
<BaseLayout
  title="I vostri use case, evoluti"
  description="Form abbandonato, use case, dato di ritorno, A/B test, DEM: quello che Agos fa già oggi, evoluto con Adobe Journey Optimizer, Target e GenStudio."
  pageSolutions={['ajo', 'target', 'genstudio']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/trait-dunion')}
    prevHref={href(base, '/fondamenta')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dashboard')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <CoverHero
        eyebrow="03 · Evoluzione"
        numeral="03"
        title="Quello che fate oggi. Meglio."
        lead="Cinque use case che esistono già nelle vostre giornate: il form abbandonato, il dato di ritorno, l'A/B test, le DEM. Ognuno ha un'evoluzione naturale, senza stravolgere chi ci lavora."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1..5: Evoluzioni oggi → domani ───────────────────── -->
    {evoluzioni.map((evo) => (
      <Slide id={evo.id} bg="primary" align="center" data-solution={evo.solution}>
        <div slot="backdrop" class="tdu-bg" aria-hidden="true" />

        <div class="w-full max-w-6xl mx-auto">
          <div class="flex items-center justify-center gap-3 mb-2.5 flex-wrap" data-reveal>
            <p class="slide-eyebrow text-[var(--accent-primary)]">{evo.eyebrow}</p>
            <span class="badge bg-[var(--accent-primary)]/12 text-[var(--accent-primary)]">{evo.product}</span>
          </div>
          <h2
            class="text-center text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.7rem, 2.8vw, 2.6rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.08"
          >
            {evo.title}
          </h2>

          {/* Transformation axis: oggi (current still partial) → domani (current whole) */}
          <div class="evo-axis" data-reveal data-reveal-delay="0.18">
            <div class="tdu-panel oggi-card evo-oggi">
              <div class="evo-panel-head">
                <span class="evo-state-tag evo-state-tag--oggi">Oggi</span>
                <span class="evo-thread evo-thread--partial" aria-hidden="true">
                  <span class="evo-thread-node" />
                  <span class="evo-thread-line evo-thread-line--dashed" />
                  <span class="evo-thread-node evo-thread-node--open" />
                </span>
              </div>
              <ul class="evo-list">
                {evo.oggi.map((item) => (
                  <li class="evo-item evo-item--oggi">
                    <span class="evo-bullet evo-bullet--oggi" aria-hidden="true" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="evo-flow" aria-hidden="true">
              <span class="tdu-node evo-flow-node" />
              <span class="evo-flow-line" />
              <svg class="evo-flow-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M2 9 H14 M9 4 L14 9 L9 14" stroke="var(--color-acqua)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>

            <div class="tdu-panel tdu-panel--acqua domani-card evo-domani">
              <div class="evo-panel-head">
                <span class="evo-state-tag evo-state-tag--domani">Domani</span>
                <span class="evo-thread evo-thread--whole" aria-hidden="true">
                  <span class="evo-thread-node" />
                  <span class="evo-thread-line" />
                  <span class="evo-thread-node" />
                </span>
              </div>
              <ul class="evo-list">
                {evo.domani.map((item) => (
                  <li class="evo-item">
                    <span class="evo-bullet evo-bullet--domani" aria-hidden="true" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="tdu-quote evo-nota" data-reveal data-reveal-delay="0.3">
            <p class="evo-nota-text">
              <strong class="evo-nota-lead">Perché funziona da voi:</strong> {evo.nota}
            </p>
          </div>
        </div>
      </Slide>
    ))}

  </DeckContainer>

  <style>
    /* Evoluzione — oggi → domani lungo la corrente (left→right axis).
       Explicit rgba only; body ≥0.95rem, lh ≥1.5; audit-readable contrast. */
    .evo-axis {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: stretch;
      gap: 0.9rem;
    }
    @media (max-width: 767px) {
      .evo-axis { grid-template-columns: 1fr; }
      .evo-flow { flex-direction: row; padding: 0.2rem 0; }
      .evo-flow-line { width: 40%; height: 1px; }
      .evo-flow-arrow { transform: none; }
    }

    /* Muted "oggi" panel — the current still partial */
    .evo-oggi { background: rgba(10, 19, 21, 0.45); }
    .evo-oggi.tdu-panel { padding: 1.05rem 1.25rem 1.15rem; }
    .evo-domani.tdu-panel { padding: 1.05rem 1.25rem 1.15rem; }

    .evo-panel-head {
      display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
      padding-bottom: 0.6rem; margin-bottom: 0.75rem;
      border-bottom: 1px solid var(--line-subtle);
    }
    .evo-state-tag {
      font-size: 0.78rem; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; font-family: var(--font-display);
    }
    .evo-state-tag--oggi { color: var(--color-grigio-300); }
    .evo-state-tag--domani { color: var(--color-acqua-chiara); }

    /* The thread inside each head: partial (dashed, open end) vs whole (solid) */
    .evo-thread { display: inline-flex; align-items: center; gap: 0; height: 8px; }
    .evo-thread-node { width: 7px; height: 7px; border-radius: 50%; flex: 0 0 auto; }
    .evo-thread--partial .evo-thread-node { background: var(--color-grigio-400); }
    .evo-thread--whole .evo-thread-node { background: var(--color-acqua); }
    .evo-thread-node--open {
      background: transparent;
      border: 1px solid var(--color-grigio-400);
    }
    .evo-thread-line { width: 26px; height: 1px; background: var(--color-acqua); }
    .evo-thread-line--dashed {
      background: none;
      border-top: 1px dashed var(--color-grigio-400);
      height: 0;
    }

    .evo-list { display: flex; flex-direction: column; gap: 0.55rem; margin: 0; }
    .evo-item {
      display: flex; align-items: flex-start; gap: 0.65rem;
      font-size: 0.95rem; line-height: 1.5; color: var(--color-grigio-200);
      list-style: none;
    }
    .evo-bullet {
      flex: 0 0 auto; margin-top: 0.42rem;
      width: 6px; height: 6px; border-radius: 50%;
    }
    .evo-bullet--oggi { background: var(--color-grigio-400); }
    .evo-bullet--domani { background: var(--color-acqua); }

    /* Central flow — the current carrying oggi into domani */
    .evo-flow {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 0.4rem; padding: 0 0.15rem;
    }
    .evo-flow-node { width: 8px; height: 8px; }
    .evo-flow-line {
      width: 1px; flex: 1 1 auto; min-height: 1.2rem;
      background: linear-gradient(to bottom, rgba(6,171,184,0.15), rgba(6,171,184,0.7));
    }
    .evo-flow-arrow { transform: rotate(90deg); }

    /* Nota — pull quote via tdu-quote (acqua hairline above, never a side-stripe) */
    .evo-nota { margin-top: 1.1rem; max-width: 60rem; margin-inline: auto; }
    .evo-nota-text {
      font-size: 0.98rem; line-height: 1.5; color: var(--color-grigio-200);
      text-align: center; max-width: none;
    }
    .evo-nota-lead { color: var(--accent-secondary); font-weight: 700; }
  </style>
</BaseLayout>
