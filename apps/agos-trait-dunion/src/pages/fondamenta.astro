---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const stack = [
  {
    cat: 'Marketing automation',
    name: 'Adobe Campaign v7',
    desc: 'Gli use case (filtri + canale) che muovono DEM, SMS, call center e direct mail sulla customer base.',
    badge: 'In produzione da anni',
  },
  {
    cat: 'Web analytics',
    name: 'Adobe Analytics',
    desc: 'Tracciamento ricco di sito e funnel, soggetto al consenso: vede in profondità, ma non tutti.',
    badge: 'In produzione',
  },
  {
    cat: 'La fonte di verità',
    name: 'Log tecnico di sistema',
    desc: 'Server-side, 100% delle richieste, ogni step del form: il metro su cui l\'azienda misura le campagne.',
    badge: 'Asset distintivo',
  },
  {
    cat: 'Attribution',
    name: 'Modello first-touch',
    desc: 'Ricostruisce il percorso pre-conversione online di chi accetta i cookie: solo online, fuori dal DWH.',
    badge: 'Da evolvere',
  },
];

const trasformazione = [
  { icon: '☁️', title: 'CRM unico', desc: 'Una piattaforma di relazione cliente unica per tutta l\'azienda' },
  { icon: '❄️', title: 'Data lake moderno', desc: 'Il patrimonio dati consolidato in un\'unica casa cloud' },
  { icon: '📞', title: 'Contact center cloud', desc: 'La barra telefonica migra su infrastruttura cloud' },
];
---
<BaseLayout
  title="Le fondamenta"
  description="Adobe Campaign, Adobe Analytics, il log tecnico e una trasformazione tecnologica in corsa: le fondamenta su cui costruire, senza sostituire nulla."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/evoluzione')}
    prevHref={href(base, '/scenario')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <CoverHero
        eyebrow="02 · Fondamenta"
        numeral="02"
        title="Le fondamenta ci sono già"
        lead="Anni di use case in Adobe Campaign, un tracciamento ricco in Adobe Analytics, un log tecnico che vede tutto. Non si riparte da zero: si costruisce sopra."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Lo stack di oggi ──────────────────────────────── -->
    <Slide id="slide-stack" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        QUELLO CHE AVETE GIÀ
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un patrimonio operativo, non un punto di partenza
      </h2>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4" data-reveal data-reveal-delay="0.18">
        {stack.map((s) => (
          <div class="px-5 py-3.5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] border-l-2 border-l-[var(--accent-primary)] rounded-sm text-left">
            <div class="flex items-center justify-between gap-3 mb-1.5 flex-wrap">
              <p class="text-[0.75rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)]">{s.cat}</p>
              <span class="badge bg-[var(--accent-primary)]/12 text-[var(--accent-primary)]">{s.badge}</span>
            </div>
            <p class="text-[1.05rem] font-semibold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-tight mb-1">{s.name}</p>
            <p class="text-[0.92rem] text-[var(--color-grigio-200)] leading-snug">{s.desc}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: La trasformazione in corso ────────────────────── -->
    <Slide id="slide-trasformazione" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        LA TRASFORMAZIONE IN CORSO
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un programma che ridisegna le piattaforme core
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-2xl mx-auto mb-4"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        CRM, dati e contact center migrano insieme verso il cloud, con go-live
        coordinato all'orizzonte 2027, un investimento che assorbe la capacità
        di delivery IT.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {trasformazione.map((t) => (
          <div class="text-center px-5 py-2.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
            <span class="text-3xl block mb-1" aria-hidden="true">{t.icon}</span>
            <p class="text-[1.05rem] font-semibold text-[var(--ink-primary)] mb-1 font-[family-name:var(--font-display)]">{t.title}</p>
            <p class="text-[0.92rem] text-[var(--color-grigio-300)] leading-snug">{t.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-3 max-w-3xl mx-auto px-5 py-2 bg-[var(--accent-secondary)]/10 border border-[var(--accent-secondary)]/30 rounded-sm" data-reveal data-reveal-delay="0.35">
        <p class="text-[0.95rem] text-[var(--color-grigio-200)] leading-snug">
          <strong class="text-[var(--ink-primary)]">E il campaign management?</strong> Nel piano attuale
          migra <em>così com'è</em>: stessa logica, nuova casa. E il marketing ha una domanda legittima:
          davvero l'evoluzione dell'esperienza cliente deve aspettare il 2027?
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 3: La finestra ───────────────────────────────────── -->
    <Slide id="slide-finestra" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        LA FINESTRA 2026 → 2027
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Preparare il terreno<br/>senza pesare sull'IT
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-5"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        C'è un modo per usare questa finestra: attivare il layer di <em>intelligence</em> e di
        <em>experience</em> che lavora con connettori e flussi già esistenti, senza nuovi
        progetti di integrazione core e senza toccare la migrazione.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        <div class="px-5 py-4 oggi-card border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-[0.78rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-2.5">La capacità IT, oggi</p>
          <ul class="space-y-2">
            {[
              'Migrazione CRM, data lake e contact center',
              'Go-live coordinato: il rischio si gestisce lì',
              'Nessuno spazio per progetti evolutivi paralleli sul core',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-snug text-[var(--color-grigio-200)]">
                <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-grigio-400)]" aria-hidden="true"/>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="px-5 py-4 domani-card border border-[var(--accent-primary)]/30 rounded-sm text-left">
          <p class="text-[0.78rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-2.5">Il terreno che il marketing può preparare adesso</p>
          <ul class="space-y-2">
            {[
              'Analisi cross-canale sui dati che già esistono: log, analytics, venduto',
              'Experimentation sulle landing, misurata sul log tecnico',
              'Use case disegnati e validati, pronti a salire sulla nuova piattaforma',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-snug text-[var(--color-grigio-200)]">
                <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"/>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 4: Non sostituire. Connettere. ───────────────────── -->
    <Slide id="slide-choice" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-orizzonte')}
        imageClass="opacity-15"
        scrim="bg-[var(--color-perla)]/93"
      />
      <p class="slide-eyebrow text-center text-[var(--color-petrolio)] mb-4" data-reveal>
        IL PRINCIPIO GUIDA
      </p>
      <h2
        class="text-[var(--color-abisso)] mb-5 font-[family-name:var(--font-display)]"
        style="font-size: clamp(2.2rem, 4vw, 3.8rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Non sostituire.<br/>Connettere.
      </h2>
      <p
        class="text-[var(--color-grigio-500)] leading-relaxed max-w-3xl mx-auto mb-5"
        style="font-size: clamp(1.05rem, 1.3vw, 1.2rem);"
        data-reveal
        data-reveal-delay="0.18"
      >
        Il CRM resta il sistema di relazione. Il data lake resta la casa dei dati, con le audience
        che si compongono <em>federate</em>, senza duplicare nulla. Il log tecnico resta la fonte di
        verità: viene ingerito, non aggirato. Adobe è il layer di esperienza e intelligenza
        che li fa parlare.
      </p>

      <div class="flex items-center justify-center gap-4 mb-4" data-reveal data-reveal-delay="0.28" aria-hidden="true">
        <span class="px-4 py-2 bg-white border border-[var(--color-grigio-200)] rounded-sm text-[0.95rem] font-semibold text-[var(--color-grigio-500)] font-[family-name:var(--font-display)]">CRM</span>
        <span class="px-4 py-2 bg-white border border-[var(--color-grigio-200)] rounded-sm text-[0.95rem] font-semibold text-[var(--color-grigio-500)] font-[family-name:var(--font-display)]">Data lake</span>
        <span class="px-4 py-2 bg-white border border-[var(--color-grigio-200)] rounded-sm text-[0.95rem] font-semibold text-[var(--color-grigio-500)] font-[family-name:var(--font-display)]">Log tecnico</span>
        <span class="text-[var(--color-petrolio)] font-bold text-xl">→</span>
        <span class="px-5 py-2 bg-[var(--color-petrolio)] rounded-sm text-[0.95rem] font-semibold text-white font-[family-name:var(--font-display)]">Adobe Experience Layer</span>
      </div>

      <div class="mt-2" data-reveal data-reveal-delay="0.38">
        <a
          href={href(base, '/evoluzione')}
          class="inline-flex items-center gap-3 px-8 py-2.5 text-base font-semibold tracking-wide bg-[var(--color-abisso)] text-[var(--color-perla)] hover:bg-[var(--color-lavagna)] transition-colors duration-300 font-[family-name:var(--font-display)]"
        >
          I vostri use case, evoluti
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
