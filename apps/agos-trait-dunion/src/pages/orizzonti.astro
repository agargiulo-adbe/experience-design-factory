---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const panorama = [
  {
    fase: 'Acquisition',
    items: [
      'Lookalike dai migliori clienti su paid media',
      'Prospect anonimi riconosciuti alla prima visita',
      'Visibilità nelle risposte AI (GEO)',
    ],
  },
  {
    fase: 'Conversion',
    items: [
      'Offerta pre-qualificata con tasso personalizzato',
      'Recupero abbandoni in tempo reale, multicanale',
      'Chi esita online viene accolto informato in filiale',
    ],
  },
  {
    fase: 'Customer base',
    items: [
      'Next best offer su tutto il portafoglio prodotti',
      'Life-event triggers: il credito quando nasce il bisogno',
      'Pagamento declinato → proposta di estensione, in secondi',
    ],
  },
  {
    fase: 'Retention',
    items: [
      'Churn score sui segnali di disengagement',
      'Riacquisto a fine piano di rimborso',
      'Comunicazioni di sicurezza che costruiscono fiducia',
    ],
  },
];
---
<BaseLayout
  title="Nuovi orizzonti"
  description="Dal playbook Adobe per il Financial Services: offerte pre-qualificate, life-event triggers, data collaboration con i partner, prospect cookieless."
  pageSolutions={['rtcdp', 'data-collab']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/valore')}
    prevHref={href(base, '/trait-dunion')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <div slot="backdrop" class="tdu-bg oriz-cover-bg" aria-hidden="true">
        <svg class="oriz-reach" viewBox="0 0 1200 675" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <!-- the acqua current reaching forward toward the horizon -->
          <line x1="0" y1="512" x2="1200" y2="300" stroke="rgba(6,171,184,0.28)" stroke-width="2" />
          <line x1="0" y1="548" x2="1200" y2="352" stroke="rgba(6,171,184,0.20)" stroke-width="2" />
          <line x1="0" y1="476" x2="1200" y2="248" stroke="rgba(6,171,184,0.16)" stroke-width="2" />
          <line x1="0" y1="584" x2="1200" y2="404" stroke="rgba(245,124,0,0.14)" stroke-width="2" />
          <circle cx="1200" cy="300" r="4" fill="rgba(6,171,184,0.55)" />
          <circle cx="1200" cy="352" r="3" fill="rgba(6,171,184,0.40)" />
          <circle cx="1200" cy="248" r="3" fill="rgba(6,171,184,0.32)" />
        </svg>
      </div>
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-orizzonte')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-primary)]/88"
      />
      <CoverHero
        eyebrow="05 · Orizzonti"
        numeral="05"
        title="Quello che ancora non fate"
        lead="Il playbook Adobe per il Financial Services raccoglie i casi d'uso che i leader del credito stanno già mettendo in produzione. Quattro meritano la vostra attenzione, e tutti poggiano sulle stesse fondamenta."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Offerta pre-qualificata ───────────────────────── -->
    <Slide id="slide-prequalified" bg="primary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="tdu-bg" aria-hidden="true"></div>
      <div class="flex items-center justify-center gap-3 mb-3 flex-wrap" data-reveal>
        <p class="slide-eyebrow text-[var(--accent-primary)]">ORIZZONTE 1 · CONVERSION</p>
        <span class="badge bg-[var(--accent-primary)]/12 text-[var(--accent-primary)]">Real-Time CDP + Journey Optimizer</span>
      </div>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        L'offerta pre-qualificata,<br/>al momento giusto
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-5"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Il cliente che rientra in area personale non vede un banner generico: vede
        <em>la sua</em> offerta: importo massimo pre-approvato e rata calcolata sul suo
        profilo. La distanza tra «pubblicità» e «proposta» si azzera.
      </p>

      <div class="w-full max-w-4xl mx-auto grid md:grid-cols-[1.2fr_1fr] gap-4 items-stretch" data-reveal data-reveal-delay="0.22">
        <div class="tdu-panel tdu-panel--acqua justify-center">
          <p class="tdu-tag mb-2.5">Come funziona</p>
          <ul class="space-y-2">
            {[
              'L\'eligibility calcolata sui vostri modelli entra nel profilo cliente',
              'Area personale, DEM e app mostrano la stessa offerta coerente',
              'Il call center e la filiale la vedono, e possono chiuderla',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-normal text-[var(--color-grigio-200)]">
                <span class="tdu-node mt-1.5" aria-hidden="true"/>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="tdu-panel tdu-panel--arancio text-center items-center justify-center">
          <p class="data-number text-[var(--accent-primary)] mb-1" data-display>+120%</p>
          <p class="text-[0.98rem] font-medium text-[var(--ink-primary)] leading-snug mb-1.5">conversion rate sulla landing dinamica con tasso personalizzato</p>
          <p class="tdu-src">Banca europea · playbook FSI Adobe · risultato non garantito</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Life events + NBO ─────────────────────────────── -->
    <Slide id="slide-life-nbo" bg="secondary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="tdu-bg-soft" aria-hidden="true"></div>
      <div class="flex items-center justify-center gap-3 mb-3 flex-wrap" data-reveal>
        <p class="slide-eyebrow text-[var(--accent-secondary)]">ORIZZONTE 2 · CUSTOMER BASE</p>
        <span class="badge bg-[var(--accent-secondary)]/15 text-[var(--accent-secondary)]">Real-Time CDP + AJO Decisioning</span>
      </div>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Il credito arriva quando nasce il bisogno
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-4"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        I cluster fotografano il passato; i trigger intercettano il presente: l'auto
        nuova, la casa, il pagamento declinato. La next best offer sceglie prodotto,
        tono e canale, con la pressione sotto controllo.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-4" data-reveal data-reveal-delay="0.22">
        {[
          { mark: 'A', title: 'Life-event trigger', desc: 'Nuova casa, nuovo lavoro, famiglia che cresce: il segnale attiva il journey giusto, prestito, CQS o assicurazione.' },
          { mark: 'B', title: 'Pagamento declinato', desc: 'Un momento negativo diventa servizio: proposta di estensione o micro-prestito in pochi secondi, sul canale preferito.' },
          { mark: 'C', title: 'Next best offer', desc: 'Una libreria unica di offerte con eligibility, priorità e capping: ogni cliente vede la migliore per lui, mai troppe.' },
        ].map((c) => (
          <div class="tdu-card">
            <span class="tdu-mark" aria-hidden="true">{c.mark}</span>
            <p class="tdu-card-title">{c.title}</p>
            <p class="tdu-card-body">{c.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-4 text-center tdu-src">
        Pattern dal playbook FSI Adobe · life-event triggers e payment denial · KPI illustrativi
      </p>
    </Slide>

    <!-- ── SLIDE 3: Data Collaboration con i partner ──────────────── -->
    <Slide id="slide-collaboration" bg="primary" align="center" data-solution="data-collab">
      <div slot="backdrop" class="tdu-bg" aria-hidden="true"></div>
      <div class="flex items-center justify-center gap-3 mb-3 flex-wrap" data-reveal>
        <p class="slide-eyebrow text-[var(--accent-primary)]">ORIZZONTE 3 · L'ECOSISTEMA PARTNER</p>
        <span class="badge bg-[var(--accent-primary)]/12 text-[var(--accent-primary)]">Real-Time CDP Collaboration</span>
      </div>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        La forza dei partner,<br/>senza scambiarsi dati personali
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-5"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Banche socie, dealer, insegne della distribuzione: la rete è il vostro
        DNA. La collaboration privacy-first fa incontrare le audience in una clean
        room, senza che nessuna PII cambi casa. E ogni match si misura.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-4" data-reveal data-reveal-delay="0.22">
        {[
          { mark: '1', title: 'Suppression intelligente', desc: 'Chi è già cliente esce dalle campagne di acquisizione: la spesa media insegue solo prospect veri.' },
          { mark: '2', title: 'Audience congiunte', desc: 'Con banche partner e retailer: segmenti condivisi per campagne co-branded, governati e misurabili.' },
          { mark: '3', title: 'Il customer match, fatto bene', desc: 'Test con gruppo di controllo dentro la piattaforma: l\'uplift si legge nel funnel, non si presume.' },
        ].map((c) => (
          <div class="tdu-card">
            <span class="tdu-mark" aria-hidden="true">{c.mark}</span>
            <p class="tdu-card-title" style="color: var(--accent-primary);">{c.title}</p>
            <p class="tdu-card-body">{c.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-4 text-center tdu-src">
        Clean room GDPR-compliant · nessuna condivisione di PII tra le parti
      </p>
    </Slide>

    <!-- ── SLIDE 4: Prospect anonimi + GEO ────────────────────────── -->
    <Slide id="slide-anonymous" bg="secondary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="tdu-bg-soft" aria-hidden="true"></div>
      <div class="flex items-center justify-center gap-3 mb-3 flex-wrap" data-reveal>
        <p class="slide-eyebrow text-[var(--accent-secondary)]">ORIZZONTE 4 · ACQUISITION</p>
        <span class="badge bg-[var(--accent-secondary)]/15 text-[var(--accent-secondary)]">RT-CDP + Target + Brand Visibility</span>
      </div>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Clienti nuovi davvero —<br/>anche dove non guardate ancora
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-5"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        L'obiettivo dichiarato è l'open market: persone che oggi si finanziano
        altrove. Due leve nuove: il traffico anonimo che diventa riconoscibile
        e la ricerca che si sposta dentro le risposte dell'AI.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4" data-reveal data-reveal-delay="0.22">
        <div class="tdu-panel tdu-panel--acqua">
          <p class="tdu-card-title mb-2">Il 97% che non si dichiara</p>
          <p class="tdu-card-body mb-2.5">
            La quasi totalità dei visitatori resta anonima. Lookalike dai migliori clienti,
            first-party data e segmentazione in millisecondi personalizzano la prima
            visita, nel rispetto del consenso e su dominio di prima parte.
          </p>
          <p class="tdu-src">Pattern «unknown to known» · playbook FSI Adobe</p>
        </div>
        <div class="tdu-panel tdu-panel--arancio">
          <p class="tdu-card-title mb-2">«Qual è il miglior prestito personale?»</p>
          <p class="tdu-card-body mb-2.5">
            Sempre più spesso questa domanda si fa a un assistente AI, non a un motore di
            ricerca. Adobe Brand Visibility misura come i modelli descrivono la vostra offerta
            e suggerisce le correzioni per essere citati, e citati bene.
          </p>
          <p class="tdu-src">Generative Engine Optimization · Adobe Brand Visibility</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Panorama ──────────────────────────────────────── -->
    <Slide id="slide-panorama" bg="primary" align="center">
      <div slot="backdrop" class="tdu-bg" aria-hidden="true"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        IL PANORAMA COMPLETO
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un funnel, dodici possibilità
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-2xl mx-auto mb-5"
        style="font-size: clamp(0.95rem, 1.1vw, 1.05rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Nessuna di queste è fantascienza: sono pattern documentati del playbook FSI,
        in produzione presso istituzioni finanziarie comparabili. Si scelgono insieme,
        si sequenziano con la roadmap.
      </p>

      <div class="w-full max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-3" data-reveal data-reveal-delay="0.22">
        {panorama.map((col) => (
          <div class="tdu-panel oriz-panorama-col text-left">
            <div class="oriz-panorama-head">
              <span class="tdu-node" aria-hidden="true"/>
              <p class="tdu-tag">{col.fase}</p>
            </div>
            <ul class="space-y-2">
              {col.items.map((item) => (
                <li class="flex items-start gap-2 text-[0.9rem] leading-normal text-[var(--color-grigio-200)]">
                  <span class="oriz-dot mt-1.5" aria-hidden="true"/>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* Orizzonti — the acqua current reaching forward toward the horizon */
  .oriz-cover-bg { position: absolute; inset: 0; overflow: hidden; }
  .oriz-reach {
    position: absolute; inset: 0; width: 100%; height: 100%;
    opacity: 0.9;
  }

  /* Panorama columns — a woven header (current node + phase tag) reading as
     four directions the current reaches into. */
  .oriz-panorama-col { padding: 1rem 1.05rem 1.1rem; gap: 0; }
  .oriz-panorama-head {
    display: flex; align-items: center; gap: 0.55rem;
    padding-bottom: 0.7rem; margin-bottom: 0.85rem;
    border-bottom: 1px solid rgba(6, 171, 184, 0.4);
  }
  .oriz-dot {
    flex-shrink: 0; width: 4px; height: 4px; border-radius: 50%;
    background: var(--color-arancio);
  }
</style>
