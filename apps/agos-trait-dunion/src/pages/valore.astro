---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const kpi = [
  {
    value: '+10–20%',
    label: 'recupero degli abbandoni di form',
    sub: 'journey real-time multicanale vs recall flat, pattern playbook FSI',
  },
  {
    value: '−X%',
    label: 'spesa media su chi è già cliente',
    sub: 'l\'overlap misurato diventa suppression: la X la scopriamo insieme, è il primo test',
  },
  {
    value: '+1 prodotto',
    label: 'per cliente sul ciclo di vita',
    sub: 'next best offer con eligibility e capping vs campagne monoprodotto',
  },
  {
    value: 'giorni → ore',
    label: 'time-to-market di DEM e varianti',
    sub: 'generazione on-brand con controlli di compliance integrati',
  },
];
---
<BaseLayout
  title="Il valore"
  description="Evidence-based: ogni claim è un test misurabile con gruppo di controllo, riconciliato con il log tecnico. KPI modellati e dichiarati come illustrativi."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/roadmap')}
    prevHref={href(base, '/orizzonti')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dashboard')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <CoverHero
        eyebrow="06 · Valore"
        numeral="06"
        title="Misurato alla vostra maniera"
        lead="Niente atti di fede: ogni beneficio qui dentro è un'ipotesi da verificare con un test controllato, riconciliato con il vostro log tecnico. Se un'iniziativa non è sostenibile, si spegne, come avete sempre fatto."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il metodo ─────────────────────────────────────── -->
    <Slide id="slide-metodo" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        IL METODO PRIMA DEI NUMERI
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un'ipotesi, un test con gruppo di controllo, una decisione.
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-5"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Avete già dimostrato di saper spegnere ciò che non sposta i numeri: è una
        forza, non un limite. La differenza, domani, è che ogni test nasce già
        strumentato: gruppo di controllo, funnel completo, esito nel venduto.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-4" data-reveal data-reveal-delay="0.22">
        {[
          { num: '1', title: 'Un\'ipotesi per volta', desc: 'Ogni use case parte con una metrica dichiarata prima di cominciare: cosa deve muoversi, di quanto, entro quando.' },
          { num: '2', title: 'Controllo sempre', desc: 'Metà del cluster vede l\'evoluzione, metà il processo attuale. L\'uplift è la differenza, non un\'impressione.' },
          { num: '3', title: 'Il log come giudice', desc: 'La misura si riconcilia con il log tecnico, la fonte su cui l\'azienda già decide. Nessuna doppia verità.' },
        ].map((m) => (
          <div class="px-5 py-4 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] text-[1.5rem] leading-none mb-2">{m.num}</p>
            <p class="text-[1.02rem] font-semibold text-[var(--ink-primary)] mb-1.5 font-[family-name:var(--font-display)]">{m.title}</p>
            <p class="text-[0.92rem] text-[var(--color-grigio-200)] leading-snug">{m.desc}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: I KPI attesi ──────────────────────────────────── -->
    <Slide id="slide-kpi" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        DOVE CERCARE IL VALORE
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Quattro ipotesi di valore, da testare
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-2xl mx-auto mb-4"
        style="font-size: clamp(0.95rem, 1.1vw, 1.05rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Ordini di grandezza dal playbook FSI e dai benchmark Adobe, dichiaratamente
        illustrativi. I vostri numeri li scriveranno i test.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-3" data-reveal data-reveal-delay="0.22">
        {kpi.map((k) => (
          <div class="flex items-center gap-5 px-5 py-2.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none flex-shrink-0" style="font-size: clamp(1.4rem, 2.4vw, 2rem); min-width: 7.5rem;">
              {k.value}
            </p>
            <div class="min-w-0">
              <p class="text-[1rem] font-medium text-[var(--ink-primary)] leading-snug mb-1">{k.label}</p>
              <p class="text-[0.85rem] text-[var(--color-grigio-300)] leading-snug">{k.sub}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-3 text-center text-[0.75rem] tracking-widest uppercase text-[var(--color-grigio-300)]">
        Valori illustrativi, non impegnativi · da validare con test controllati sul vostro funnel
      </p>
    </Slide>

    <!-- ── SLIDE 3: Sostenibilità ─────────────────────────────────── -->
    <Slide id="slide-sostenibilita" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-orizzonte')}
        imageClass="opacity-15"
        scrim="bg-[var(--color-perla)]/93"
      />
      <p class="slide-eyebrow text-center text-[var(--color-petrolio)] mb-4" data-reveal>
        SOSTENIBILITÀ FINANZIARIA
      </p>
      <h2
        class="text-[var(--color-abisso)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Nessun big bang.<br/>Ogni fase paga la successiva.
      </h2>
      <p
        class="text-[var(--color-grigio-500)] leading-relaxed max-w-3xl mx-auto mb-5"
        style="font-size: clamp(1rem, 1.2vw, 1.15rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Si parte dal layer di analisi, che lavora sui dati che già esistono e produce
        il primo valore misurabile: l'overlap, il fallout, l'attribution. Quel valore
        finanzia e giustifica il passo dopo. Se un passo non regge la prova dei numeri,
        la roadmap si ferma lì: è il vostro criterio, ed è anche il nostro.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap mb-4" data-reveal data-reveal-delay="0.25" aria-hidden="true">
        {['Misura', 'Decisione', 'Evoluzione', 'Scala'].map((step, i, arr) => (
          <>
            <span class="px-4 py-2 bg-white border border-[var(--color-grigio-200)] rounded-sm text-[0.95rem] font-semibold text-[var(--color-petrolio)] font-[family-name:var(--font-display)]">{step}</span>
            {i < arr.length - 1 && <span class="text-[var(--color-petrolio)] font-bold">→</span>}
          </>
        ))}
      </div>

      <div class="mt-2" data-reveal data-reveal-delay="0.35">
        <a
          href={href(base, '/roadmap')}
          class="inline-flex items-center gap-3 px-8 py-2.5 text-base font-semibold tracking-wide bg-[var(--color-abisso)] text-[var(--color-perla)] hover:bg-[var(--color-lavagna)] transition-colors duration-300 font-[family-name:var(--font-display)]"
        >
          La roadmap, sequenziata
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
