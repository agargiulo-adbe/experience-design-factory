---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const fasi = [
  {
    anno: '2026',
    verbo: 'Preparare',
    desc: 'Il layer di analisi sopra lo stack attuale: CJA su log tecnico, Analytics e venduto. Assessment dei tracciamenti. Experimentation sulle landing.',
    tags: ['CJA', 'Target', 'Assessment'],
    accent: true,
  },
  {
    anno: '2027',
    verbo: 'Migrare evolvendo',
    desc: 'La migrazione del campaign management diventa evoluzione: continuità batch, journey real-time dove il valore è dimostrato, in sequenza con il go-live.',
    tags: ['AJO', 'Orchestrated Campaigns'],
    accent: false,
  },
  {
    anno: '2028',
    verbo: 'Scalare',
    desc: 'Il profilo unificato apre l\'open market: prospect anonimi, collaboration con i partner, next best offer su tutto il portafoglio.',
    tags: ['RT-CDP', 'Collaboration'],
    accent: false,
  },
];

const nextSteps = [
  { num: '01', title: 'Assessment dei tracciamenti', desc: 'Mappare insieme ciò che Analytics già raccoglie: cosa c\'è, cosa manca, cosa serve alle campagne. Due settimane, zero impatti.' },
  { num: '02', title: 'Il funnel end-to-end su dati reali', desc: 'Un proof-of-value di CJA sul funnel prestito personale: log tecnico + venduto, overlap e fallout misurati per la prima volta.' },
  { num: '03', title: 'Il primo test controllato', desc: 'Un A/B sulle landing social, form completo contro form leggero, misurato e riconciliato con il log: il metodo, dimostrato.' },
];
---
<BaseLayout
  title="Roadmap"
  description="2026 preparare, 2027 migrare evolvendo, 2028 scalare: la roadmap Adobe sequenziata con la trasformazione tecnologica, e i primi tre passi concreti."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/')}
    prevHref={href(base, '/valore')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-orizzonte')}
        imageClass="opacity-18"
        scrim="bg-[var(--surface-primary)]/88"
      />
      <CoverHero
        eyebrow="07 · Roadmap"
        numeral="07"
        title="Il terreno si prepara adesso"
        lead="La trasformazione detta i tempi delle piattaforme core, e va rispettata. Ma l'evoluzione dell'esperienza cliente ha una corsia propria: parte dai dati che esistono già e arriva puntuale all'appuntamento del 2027."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Le tre fasi ───────────────────────────────────── -->
    <Slide id="slide-3fasi" bg="primary" align="center">
      <div slot="backdrop" class="tdu-bg"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        TRE FASI, UNA SEQUENZA
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        In sequenza con la trasformazione, mai in competizione
      </h2>

      <!-- Timeline device: the acqua current runs left→right through the three phases,
           with milestone nodes woven at each phase. The trait d'union over time. -->
      <div class="tl w-full max-w-6xl mx-auto" data-reveal data-reveal-delay="0.18">
        <div class="tl-track" aria-hidden="true">
          <span class="tl-current"></span>
          {fasi.map((f, i) => (
            <span
              class={['tdu-node tl-node', f.accent ? 'tl-node--live' : ''].join(' ')}
              style={`left: ${16.66 + i * 33.33}%;`}
            ></span>
          ))}
          <span class="tdu-node tdu-node--arancio tl-node tl-node--end" style="left: 100%;"></span>
        </div>
        <div class="tl-phases">
          {fasi.map((f) => (
            <div class={['tl-phase', f.accent ? 'tl-phase--live' : ''].join(' ')}>
              <div class="tl-year-row">
                <p class={[
                  'font-[family-name:var(--font-display)] font-bold leading-none',
                  f.accent ? 'text-[var(--accent-primary)]' : 'text-[var(--ink-primary)]',
                ].join(' ')} style="font-size: clamp(1.4rem, 2.2vw, 1.9rem);">{f.anno}</p>
                <p class="text-[0.85rem] font-semibold tracking-wide uppercase text-[var(--color-grigio-300)] mt-1">{f.verbo}</p>
              </div>
              <p class="text-[0.95rem] text-[var(--color-grigio-200)] mb-3" style="line-height: 1.5;">{f.desc}</p>
              <div class="flex gap-1.5 items-center flex-wrap">
                {f.tags.map((t) => (
                  <span class="badge bg-[var(--accent-primary)]/12 text-[var(--accent-primary)]">{t}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
      <p class="mt-5 text-center text-[0.75rem] tracking-widest uppercase text-[var(--color-grigio-300)]">
        Sequenza indicativa · da allineare ai milestone del programma di trasformazione
      </p>
    </Slide>

    <!-- ── SLIDE 2: Perché la fase 1 non pesa sull'IT ─────────────── -->
    <Slide id="slide-fase1" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        FASE 1 · DEEP-DIVE
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Perché il 2026 non pesa sull'IT
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-5"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        La fase 1 è progettata attorno a un vincolo dichiarato: la capacità di delivery
        è tutta sulla migrazione. Tre scelte tecniche la rendono possibile comunque.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-4" data-reveal data-reveal-delay="0.22">
        {[
          { title: 'I dati non si spostano', desc: 'Connettori out-of-the-box, SFTP e flussi già esistenti. Le audience si compongono federate sul data lake: si legge, non si duplica.' },
          { title: 'Nessun nuovo tracciamento', desc: 'Il log tecnico e i tag Analytics già mappati sono le fonti. L\'assessment fa ordine, non aggiunge cantieri.' },
          { title: 'Autonomia del marketing', desc: 'Query, viste e segmenti si costruiscono da interfaccia. La BI del journey corre alla velocità del marketing.' },
        ].map((c) => (
          <div class="px-5 py-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-[1.02rem] font-semibold text-[var(--accent-primary)] mb-1.5 font-[family-name:var(--font-display)]">{c.title}</p>
            <p class="text-[0.92rem] text-[var(--color-grigio-200)] leading-snug">{c.desc}</p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: 2027 — migrare evolvendo ──────────────────────── -->
    <Slide id="slide-fase2" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        FASE 2 · DEEP-DIVE
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        La stessa migrazione. Due destinazioni possibili.
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-4"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Nel 2027 il campaign management si sposta comunque. La differenza è dove atterra,
        e la preparazione del 2026 è ciò che rende la seconda strada realistica.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4" data-reveal data-reveal-delay="0.22">
        <div class="px-5 py-3 oggi-card border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-[0.78rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-2">Lift & shift</p>
          <ul class="space-y-1.5">
            {[
              'Stessi use case, stessa logica, nuova casa',
              'L\'evoluzione resta un progetto futuro, da giustificare di nuovo',
              'Il debito funzionale trasloca insieme alla piattaforma',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-snug text-[var(--color-grigio-200)]">
                <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-grigio-400)]" aria-hidden="true"/>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="px-5 py-3 domani-card border border-[var(--accent-primary)]/30 rounded-sm text-left">
          <p class="text-[0.78rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-2">Migrazione evolutiva</p>
          <ul class="space-y-1.5">
            {[
              'Orchestrated Campaigns: continuità piena per chi opera ogni giorno',
              'I use case validati in fase 1 salgono già orchestrati e misurati',
              'Il real-time si accende caso per caso, dove il test lo giustifica',
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-snug text-[var(--color-grigio-200)]">
                <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"/>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="mt-3 text-center text-[0.75rem] tracking-widest uppercase text-[var(--color-grigio-300)]" data-reveal data-reveal-delay="0.32">
        Stesso sforzo di migrazione, valore diverso all'arrivo
      </p>
    </Slide>

    <!-- ── SLIDE 4: Invito ────────────────────────────────────────── -->
    <Slide id="slide-invito" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-due-mondi')}
        imageClass="opacity-10"
        scrim="bg-[var(--color-petrolio)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--color-perla)]/70 mb-4" data-reveal>
        I PROSSIMI TRE PASSI
      </p>
      <h2
        class="font-[family-name:var(--font-display)] text-[var(--color-perla)] mb-4 max-w-3xl"
        style="font-size: clamp(2rem, 3.4vw, 3rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Due mondi. Un trait d'union.<br/>Si comincia da qui.
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-3 mb-4"
        data-reveal
        data-reveal-delay="0.18"
      >
        {nextSteps.map((s) => (
          <div class="journey-card px-5 py-4 border border-[var(--color-perla)]/25 rounded-sm text-left text-[var(--color-perla)]">
            <p class="text-xs font-semibold text-[var(--color-perla)]/50 mb-1 font-[family-name:var(--font-display)] tabular-nums">{s.num}</p>
            <p class="text-[1.05rem] font-semibold mb-1.5 font-[family-name:var(--font-display)]">{s.title}</p>
            <p class="text-[0.9rem] text-[var(--color-perla)]/75 leading-snug">{s.desc}</p>
          </div>
        ))}
      </div>

      <p
        class="text-[clamp(0.95rem,1.1vw,1.05rem)] text-[var(--color-perla)]/80 max-w-2xl mb-4"
        data-reveal
        data-reveal-delay="0.28"
      >
        Nessuna decisione di piattaforma oggi: tre passi piccoli, misurabili,
        reversibili, perfettamente nello stile della casa.
      </p>

      <div data-reveal data-reveal-delay="0.36">
        <a
          href={href(base, '/')}
          class="inline-flex items-center gap-3 px-9 py-2.5 text-[clamp(1rem,1.2vw,1.15rem)] font-semibold tracking-wide bg-[var(--color-perla)] text-[var(--color-abisso)] hover:bg-white transition-colors duration-300 font-[family-name:var(--font-display)]"
        >
          Torna alla cover
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>

  <style>
    /* Roadmap timeline device — the acqua current (trait d'union) runs left→right
       through the phases, milestone nodes woven at each. Explicit rgba only. */
    .tl { display: flex; flex-direction: column; }

    .tl-track {
      position: relative;
      height: 15px;
      margin-bottom: 1.1rem;
    }
    /* The connecting current — the acqua line running the full width */
    .tl-current {
      position: absolute;
      left: 0; right: 0; top: 50%;
      height: 2px;
      transform: translateY(-50%);
      background: linear-gradient(
        90deg,
        rgba(6, 171, 184, 0.35) 0%,
        rgba(6, 171, 184, 0.9) 45%,
        rgba(245, 124, 0, 0.9) 100%
      );
      border-radius: 2px;
    }
    /* Milestone nodes sit on the current, one at each phase-column centre
       (16.66% / 50% / 83.33%), plus the arancio connected end-state at 100%.
       Each is absolutely positioned via an inline `left`. */
    .tl-node {
      position: absolute;
      top: 50%;
      z-index: 1;
      width: 12px; height: 12px;
      transform: translate(-50%, -50%);
      box-shadow: 0 0 0 3px var(--surface-primary);
    }
    .tl-node--live {
      width: 15px; height: 15px;
      box-shadow: 0 0 0 3px var(--surface-primary), 0 0 12px 0 rgba(6, 171, 184, 0.55);
    }

    .tl-phases {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      text-align: left;
    }
    .tl-phase {
      background: rgba(10, 19, 21, 0.5);
      border: 1px solid var(--line-subtle);
      border-radius: 8px;
      padding: 1.05rem 1.15rem 1.1rem;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }
    .tl-phase--live {
      background: rgba(6, 171, 184, 0.08);
      border-color: rgba(6, 171, 184, 0.35);
      box-shadow: inset 0 2px 0 0 var(--color-acqua);
    }
    .tl-year-row {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin-bottom: 0.65rem;
    }

    @media (max-width: 900px) {
      .tl-track { display: none; }
      .tl-phases { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
