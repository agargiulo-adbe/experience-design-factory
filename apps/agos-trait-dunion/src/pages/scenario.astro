---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgosNavigation from '../components/AgosNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const mondi = [
  {
    label: 'Il mondo digitale',
    accent: 'acqua',
    who: 'Open market · prospect',
    items: [
      'Search e display negoziati in autonomia',
      'Il log tecnico vede il 100% delle richieste',
      'Ragiona per sessioni, click e canali',
    ],
  },
  {
    label: 'Il mondo della customer base',
    accent: 'arancio',
    who: 'Clienti noti · cross-sell',
    items: [
      'Cluster sollecitati ogni mese su più canali',
      'DEM, SMS, telemarketing e rete fisica',
      'Ragiona per anagrafiche, prodotti, propensione',
    ],
  },
];

const pressioni = [
  { value: '19%', label: 'dei prestiti personali è ormai collocato 100% online', src: 'Osservatorio Assofin–CRIF–Prometeia, giu 2026' },
  { value: '+4,9%', label: 'crescita del credito al consumo nel Q1 2026', src: 'Osservatorio Assofin–CRIF–Prometeia, giu 2026' },
  { value: 'CCD2', label: 'più trasparenza e merito creditizio: vince chi conosce meglio il cliente', src: 'Direttiva UE 2023/2225' },
];
---
<BaseLayout
  title="Il paradosso dei due mondi"
  description="Il digitale convince, la filiale registra il merito. Due mondi che non si parlano — e un overlap che nessuno misura."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AgosNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/fondamenta')}
    prevHref={href(base, '/')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-due-mondi')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <CoverHero
        eyebrow="01 · Scenario"
        numeral="01"
        title="Il paradosso dei due mondi"
        lead="Ogni giorno il digitale convince clienti che poi firmano in filiale. Ogni giorno la customer base riceve solleciti mentre l'advertising insegue le stesse persone. Nessuno, oggi, può misurarlo."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Elisa ─────────────────────────────────────────── -->
    <Slide id="slide-elisa" bg="primary" align="split">
      <div class="w-full flex-1 min-h-0 grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="flex items-center justify-center" data-reveal>
          <div class="relative overflow-hidden rounded-sm mx-auto" style="width:min(100%,420px); aspect-ratio:4/5; height:min(500px,58dvh);">
            <MediaSlot {...mediaProps('persona-elisa')} fill objectPosition="50% 30%" />
          </div>
        </div>

        <div class="text-left">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>
            STORIA DI ELISA · IL VIAGGIO DI UNA PRATICA
          </p>
          <h2
            class="text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.1"
          >
            Elisa, 34 anni.<br />Un progetto da finanziare.
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed mb-6"
            style="font-size: clamp(1rem, 1.4vw, 1.25rem);"
            data-reveal
            data-reveal-delay="0.2"
          >
            Cerca «prestito personale 12.000 euro», clicca un annuncio, prova il simulatore
            di rata, inizia la richiesta online. All'ultimo passo esita — è una firma
            importante. Tre giorni dopo entra nella filiale vicino casa e completa lì la
            sua pratica, con un consulente.
          </p>
          <div
            class="mt-8 flex items-start gap-4 p-4 bg-[var(--surface-secondary)] border-l-2 border-[var(--accent-secondary)] rounded-r-sm"
            data-reveal
            data-reveal-delay="0.4"
          >
            <div class="flex-shrink-0 size-9 rounded-full bg-[var(--accent-secondary)]/15 flex items-center justify-center font-bold text-[var(--accent-secondary)] font-[family-name:var(--font-display)]">
              !
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-[var(--ink-tertiary)] mb-1">Nei sistemi, oggi</p>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">
                La pratica di Elisa nasce come <strong class="text-[var(--ink-primary)]">«rete fisica»</strong>.
                La campagna digitale che l'ha convinta non riceverà mai il merito —
                e il suo percorso online resta invisibile al consulente che l'ha accolta.
              </p>
            </div>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: I due mondi ───────────────────────────────────── -->
    <Slide id="slide-due-mondi" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        DUE ECCELLENZE, ZERO PONTI
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Due mondi che funzionano. Separatamente.
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-2xl mx-auto mb-3.5"
        style="font-size: clamp(0.95rem, 1.1vw, 1.05rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Uno parla la lingua dei click, l'altro quella delle anagrafiche —
        e tra i due manca il trait d'union.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {mondi.map((m) => (
          <div class={[
            'px-5 py-2.5 bg-[var(--surface-secondary)] border-t-2 rounded-sm text-left',
            m.accent === 'acqua' ? 'border-[var(--accent-primary)]' : 'border-[var(--accent-secondary)]',
          ].join(' ')}>
            <div class="flex items-baseline justify-between gap-3 mb-1 flex-wrap">
              <p class="text-[1.1rem] font-semibold text-[var(--ink-primary)] font-[family-name:var(--font-display)]">{m.label}</p>
              <p class={[
                'text-[0.75rem] font-bold tracking-widest uppercase',
                m.accent === 'acqua' ? 'text-[var(--accent-primary)]' : 'text-[var(--accent-secondary)]',
              ].join(' ')}>{m.who}</p>
            </div>
            <ul class="space-y-1.5 mt-2.5">
              {m.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.95rem] leading-snug text-[var(--color-grigio-200)]">
                  <span class={[
                    'flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full',
                    m.accent === 'acqua' ? 'bg-[var(--accent-primary)]' : 'bg-[var(--accent-secondary)]',
                  ].join(' ')} aria-hidden="true"/>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-2.5 max-w-3xl mx-auto px-5 py-1.5 bg-[var(--accent-primary)]/8 border border-[var(--accent-primary)]/25 rounded-sm" data-reveal data-reveal-delay="0.35">
        <p class="text-[0.95rem] text-[var(--color-grigio-200)] leading-snug">
          <strong class="text-[var(--ink-primary)]">Il costo dell'assenza di ponte:</strong> overlap invisibile tra
          advertising e customer base, pressione commerciale non coordinata, attribution che si ferma
          al canale in cui la pratica viene caricata.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Il paradosso + la pressione del mercato ───────── -->
    <Slide id="slide-paradosso" bg="secondary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        IL PARADOSSO
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Più investi online, più rischi di sollecitare chi è già cliente
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-4"
        style="font-size: clamp(0.98rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Senza una misura dell'overlap, parte della spesa insegue persone che la
        customer base sta già sollecitando — mentre il mercato accelera sul digitale.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid grid-cols-3 gap-4"
        data-reveal
        data-reveal-delay="0.22"
      >
        {pressioni.map((p) => (
          <div class="text-center px-4 py-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-2"
              style="font-size: clamp(1.7rem, 3vw, 2.5rem);"
            >
              {p.value}
            </p>
            <p class="text-[0.95rem] text-[var(--ink-primary)] leading-snug mb-2">{p.label}</p>
            <p class="text-[0.75rem] tracking-wide uppercase text-[var(--color-grigio-300)]">{p.src}</p>
          </div>
        ))}
      </div>

      <p class="mt-4 text-center max-w-3xl mx-auto text-[clamp(1rem,1.2vw,1.15rem)] text-[var(--color-grigio-200)] leading-relaxed" data-reveal data-reveal-delay="0.32">
        La domanda non è <em>se</em> i due mondi si sovrappongono.<br/>
        È <strong class="text-[var(--ink-primary)]">quanto</strong> — e quanto vale scoprirlo.
      </p>
    </Slide>

    <!-- ── SLIDE 4: L'opportunità ─────────────────────────────────── -->
    <Slide id="slide-opportunity" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-filiale')}
        imageClass="opacity-18"
        scrim="bg-[var(--color-perla)]/92"
      />
      <p class="slide-eyebrow text-center text-[var(--color-petrolio)] mb-4" data-reveal>
        L'OPPORTUNITÀ
      </p>
      <h2
        class="text-[var(--color-abisso)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Tre mosse. Nessuna richiede<br/>di aspettare la trasformazione.
      </h2>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-4 mb-4"
        data-reveal
        data-reveal-delay="0.18"
      >
        {[
          { num: '1', title: 'Misurare', desc: 'Una vista unica di digitale, filiali e call center — overlap incluso, fino a caricata e liquidata.' },
          { num: '2', title: 'Connettere', desc: 'Journey che seguono il cliente tra i due mondi: chi esita online viene accolto — informato — in filiale.' },
          { num: '3', title: 'Evolvere', desc: 'I use case di oggi che diventano orchestrazione intelligente, sopra lo stack che già usate.' },
        ].map((m) => (
          <div class="px-5 py-4 bg-[var(--color-bianco,#FFFFFF)] border border-[var(--color-grigio-200)] rounded-sm text-left" style="background:#FFFFFF;">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--color-petrolio)] text-[1.6rem] leading-none mb-2">{m.num}</p>
            <p class="text-[1.05rem] font-semibold text-[var(--color-abisso)] mb-1.5 font-[family-name:var(--font-display)]">{m.title}</p>
            <p class="text-[0.92rem] text-[var(--color-grigio-500)] leading-snug">{m.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-2" data-reveal data-reveal-delay="0.35">
        <a
          href={href(base, '/fondamenta')}
          class="inline-flex items-center gap-3 px-8 py-2.5 text-base font-semibold tracking-wide bg-[var(--color-abisso)] text-[var(--color-perla)] hover:bg-[var(--color-lavagna)] transition-colors duration-300 font-[family-name:var(--font-display)]"
        >
          Le fondamenta che avete già
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
