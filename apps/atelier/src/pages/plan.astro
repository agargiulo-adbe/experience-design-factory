                    en={f.name.en}
                    it={f.name.it}
                    fr={f.name.fr}
                    class="min-w-0 text-[var(--ink-primary)] font-semibold font-[family-name:var(--font-display)]"
                    style="font-size: 1.05rem; line-height: 1.2;"
                  />
                </div>
                <ul class="flex flex-wrap gap-1.5">
                  {items.en.map((_, k) => (
                    <li class="atl-kpi-pill">
                      <T as="span" en={items.en[k]} it={items.it[k]} fr={items.fr[k]} />
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>

        <div class="loom-quote w-full" data-reveal data-reveal-delay="0.28">
          <T
            as="p"
            en="Every milestone declares its targets in advance. The plan is falsifiable, on purpose."
