          data-reveal-delay="0.08"
        />

        <div class="grid md:grid-cols-2 gap-3" data-reveal data-reveal-delay="0.16">
          {kpiFamilies.map((f, i) => {
            const items = {
              en: f.metrics.en.split(' · '),
              it: f.metrics.it.split(' · '),
              fr: f.metrics.fr.split(' · '),
