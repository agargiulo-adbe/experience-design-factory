---
import BaseLayout from '../layouts/BaseLayout.astro';
import AtelierNavigation from '../components/AtelierNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const kickerStyle = 'font-size: clamp(0.8rem, 0.95vw, 0.95rem); letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; font-family: var(--font-body);';

const resources = [
  {
    mark: '01',
    width: '100%',
    name: {
      en: 'Enterprise AI licenses, tiered',
      it: 'Licenze AI enterprise, a livelli',
      fr: 'Licences IA enterprise, par paliers',
    },
    why: {
      en: 'Top tier for the core builders, mid tier for power creators, standard for pilot users. Billing follows real usage; the caps are ceilings, not spend.',
      it: 'Livello alto per i builder del nucleo, intermedio per i power creator, standard per gli utenti pilota. La fatturazione segue l’uso reale; i tetti sono limiti, non spesa.',
      fr: 'Palier haut pour l’équipe cœur, intermédiaire pour les power creators, standard pour les pilotes. La facturation suit l’usage réel&nbsp;; les plafonds sont des limites, pas une dépense.',
    },
  },
  {
    mark: '02',
    width: '55%',
    name: {
      en: 'Sponsored time',
      it: 'Tempo sponsorizzato',
      fr: 'Temps sponsorisé',
    },
    why: {
      en: 'An official allocation for the project lead, Solution Consultant hours for the Context Layer, one professional design review.',
      it: 'Un’allocazione ufficiale per il project lead, ore di Solution Consultant per il Context Layer, una design review professionale.',
      fr: 'Une allocation officielle pour le responsable du projet, des heures de Solution Consultant pour le Context Layer, une revue de design professionnelle.',
    },
  },
  {
    mark: '03',
    width: '35%',
    name: {
      en: 'Events',
      it: 'Eventi',
      fr: 'Événements',
    },
    why: {
      en: 'A hackathon day at milestone two; a demo pod and speaking submission at Adobe Summit 2027.',
      it: 'Una giornata di hackathon alla milestone due; un demo pod e una proposta di speech all’Adobe Summit 2027.',
      fr: 'Une journée de hackathon au jalon deux&nbsp;; un pod de démo et une proposition d’intervention à l’Adobe Summit 2027.',
    },
  },
  {
    mark: '04',
    width: '15%',
    name: {
      en: 'Infrastructure and tooling',
      it: 'Infrastruttura e tooling',
      fr: 'Infrastructure et outillage',
    },
    why: {
      en: 'Hosting, database, asset licensing, CI. Deliberately the smallest line on this slide.',
      it: 'Hosting, database, licenze degli asset, CI. Volutamente la voce più piccola di questa slide.',
      fr: 'Hébergement, base de données, licences d’assets, CI. Délibérément la plus petite ligne de cette slide.',
    },
  },
];

const moments = [
  {
    kicker: { en: 'Milestone 2', it: 'Milestone 2', fr: 'Jalon 2' },
    name: { en: 'Hackathon day', it: 'Giornata di hackathon', fr: 'Journée de hackathon' },
    body: {
      en: 'Adobians, partners and clients build experiences together for one day. The template gallery grows by ten, and the next wave of users leaves trained.',
      it: 'Adobiani, partner e clienti costruiscono esperienze insieme per un giorno. La galleria di template cresce di dieci modelli, e la nuova ondata di utenti esce già formata.',
      fr: 'Adobiens, partenaires et clients construisent des expériences ensemble pendant une journée. La galerie de templates gagne dix modèles, et la prochaine vague d’utilisateurs repart formée.',
    },
  },
  {
    kicker: { en: 'Milestone 3', it: 'Milestone 3', fr: 'Jalon 3' },
    name: { en: 'Adobe Summit 2027', it: 'Adobe Summit 2027', fr: 'Adobe Summit 2027' },
    body: {
      en: 'Las Vegas, March 22–25. A demo pod where visitors create an experience live, and a speaking submission telling how one person’s craft became a capability.',
      it: 'Las Vegas, 22–25 marzo. Un demo pod dove i visitatori creano un’esperienza dal vivo, e una proposta di speech che racconta come il mestiere di una persona è diventato una capability.',
      fr: 'Las Vegas, du 22 au 25 mars. Un pod de démo où les visiteurs créent une expérience en direct, et une proposition d’intervention qui raconte comment le métier d’une personne est devenu une capacité.',
    },
  },
];
---
<BaseLayout
  title="What it takes"
  description="What it takes — a small stack of asks, sized to the milestones they serve: tiered AI licenses, sponsored time, two funded moments and an executive sponsor."
  pageSolutions={['asks']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AtelierNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/closing')}
    prevHref={href(base, '/plan')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <div slot="backdrop" class="loom-bg"></div>
      <T
        as="p"
        en="What it takes"
        it="Cosa serve"
        fr="Ce qu’il faut"
        class="text-center text-[var(--accent-primary)] mb-5"
        style={kickerStyle}
        data-reveal
      />
      <p
        class="text-center font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-6"
        style="font-size: clamp(2.5rem, 6vw, 6rem);"
        data-reveal
        data-reveal-delay="0.08"
        data-display
        aria-hidden="true"
      >06</p>
      <T
        as="h1"
        en="A small stack of asks, in the right order."
        it="Poche richieste, messe nell’ordine giusto."
        fr="Une courte liste de demandes, dans le bon ordre."
        class="slide-title text-center text-[var(--ink-primary)] mx-auto max-w-5xl mb-6"
        style="font-size: clamp(2.2rem, 4.4vw, 4rem);"
        data-reveal
        data-reveal-delay="0.15"
      />
      <T
        as="p"
        en="Everything below is sized to the milestones it serves. Nothing here funds a tool; it enables people."
        it="Tutto quel che segue è dimensionato sulle milestone che serve. Niente qui finanzia uno strumento; tutto serve ad abilitare le persone."
        fr="Tout ce qui suit est dimensionné sur les jalons qu’il sert. Rien ici ne finance un outil&nbsp;; tout sert à outiller les personnes."
        class="text-center text-[var(--color-sabbia-200)] mx-auto max-w-3xl"
        style="font-size: clamp(1.05rem, 1.3vw, 1.3rem); line-height: 1.55;"
        data-reveal
        data-reveal-delay="0.22"
      />
    </Slide>

    <!-- ── SLIDE 1: Resources ─────────────────────────────────────── -->
    <Slide id="slide-resources" bg="secondary" align="left">
      <div slot="backdrop" class="loom-bg-soft"></div>
      <div class="w-full max-w-6xl mx-auto">
        <T
          as="p"
          en="The envelope"
          it="La dotazione"
          fr="L’enveloppe"
          class="text-[var(--accent-primary)] mb-2"
          style={kickerStyle}
          data-reveal
        />
        <T
          as="h2"
          en="Resources"
          it="Risorse"
          fr="Ressources"
          class="text-[var(--ink-primary)] mb-4 min-[1360px]:mb-6 font-[family-name:var(--font-display)]"
          style="font-size: clamp(1.7rem, 2.6vw, 2.4rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
          data-reveal
          data-reveal-delay="0.08"
        />

        <div class="w-full grid min-[1360px]:grid-cols-2 gap-3 min-[1360px]:gap-4" data-reveal data-reveal-delay="0.16">
          {resources.map((row) => (
            <div class="loom-card asks-res-card">
              <div class="asks-res-head">
                <span class="loom-mark asks-res-mark" aria-hidden="true">{row.mark}</span>
                <T
                  as="p"
                  en={row.name.en}
                  it={row.name.it}
                  fr={row.name.fr}
                  class="loom-card-title asks-res-title"
                />
              </div>
              <T
                as="p"
                en={row.why.en}
                it={row.why.it}
                fr={row.why.fr}
                class="loom-card-body asks-res-body"
              />
              <div class="asks-res-foot">
                <T
                  as="p"
                  en="Relative envelope"
                  it="Dotazione relativa"
                  fr="Enveloppe relative"
                  class="asks-res-label"
                />
                <div class="asks-res-track" aria-hidden="true">
                  <div class="asks-res-fill" style={`width: ${row.width};`}></div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <T
          as="p"
          en="Figures live in a separate annex; this page carries proportions only."
          it="Le cifre stanno in un allegato separato; questa pagina riporta solo proporzioni."
          fr="Les chiffres figurent dans une annexe séparée&nbsp;; cette page ne porte que des proportions."
          class="asks-annex"
          data-reveal
          data-reveal-delay="0.24"
        />
      </div>
    </Slide>

    <!-- ── SLIDE 2: Two funded moments ────────────────────────────── -->
    <Slide id="slide-moments" bg="primary" align="left">
      <div slot="backdrop" class="loom-bg"></div>
      <div class="w-full max-w-6xl mx-auto">
        <T
          as="p"
          en="Where the events line goes"
          it="Dove va la voce eventi"
          fr="Où va la ligne événements"
          class="text-[var(--accent-primary)] mb-2"
          style={kickerStyle}
          data-reveal
        />
        <T
          as="h2"
          en="Two funded moments"
          it="Due momenti finanziati"
          fr="Deux moments financés"
          class="text-[var(--ink-primary)] mb-3 min-[1360px]:mb-5 font-[family-name:var(--font-display)]"
          style="font-size: clamp(1.7rem, 2.6vw, 2.4rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
          data-reveal
          data-reveal-delay="0.08"
        />

        <div class="loom-weave" data-reveal data-reveal-delay="0.16">
          {moments.map((m, i) => (
            <div class="loom-thread" style={`--thread: ${i};`}>
              <div class="loom-thread-rail">
                <span class="loom-thread-num" aria-hidden="true">{i + 1}</span>
                <T
                  as="p"
                  en={m.kicker.en}
                  it={m.kicker.it}
                  fr={m.kicker.fr}
                  class="asks-moment-kicker"
                />
              </div>
              <div class="loom-thread-copy">
                <T
                  as="p"
                  en={m.name.en}
                  it={m.name.it}
                  fr={m.name.fr}
                  class="loom-thread-title asks-moment-name"
                />
                <T
                  as="p"
                  en={m.body.en}
                  it={m.body.it}
                  fr={m.body.fr}
                  class="loom-thread-body"
                />
              </div>
            </div>
          ))}
        </div>

        <div class="loom-quote hidden min-[1360px]:block" data-reveal data-reveal-delay="0.24">
          <T
            as="p"
            en="Both days end the same way, with more people able to build."
            it="Le due giornate finiscono allo stesso modo, con più persone capaci di costruire."
            fr="Les deux journées se terminent de la même façon, avec plus de personnes capables de construire."
            class="loom-quote-text"
          />
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: The sponsor ───────────────────────────────────── -->
    <Slide id="slide-sponsor" bg="secondary" align="center">
      <div slot="backdrop" class="loom-bg-soft"></div>
      <T
        as="p"
        en="The most important ask"
        it="La richiesta più importante"
        fr="La demande la plus importante"
        class="text-center text-[var(--accent-primary)] mb-8"
        style={kickerStyle}
        data-reveal
      />
      <T
        as="p"
        en="An executive sponsor, and thirty minutes a month to keep score together."
        it="Uno sponsor executive, e trenta minuti al mese per fare il punto insieme."
        fr="Un sponsor exécutif, et trente minutes par mois pour faire le point ensemble."
        class="text-center text-[var(--ink-primary)] mx-auto max-w-4xl font-[family-name:var(--font-display)] mb-8"
        style="font-size: clamp(1.9rem, 3.2vw, 3rem); font-weight: 500; line-height: 1.3; letter-spacing: -0.01em;"
        data-reveal
        data-reveal-delay="0.1"
      />
      <T
        as="p"
        en="It is also the cheapest item on every slide you just saw."
        it="Ed è anche la voce più economica di tutte le slide che avete appena visto."
        fr="C’est aussi le poste le moins coûteux de toutes les slides que vous venez de voir."
        class="text-center text-[var(--color-sabbia-200)] mx-auto max-w-3xl"
        style="font-size: clamp(1.05rem, 1.3vw, 1.3rem); line-height: 1.55;"
        data-reveal
        data-reveal-delay="0.18"
      />
    </Slide>

  </DeckContainer>

  <style>
    /* ── Asks — resources as dignified loom-cards ─────────────────── */
    .asks-res-card { padding: 1.2rem 1.35rem 1.1rem; }
    .asks-res-head {
      display: flex; align-items: flex-start; gap: 0.85rem;
      margin-bottom: 0.7rem;
    }
    .asks-res-mark { margin-bottom: 0; }
    .asks-res-title { margin-bottom: 0; font-size: 1.12rem; align-self: center; }
    .asks-res-body { font-size: 0.95rem; margin-bottom: 0.9rem; }
    .asks-res-foot {
      margin-top: auto;
      display: flex; align-items: center; gap: 0.85rem;
      padding-top: 0.7rem;
      border-top: 1px solid var(--line-subtle);
    }
    .asks-res-label {
      flex: 0 0 auto;
      font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
      font-weight: 600; color: var(--color-sabbia-300);
      max-width: none; white-space: nowrap;
    }
    .asks-res-track {
      flex: 1 1 auto; height: 6px; border-radius: 999px; overflow: hidden;
      background: rgba(201, 169, 106, 0.14);
    }
    .asks-res-fill {
      height: 100%; border-radius: 999px;
      background: var(--color-champagne);
    }
    .asks-annex {
      margin-top: 1rem; padding-top: 0.7rem;
      border-top: 1px solid var(--line-subtle);
      font-size: 0.78rem; line-height: 1.5; letter-spacing: 0.02em;
      color: var(--color-sabbia-300); max-width: none;
    }

    /* ── Asks — moments woven ─────────────────────────────────────── */
    .asks-moment-kicker {
      flex: 0 0 auto; max-width: none;
      font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase;
      font-weight: 700; color: var(--accent-primary);
    }
    .asks-moment-name { font-size: 1.15rem; margin-bottom: 0.35rem; }
  </style>
</BaseLayout>
