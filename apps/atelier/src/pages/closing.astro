---
import BaseLayout from '../layouts/BaseLayout.astro';
import AtelierNavigation from '../components/AtelierNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import MediaSlot from '@edf/core/blocks/MediaSlot.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---
<BaseLayout
  title="Closing"
  description="Closing — the thesis in one breath and the next step: green-light an eight-week pilot with five to ten sellers."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AtelierNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/')}
    prevHref={href(base, '/asks')}
  >

    <!-- ── SLIDE 0: Thesis, restated in one breath ────────────────── -->
    <Slide id="slide-thesis" bg="primary" align="center">
      <T
        as="p"
        en="In one breath"
        it="In un respiro"
        fr="En un souffle"
        class="slide-eyebrow text-center text-[var(--accent-primary)] mb-8"
        data-reveal
      />
      <T
        as="p"
        en="The six live experiences show it works. The engine makes it repeatable, the plan makes it a capability, the KPIs keep it honest."
        it="Le sei esperienze live mostrano che funziona. Il motore lo rende ripetibile, il piano ne fa una capability, i KPI lo tengono onesto."
        fr="Les six expériences en production montrent que ça marche. Le moteur le rend reproductible, le plan en fait une capacité, les KPI le gardent honnête."
        class="text-center font-[family-name:var(--font-display)] text-[var(--color-avorio)] mx-auto max-w-4xl"
        style="font-size: clamp(1.8rem, 2.5vw, 2.35rem); line-height: 1.48; font-weight: 500; letter-spacing: -0.01em; max-width: 58rem;"
        data-reveal
        data-reveal-delay="0.1"
      />
      <div class="mt-14 flex justify-center" data-reveal data-reveal-delay="0.2">
        <div class="w-10 h-px bg-[var(--accent-primary)]" aria-hidden="true"></div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: The next step — lone figure on stage ──────────── -->
    <!-- Backdrop composed inline (same markup as SlideBackdrop) because the
         no-text zone over the dancer must ride on the MediaSlot figure for
         audit check (d). Zone = dancer + spotlight pool, measured on the
         source image: x 38–68%, y 52–96%. The silhouette stays visible under
         the scrim: one person, a stage, the beginning. -->
    <Slide id="slide-next" bg="primary" align="center">
      <div slot="backdrop" class="slide-backdrop absolute inset-0 overflow-hidden" aria-hidden="true">
        <div data-parallax class="absolute inset-0 will-change-transform">
          <MediaSlot {...mediaProps('bg-stage')} fill noText="54,38,30,44" class="opacity-[0.45]" />
        </div>
        <div data-scrim class="absolute inset-0 bg-[var(--color-carbone)]/80"></div>
      </div>

      <div class="next-lift w-full flex flex-col items-center">
        <T
          as="p"
          en="The next step"
          it="Il prossimo passo"
          fr="La prochaine étape"
          class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5"
          data-reveal
        />
        <T
          as="h1"
          en="Green-light the pilot."
          it="Via libera al pilota."
          fr="Donnez le feu vert au pilote."
          class="slide-title text-center text-[var(--ink-primary)] mx-auto max-w-5xl mb-6"
          style="font-size: clamp(2.2rem, 3.6vw, 3.4rem);"
          data-reveal
          data-reveal-delay="0.08"
        />
        <T
          as="p"
          en="Five to ten sellers, one guided intake, eight weeks. By mid-September there are new experiences in the field and a baseline to judge everything that follows."
          it="Da cinque a dieci seller, un intake guidato, otto settimane. A metà settembre ci sono nuove esperienze sul campo e una baseline per giudicare tutto quello che viene dopo."
          fr="Cinq à dix vendeurs, un intake guidé, huit semaines. À la mi-septembre, de nouvelles expériences sont sur le terrain, avec une base de référence pour juger la suite."
          class="text-center text-[var(--color-sabbia-200)] mx-auto max-w-3xl mb-6"
          style="font-size: clamp(1.05rem, 1.25vw, 1.25rem); line-height: 1.55;"
          data-reveal
          data-reveal-delay="0.16"
        />
        <T
          as="p"
          en="This deck is live at its own address, in three languages. Forward it."
          it="Questo deck è online al suo indirizzo, in tre lingue. Fatelo girare."
          fr="Ce deck est en ligne à sa propre adresse, en trois langues. Faites-le circuler."
          class="text-center text-[var(--color-sabbia-300)] mx-auto"
          style="font-size: 0.95rem; letter-spacing: 0.02em;"
          data-reveal
          data-reveal-delay="0.24"
        />
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* Lift the text block into the upper-centre band so it clears the dancer's
     no-text zone (which starts at ~52% of the backdrop) at all three
     projection sizes, while keeping significant text inside the 30–70% band. */
  .next-lift {
    transform: translateY(clamp(-8rem, -12vh, -6rem));
  }
</style>
