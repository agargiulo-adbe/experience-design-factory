---
import BaseLayout from '../layouts/BaseLayout.astro';
import AtelierNavigation from '../components/AtelierNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---
<BaseLayout title="Experience Atelier">
  <div class="fixed top-0 left-0 right-0 z-50">
    <AtelierNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/method')}>

    <!-- ── SLIDE 0: Cover (placeholder — full Overture arrives with the index task) ── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <T
        as="h1"
        en="Experience Atelier"
        it="Experience Atelier"
        fr="Experience Atelier"
        class="slide-title text-center text-[var(--ink-primary)] mb-5"
        style="font-size: clamp(2.5rem, 5vw, 4.5rem);"
      />
      <T
        as="p"
        en="Six experiences. One person, paired with AI."
        it="Sei esperienze. Una persona, in coppia con l'AI."
        fr="Six expériences. Une personne, en binôme avec l'IA."
        class="text-center text-[var(--ink-secondary)] mx-auto"
        style="font-size: clamp(1.05rem, 1.4vw, 1.35rem); line-height: 1.5;"
      />
    </Slide>

  </DeckContainer>
</BaseLayout>
