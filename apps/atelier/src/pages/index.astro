---
import BaseLayout from '../layouts/BaseLayout.astro';
import AtelierNavigation from '../components/AtelierNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const LIVE = 'https://agargiulo-adbe.github.io/experience-design-factory';

// Accent tints tuned for AA (≥4.5:1) on the dark card surface — the raw brand
// hues (UniCredit #BE2027, Ferrari #FF2800, FS #E2001A) fall below 4.5:1 on
// fuliggine, so each kicker uses a lightened tint of its brand accent.
const wall = [
  {
    kicker: 'Max Mara',
    accent: '#C9A272',
    name: 'Generazioni',
    url: `${LIVE}/generazioni-maxmara/`,
    tag: {
      en: 'A quiet-luxury generational journey',
      it: 'Un viaggio generazionale quiet-luxury',
      fr: 'Un voyage générationnel quiet-luxury',
    },
  },
  {
    kicker: 'UniCredit',
    accent: '#E8858B',
    name: 'Engagement Unlimited',
    url: `${LIVE}/unicredit-engagement/`,
    tag: {
      en: 'A complete Adobe CX story with real personas',
      it: 'Una storia Adobe CX completa, con personas reali',
      fr: 'Un récit Adobe CX complet, avec de vrais personas',
    },
  },
  {
    kicker: 'Ferrari Racing × Adobe',
    accent: '#FF7A5C',
    name: 'Pole Position',
    url: `${LIVE}/ferrari-racing/`,
    tag: {
      en: 'Data collaboration from Maranello to every fan',
      it: 'Data collaboration da Maranello a ogni tifoso',
      fr: 'La data collaboration, de Maranello à chaque fan',
    },
  },
  {
    kicker: 'FS Group',
    accent: '#F2777D',
    name: 'Connessioni Intelligenti',
    url: `${LIVE}/trenitalia-connessioni/`,
    tag: {
      en: 'One measurable journey for trains and travellers',
      it: 'Un journey misurabile dai treni ai viaggiatori',
      fr: 'Un parcours mesurable, des trains aux voyageurs',
    },
  },
  {
    kicker: 'Agos',
    accent: '#2BC2CE',
    name: "Trait d'Union",
    url: `${LIVE}/agos-trait-dunion/`,
    tag: {
      en: 'Digital and branch, joined in one client intelligence',
      it: "Digitale e filiale, uniti in un'unica intelligenza cliente",
      fr: 'Digital et agence, réunis dans une même intelligence client',
    },
  },
  {
    kicker: 'Console · Hub · Showcase',
    accent: '#C9A96A',
    name: { en: 'The Platform', it: 'La Piattaforma', fr: 'La Plateforme' },
    url: `${LIVE}/`,
    tag: {
      en: 'The engine behind them all: one console, every experience',
      it: 'Il motore dietro a tutte: una console, ogni esperienza',
      fr: "Le moteur de l'ensemble : une console, chaque expérience",
    },
  },
];
---
<BaseLayout title="Overture">
  <div class="fixed top-0 left-0 right-0 z-50">
    <AtelierNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/method')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <div slot="backdrop" class="loom-bg">
        <SlideBackdrop
          {...mediaProps('bg-atelier')}
          imageClass="opacity-[0.14]"
          scrim="bg-[var(--color-carbone)]/90"
        />
      </div>

      <div class="overture-cover mx-auto w-full max-w-6xl" data-reveal>
        <T
          as="p"
          en="Experience Atelier"
          it="Experience Atelier"
          fr="Experience Atelier"
          class="slide-eyebrow text-center text-[var(--accent-primary)] mb-6"
        />
        <T
          as="h1"
          en="Six experiences. Five brands.<br/>One person, paired with AI."
          it="Sei esperienze. Cinque brand.<br/>Una persona, in coppia con l'AI."
          fr="Six expériences. Cinq marques.<br/>Une personne, en binôme avec l'IA."
          data-display
          class="slide-title text-center text-[var(--ink-primary)] mb-8 mx-auto"
          style="font-size: clamp(2.7rem, 4.9vw, 4.7rem);"
        />

        <!-- Concept device: one warp fanning into six woven experiences (1 → 6). -->
        <div class="overture-loom" data-reveal data-reveal-delay="0.12" aria-hidden="true">
          <span class="overture-loom-cap overture-loom-cap--one">1</span>
          <svg class="overture-loom-svg" viewBox="0 0 480 120" preserveAspectRatio="none" role="presentation">
            <line x1="6" y1="60" x2="474" y2="10" />
            <line x1="6" y1="60" x2="474" y2="30" />
            <line x1="6" y1="60" x2="474" y2="50" />
            <line x1="6" y1="60" x2="474" y2="70" />
            <line x1="6" y1="60" x2="474" y2="90" />
            <line x1="6" y1="60" x2="474" y2="110" />
          </svg>
          <span class="overture-loom-cap overture-loom-cap--many">6</span>
        </div>

        <T
          as="p"
          en="Live in production, each built in weeks. This deck runs on the same engine."
          it="In produzione, ognuna costruita in poche settimane. Anche questo deck gira sullo stesso motore."
          fr="En production, chacune montée en quelques semaines. Ce deck aussi tourne sur le même moteur."
          class="text-center text-[var(--color-sabbia-200)] mx-auto max-w-3xl mt-8"
          style="font-size: clamp(1.1rem, 1.4vw, 1.4rem); line-height: 1.55;"
          data-reveal
          data-reveal-delay="0.22"
        />

        <div class="mt-10 flex flex-col items-center gap-3" data-reveal data-reveal-delay="0.3">
          <div class="w-10 h-px bg-[var(--accent-primary)]" aria-hidden="true"></div>
          <T
            as="p"
            en="Adobe"
            it="Adobe"
            fr="Adobe"
            class="text-center text-[0.78rem] font-semibold tracking-[0.22em] uppercase text-[var(--color-sabbia-300)]"
          />
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: The wall — six live tiles ─────────────────────── -->
    <Slide id="slide-wall" bg="secondary" align="center">
      <div slot="backdrop" class="loom-bg-soft"></div>

      <T
        as="p"
        en="Six live deployments"
        it="Sei esperienze live"
        fr="Six déploiements en production"
        class="slide-eyebrow text-center text-[var(--accent-primary)] mb-3"
        data-reveal
      />
      <T
        as="h2"
        en="Every tile is live. Click any of them."
        it="Ogni card è live. Aprine una qualsiasi."
        fr="Tout est en ligne. Ouvrez une carte."
        class="slide-title text-center text-[var(--ink-primary)] mb-7"
        style="font-size: clamp(1.6rem, 2.6vw, 2.5rem);"
        data-reveal
        data-reveal-delay="0.08"
      />
      <div
        class="w-full max-w-6xl mx-auto grid grid-cols-2 lg:grid-cols-3 gap-[clamp(0.7rem,1vw,1.1rem)]"
        data-reveal
        data-reveal-delay="0.16"
      >
        {wall.map((card) => (
          <a
            target="_blank"
            rel="noopener"
            href={card.url}
            class="loom-panel wall-card group no-underline"
            style={`--wall-accent: ${card.accent};`}
          >
            <span class="wall-accent-cap" aria-hidden="true" style={`background: ${card.accent};`}></span>
            <p
              class="loom-tag mb-2"
              style={`color: ${card.accent};`}
            >
              {card.kicker}
            </p>
            {typeof card.name === 'string' ? (
              <p
                class="font-semibold text-[var(--ink-primary)] mb-1.5 font-[family-name:var(--font-display)]"
                style="font-size: clamp(1.05rem, 1.25vw, 1.3rem); line-height: 1.15;"
              >
                {card.name}
              </p>
            ) : (
              <T
                as="p"
                en={card.name.en}
                it={card.name.it}
                fr={card.name.fr}
                class="font-semibold text-[var(--ink-primary)] mb-1.5 font-[family-name:var(--font-display)]"
                style="font-size: clamp(1.05rem, 1.25vw, 1.3rem); line-height: 1.15;"
              />
            )}
            <T
              as="p"
              en={card.tag.en}
              it={card.tag.it}
              fr={card.tag.fr}
              class="text-[var(--color-sabbia-200)]"
              style="font-size: clamp(0.85rem, 0.95vw, 1rem); line-height: 1.5;"
            />
          </a>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: Thesis ────────────────────────────────────────── -->
    <Slide id="slide-thesis" bg="primary" align="center">
      <div slot="backdrop" class="loom-bg"></div>

      <T
        as="p"
        en="From one maker to a workforce"
        it="Da un solo maker a una workforce"
        fr="D'un seul artisan à toute une équipe"
        class="slide-eyebrow text-center text-[var(--accent-primary)] mb-8"
        data-reveal
      />
      <T
        as="h2"
        en="What follows is a plan to turn this way of working into a capability many people at Adobe can use."
        it="Quello che segue è un piano per trasformare questo modo di lavorare in una capability diffusa in Adobe."
        fr="La suite est un plan pour faire de cette façon de travailler une capacité partagée chez Adobe."
        class="slide-title text-center text-[var(--ink-primary)] max-w-4xl mx-auto mb-10"
        style="font-size: clamp(2rem, 3.3vw, 3.2rem); line-height: 1.22;"
        data-reveal
        data-reveal-delay="0.08"
      />
      <div class="loom-thesis-rule mx-auto mb-10" aria-hidden="true" data-reveal data-reveal-delay="0.16"></div>
      <T
        as="p"
        en="Use ← → to move. EN, IT and FR live in the toggle above."
        it="Frecce ← → per muoversi. EN, IT e FR nel selettore in alto."
        fr="← → pour avancer. EN, IT et FR via le sélecteur en haut."
        class="text-center text-[var(--color-sabbia-300)] mx-auto"
        style="font-size: 0.875rem; letter-spacing: 0.02em;"
        data-reveal
        data-reveal-delay="0.2"
      />
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* ── Overture cover: restrained, less dead space, editorial rhythm ─── */
  .overture-cover {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Concept device — one warp thread (1) fanning into the six woven cloths (6). */
  .overture-loom {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 2.2rem);
    width: min(100%, 42rem);
    margin: 0.5rem auto 0;
  }
  .overture-loom-svg {
    flex: 1 1 auto;
    width: 100%;
    height: clamp(58px, 8vh, 96px);
  }
  .overture-loom-svg line {
    stroke: rgba(201, 169, 106, 0.55);
    stroke-width: 1.4;
    vector-effect: non-scaling-stroke;
  }
  .overture-loom-cap {
    flex: 0 0 auto;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-champagne);
    line-height: 1;
  }
  .overture-loom-cap--one { font-size: clamp(1.5rem, 2.2vw, 2rem); opacity: 0.9; }
  .overture-loom-cap--many { font-size: clamp(2.2rem, 3.6vw, 3.1rem); }

  @media (prefers-reduced-motion: no-preference) {
    .overture-loom-svg line {
      stroke-dasharray: 3 6;
      animation: overture-flow 3s linear infinite;
    }
    @keyframes overture-flow { to { stroke-dashoffset: -18; } }
  }

  /* ── Wall tiles as woven panels — full hairline border, top accent cap
     (never a coloured side-stripe). ─────────────────────────────────── */
  .wall-card {
    position: relative;
    overflow: hidden;
    text-align: left;
    transition: border-color var(--duration-fast) var(--easing-default),
                transform var(--duration-fast) var(--easing-out);
  }
  .wall-accent-cap {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0.55;
    transition: opacity var(--duration-fast) var(--easing-default);
  }
  .wall-card:hover {
    border-color: var(--wall-accent) !important;
    transform: translateY(-2px);
  }
  .wall-card:hover .wall-accent-cap { opacity: 1; }

  /* ── Thesis: champagne hairline separating the statement from the hint. */
  .loom-thesis-rule {
    width: clamp(3rem, 6vw, 5rem);
    height: 1px;
    background: rgba(201, 169, 106, 0.4);
  }
</style>
