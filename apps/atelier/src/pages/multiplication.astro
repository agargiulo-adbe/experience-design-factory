---
import BaseLayout from '../layouts/BaseLayout.astro';
import AtelierNavigation from '../components/AtelierNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---
<BaseLayout
  title="The multiplication"
  description="The multiplication — from one person's craft to a shared capability: market evidence, precedents, and the model that turns one into fifty."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <AtelierNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/frontiers')}
    prevHref={href(base, '/capability')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-horizon')}
        imageClass="opacity-15"
        scrim="bg-[var(--surface-primary)]/88"
      />
      <T
        as="p"
        en="The multiplication"
        it="La moltiplicazione"
        fr="La multiplication"
        class="text-center font-semibold uppercase text-[var(--accent-primary)] mb-5"
        style="font-size: clamp(1.05rem, 1.3vw, 1.3rem); letter-spacing: 0.14em;"
        data-reveal
      />
      <p
        class="text-center font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] leading-none mb-5"
        style="font-size: clamp(2.5rem, 5vw, 5.5rem);"
        data-reveal
        data-reveal-delay="0.08"
        data-display
        aria-hidden="true"
      >03</p>
      <T
        as="h1"
        en="What if fifty people could do this?"
        it="E se cinquanta persone potessero farlo?"
        fr="Et si cinquante personnes pouvaient le faire&nbsp;?"
        class="slide-title text-center text-[var(--ink-primary)] mx-auto max-w-5xl mb-5"
        style="font-size: clamp(2.2rem, 4vw, 3.9rem);"
        data-reveal
        data-reveal-delay="0.15"
      />
      <T
        as="p"
        en="Today this is one person's craft. The next nine months turn it into a shared capability."
        it="Oggi è il mestiere di una persona. Nei prossimi nove mesi diventa una capability condivisa."
        fr="Aujourd'hui, c'est le métier d'une personne. Les neuf prochains mois en font une capacité partagée."
        class="text-center text-[var(--color-sabbia-200)] mx-auto max-w-3xl"
        style="font-size: clamp(1.05rem, 1.3vw, 1.3rem); line-height: 1.55;"
        data-reveal
        data-reveal-delay="0.22"
      />
      <div class="flex items-center justify-center flex-wrap gap-x-4 gap-y-2 mt-6" data-reveal data-reveal-delay="0.3">
        <T
          en="The market"
          it="Il mercato"
          fr="Le marché"
          class="font-semibold tracking-widest uppercase text-[var(--color-sabbia-300)]"
          style="font-size: 0.9rem;"
        />
        <span class="w-1 h-1 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
        <T
          en="The precedents"
          it="I precedenti"
          fr="Les précédents"
          class="font-semibold tracking-widest uppercase text-[var(--color-sabbia-300)]"
          style="font-size: 0.9rem;"
        />
        <span class="w-1 h-1 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
        <T
          en="The model"
          it="Il modello"
          fr="Le modèle"
          class="font-semibold tracking-widest uppercase text-[var(--color-sabbia-300)]"
          style="font-size: 0.9rem;"
        />
      </div>
    </Slide>

    <!-- ── SLIDE 1: Market evidence ───────────────────────────────── -->
    <Slide id="slide-market" bg="secondary" align="left">
      <T
        as="p"
        en="Market evidence"
        it="Evidenze di mercato"
        fr="Preuves de marché"
        class="slide-eyebrow text-[var(--accent-primary)] mb-2.5"
        data-reveal
      />
      <T
        as="h2"
        en="Buyers already pay for experience-led selling"
        it="C'è già chi paga per l'experience-led selling"
        fr="L'experience-led selling a déjà des acheteurs"
        class="text-[var(--ink-primary)] mb-4"
        style="font-size: clamp(1.65rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      />

      <div class="w-full max-w-6xl grid md:grid-cols-[13rem_minmax(0,1fr)] gap-x-6 gap-y-4 items-stretch" data-reveal data-reveal-delay="0.16">
        <T
          as="p"
          en="The category"
          it="La categoria"
          fr="La catégorie"
          class="text-[0.8rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] md:pt-4"
        />
        <div class="min-w-0 px-5 py-2.5 bg-[var(--surface-tertiary)] border border-[var(--line-subtle)] rounded-sm">
          <T
            as="p"
            en="Demo-experience platforms are a funded product category: Consensus raised $110M from Sumeru Equity Partners in 2023 and consolidated the space in 2026 by acquiring Peel and Saleo."
            it="Le piattaforme di demo experience sono una categoria finanziata: nel 2023 Consensus ha raccolto 110M$ da Sumeru Equity Partners e nel 2026 ha consolidato il settore acquisendo Peel e Saleo."
            fr="Les plateformes de démo sont une catégorie financée&nbsp;: Consensus a levé 110&nbsp;M$ auprès de Sumeru Equity Partners en 2023, puis consolidé le secteur en 2026 en rachetant Peel et Saleo."
            class="text-[var(--color-sabbia-200)] mb-1"
            style="font-size: 0.98rem; line-height: 1.55; max-width: none;"
          />
          <T
            as="p"
            en="Business Wire, Mar 2023 · PR Newswire, Apr–Jun 2026"
            it="Business Wire, mar 2023 · PR Newswire, apr–giu 2026"
            fr="Business Wire, mars 2023 · PR Newswire, avr–juin 2026"
            class="text-[0.75rem] tracking-wide uppercase text-[var(--color-sabbia-300)]"
          />
        </div>

        <T
          as="p"
          en="Claimed impact"
          it="Impatto dichiarato"
          fr="Impact déclaré"
          class="text-[0.8rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] md:pt-4"
        />
        <div class="min-w-0 px-5 py-2.5 bg-[var(--surface-tertiary)] border border-[var(--line-subtle)] rounded-sm">
          <T
            as="p"
            en="The category sells on speed: Consensus itself reports sales cycles shortened by 29–68%; a Reprise-commissioned Forrester study reports a 60% lift in pipeline conversion."
            it="La categoria vende velocità: Consensus dichiara cicli di vendita ridotti del 29–68%; uno studio Forrester commissionato da Reprise riporta +60% di conversione in pipeline."
            fr="La catégorie se vend sur la vitesse&nbsp;: Consensus annonce des cycles de vente réduits de 29–68&nbsp;%&nbsp;; une étude Forrester commandée par Reprise rapporte +60&nbsp;% de conversion du pipeline."
            class="text-[var(--color-sabbia-200)] mb-1"
            style="font-size: 0.98rem; line-height: 1.55; max-width: none;"
          />
          <T
            as="p"
            en="Vendor-reported figures: Consensus releases 2023–2026; Forrester TEI for Reprise, Feb 2022"
            it="Dati dichiarati dai vendor: comunicati Consensus 2023–2026; Forrester TEI per Reprise, feb 2022"
            fr="Chiffres déclarés par les éditeurs&nbsp;: communiqués Consensus 2023–2026&nbsp;; TEI Forrester pour Reprise, févr. 2022"
            class="text-[0.75rem] tracking-wide uppercase text-[var(--color-sabbia-300)]"
          />
        </div>
      </div>

      <div class="w-full max-w-6xl mt-4 border-l-2 border-[var(--accent-primary)] pl-5" data-reveal data-reveal-delay="0.24">
        <T
          as="p"
          en="Those are demo products, bought by sales teams. This is the same need, met inside Adobe."
          it="Quelli sono prodotti per demo, comprati dai team di vendita. Qui c'è lo stesso bisogno, coperto dentro Adobe."
          fr="Ce sont des produits de démo, achetés par les équipes commerciales. Ici, le même besoin, couvert chez Adobe."
          class="font-[family-name:var(--font-display)] text-[var(--color-avorio)]"
          style="font-size: clamp(1.2rem, 1.5vw, 1.5rem); line-height: 1.3; font-weight: 500; max-width: none;"
        />
      </div>
    </Slide>

    <!-- ── SLIDE 2: Precedents ────────────────────────────────────── -->
    <Slide id="slide-precedent" bg="primary" align="left">
      <T
        as="p"
        en="Precedents"
        it="Precedenti"
        fr="Précédents"
        class="slide-eyebrow text-[var(--accent-primary)] mb-3"
        data-reveal
      />
      <T
        as="h2"
        en="The playbook has precedents"
        it="Il playbook ha dei precedenti"
        fr="Le playbook a des précédents"
        class="text-[var(--ink-primary)] mb-4"
        style="font-size: clamp(1.7rem, 2.7vw, 2.5rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      />
      <T
        as="p"
        en="One enterprise vendor and one biotech already run the two halves of this play."
        it="Un vendor enterprise e una biotech giocano già le due metà di questa partita."
        fr="Un éditeur enterprise et une biotech jouent déjà les deux volets de ce playbook."
        class="text-[var(--color-sabbia-200)] mb-6"
        style="font-size: clamp(1rem, 1.2vw, 1.15rem); line-height: 1.55;"
        data-reveal
        data-reveal-delay="0.14"
      />

      <div class="w-full max-w-6xl grid md:grid-cols-2 gap-5" data-reveal data-reveal-delay="0.2">
        <div class="min-w-0 px-6 py-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] border-t-2 border-t-[var(--accent-primary)] rounded-sm flex flex-col">
          <T
            as="p"
            en="SAP institutionalized pre-sales play"
            it="SAP: il gioco pre-sales è un'istituzione"
            fr="SAP a fait du jeu un outil d'avant-vente"
            class="font-[family-name:var(--font-display)] font-semibold text-[var(--color-avorio)] mb-2.5"
            style="font-size: 1.15rem; line-height: 1.25;"
          />
          <T
            as="p"
            en="Since 2020 SAP runs facilitator-led board games with customers, from the S/4HANA virtual board game to the BTP Diamond Game, positioned in the discovery phase of the sales cycle, with partners selling facilitated workshops."
            it="Dal 2020 SAP gioca con i clienti board game guidati da facilitatori, dal board game virtuale S/4HANA al BTP Diamond Game, collocati nella fase di discovery del ciclo di vendita, con partner che vendono workshop facilitati."
            fr="Depuis 2020, SAP anime avec ses clients des jeux de plateau facilités, du board game virtuel S/4HANA au BTP Diamond Game, placés en phase de discovery du cycle de vente, avec des partenaires qui vendent des ateliers animés."
            class="text-[var(--color-sabbia-200)] mb-3"
            style="font-size: 0.97rem; line-height: 1.55; max-width: none;"
          />
          <T
            as="p"
            en="SAP News 2020–2023, partner Bluestonex"
            it="SAP News 2020–2023, partner Bluestonex"
            fr="SAP News 2020–2023, partenaire Bluestonex"
            class="mt-auto text-[0.75rem] tracking-wide uppercase text-[var(--color-sabbia-300)]"
          />
        </div>

        <div class="min-w-0 px-6 py-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] border-t-2 border-t-[var(--accent-primary)] rounded-sm flex flex-col">
          <T
            as="p"
            en="Workforces build their own AI"
            it="La forza lavoro si costruisce l'AI"
            fr="Les équipes se fabriquent leur IA"
            class="font-[family-name:var(--font-display)] font-semibold text-[var(--color-avorio)] mb-2.5"
            style="font-size: 1.15rem; line-height: 1.25;"
          />
          <T
            as="p"
            en="Moderna reports that within two months of adopting ChatGPT Enterprise, employees had built 750 custom GPTs, with 40% of weekly active users creating their own."
            it="Moderna riferisce che due mesi dopo l'adozione di ChatGPT Enterprise i dipendenti avevano creato 750 GPT custom; il 40% degli utenti attivi settimanali ne costruiva di propri."
            fr="Moderna rapporte que deux mois après l'adoption de ChatGPT Enterprise, ses employés avaient créé 750 GPT custom&nbsp;; 40&nbsp;% des actifs hebdomadaires bâtissaient les leurs."
            class="text-[var(--color-sabbia-200)] mb-3"
            style="font-size: 0.97rem; line-height: 1.55; max-width: none;"
          />
          <T
            as="p"
            en="OpenAI customer story, Apr 2024 (vendor-reported)"
            it="Customer story OpenAI, apr 2024 (dato del vendor)"
            fr="Customer story OpenAI, avr 2024 (chiffres de l'éditeur)"
            class="mt-auto text-[0.75rem] tracking-wide uppercase text-[var(--color-sabbia-300)]"
          />
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: The model ─────────────────────────────────────── -->
    <Slide id="slide-model" bg="secondary" align="left">
      <T
        as="p"
        en="The model"
        it="Il modello"
        fr="Le modèle"
        class="slide-eyebrow text-[var(--accent-primary)] mb-2.5"
        data-reveal
      />
      <T
        as="h2"
        en="How one becomes fifty"
        it="Come uno diventa cinquanta"
        fr="Comment un devient cinquante"
        class="text-[var(--ink-primary)] mb-4"
        style="font-size: clamp(1.65rem, 2.5vw, 2.3rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      />

      <div class="w-full max-w-6xl flex flex-col gap-3" data-reveal data-reveal-delay="0.16">
        <div class="min-w-0 grid md:grid-cols-[15rem_minmax(0,1fr)] gap-x-6 gap-y-1 items-center px-5 py-3 bg-[var(--surface-tertiary)] border border-[var(--line-subtle)] rounded-sm">
          <div class="flex items-baseline gap-2.5 min-w-0">
            <span class="font-[family-name:var(--font-display)] font-semibold text-[var(--accent-primary)] flex-shrink-0" style="font-size: 1.1rem;" aria-hidden="true">1</span>
            <T as="p" en="Guided intake" it="Intake guidato" fr="Intake guidé" class="font-[family-name:var(--font-display)] font-semibold text-[var(--color-avorio)]" style="font-size: 1.1rem; line-height: 1.3;" />
          </div>
          <T
            as="p"
            en="A shareable brief skill interviews the seller and produces a structured brief the engine can build from. It exists today."
            it="Una skill di brief condivisibile intervista il seller e produce un brief strutturato da cui il motore costruisce. Esiste già."
            fr="Une skill de brief partageable interroge le vendeur et produit un brief structuré dont le moteur peut partir. Elle existe déjà."
            class="text-[var(--color-sabbia-200)]"
            style="font-size: 0.98rem; line-height: 1.55; max-width: none;"
          />
        </div>

        <div class="min-w-0 grid md:grid-cols-[15rem_minmax(0,1fr)] gap-x-6 gap-y-1 items-center px-5 py-3 bg-[var(--surface-tertiary)] border border-[var(--line-subtle)] rounded-sm">
          <div class="flex items-baseline gap-2.5 min-w-0">
            <span class="font-[family-name:var(--font-display)] font-semibold text-[var(--accent-primary)] flex-shrink-0" style="font-size: 1.1rem;" aria-hidden="true">2</span>
            <T as="p" en="Templates and self-service" it="Template e self-service" fr="Templates et self-service" class="font-[family-name:var(--font-display)] font-semibold text-[var(--color-avorio)]" style="font-size: 1.1rem; line-height: 1.3;" />
          </div>
          <T
            as="p"
            en="A template gallery and a guided wizard let a BDR or AE assemble an experience without touching code."
            it="Galleria di template e wizard guidato: un BDR o un AE monta un'esperienza senza toccare codice."
            fr="Galerie de templates et assistant guidé&nbsp;: un BDR ou un AE assemble une expérience sans toucher au code."
            class="text-[var(--color-sabbia-200)]"
            style="font-size: 0.98rem; line-height: 1.55; max-width: none;"
          />
        </div>

        <div class="min-w-0 grid md:grid-cols-[15rem_minmax(0,1fr)] gap-x-6 gap-y-1 items-center px-5 py-3 bg-[var(--surface-tertiary)] border border-[var(--line-subtle)] rounded-sm">
          <div class="flex items-baseline gap-2.5 min-w-0">
            <span class="font-[family-name:var(--font-display)] font-semibold text-[var(--accent-primary)] flex-shrink-0" style="font-size: 1.1rem;" aria-hidden="true">3</span>
            <T as="p" en="Partners" it="Partner" fr="Partenaires" class="font-[family-name:var(--font-display)] font-semibold text-[var(--color-avorio)]" style="font-size: 1.1rem; line-height: 1.3;" />
          </div>
          <T
            as="p"
            en="Adobe partners co-build joint experience designs with their own brand next to ours, on the same engine."
            it="I partner Adobe co-firmano experience design congiunti, il loro brand accanto al nostro, sullo stesso motore."
            fr="Les partenaires Adobe co-signent des experience designs, leur marque à côté de la nôtre, sur le même moteur."
            class="text-[var(--color-sabbia-200)]"
            style="font-size: 0.98rem; line-height: 1.55; max-width: none;"
          />
        </div>
      </div>

      <div class="w-full max-w-6xl mt-4 border-l-2 border-[var(--accent-primary)] pl-5" data-reveal data-reveal-delay="0.24">
        <T
          as="p"
          en="The plan ahead is sized on exactly this: enable people, measure what they ship."
          it="Il piano è tarato proprio su questo: abilitare le persone, misurare ciò che rilasciano."
          fr="Le plan qui suit est calibré là-dessus&nbsp;: outiller les équipes, mesurer ce qu'elles livrent."
          class="font-[family-name:var(--font-display)] text-[var(--color-avorio)]"
          style="font-size: clamp(1.15rem, 1.6vw, 1.45rem); line-height: 1.35; font-weight: 500; max-width: none;"
        />
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
