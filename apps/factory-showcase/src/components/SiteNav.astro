---
import { href as buildHref } from '@edf/core/utils/url.js';
import LangToggle from '@edf/core/blocks/i18n/LangToggle.astro';

interface Props { base: string; }
const { base } = Astro.props;

const home = buildHref(base, '/');
const blueprint = buildHref(base, '/blueprint');

// In-page anchors (index). On other pages they jump back to the home section.
const links = [
  { id: 'what', en: 'What', it: 'Cos’è' },
  { id: 'why', en: 'Why', it: 'Perché' },
  { id: 'proof', en: 'Proof', it: 'La prova' },
  { id: 'architecture', en: 'Architecture', it: 'Architettura' },
  { id: 'flow', en: 'Flow', it: 'Il flusso' },
  { id: 'skill', en: 'Skill', it: 'Skill' },
  { id: 'grow', en: 'Roadmap', it: 'Roadmap' },
];
---
<header class="nav" role="banner">
  <nav class="nav-inner wrap" aria-label="Primary">
    <a href={home} class="brand" aria-label="Experience Design Factory — home">
      <svg viewBox="0 0 32 32" width="26" height="26" aria-hidden="true" class="brand-mark">
        <defs>
          <linearGradient id="edf-grad-nav" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#EB1000"/><stop offset=".55" stop-color="#E1077B"/><stop offset="1" stop-color="#6236FF"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="7" fill="url(#edf-grad-nav)"/>
        <rect x="6.5" y="6.5" width="13" height="13" rx="3.6" fill="#fff" fill-opacity=".5"/>
        <rect x="11.6" y="11.6" width="14.4" height="14.4" rx="4.2" fill="url(#edf-grad-nav)"/>
        <rect x="13" y="13" width="12" height="12" rx="3.4" fill="#fff"/>
      </svg>
      <span class="brand-name">Experience&nbsp;Design&nbsp;<span class="brand-strong">Factory</span></span>
    </a>

    <ul class="nav-links" role="list">
      {links.map((l) => (
        <li>
          <a href={`${home}#${l.id}`} class="nav-link" data-nav={l.id}>
            <span data-lang-en>{l.en}</span><span data-lang-it>{l.it}</span>
          </a>
        </li>
      ))}
      <li>
        <a href={blueprint} class="nav-link nav-link--blueprint">
          <span data-lang-en>Blueprint</span><span data-lang-it>Blueprint</span>
        </a>
      </li>
    </ul>

    <div class="nav-right">
      <LangToggle />
    </div>
  </nav>
  <div class="nav-progress" aria-hidden="true"><span class="nav-progress-fill"></span></div>
</header>

<style>
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50; height: var(--nav-h);
    background: color-mix(in srgb, var(--surface-primary) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(12px);
    border-bottom: 1px solid var(--line-subtle);
  }
  .nav-inner { height: var(--nav-h); display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }
  .brand-mark { border-radius: 6px; flex-shrink: 0; }
  .brand-name { font-family: var(--font-display); font-weight: 600; font-size: 0.85rem; letter-spacing: -0.01em; color: var(--ink-secondary); }
  .brand-strong { color: var(--ink-primary); font-weight: 800; }

  .nav-links { display: none; align-items: center; gap: 0.05rem; flex-wrap: nowrap; min-width: 0; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; }
  .nav-links::-webkit-scrollbar { display: none; }
  .nav-links > li { flex-shrink: 0; }
  @media (min-width: 1080px) { .nav-links { display: flex; } }
  .nav-link {
    display: block; white-space: nowrap;
    padding: 0.4rem 0.6rem; font-size: 0.76rem; font-weight: 600; letter-spacing: 0.01em;
    color: var(--ink-tertiary); border-radius: 6px; transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover { color: var(--ink-primary); }
  .nav-link.is-active { color: var(--accent-primary); }
  .nav-link--blueprint { color: var(--ink-primary); border: 1px solid var(--line-default); margin-left: 0.4rem; }
  .nav-link--blueprint:hover { border-color: var(--accent-primary); color: var(--accent-primary); }

  .nav-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }

  .nav-progress { position: absolute; left: 0; right: 0; bottom: -1px; height: 2px; background: transparent; }
  .nav-progress-fill { display: block; height: 100%; width: 0%; background: var(--grad-adobe); transition: width 0.08s linear; }
</style>

<script is:inline>
  (function () {
    function initSpy() {
      var sections = Array.prototype.slice.call(document.querySelectorAll('section[id]'));
      var links = {};
      document.querySelectorAll('.nav-link[data-nav]').forEach(function (a) {
        links[a.getAttribute('data-nav')] = a;
      });
      if (!sections.length || !('IntersectionObserver' in window)) return;
      var spy = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (!e.isIntersecting) return;
          var id = e.target.id;
          Object.keys(links).forEach(function (k) { links[k].classList.toggle('is-active', k === id); });
        });
      }, { rootMargin: '-45% 0px -50% 0px' });
      sections.forEach(function (s) { if (links[s.id]) spy.observe(s); });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSpy);
    } else { initSpy(); }
    document.addEventListener('astro:page-load', initSpy);

    // Scroll progress bar
    var fill = document.querySelector('.nav-progress-fill');
    function onScroll() {
      if (!fill) fill = document.querySelector('.nav-progress-fill');
      if (!fill) return;
      var h = document.documentElement;
      var max = h.scrollHeight - h.clientHeight;
      var p = max > 0 ? (h.scrollTop / max) * 100 : 0;
      fill.style.width = p.toFixed(1) + '%';
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    document.addEventListener('astro:page-load', function () { fill = document.querySelector('.nav-progress-fill'); onScroll(); });
    onScroll();
  })();
</script>
