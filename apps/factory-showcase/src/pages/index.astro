      radial-gradient(50% 48% at 14% 92%, color-mix(in srgb, var(--color-adobe-violet) 20%, transparent), transparent 70%),
      radial-gradient(42% 42% at 52% 40%, color-mix(in srgb, var(--color-adobe-magenta) 12%, transparent), transparent 72%);
