---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href as buildHref } from '@edf/core/utils/url.js';
import T from '@edf/core/blocks/i18n/T.astro';
import { EXPERIENCES, EXPERIENCE_COUNT, spellCount } from '../data/experiences';

const base = import.meta.env.BASE_URL;
const b = base.replace(/\/?$/, '/');
const blueprint = buildHref(base, '/blueprint');
const TEAMS_URL = 'https://teams.microsoft.com/l/chat/0/0?users=agargiulo@adobe.com';
const SKILL_URL = 'https://github.com/agargiulo-adbe/experience-design-factory/tree/main/skills/experience-brief';
const SKILL_ZIP = `${b}skill/experience-brief-skill.zip`;
const SKILL_MD = `${b}skill/experience-brief-SKILL.md`;

// The entire site derives from the central EXPERIENCES module — add an entry
// there and the hero stats, prose counts, proof grid and architecture diagram
// all update automatically. LIVE URL lives on each entry; shots are resolved
// against the app base here.
const LIVE = 'https://agargiulo-adbe.github.io/experience-design-factory';
const experiences = EXPERIENCES.map((e) => ({
  ...e,
  href: e.url,
  shot: `${b}${e.shot}`,
}));
// Spelled-out portfolio count for prose ("Four" / "Quattro"), derived from data.
const countWords = spellCount(EXPERIENCE_COUNT);

const values = [
  {
    n: '01',
    titleEn: 'No rebuilding, ever', titleIt: 'Mai più da zero',
    bodyEn: 'A brand-perfect, accessible experience isn’t rebuilt each time — it’s a skin over a shared core. Once the thinking is done, the engine assembles a working build in an hour, so effort goes to strategy, not scaffolding.',
    bodyIt: 'Un’esperienza on-brand e accessibile non si ricostruisce ogni volta — è una skin sopra un core condiviso. Fatto il pensiero, il motore assembla una build funzionante in un’ora: l’impegno va alla strategia, non all’impalcatura.',
  },
  {
    n: '02',
    titleEn: 'Improve once, everyone inherits', titleIt: 'Migliora una volta, tutti ereditano',
    bodyEn: 'The deck, the admin console, i18n, responsiveness — they live in one engine. Fix or enhance it once and every experience in the portfolio gets it, verified.',
    bodyIt: 'Il deck, la console admin, l’i18n, il responsive — vivono in un solo motore. Correggi o migliori una volta e ogni esperienza del portfolio lo riceve, verificato.',
  },
  {
    n: '03',
    titleEn: 'A hard quality bar, enforced', titleIt: 'Uno standard alto, garantito',
    bodyEn: 'WCAG 2.2 AA, Lighthouse ≥ 95, auto-responsive from phone to giant TV. A deterministic 12-point deck audit runs at three projection sizes — quality is measured, not hoped for.',
    bodyIt: 'WCAG 2.2 AA, Lighthouse ≥ 95, auto-responsive dal telefono al maxi-schermo. Un audit deterministico a 12 punti gira su tre risoluzioni di proiezione — la qualità è misurata, non sperata.',
  },
  {
    n: '04',
    titleEn: 'Reconfigurable at runtime', titleIt: 'Riconfigurabile a runtime',
    bodyEn: 'Toggle Adobe solutions on or off, attach demo media to any slide, author new on-brand slides — then share a link. Tailor a live demo per audience with no redeploy.',
    bodyIt: 'Attiva o disattiva le solution Adobe, allega media demo a ogni slide, crea nuove slide on-brand — poi condividi un link. Adatta una demo live per ogni pubblico senza redeploy.',
  },
  {
    n: '05',
    titleEn: 'Bilingual by construction', titleIt: 'Bilingue per costruzione',
    bodyEn: 'Every string can carry EN and IT together; the active language switches instantly, with no reload. Built for an international audience from the first line.',
    bodyIt: 'Ogni stringa può portare EN e IT insieme; la lingua attiva cambia all’istante, senza reload. Pensato per un pubblico internazionale dalla prima riga.',
  },
  {
    n: '06',
    titleEn: 'Governed and multi-user', titleIt: 'Governato e multi-utente',
    bodyEn: 'A Super Admin Console with real authentication and per-experience roles sits on top — the system of record for who can configure what.',
    bodyIt: 'In cima c’è una Super Admin Console con autenticazione reale e ruoli per-esperienza — il sistema di riferimento su chi può configurare cosa.',
  },
];
---
<BaseLayout title="Home">
  <!-- ══ HERO ══ -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <p class="eyebrow" data-reveal>Adobe · Experience Design</p>
      <h1 id="hero-title" class="h-display hero-title" data-reveal data-reveal-delay="1">
        <T en="One engine." it="Un solo motore." as="span" class="hero-line" />
        <T en="Every brand." it="Ogni brand." as="span" class="hero-line" />
        <T en="Any experience." it="Qualunque esperienza." as="span" class="hero-line hero-line--grad" />
      </h1>
      <T
        en="The Experience Design Factory turns brand-perfect, accessible, interactive Adobe experiences into something you assemble — not rebuild. A shared core, a skin per client, and a console to run them all."
        it="La Experience Design Factory trasforma esperienze Adobe on-brand, accessibili e interattive in qualcosa che assembli — non ricostruisci. Un core condiviso, una skin per cliente e una console per governarle tutte."
        as="p" class="lead hero-lead" data-reveal data-reveal-delay="2" />
      <div class="hero-cta" data-reveal data-reveal-delay="3">
        <a href="#proof" class="btn btn-primary">
          <T en="See it live" it="Guardalo dal vivo" />
          <span aria-hidden="true">→</span>
        </a>
        <a href="#skill" class="btn btn-ghost hero-skill-cta">
          <span class="hero-skill-dot" aria-hidden="true"></span>
          <T en="Get the skill" it="Ottieni la skill" />
        </a>
      </div>
      <a href={blueprint} class="hero-textlink" data-reveal data-reveal-delay="3">
        <T en="or read the architecture blueprint" it="o leggi il blueprint dell’architettura" /> <span aria-hidden="true">→</span>
      </a>
      <dl class="hero-stats" data-reveal data-reveal-delay="3">
        <div><dt><span data-count={String(EXPERIENCE_COUNT)}>{EXPERIENCE_COUNT}</span></dt><dd><T en="live experiences" it="esperienze live" /></dd></div>
        <div><dt><span class="hero-stat-lt">&lt;</span>&nbsp;1<span class="hero-stat-u">h</span></dt><dd><T en="from brief to a working build" it="dal brief a una build funzionante" /></dd></div>
        <div><dt><span data-count="12">12</span></dt><dd><a class="hero-stat-ref" href={`${blueprint}#deck`}><T en="layout & accessibility checks, per slide" it="controlli di layout e accessibilità, per slide" /></a></dd></div>
        <div><dt><span data-count="2">2</span></dt><dd><T en="languages, instant switch" it="lingue, switch istantaneo" /></dd></div>
      </dl>
    </div>
  </section>

  <!-- ══ WHAT IT IS ══ -->
  <section id="what" class="section band-what" aria-labelledby="what-title">
    <div class="wrap">
      <p class="eyebrow" data-reveal><T en="What it is" it="Cos’è" /></p>
      <h2 id="what-title" class="h-section" data-reveal>
        <T en="A factory, not a folder of templates." it="Una fabbrica, non una cartella di template." />
      </h2>
      <T
        en="Every client Experience Design is a <em>skin</em> — design tokens, content, assets and configuration — laid over one shared engine. The engine owns the hard parts: the immersive keynote deck, the admin console, bilingual text, motion, the responsive behaviour and the quality gate. The skin owns what makes it unmistakably that brand."
        it="Ogni Experience Design cliente è una <em>skin</em> — design token, contenuti, asset e configurazione — stesa su un unico motore condiviso. Il motore possiede le parti difficili: il deck keynote immersivo, la console admin, il testo bilingue, il motion, il comportamento responsive e il controllo qualità. La skin possiede ciò che la rende inconfondibilmente quel brand."
        as="p" class="lead prose-max what-lead serif-note" data-reveal />

      <div class="split-cards">
        <article class="split-card split-card--engine" data-reveal>
          <span class="split-tag"><T en="The engine" it="Il motore" /></span>
          <h3><T en="Shared core" it="Core condiviso" /></h3>
          <ul role="list">
            <li><T en="Immersive keynote deck + presenter controls" it="Deck keynote immersivo + controlli presenter" /></li>
            <li><T en="Config-driven Admin Console" it="Admin Console guidata da configurazione" /></li>
            <li><T en="Bilingual i18n · motion · design-token contract" it="i18n bilingue · motion · contratto design-token" /></li>
            <li><T en="Responsive + fullscreen, phone → giant TV" it="Responsive + fullscreen, telefono → maxi-schermo" /></li>
          </ul>
        </article>
        <div class="split-plus" aria-hidden="true">+</div>
        <article class="split-card split-card--skin" data-reveal data-reveal-delay="1">
          <span class="split-tag"><T en="The skin" it="La skin" /></span>
          <h3><T en="Per client" it="Per cliente" /></h3>
          <ul role="list">
            <li><T en="Design tokens — colour, type, spacing" it="Design token — colore, tipografia, spaziatura" /></li>
            <li><T en="Real bilingual copy — never lorem" it="Copy bilingue reale — mai lorem" /></li>
            <li><T en="Curated, brand-safe imagery" it="Imagery curata e brand-safe" /></li>
            <li><T en="Section flow + solution configuration" it="Flusso sezioni + configurazione solution" /></li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ══ WHY IT MATTERS ══ -->
  <section id="why" class="section band-why" aria-labelledby="why-title">
    <div class="wrap">
      <p class="eyebrow" data-reveal><T en="Why it matters" it="Perché conta" /></p>
      <h2 id="why-title" class="h-section" data-reveal>
        <T en="Speed and quality usually trade off. Here they compound." it="Velocità e qualità di solito sono un compromesso. Qui si sommano." />
      </h2>
      <div class="value-grid">
        {values.map((v, i) => (
          <article class="value-card" data-reveal data-reveal-delay={String((i % 3) as 0 | 1 | 2)}>
            <span class="value-n">{v.n}</span>
            <h3 class="value-title"><T en={v.titleEn} it={v.titleIt} /></h3>
            <T en={v.bodyEn} it={v.bodyIt} as="p" class="value-body" />
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ PROOF ══ -->
  <section id="proof" class="section band-proof" aria-labelledby="proof-title">
    <div class="wrap">
      <p class="eyebrow eyebrow--dark" data-reveal><T en="Proof" it="La prova" /></p>
      <h2 id="proof-title" class="h-section proof-title" data-reveal>
        <T en="Not slides. Live, running software." it="Non slide. Software vivo, in esecuzione." />
      </h2>
      <T
        en={`${countWords.en} experiences are deployed and interactive right now — each a different brand, all the same engine. Open any of them.`}
        it={`${countWords.it} esperienze sono già online e interattive — ognuna un brand diverso, tutte lo stesso motore. Aprine una qualsiasi.`}
        as="p" class="lead proof-lead" data-reveal />

      <div class="exp-grid">
        {experiences.map((e, i) => (
          <a class="exp-card" href={e.href} target="_blank" rel="noopener" data-reveal data-reveal-delay={String((i % 3) as 0 | 1 | 2)} style={`--exp-accent:${e.accent}`}>
            <div class="exp-visual">
              <img class="exp-shot" src={e.shot} alt={`${e.name} — ${e.client}, live experience`} loading="lazy" width="1200" height="750" />
              <span class="exp-chip">{e.client}</span>
              <span class="exp-live" aria-hidden="true"><span class="exp-live-dot"></span>LIVE</span>
            </div>
            <div class="exp-body">
              <h3 class="exp-name">{e.name}</h3>
              <p class="exp-tag"><T en={e.tag.en} it={e.tag.it} /></p>
              <T en={e.desc.en} it={e.desc.it} as="p" class="exp-desc" />
              <span class="exp-open">
                <T en="Open experience" it="Apri l’esperienza" /> <span aria-hidden="true">↗</span>
              </span>
            </div>
          </a>
        ))}
      </div>

      <a class="console-strip" href={`${LIVE}/console/`} target="_blank" rel="noopener" data-reveal>
        <div class="console-ico" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
            <rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/>
            <rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/>
          </svg>
        </div>
        <div class="console-text">
          <p class="console-title"><T en="Super Admin Console" it="Super Admin Console" /></p>
          <T en="The governance layer — auth, users, and the experiences registry that runs above them all."
             it="Il layer di governance — auth, utenti e il registry delle esperienze che sta sopra a tutte." as="p" class="console-desc" />
        </div>
        <span class="console-open" aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  <!-- ══ ARCHITECTURE ══ -->
  <section id="architecture" class="section band-arch" aria-labelledby="arch-title">
    <div class="wrap">
      <p class="eyebrow" data-reveal><T en="How it’s built" it="Com’è fatto" /></p>
      <h2 id="arch-title" class="h-section" data-reveal>
        <T en="One monorepo, cleanly layered." it="Un monorepo, a strati puliti." />
      </h2>
      <T
        en="A shared engine at the bottom, client skins in the middle, a governance console on top, a backend for auth and sharing, and a build that merges everything into one deploy."
        it="Un motore condiviso alla base, le skin cliente al centro, una console di governance in cima, un backend per auth e condivisione, e una build che unisce tutto in un unico deploy."
        as="p" class="lead prose-max" data-reveal />

      <div class="arch-diagram" data-reveal role="img"
           aria-label={`Architecture: console and backend on top, ${EXPERIENCE_COUNT} client skins in the middle, shared core engine at the base, delivered to GitHub Pages.`}>
        <div class="arch-layer arch-top">
          <div class="arch-box arch-box--console">
            <span class="arch-kicker">apps/console</span>
            <strong><T en="Super Admin Console" it="Super Admin Console" /></strong>
            <em><T en="auth · users · experiences registry" it="auth · utenti · registry esperienze" /></em>
          </div>
          <div class="arch-box arch-box--backend">
            <span class="arch-kicker">supabase</span>
            <strong>Backend</strong>
            <em><T en="Auth · Postgres/RLS · Edge Function" it="Auth · Postgres/RLS · Edge Function" /></em>
          </div>
        </div>

        <div class="arch-layer arch-skins">
          <span class="arch-layer-label"><T en="Client skins — apps/*" it="Skin cliente — apps/*" /></span>
          <div class="arch-skins-row">
            {EXPERIENCES.map((e) => (
              <div class="arch-skin" style={`--k:${e.accent}`}><strong>{e.brandLabel}</strong><span>{e.name}</span></div>
            ))}
            <div class="arch-skin arch-skin--next"><strong>+</strong><span><T en="the next brand" it="il prossimo brand" /></span></div>
          </div>
        </div>

        <div class="arch-layer arch-core">
          <span class="arch-core-kicker">packages/core · @edf/core</span>
          <strong class="arch-core-title"><T en="Shared engine" it="Motore condiviso" /></strong>
          <div class="arch-core-chips">
            <span>Immersive deck</span><span>Admin engine</span><span>i18n</span>
            <span>Design tokens</span><span>Motion</span><span>Responsive + fullscreen</span>
          </div>
        </div>

        <div class="arch-deliver">
          <span class="arch-arrow" aria-hidden="true">↓</span>
          <span class="arch-deliver-label">GitHub Actions → GitHub Pages · <T en="one merged artifact, one URL space" it="un artifact unico, un solo spazio di URL" /></span>
        </div>
      </div>

      <div class="arch-cta" data-reveal>
        <div>
          <h3 class="arch-cta-title"><T en="Want the engineering detail?" it="Vuoi il dettaglio ingegneristico?" /></h3>
          <T en="The blueprint covers the deck visual contract, runtime configurability, i18n, governance, delivery and the quality method."
             it="Il blueprint copre il contratto visivo del deck, la configurabilità a runtime, l’i18n, la governance, la delivery e il metodo di qualità."
             as="p" class="arch-cta-desc" />
        </div>
        <a href={blueprint} class="btn btn-primary">
          <T en="Open the blueprint" it="Apri il blueprint" /> <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══ HOW AN EXPERIENCE IS BORN ══ -->
  <section id="flow" class="section band-flow" aria-labelledby="flow-title">
    <div class="wrap">
      <p class="eyebrow" data-reveal><T en="How an experience is born" it="Come nasce un’esperienza" /></p>
      <h2 id="flow-title" class="h-section" data-reveal>
        <T en="You do the thinking. The engine does the hour." it="Il pensiero è tuo. L’ora è del motore." />
      </h2>
      <p class="lead prose-max flow-lead serif-note" data-reveal>
        <T en="Researching the brand, finding the angle, shaping the story — that’s the Adobian’s craft, and it takes the time it deserves. The factory removes everything that <em>isn’t</em> that: once the brief is ready, a working, brand-perfect experience is scaffolded in under an hour — then the Adobian makes it grow."
           it="Studiare il brand, trovare l’angolo, dare forma alla storia — è il mestiere dell’Adobian, e prende il tempo che merita. La fabbrica toglie tutto ciò che <em>non</em> è quello: quando il brief è pronto, un’esperienza funzionante e on-brand viene scaffoldata in meno di un’ora — poi l’Adobian la fa crescere." />
      </p>

      <div class="flow-kb" data-reveal>
        <span class="flow-kb-badge" aria-hidden="true">KB</span>
        <div>
          <h3 class="flow-kb-title"><T en="It starts with grounded knowledge — kept strictly local" it="Parte da una conoscenza fondata — e rigorosamente locale" /></h3>
          <p class="flow-kb-desc">
            <T en="A curated knowledge base — Adobe product depth, points of view, use cases and positioning — grounds every experience. It lives <strong>only on Antonio’s own computer</strong>, like any other file on his machine: it is <strong>never uploaded to any third-party, cloud or external system</strong>. To protect Adobe’s data, by design."
               it="Una knowledge base curata — competenza sui prodotti Adobe, point of view, casi d’uso e posizionamento — fonda ogni esperienza. Vive <strong>solo sul computer di Antonio</strong>, come qualunque altro file sulla sua macchina: <strong>non viene mai caricata su alcun sistema terzo, cloud o esterno</strong>. A tutela dei dati Adobe, per scelta." />
          </p>
        </div>
      </div>

      <ol class="flow-steps" role="list">
        <li class="flow-step" data-reveal>
          <span class="flow-step-n" aria-hidden="true">01</span>
          <div class="flow-step-body">
            <span class="flow-step-actor" data-actor="human"><T en="Adobian" it="Adobian" /></span>
            <h3 class="flow-step-title"><T en="Research" it="Ricerca" /></h3>
            <p class="flow-step-desc">
              <T en="An Adobian runs deep research in their own Claude, ChatGPT or Copilot — objectives, industrial plan, financials, news, brand and CX initiatives: the full context of the company the experience is for. A shareable Factory skill asks the right questions."
                 it="Un Adobian conduce una ricerca approfondita nel proprio Claude, ChatGPT o Copilot — obiettivi, piano industriale, bilanci, news, brand e iniziative CX: tutto il contesto dell’azienda per cui si costruisce. Una skill condivisibile della Factory pone le domande giuste." />
            </p>
            <a class="flow-step-link" href="#skill">
              <T en="Get the skill for Claude, ChatGPT or Copilot" it="Ottieni la skill per Claude, ChatGPT o Copilot" /> <span aria-hidden="true">↓</span>
            </a>
          </div>
        </li>
        <li class="flow-step" data-reveal>
          <span class="flow-step-n" aria-hidden="true">02</span>
          <div class="flow-step-body">
            <span class="flow-step-actor" data-actor="human"><T en="Adobian" it="Adobian" /></span>
            <h3 class="flow-step-title"><T en="Draft" it="Draft" /></h3>
            <p class="flow-step-desc">
              <T en="The same Adobian sketches the experience they want to create — the story, the sections, the Adobe capabilities to reveal."
                 it="Lo stesso Adobian abbozza l’esperienza che vuole creare — la storia, le sezioni, le capability Adobe da svelare." />
            </p>
          </div>
        </li>
        <li class="flow-step" data-reveal>
          <span class="flow-step-n" aria-hidden="true">03</span>
          <div class="flow-step-body">
            <span class="flow-step-actor" data-actor="human"><T en="Adobian" it="Adobian" /></span>
            <h3 class="flow-step-title"><T en="The brief" it="Il brief" /></h3>
            <p class="flow-step-desc">
              <T en="The output is a hyper-detailed brief. It lands with Antonio Gargiulo, who turns intent into an executable spec."
                 it="L’output è un brief di iper-dettaglio. Arriva ad Antonio Gargiulo, che trasforma l’intento in uno spec eseguibile." />
            </p>
          </div>
        </li>
        <li class="flow-step" data-reveal>
          <span class="flow-step-n" aria-hidden="true">04</span>
          <div class="flow-step-body">
            <span class="flow-step-actor" data-actor="engine"><T en="The engine · ~1h" it="Il motore · ~1h" /></span>
            <h3 class="flow-step-title"><T en="Scaffold" it="Scaffold" /></h3>
            <p class="flow-step-desc">
              <T en="The engine assembles the skin over the shared core — deck, Admin Console, i18n and responsiveness included. A working build is ready in under an hour."
                 it="Il motore assembla la skin sul core condiviso — deck, Admin Console, i18n e responsive inclusi. Una build funzionante è pronta in meno di un’ora." />
            </p>
          </div>
        </li>
        <li class="flow-step" data-reveal>
          <span class="flow-step-n" aria-hidden="true">05</span>
          <div class="flow-step-body">
            <span class="flow-step-actor" data-actor="human"><T en="Adobian" it="Adobian" /></span>
            <h3 class="flow-step-title"><T en="Grow" it="Crescita" /></h3>
            <p class="flow-step-desc">
              <T en="The commissioning Adobian is granted Admin Console access — and grows the experience themselves: sections, demo media, custom slides, shareable links."
                 it="All’Adobian committente viene dato accesso alla Admin Console — e fa crescere l’esperienza in autonomia: sezioni, media demo, slide personalizzate, link condivisibili." />
            </p>
          </div>
        </li>
        <li class="flow-step" data-reveal>
          <span class="flow-step-n" aria-hidden="true">06</span>
          <div class="flow-step-body">
            <span class="flow-step-actor" data-actor="factory"><T en="Factory KB" it="KB Factory" /></span>
            <h3 class="flow-step-title"><T en="Verified" it="Verifica" /></h3>
            <p class="flow-step-desc">
              <T en="Every step is checked against the Experience Design Factory knowledge base — so what ships is accurate, on-message and on-brand."
                 it="Ogni passo è verificato contro la knowledge base della Experience Design Factory — così ciò che va live è accurato, coerente nel messaggio e on-brand." />
            </p>
          </div>
        </li>
      </ol>

      <aside class="flow-note" data-reveal>
        <span class="flow-note-tag"><T en="Worth noting" it="Da segnalare" /></span>
        <p class="flow-note-text">
          <T en="Everything here — every tool in this chain <strong>and</strong> every component behind the Factory’s architecture and runtime — is active and accessible with an @adobe.com account via Google login. Technologies neither blocked nor precluded by Adobe. No additional licence."
             it="Tutto qui — ogni strumento di questa catena <strong>e</strong> ogni componente dietro l’architettura e il runtime della Factory — è attivo e accessibile con un account @adobe.com via login Google. Tecnologie né bloccate né precluse da Adobe. Nessuna licenza aggiuntiva." />
        </p>
      </aside>
    </div>
  </section>

  <!-- ══ THE SKILL ══ -->
