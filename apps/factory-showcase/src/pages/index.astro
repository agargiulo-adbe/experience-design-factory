<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function countUp(el) {
      var target = parseInt(el.getAttribute('data-count'), 10);
      if (isNaN(target) || reduce) { return; }
      var dur = 900, start = null;
      function step(ts) {
        if (start === null) start = ts;
        var p = Math.min((ts - start) / dur, 1);
        var eased = 1 - Math.pow(1 - p, 3);
        el.textContent = String(Math.round(eased * target));
        if (p < 1) requestAnimationFrame(step); else el.textContent = String(target);
      }
      el.textContent = '0';
      requestAnimationFrame(step);
    }
    function initCount() {
      var els = document.querySelectorAll('[data-count]:not([data-counted])');
      if (!('IntersectionObserver' in window)) { els.forEach(function (e) { e.setAttribute('data-counted',''); }); return; }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.setAttribute('data-counted',''); countUp(e.target); io.unobserve(e.target); }
        });
      }, { threshold: 0.6 });
      els.forEach(function (e) { io.observe(e); });
    }
    function initCopy() {
      document.querySelectorAll('[data-copy-skill]').forEach(function (btn) {
        if (btn.__wired) return; btn.__wired = true;
        btn.addEventListener('click', function () {
          var src = btn.getAttribute('data-skill-src');
          fetch(src).then(function (r) { return r.text(); }).then(function (txt) {
            var body = txt.replace(/^---[\s\S]*?---\s*/, '');
            return navigator.clipboard.writeText(body);
          }).then(function () {
            var idle = btn.querySelector('[data-copy-idle]'), done = btn.querySelector('[data-copy-done]');
            if (idle && done) { idle.hidden = true; done.hidden = false; setTimeout(function () { idle.hidden = false; done.hidden = true; }, 2200); }
          }).catch(function () {
            var src2 = btn.getAttribute('data-skill-src'); if (src2) window.open(src2, '_blank');
          });
        });
      });
    }
    function init() { initCount(); initCopy(); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
