---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Experiences" active="experiences">
  <div class="page-head">
    <div>
      <h1 class="page-title">Experiences</h1>
      <p class="page-sub" data-sub>Gestisci le Experience Design attive e apri la loro console di configurazione.</p>
    </div>
  </div>

  <div class="exp-grid" data-exp-grid>
    <div class="exp-skeleton">Caricamento…</div>
  </div>

  <script>
    import { requireAuth, consoleHref } from '../lib/guard';
    import { listExperiences, rest } from '../lib/supabase';

    const STATUS = {
      live:     { label: 'Live',       color: 'var(--accent-green)', soft: 'var(--accent-green-soft)' },
      draft:    { label: 'Bozza',      color: 'var(--accent-gold)',  soft: 'var(--accent-gold-soft)' },
      archived: { label: 'Archiviata', color: 'var(--ink-tertiary)', soft: 'var(--bg-card)' },
    };

    function esc(s) { return String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c])); }

    (async () => {
      const ctx = await requireAuth();
      if (!ctx) return;
      const { session, profile, access } = ctx;
      const grid = document.querySelector('[data-exp-grid]');
      const sub = document.querySelector('[data-sub]');

      let experiences = [];
      try { experiences = await listExperiences(session); } catch (e) { grid.innerHTML = '<p class="exp-empty">Impossibile caricare le experience.</p>'; return; }

      const accessSlugs = new Set(access.map((a) => a.experience_slug));
      const visible = profile.is_super_admin ? experiences : experiences.filter((e) => accessSlugs.has(e.slug) && e.status !== 'archived');

      if (sub) sub.textContent = profile.is_super_admin
        ? 'Gestisci le Experience Design, il loro stato e apri la console di configurazione.'
        : 'Le Experience Design a cui hai accesso. Apri la console per configurarle.';

      if (visible.length === 0) {
        grid.innerHTML = '<p class="exp-empty">Nessuna experience assegnata. Chiedi a un Super Admin l\'accesso.</p>';
        return;
      }

      grid.innerHTML = visible.map((exp) => {
        const st = STATUS[exp.status] || STATUS.draft;
        const adminUrl = exp.base_url.replace(/\/$/, '') + '/admin/';
        const canManage = profile.is_super_admin;
        return `
        <article class="exp-card" data-slug="${esc(exp.slug)}">
          <div class="exp-card-top">
            <div>
              <p class="exp-client">${esc(exp.client)}</p>
              <h2 class="exp-name">${esc(exp.name)}</h2>
            </div>
            <span class="exp-status" style="color:${st.color};background:${st.soft};">${st.label}</span>
          </div>
          <p class="exp-desc">${esc(exp.description || '')}</p>
          <div class="exp-actions">
            <a class="btn-primary" href="${adminUrl}">Apri Console</a>
            <a class="btn-ghost" href="${esc(exp.base_url)}" target="_blank" rel="noopener">Apri experience</a>
            ${canManage ? `
            <select class="exp-status-select" data-status-select aria-label="Stato">
              <option value="live" ${exp.status==='live'?'selected':''}>Live</option>
              <option value="draft" ${exp.status==='draft'?'selected':''}>Bozza</option>
              <option value="archived" ${exp.status==='archived'?'selected':''}>Archiviata</option>
            </select>` : ''}
          </div>
          <span class="exp-saved" data-saved hidden>✓ Aggiornata</span>
        </article>`;
      }).join('');

      // Wire status changes (super admin only)
      if (profile.is_super_admin) {
        grid.querySelectorAll('[data-status-select]').forEach((sel) => {
          sel.addEventListener('change', async () => {
            const card = sel.closest('.exp-card');
            const slug = card.getAttribute('data-slug');
            const status = sel.value;
            try {
              await rest(`experiences?slug=eq.${slug}`, {
                method: 'PATCH',
                headers: { Prefer: 'return=minimal' },
                body: JSON.stringify({ status, updated_at: new Date().toISOString() }),
              }, session);
              const pill = card.querySelector('.exp-status');
              const st = STATUS[status];
              if (pill) { pill.textContent = st.label; pill.style.color = st.color; pill.style.background = st.soft; }
              const saved = card.querySelector('[data-saved]');
              if (saved) { saved.hidden = false; setTimeout(() => saved.hidden = true, 1800); }
            } catch (e) { alert('Aggiornamento non riuscito.'); }
          });
        });
      }
    })();
  </script>

  <style>
    .page-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.75rem; }
    .page-title { font-size: 1.6rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 0.35rem; }
    .page-sub { font-size: 0.9rem; color: var(--ink-secondary); max-width: 42rem; line-height: 1.55; }
    .exp-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    @media (max-width: 640px) { .exp-grid { grid-template-columns: 1fr; } }
    .exp-skeleton, .exp-empty { grid-column: 1 / -1; color: var(--ink-tertiary); font-size: 0.9rem; padding: 2rem 0; text-align: center; }
    .exp-card { background: var(--bg-panel); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem 1.4rem; display: flex; flex-direction: column; }
    .exp-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.75rem; }
    .exp-client { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-tertiary); margin-bottom: 0.15rem; }
    .exp-name { font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; }
    .exp-status { font-size: 0.6875rem; font-weight: 600; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
    .exp-desc { font-size: 0.8125rem; color: var(--ink-secondary); line-height: 1.55; margin-bottom: 1.1rem; flex: 1; }
    .exp-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
    .exp-status-select { margin-left: auto; font-size: 0.8125rem; padding: 0.35rem 0.5rem; border: 1px solid var(--border-strong); border-radius: 6px; background: #fff; color: var(--ink-secondary); cursor: pointer; }
    .exp-saved { font-size: 0.75rem; color: var(--accent-green); margin-top: 0.6rem; }
  </style>
</BaseLayout>
