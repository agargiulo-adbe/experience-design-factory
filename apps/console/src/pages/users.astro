---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Utenti" active="users">
  <div class="page-head">
    <div>
      <h1 class="page-title">Utenti</h1>
      <p class="page-sub">Invita collaboratori e gestisci ruoli e accessi per singola experience.</p>
    </div>
    <button class="btn-primary" data-open-invite>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M8 3v10M3 8h10"/></svg>
      Invita utente
    </button>
  </div>

  <!-- Invite panel -->
  <div class="invite-panel" data-invite-panel hidden>
    <div class="invite-grid">
      <div>
        <label class="fld-label" for="inv-email">Email</label>
        <input class="field-input" type="email" id="inv-email" placeholder="nome@azienda.com" />
      </div>
      <div>
        <label class="fld-label" for="inv-name">Nome completo</label>
        <input class="field-input" type="text" id="inv-name" placeholder="Nome Cognome" />
      </div>
    </div>
    <label class="inv-super"><input type="checkbox" id="inv-super" /> Super Admin <span>(accesso completo + gestione utenti)</span></label>
    <div data-inv-access-wrap>
      <p class="fld-label">Accesso alle experience</p>
      <div class="inv-access" data-inv-access></div>
    </div>
    <p class="invite-feedback" data-invite-feedback hidden></p>
    <div class="invite-actions">
      <button class="btn-primary" data-send-invite>Invia invito</button>
      <button class="btn-ghost" data-cancel-invite>Annulla</button>
    </div>
  </div>

  <div class="users-wrap" data-users-wrap>
    <div class="users-loading">Caricamento…</div>
  </div>

  <script>
    import { requireAuth } from '../lib/guard';
    import { rest, inviteUser } from '../lib/supabase';

    function esc(s) { return String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c])); }

    (async () => {
      const ctx = await requireAuth({ superOnly: true });
      if (!ctx) return;
      const { session, profile } = ctx;

      const wrap = document.querySelector('[data-users-wrap]');
      let experiences = [], profiles = [], roles = [];
      async function loadAll() {
        [experiences, profiles, roles] = await Promise.all([
          rest('experiences?select=slug,name,client&order=name.asc', {}, session),
          rest('profiles?select=*&order=created_at.asc', {}, session),
          rest('user_experience_roles?select=*', {}, session),
        ]);
      }
      try { await loadAll(); } catch (e) { wrap.innerHTML = '<p class="users-empty">Impossibile caricare gli utenti.</p>'; return; }

      // ── Invite panel ──────────────────────────────────────────────
      const panel = document.querySelector('[data-invite-panel]');
      const accessWrap = document.querySelector('[data-inv-access]');
      accessWrap.innerHTML = experiences.map((e) =>
        `<label class="inv-access-chip"><input type="checkbox" value="${esc(e.slug)}" /> ${esc(e.name)}</label>`
      ).join('');

      document.querySelector('[data-open-invite]')?.addEventListener('click', () => panel.hidden = !panel.hidden);
      document.querySelector('[data-cancel-invite]')?.addEventListener('click', () => panel.hidden = true);
      const invSuper = document.querySelector('#inv-super');
      const accessBlock = document.querySelector('[data-inv-access-wrap]');
      invSuper?.addEventListener('change', () => { accessBlock.style.opacity = invSuper.checked ? '0.4' : '1'; accessBlock.style.pointerEvents = invSuper.checked ? 'none' : ''; });

      document.querySelector('[data-send-invite]')?.addEventListener('click', async () => {
        const email = document.querySelector('#inv-email').value.trim();
        const full_name = document.querySelector('#inv-name').value.trim();
        const is_super_admin = invSuper.checked;
        const access = [...accessWrap.querySelectorAll('input:checked')].map((c) => ({ experience_slug: c.value, role: 'admin' }));
        const fb = document.querySelector('[data-invite-feedback]');
        if (!email) { fb.hidden = false; fb.textContent = 'Inserisci un\'email.'; fb.style.color = 'var(--accent-red)'; return; }
        const btn = document.querySelector('[data-send-invite]');
        btn.disabled = true; btn.textContent = 'Invio…';
        try {
          await inviteUser(session, { email, full_name, is_super_admin, access });
          fb.hidden = false; fb.textContent = '✓ Invito inviato a ' + email; fb.style.color = 'var(--accent-green)';
          await loadAll(); render();
          document.querySelector('#inv-email').value = ''; document.querySelector('#inv-name').value = '';
        } catch (ex) {
          fb.hidden = false; fb.textContent = ex.message || 'Invito non riuscito.'; fb.style.color = 'var(--accent-red)';
        } finally { btn.disabled = false; btn.textContent = 'Invia invito'; }
      });

      // ── Users table ───────────────────────────────────────────────
      function accessFor(uid) { return roles.filter((r) => r.user_id === uid); }

      function render() {
        if (profiles.length === 0) { wrap.innerHTML = '<p class="users-empty">Nessun utente.</p>'; return; }
        wrap.innerHTML = profiles.map((u) => {
          const acc = accessFor(u.id);
          const roleChips = u.is_super_admin
            ? '<span class="role-chip role-super">Super Admin · tutte le experience</span>'
            : (acc.length ? acc.map((a) => `<span class="role-chip">${esc(a.experience_slug)}</span>`).join('') : '<span class="role-none">nessun accesso</span>');
          const isSelf = u.id === profile.id;
          return `
          <div class="user-row" data-uid="${esc(u.id)}">
            <div class="user-main">
              <div class="user-avatar">${esc((u.full_name || u.email || '?').slice(0,1).toUpperCase())}</div>
              <div>
                <p class="user-name">${esc(u.full_name || '—')}${isSelf ? ' <span class="user-you">tu</span>' : ''}</p>
                <p class="user-email">${esc(u.email)}</p>
              </div>
            </div>
            <div class="user-roles">${roleChips}</div>
            <div class="user-status">
              <span class="status-dot ${u.status === 'active' ? 'ok' : 'off'}"></span>${u.status === 'active' ? 'Attivo' : 'Sospeso'}
            </div>
            <div class="user-actions">
              <button class="btn-ghost" data-edit-access ${u.is_super_admin ? 'disabled' : ''}>Accessi</button>
              <button class="btn-ghost" data-toggle-super ${isSelf ? 'disabled title="Non puoi cambiare il tuo ruolo"' : ''}>${u.is_super_admin ? 'Rimuovi Super' : 'Rendi Super'}</button>
              <button class="btn-ghost" data-toggle-status ${isSelf ? 'disabled' : ''}>${u.status === 'active' ? 'Sospendi' : 'Riattiva'}</button>
            </div>
            <div class="access-editor" data-access-editor hidden>
              ${experiences.map((e) => {
                const on = acc.some((a) => a.experience_slug === e.slug);
                return `<label class="acc-chip ${on ? 'on' : ''}"><input type="checkbox" value="${esc(e.slug)}" ${on ? 'checked' : ''}/> ${esc(e.name)}</label>`;
              }).join('')}
            </div>
          </div>`;
        }).join('');
        wire();
      }

      function wire() {
        wrap.querySelectorAll('.user-row').forEach((row) => {
          const uid = row.getAttribute('data-uid');
          const user = profiles.find((p) => p.id === uid);

          row.querySelector('[data-toggle-super]')?.addEventListener('click', async (e) => {
            if (e.currentTarget.disabled) return;
            try {
              await rest(`profiles?id=eq.${uid}`, { method: 'PATCH', headers: { Prefer: 'return=minimal' }, body: JSON.stringify({ is_super_admin: !user.is_super_admin }) }, session);
              await loadAll(); render();
            } catch { alert('Operazione non riuscita.'); }
          });

          row.querySelector('[data-toggle-status]')?.addEventListener('click', async (e) => {
            if (e.currentTarget.disabled) return;
            try {
              await rest(`profiles?id=eq.${uid}`, { method: 'PATCH', headers: { Prefer: 'return=minimal' }, body: JSON.stringify({ status: user.status === 'active' ? 'suspended' : 'active' }) }, session);
              await loadAll(); render();
            } catch { alert('Operazione non riuscita.'); }
          });

          const editor = row.querySelector('[data-access-editor]');
          row.querySelector('[data-edit-access]')?.addEventListener('click', (e) => {
            if (e.currentTarget.disabled) return;
            editor.hidden = !editor.hidden;
          });

          editor?.querySelectorAll('input[type=checkbox]').forEach((cb) => {
            cb.addEventListener('change', async () => {
              const slug = cb.value;
              try {
                if (cb.checked) {
                  await rest('user_experience_roles', { method: 'POST', headers: { Prefer: 'resolution=merge-duplicates,return=minimal' }, body: JSON.stringify({ user_id: uid, experience_slug: slug, role: 'admin' }) }, session);
                } else {
                  await rest(`user_experience_roles?user_id=eq.${uid}&experience_slug=eq.${slug}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, session);
                }
                cb.closest('.acc-chip').classList.toggle('on', cb.checked);
                await loadAll();
                // refresh only the role chips for this row
                const acc = roles.filter((r) => r.user_id === uid);
                const rolesEl = row.querySelector('.user-roles');
                if (rolesEl) rolesEl.innerHTML = acc.length ? acc.map((a) => `<span class="role-chip">${esc(a.experience_slug)}</span>`).join('') : '<span class="role-none">nessun accesso</span>';
              } catch { alert('Operazione non riuscita.'); cb.checked = !cb.checked; }
            });
          });
        });
      }

      render();
    })();
  </script>

  <style is:global>
    .page-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
    .page-title { font-size: 1.6rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 0.35rem; }
    .page-sub { font-size: 0.9rem; color: var(--ink-secondary); }

    .invite-panel { background: var(--bg-panel); border: 1px solid var(--border); border-radius: 12px; padding: 1.4rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .invite-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 560px) { .invite-grid { grid-template-columns: 1fr; } }
    .fld-label { font-size: 0.75rem; font-weight: 500; color: var(--ink-secondary); margin-bottom: 0.3rem; display: block; }
    .inv-super { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 500; color: var(--ink-primary); cursor: pointer; }
    .inv-super span { font-weight: 400; color: var(--ink-tertiary); }
    .inv-super input { accent-color: var(--accent-red); }
    .inv-access { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .inv-access-chip, .acc-chip { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8125rem; padding: 0.35rem 0.7rem; border: 1px solid var(--border-strong); border-radius: 20px; cursor: pointer; color: var(--ink-secondary); }
    .inv-access-chip input, .acc-chip input { accent-color: var(--accent-red); }
    .acc-chip.on { border-color: var(--accent-red); color: var(--accent-red); background: var(--accent-red-soft); }
    .invite-feedback { font-size: 0.8125rem; margin: 0; }
    .invite-actions { display: flex; gap: 0.6rem; }

    .users-wrap { background: var(--bg-panel); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .users-loading, .users-empty { padding: 2rem; text-align: center; color: var(--ink-tertiary); font-size: 0.9rem; }
    .user-row { display: grid; grid-template-columns: minmax(0,1.4fr) minmax(0,1.6fr) auto auto; gap: 1rem; align-items: center; padding: 1rem 1.4rem; border-bottom: 1px solid var(--border); }
    .user-row:last-child { border-bottom: none; }
    .user-main { display: flex; align-items: center; gap: 0.75rem; min-width: 0; }
    .user-avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--accent-red-soft); color: var(--accent-red); font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .user-name { font-size: 0.875rem; font-weight: 600; }
    .user-you { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; color: var(--ink-tertiary); border: 1px solid var(--border); padding: 0 5px; border-radius: 10px; margin-left: 0.35rem; }
    .user-email { font-size: 0.8125rem; color: var(--ink-secondary); }
    .user-roles { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .role-chip { font-size: 0.6875rem; font-weight: 600; padding: 2px 8px; border-radius: 20px; background: var(--accent-blue-soft); color: var(--accent-blue); }
    .role-super { background: var(--accent-red-soft); color: var(--accent-red); }
    .role-none { font-size: 0.75rem; color: var(--ink-tertiary); font-style: italic; }
    .user-status { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8125rem; color: var(--ink-secondary); white-space: nowrap; }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; }
    .status-dot.ok { background: var(--accent-green); }
    .status-dot.off { background: var(--ink-tertiary); }
    .user-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; justify-content: flex-end; }
    .access-editor { grid-column: 1 / -1; display: flex; flex-wrap: wrap; gap: 0.5rem; padding-top: 0.75rem; }
  </style>
</BaseLayout>
