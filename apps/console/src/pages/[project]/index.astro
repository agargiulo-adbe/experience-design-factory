---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROJECTS, getProject } from '../../data/projects-registry';

export function getStaticPaths() {
  return PROJECTS.filter(p => p.solutions.length > 0).map((p) => ({
    params: { project: p.slug },
  }));
}

const { project: slug } = Astro.params;
const project = getProject(slug!)!;

const base = import.meta.env.BASE_URL;
function consoleHref(path: string): string {
  return base.replace(/\/$/, '') + path;
}

// La configurazione (sezioni on/off + media demo) è stata unificata
// nella console di configurazione dell'experience: {baseUrl}admin/.
const adminUrl = `${project.baseUrl}admin/`;
---
<BaseLayout title={`${project.name} — Configura`}>
  <div class="max-w-lg mx-auto px-6 py-24 text-center">
    <nav class="flex items-center justify-center gap-2 text-xs mb-10" style="color: var(--ink-tertiary);" aria-label="Breadcrumb">
      <a href={consoleHref('/')} class="hover:underline" style="color: var(--ink-secondary);">Progetti</a>
      <span aria-hidden="true">›</span>
      <span style="color: var(--ink-primary);">{project.client} · {project.name}</span>
    </nav>

    <h1 class="text-xl font-semibold mb-3" style="color: var(--ink-primary);">Console di configurazione</h1>
    <p class="text-sm mb-8" style="color: var(--ink-secondary); line-height: 1.6;">
      La configurazione delle sezioni e dei media demo è ora unificata nella
      console dell'experience. Ti stiamo reindirizzando…
    </p>

    <a
      href={adminUrl}
      class="inline-flex items-center gap-2 py-2.5 px-5 rounded text-sm font-medium transition-colors"
      style="background: var(--accent-red-soft); color: var(--accent-red);"
    >
      Apri la console di configurazione
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4"/>
      </svg>
    </a>
  </div>

  <script is:inline define:vars={{ adminUrl }}>
    location.replace(adminUrl);
  </script>
</BaseLayout>
