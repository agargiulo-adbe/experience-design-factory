---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import MockupSlide from '@edf/core/blocks/immersive/MockupSlide.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const cjaCards = [
  { en: 'Every partner', it: 'Ogni partner', subEn: 'HP · Shell · Puma · IBM · UniCredit · Aon, one portfolio', subIt: 'HP · Shell · Puma · IBM · UniCredit · Aon, un unico portfolio' },
  { en: 'Every channel', it: 'Ogni canale', subEn: 'Web, app, social, CRM and on-site, all unified', subIt: 'Web, app, social, CRM e on-site, tutti unificati' },
  { en: 'Every season', it: 'Ogni stagione', subEn: 'Race by race, campaign by campaign, year over year', subIt: 'Gara dopo gara, campagna dopo campagna, anno su anno' },
];

const partners = ['HP', 'Shell', 'Puma', 'IBM', 'UniCredit', 'Aon'];

const insights = [
  { en: 'Audience value, proven', it: 'Valore dell’audience, dimostrato', subEn: 'Which Tifosi segments each partner really reached, and really moved.', subIt: 'Quali segmenti di Tifosi ogni partner ha davvero raggiunto, e davvero attivato.' },
  { en: 'ROI per partner', it: 'ROI per partner', subEn: 'Value read side by side in one shared model. No more black box.', subIt: 'Valore letto fianco a fianco in un unico modello condiviso. Niente più scatola nera.' },
  { en: 'What to scale next', it: 'Cosa scalare dopo', subEn: 'The activations that earned their place in next season’s plan.', subIt: 'Le attivazioni che si sono guadagnate un posto nel piano della prossima stagione.' },
];
---
<BaseLayout title="Analytics" pageSolutions={['cja']}>
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/proof')} prevHref={href(base, '/activate')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('data-telemetry')} imageClass="opacity-30" scrim="bg-[var(--surface-inverse)]/78" />
      <T en="ANALYTICS" it="ANALISI" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1.5rem,4.2vh,3rem)]" />
      <T
        as="h1" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.75rem,5.2vh,3.75rem)]" style="font-size: clamp(3rem, 7.5vw, 6.5rem);"
        en="One CJA.<br/>Every partner."
        it="Una CJA.<br/>Ogni partner."
      />
      <T
        as="p"
        class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
        en="Each partner sees its own results in GenStudio, while all campaign data converges into Ferrari Racing's Customer Journey Analytics: one view of the whole season."
        it="Ogni partner vede i propri risultati in GenStudio, mentre tutti i dati delle campagne confluiscono nella Customer Journey Analytics di Ferrari Racing: un'unica vista dell'intera stagione."
      />
    </Slide>

    <!-- ── SLIDE 1: CJA — the whole portfolio ─────────────────────── -->
    <Slide id="slide-cja" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-pit')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <div class="w-full max-w-6xl mx-auto text-center">
        <T en="CUSTOMER JOURNEY ANALYTICS" it="CUSTOMER JOURNEY ANALYTICS" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-4" />
        <T
          as="h2" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.25rem,3.5vh,2.5rem)]" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
          en="The whole portfolio, in one place."
          it="L'intero portfolio, in un unico posto."
        />
        <T
          as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mx-auto mb-[clamp(1.75rem,4.5vh,3rem)]"
          en="Results from every partner campaign flow into Ferrari's CJA instance on Adobe Experience Platform, across channels, partners and seasons."
          it="I risultati di ogni campagna partner confluiscono nell'istanza CJA di Ferrari su Adobe Experience Platform, tra canali, partner e stagioni."
        />
        <div class="frl-line max-w-4xl mx-auto mb-[clamp(1.5rem,3.5vh,2.5rem)]" aria-hidden="true">
          <span class="frl-node"></span>
          <span class="frl-line-track"></span>
          <span class="frl-node frl-node--giallo"></span>
        </div>
        <div class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5" data-reveal data-reveal-delay="0.22">
          {cjaCards.map((c, ci) => (
            <div class={`frl-panel text-left ${ci === 1 ? 'frl-panel--giallo' : 'frl-panel--rosso'}`}>
              <div class="frl-panel-head">
                <span class="frl-tag" style="color: var(--ink-inverse);"><span data-lang-en>{c.en}</span><span data-lang-it>{c.it}</span></span>
              </div>
              <p class="frl-panel-body" style="margin-bottom: 0;"><span data-lang-en>{c.subEn}</span><span data-lang-it>{c.subIt}</span></p>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Cross-partner view (demo) ─────────────────────── -->
    <Slide id="slide-aggregate" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-carbon')} imageClass="opacity-20" scrim="bg-[var(--surface-inverse)]/86" />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <T en="CROSS-PARTNER VIEW" it="VISTA CROSS-PARTNER" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1.5rem,5vh,3.25rem)]" />
          <T
            as="h2" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.75rem,5.5vh,3.75rem)]" style="font-size: clamp(2.25rem, 4.8vw, 4.25rem);"
            en="Compare, rank, learn."
            it="Confronta, classifica, impara."
          />
          <T
            as="p" class="text-[clamp(1.1rem,1.55vw,1.45rem)] text-[var(--color-grigio-300)] max-w-2xl mb-[clamp(1.75rem,5.5vh,3.75rem)] leading-relaxed"
            en="Ferrari compares partners, audiences and channels side by side to see which segments and which activations created the most value."
            it="Ferrari confronta partner, audience e canali fianco a fianco per vedere quali segmenti e quali attivazioni hanno creato più valore."
          />
          <div class="flex flex-wrap items-center justify-center gap-3 mb-[clamp(1.5rem,5vh,3.25rem)]" data-reveal data-reveal-delay="0.25">
            {partners.map((p) => (
              <span class="inline-flex items-center gap-2 px-4 py-2 text-base font-semibold rounded-sm bg-[var(--color-grafite)]/60 border border-white/10 text-[var(--ink-inverse)]"><span class="frl-node"></span>{p}</span>
            ))}
          </div>
          <p class="text-center text-[0.62rem] tracking-widest uppercase text-[var(--color-grigio-500)]">
            <span data-lang-en>Illustrative sponsors — six partners feeding one dashboard</span>
            <span data-lang-it>Sponsor illustrativi — sei partner in un'unica dashboard</span>
          </p>
        </div>
        <MediaDemoSlot id="analisi-cja-demo" label="CJA — Cross-partner dashboard" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Season insights ───────────────────────────────── -->
    <Slide id="slide-insights" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-track-night')} imageClass="opacity-25" scrim="bg-[var(--surface-inverse)]/84" />
      <div class="w-full max-w-6xl mx-auto text-center">
        <T en="SEASON INSIGHTS" it="INSIGHT DI STAGIONE" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-4" />
        <T
          as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 3.75rem);"
          en="Data that wins the next deal."
          it="Dati che vincono il prossimo accordo."
        />
        <T
          as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mx-auto mb-6"
          en="The season's insights quantify what each partnership was worth. That's the evidence Ferrari brings to renewals and to net-new sponsors."
          it="Gli insight di stagione quantificano quanto è valsa ogni partnership. Sono le prove che Ferrari porta ai rinnovi e ai nuovi sponsor."
        />
        <div class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5 mb-6 text-left" data-reveal data-reveal-delay="0.22">
          {insights.map((i, ii) => (
            <div class="frl-card">
              <span class="frl-mark">{`0${ii + 1}`}</span>
              <p class="frl-card-title" style="color: var(--ink-inverse);"><span data-lang-en>{i.en}</span><span data-lang-it>{i.it}</span></p>
              <p class="frl-card-body" style="margin-bottom: 0;"><span data-lang-en>{i.subEn}</span><span data-lang-it>{i.subIt}</span></p>
            </div>
          ))}
        </div>
        <a href={href(base, '/proof')}
           class="inline-flex items-center gap-3 px-9 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-semibold tracking-wide uppercase bg-[var(--accent-primary)] text-[var(--color-carbonio)] hover:bg-[var(--accent-hover)] transition-colors rounded-sm" data-reveal data-reveal-delay="0.4">
          <span data-lang-en>Next: The Proof</span><span data-lang-it>Avanti: La Prova</span>
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </Slide>

    <!-- ── MOCKUP: CJA live demo ──────────────────────────────────── -->
    <MockupSlide mockupId="cja" sectionId="analisi" slug="ferrari-racing" />

  </DeckContainer>
</BaseLayout>
