---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import { cite } from '../data/sources';
import { STATS } from '../data/stats';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Ferrari slide-ferrari: raceday + downloads (€800M/+22% are auth on index; ~400M on slide-tifosi)
const ferrariStats = [
  { stat: STATS.raceday.value, en: STATS.raceday.en, it: STATS.raceday.it },
  { stat: STATS.downloads.value, en: STATS.downloads.en, it: STATS.downloads.it },
];

const partners = ['HP', 'Shell', 'Puma', 'IBM', 'UniCredit', 'Aon'];
---
<BaseLayout title="Protagonists">
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/define')} prevHref={href(base, '/')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('boardroom')} imageClass="opacity-25" scrim="bg-[var(--surface-inverse)]/85" />
      <T en="THE CAST" it="I PROTAGONISTI" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1.25rem,3.5vh,2.75rem)]" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.5rem,4.5vh,3.25rem)]" style="font-size: clamp(2.5rem, 5.2vw, 4.75rem);"
        en="Three winners.<br/>One loop."
        it="Tre vincitori.<br/>Un loop."
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-[clamp(2rem,4vh,3rem)]"
        en="Ferrari Racing, its sponsor partners and millions of Tifosi, brought together by first-party data into a partnership that keeps building on itself."
        it="Ferrari Racing, i suoi partner sponsor e milioni di Tifosi, uniti dal dato first-party in una partnership che cresce su se stessa nel tempo."
      />

      <!-- Racing line — three apex points, one shared loop.
           Labels reuse the section eyebrows verbatim; no new copy. -->
      <div class="cast-line w-full max-w-4xl mx-auto mb-[clamp(1.75rem,4vh,2.75rem)]" data-reveal data-reveal-delay="0.22">
        <div class="cast-apex">
          <div class="cast-apex-node"><span class="frl-node" style="width:14px;height:14px;"></span></div>
          <T en="THE RIGHTS-HOLDER" it="IL RIGHTS-HOLDER" as="span" class="cast-apex-tag frl-tag" />
          <T en="Ferrari Racing" it="Ferrari Racing" as="span" class="cast-apex-name" />
          <span class="cast-apex-track frl-line-track" aria-hidden="true"></span>
        </div>
        <div class="cast-apex">
          <div class="cast-apex-node"><span class="frl-node frl-node--giallo" style="width:14px;height:14px;"></span></div>
          <T en="THE SPONSOR PARTNERS" it="I PARTNER SPONSOR" as="span" class="cast-apex-tag frl-tag" />
          <T en="Brands that want the right fans" it="Brand che vogliono i tifosi giusti" as="span" class="cast-apex-name" />
          <span class="cast-apex-track frl-line-track" aria-hidden="true"></span>
        </div>
        <div class="cast-apex">
          <div class="cast-apex-node"><span class="frl-node" style="width:14px;height:14px;"></span></div>
          <T en="THE FANS" it="I TIFOSI" as="span" class="cast-apex-tag frl-tag" />
          <T en="The Tifosi are the field" it="I Tifosi sono il campo" as="span" class="cast-apex-name" />
        </div>
      </div>

      <p class="text-center text-[0.72rem] tracking-widest uppercase text-[var(--color-grigio-400)]" data-reveal data-reveal-delay="0.3">
        <span data-lang-en>Three players, one shared asset they all build around: fan data.</span>
        <span data-lang-it>Tre attori, un unico asset condiviso attorno a cui costruiscono: il dato dei tifosi.</span>
      </p>
    </Slide>

    <!-- ── SLIDE 1: Ferrari, the rights-holder ────────────────────── -->
    <Slide id="slide-ferrari" bg="brand" align="center">
      <T en="THE RIGHTS-HOLDER" it="IL RIGHTS-HOLDER" as="p" class="slide-eyebrow text-white/75 mb-4" />
      <T
        as="h2" class="slide-title text-white mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="Ferrari Racing"
        it="Ferrari Racing"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-white/85 max-w-3xl mb-10"
        en="Maranello. The Cavallino Rampante. The most-followed team in Formula 1. Its real asset today is fan attention, and the consented first-party data behind it."
        it="Maranello. Il Cavallino Rampante. La squadra più seguita della Formula 1. Il suo vero asset oggi è l'attenzione dei tifosi, e il dato first-party con consenso che la sostiene."
      />
      <div class="w-full max-w-3xl mx-auto grid md:grid-cols-2 gap-5" data-reveal data-reveal-delay="0.22">
        {ferrariStats.map((s) => (
          <div class="ferrari-stat rounded-sm text-center">
            <p class="font-[family-name:var(--font-display)] font-bold text-white leading-none mb-3" style="font-size: clamp(2rem, 4vw, 3.25rem);">{s.stat}</p>
            <T as="p" class="text-sm text-white/85 leading-relaxed" en={s.en} it={s.it} />
          </div>
        ))}
      </div>
      <p class="mt-7 text-center text-[0.72rem] tracking-widest uppercase text-white/55">
        <span data-lang-en>Source: {cite('ibm_ferrari_2026')}</span>
        <span data-lang-it>Fonte: {cite('ibm_ferrari_2026')}</span>
      </p>
    </Slide>

    <!-- ── SLIDE 2: The sponsor partners ──────────────────────────── -->
    <Slide id="slide-partner" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('billboard')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <T en="THE SPONSOR PARTNERS" it="I PARTNER SPONSOR" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="Brands that want the right fans"
        it="Brand che vogliono i tifosi giusti"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-9"
        en="A logo on the car isn't what partners are paying for. They want measurable access to engaged Tifosi, activated on their own channels."
        it="Un logo sulla monoposto non è ciò per cui i partner pagano. Vogliono un accesso misurabile ai Tifosi più coinvolti, attivato sui propri canali."
      />
      <div class="w-full max-w-3xl mx-auto flex flex-wrap items-center justify-center gap-3" data-reveal data-reveal-delay="0.22">
        {partners.map((p) => (
          <span class="partner-chip">{p}</span>
        ))}
      </div>
      <p class="frl-quote mx-auto text-center" data-reveal data-reveal-delay="0.35">
        <span class="frl-quote-text mx-auto block" style="max-width:52ch;">
          <span data-lang-en>HP, as title partner (Scuderia Ferrari HP), is the guiding example throughout.</span>
          <span data-lang-it>HP, come title partner (Scuderia Ferrari HP), è l'esempio guida in tutto il percorso.</span>
        </span>
      </p>
      <p class="mt-5 text-center text-[0.72rem] tracking-widest uppercase text-[var(--color-grigio-400)]">
        <span data-lang-en>names/logos illustrative</span><span data-lang-it>nomi/loghi illustrativi</span>
      </p>
    </Slide>

    <!-- ── SLIDE 3: The Tifosi ────────────────────────────────────── -->
    <Slide id="slide-tifosi" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('tifosi')} imageClass="opacity-25" scrim="bg-[var(--surface-inverse)]/85" />
      <T en="THE FANS" it="I TIFOSI" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="The Tifosi are the field"
        it="I Tifosi sono il campo"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-7"
        en="Their consented first-party data is the common ground where Ferrari and its partners win together, without exposing a single individual."
        it="Il loro dato first-party con consenso è il terreno comune dove Ferrari e i suoi partner vincono insieme, senza esporre alcun individuo."
      />
      <div class="tifosi-stat w-full max-w-xl mx-auto text-center mb-9 rounded-sm" data-reveal data-reveal-delay="0.25">
        <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-2" style="font-size: clamp(2.5rem,5vw,4rem);">{STATS.tifosi.value}</p>
        <T as="p" class="text-sm text-[var(--color-grigio-300)]" en="Tifosi worldwide" it="Tifosi nel mondo" />
        <p class="mt-3 text-center text-[0.72rem] tracking-widest uppercase text-[var(--color-grigio-400)]">
          <span data-lang-en>Source: {cite('ibm_case_study')}</span>
          <span data-lang-it>Fonte: {cite('ibm_case_study')}</span>
        </p>
      </div>
      <a href={href(base, '/define')}
         class="inline-flex items-center gap-3 px-9 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-semibold tracking-wide uppercase bg-[var(--accent-primary)] text-[var(--color-carbonio)] hover:bg-[var(--accent-hover)] transition-colors rounded-sm" data-reveal data-reveal-delay="0.4">
        <span data-lang-en>Define the loop</span><span data-lang-it>Definisci il loop</span>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </Slide>

  </DeckContainer>

  <style>
    /* Cover — three apex points on one racing line */
    .cast-line {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .cast-apex {
      position: relative;
      flex: 1 1 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 0.35rem;
    }
    .cast-apex-node {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 22px;
      margin-bottom: 0.9rem;
    }
    .cast-apex-tag {
      color: var(--accent-secondary);
      margin-bottom: 0.4rem;
    }
    .cast-apex-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(1.05rem, 1.5vw, 1.4rem);
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--ink-inverse);
    }
    /* connector between apexes, aligned to the node row */
    .cast-apex-track {
      position: absolute;
      top: 10px;
      left: 50%;
      width: 100%;
      height: 2px;
    }
    @media (max-width: 640px) {
      .cast-line { flex-direction: column; align-items: stretch; gap: 1.1rem; }
      .cast-apex { flex-direction: row; align-items: center; gap: 0.85rem; text-align: left; padding: 0; }
      .cast-apex-node { width: 22px; height: 22px; margin-bottom: 0; }
      .cast-apex-track { display: none; }
      .cast-apex-tag { margin-bottom: 0.15rem; }
    }

    /* Ferrari brand-slide stat cells — explicit rgba on the red surface */
    .ferrari-stat {
      padding: 1.5rem;
      background: rgba(23, 23, 28, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.12);
    }
    /* Partner chips — carbon on carbon, giallo underline accent */
    .partner-chip {
      padding: 0.6rem 1.25rem;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      color: var(--ink-inverse);
      background: rgba(23, 23, 28, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: inset 0 -2px 0 0 rgba(255, 242, 0, 0.85);
      border-radius: 3px;
    }
    /* Tifosi hero metric cell */
    .tifosi-stat {
      padding: 1.75rem 1.5rem;
      background: rgba(23, 23, 28, 0.55);
      border: 1px solid rgba(255, 40, 0, 0.35);
    }
  </style>
</BaseLayout>
