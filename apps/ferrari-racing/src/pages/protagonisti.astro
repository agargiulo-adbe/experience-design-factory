---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const ferrariStats = [
  { stat: '~400M', en: 'Tifosi worldwide — the most-followed team in Formula 1', it: 'Tifosi nel mondo — la squadra più seguita della Formula 1' },
  { stat: '+56%', en: 'race-day active users on the Scuderia Ferrari HP app (2025)', it: 'utenti attivi nei giorni di gara sull\'app Scuderia Ferrari HP (2025)' },
  { stat: '€800M+', en: 'sponsorship, commercial & brand revenue — +22% YoY', it: 'ricavi sponsorship, commercial & brand — +22% su base annua' },
];

const partners = ['HP', 'Shell', 'Puma', 'IBM', 'UniCredit', 'Aon'];
---
<BaseLayout title="Protagonists">
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/define')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('boardroom')} imageClass="opacity-25" scrim="bg-[var(--surface-inverse)]/85" />
      <T en="THE CAST" it="I PROTAGONISTI" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="Three winners.<br/>One loop."
        it="Tre vincitori.<br/>Un loop."
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-10"
        en="Ferrari Racing, its sponsor partners, and ~400 million Tifosi — brought together by first-party data into a partnership that compounds."
        it="Ferrari Racing, i suoi partner sponsor e ~400 milioni di Tifosi — uniti dal dato first-party in una partnership che si accumula nel tempo."
      />
      <p class="text-center text-[0.62rem] tracking-widest uppercase text-[var(--color-grigio-500)]" data-reveal data-reveal-delay="0.3">
        <span data-lang-en>The story aligns three players around one shared asset — fan data.</span>
        <span data-lang-it>La storia allinea tre attori attorno a un unico asset condiviso — il dato dei tifosi.</span>
      </p>
    </Slide>

    <!-- ── SLIDE 1: Ferrari, the rights-holder ────────────────────── -->
    <Slide id="slide-ferrari" bg="brand" align="center">
      <T en="THE RIGHTS-HOLDER" it="IL RIGHTS-HOLDER" as="p" class="slide-eyebrow text-white/75 mb-4" />
      <T
        as="h2" class="slide-title text-white mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="Ferrari Racing"
        it="Ferrari Racing"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-white/85 max-w-3xl mb-10"
        en="Maranello. The Cavallino Rampante. The most-followed team in Formula 1. Its real asset today is fan attention — and the consented, first-party data behind it."
        it="Maranello. Il Cavallino Rampante. La squadra più seguita della Formula 1. Il suo vero asset oggi è l'attenzione dei tifosi — e il dato first-party, con consenso, che la sostiene."
      />
      <div class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5" data-reveal data-reveal-delay="0.22">
        {ferrariStats.map((s) => (
          <div class="p-6 bg-[var(--color-grafite)]/40 border border-white/10 rounded-sm text-center">
            <p class="font-[family-name:var(--font-display)] font-bold text-white leading-none mb-3" style="font-size: clamp(2rem, 4vw, 3.25rem);">{s.stat}</p>
            <p class="text-sm text-white/80 leading-relaxed"><span data-lang-en>{s.en}</span><span data-lang-it>{s.it}</span></p>
          </div>
        ))}
      </div>
      <p class="mt-7 text-center text-[0.62rem] tracking-widest uppercase text-white/45">
        <span data-lang-en>Source: Ferrari FY2025 · Scuderia Ferrari HP app metrics 2025</span>
        <span data-lang-it>Fonte: Ferrari FY2025 · metriche app Scuderia Ferrari HP 2025</span>
      </p>
    </Slide>

    <!-- ── SLIDE 2: The sponsor partners ──────────────────────────── -->
    <Slide id="slide-partner" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('billboard')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <T en="THE SPONSOR PARTNERS" it="I PARTNER SPONSOR" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="Brands that want the right fans"
        it="Brand che vogliono i tifosi giusti"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-10"
        en="Partners don't want a logo on the car — they want measurable access to engaged Tifosi, activated on their own channels."
        it="I partner non vogliono un logo sulla monoposto — vogliono un accesso misurabile ai Tifosi più coinvolti, attivato sui propri canali."
      />
      <div class="w-full max-w-3xl mx-auto flex flex-wrap items-center justify-center gap-3" data-reveal data-reveal-delay="0.22">
        {partners.map((p) => (
          <span class="px-5 py-2.5 text-base font-semibold tracking-wide bg-[var(--color-grafite)]/40 border border-white/10 rounded-sm text-[var(--ink-inverse)]">{p}</span>
        ))}
      </div>
      <p class="mt-7 max-w-2xl text-center text-[clamp(0.9rem,1.1vw,1.05rem)] text-[var(--color-grigio-400)]" data-reveal data-reveal-delay="0.35">
        <span data-lang-en>HP, as title partner (Scuderia Ferrari HP), is the guiding example throughout.</span>
        <span data-lang-it>HP, come title partner (Scuderia Ferrari HP), è l'esempio guida in tutto il percorso.</span>
      </p>
      <p class="mt-5 text-center text-[0.62rem] tracking-widest uppercase text-[var(--color-grigio-500)]">
        <span data-lang-en>names/logos illustrative</span><span data-lang-it>nomi/loghi illustrativi</span>
      </p>
    </Slide>

    <!-- ── SLIDE 3: The Tifosi ────────────────────────────────────── -->
    <Slide id="slide-tifosi" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('tifosi')} imageClass="opacity-25" scrim="bg-[var(--surface-inverse)]/85" />
      <T en="THE FANS" it="I TIFOSI" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 4rem);"
        en="The Tifosi are the field"
        it="I Tifosi sono il campo"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-10"
        en="~400 million passionate fans. Their consented, first-party data is the shared ground where Ferrari and its partners win together — privacy-first, always."
        it="~400 milioni di tifosi appassionati. Il loro dato first-party, con consenso, è il terreno condiviso dove Ferrari e i suoi partner vincono insieme — con la privacy al primo posto, sempre."
      />
      <a href={href(base, '/define')}
         class="inline-flex items-center gap-3 px-9 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-semibold tracking-wide uppercase bg-[var(--accent-primary)] text-white hover:bg-[var(--accent-hover)] transition-colors rounded-sm" data-reveal data-reveal-delay="0.4">
        <span data-lang-en>Define the loop</span><span data-lang-it>Definisci il loop</span>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </Slide>

  </DeckContainer>
</BaseLayout>
