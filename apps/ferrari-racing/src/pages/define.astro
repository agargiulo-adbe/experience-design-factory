---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import RtcdpMockup from '@edf/core/blocks/immersive/RtcdpMockup.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const pillars = [
  {
    en: 'Discover', it: 'Scopri',
    bodyEn: 'The clean room computes how many fans Ferrari and the partner share, without ever revealing an individual.',
    bodyIt: 'La clean room calcola quanti fan Ferrari e partner condividono, senza mai rivelare un individuo.',
  },
  {
    en: 'Activate', it: 'Attiva',
    bodyEn: 'Shared audiences are built and made available for campaigns securely. No raw customer data ever leaves either side.',
    bodyIt: 'Le audience condivise si costruiscono e si rendono disponibili alle campagne in modo sicuro. Nessun dato grezzo lascia le due parti.',
  },
  {
    en: 'Measure', it: 'Misura',
    bodyEn: 'Results flow back into a closed loop, so both brands see what worked and refine the next race, together.',
    bodyIt: 'I risultati tornano in un loop chiuso, così entrambi i brand vedono cosa ha funzionato e affinano la gara dopo, insieme.',
  },
];

const audienceCards = [
  { en: 'Overlap insights', it: 'Overlap insights', subEn: 'Shared fans, quantified', subIt: 'Fan condivisi, quantificati' },
  { en: 'Audience expansion', it: 'Espansione audience', subEn: 'Look-alike reach', subIt: 'Reach look-alike' },
  { en: 'Campaign planning', it: 'Pianificazione campagne', subEn: 'Segments ready to brief', subIt: 'Segmenti pronti al brief' },
];

const privacyPoints = [
  {
    en: 'Clean sketches', it: 'Clean sketches',
    bodyEn: 'Aggregates with noise injection give you the insight without exposing any single fan.',
    bodyIt: 'Aggregati con noise injection danno l\'insight senza esporre alcun singolo tifoso.',
  },
  {
    en: 'No identity movement', it: 'Nessun movimento di identità',
    bodyEn: 'No underlying customer data ever moves between Ferrari and the partner.',
    bodyIt: 'Nessun dato cliente sottostante si muove mai tra Ferrari e il partner.',
  },
  {
    en: 'Role-based governance', it: 'Governance basata sui ruoli',
    bodyEn: 'Every action is permissioned. Who can see and do what is controlled by design.',
    bodyIt: 'Ogni azione è autorizzata. Chi può vedere e fare cosa è controllato per design.',
  },
  {
    en: 'Consent enforced', it: 'Consenso applicato',
    bodyEn: 'Only consented Tifosi data is ever eligible. That is the standard Ferrari requires.',
    bodyIt: 'Solo i dati dei Tifosi con consenso sono ammessi. È lo standard che Ferrari richiede.',
  },
];
---
<BaseLayout title="Define" pageSolutions={['rtcdp-collab']}>
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/create')} prevHref={href(base, '/protagonisti')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('data-telemetry')} imageClass="opacity-25" scrim="bg-[var(--surface-inverse)]/82" />

      <!-- Apex marker: Define is the first point on the racing line -->
      <div class="dfn-apex" data-reveal data-reveal-delay="0.08" aria-hidden="true">
        <span class="dfn-apex-track"></span>
        <span class="frl-node frl-node--giallo dfn-apex-node"></span>
        <span class="dfn-apex-track"></span>
      </div>

      <T en="DEFINE" it="DEFINISCI" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1.5rem,4.2vh,3rem)]" />
      <T
        as="h1" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.75rem,5.2vh,3.75rem)]" style="font-size: clamp(2.5rem, 6vw, 5.5rem);"
        en="It starts before the lights go out."
        it="Comincia prima del semaforo verde."
      />
      <T
        as="p"
        class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
        en="Before a single asset is created, Ferrari and the partner agree who to reach together, privacy-first, with Real-Time CDP Collaboration."
        it="Prima ancora di creare un solo asset, Ferrari e il partner decidono insieme chi raggiungere, privacy-first, con Real-Time CDP Collaboration."
      />
    </Slide>

    <!-- ── SLIDE 1: Collaboration ─────────────────────────────────── -->
    <Slide id="slide-collab" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-carbon')} imageClass="opacity-18" scrim="bg-[var(--surface-inverse)]/86" />
      <T en="REAL-TIME CDP COLLABORATION" it="REAL-TIME CDP COLLABORATION" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-7" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
        en="Two datasets. Zero data movement."
        it="Due dataset. Zero movimento di dati."
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-11"
        en="Ferrari's consented Tifosi data and the partner's customer data meet in a privacy-safe clean room. The raw data stays put; only the insight moves."
        it="I dati dei Tifosi con consenso di Ferrari e i dati clienti del partner si incontrano in una clean room privacy-safe. Il dato grezzo resta fermo; si muove solo l'insight."
      />
      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-5 dfn-flow" data-reveal data-reveal-delay="0.22">
        {pillars.map((p, i) => (
          <div class="frl-card dfn-on-dark">
            <span class="frl-mark">{i + 1}</span>
            <p class="frl-card-title dfn-title-dark"><span data-lang-en>{p.en}</span><span data-lang-it>{p.it}</span></p>
            <T as="p" class="frl-card-body" en={p.bodyEn} it={p.bodyIt} />
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: Shared Audiences ──────────────────────────────── -->
    <Slide id="slide-audiences" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('tifosi')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <T en="SHARED AUDIENCES" it="AUDIENCE CONDIVISE" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(2.25rem, 4.4vw, 3.75rem);"
        en="Find the fans you both want"
        it="Trova i tifosi che volete entrambi"
      />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <T
            as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-9"
            en="The overlap between the Tifosi and the partner's audience surfaces high-value segments, and look-alike expansion grows the reach. Illustrative example: HP × Ferrari → tech-forward Tifosi across EMEA."
            it="L'overlap tra i Tifosi e l'audience del partner fa emergere segmenti ad alto valore, e l'espansione look-alike aumenta la reach. Esempio illustrativo: HP × Ferrari → Tifosi tech-forward in EMEA."
          />
          <div class="w-full max-w-3xl grid grid-cols-3 gap-5 dfn-flow" data-reveal data-reveal-delay="0.22">
            {audienceCards.map((c) => (
              <div class="frl-card dfn-on-dark">
                <p class="frl-card-title dfn-title-dark text-[1.05rem] mb-1.5"><span data-lang-en>{c.en}</span><span data-lang-it>{c.it}</span></p>
                <p class="text-[0.9rem] text-[var(--color-grigio-400)]"><span data-lang-en>{c.subEn}</span><span data-lang-it>{c.subIt}</span></p>
              </div>
            ))}
          </div>
        </div>
        <MediaDemoSlot id="define-audiences-demo" label="RT-CDP Collaboration — Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Privacy by design ─────────────────────────────── -->
    <Slide id="slide-privacy" bg="secondary" align="center">
      <T en="PRIVACY BY DESIGN" it="PRIVACY BY DESIGN" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-primary)] mb-4" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
        en="Trust is part of the brand"
        it="La fiducia è parte del brand"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--ink-secondary)] max-w-3xl mb-3"
        en="Clean sketches with noise, no identity movement, role-based governance, consent enforced. This is the standard a brand like Ferrari requires."
        it="Clean sketches con noise, nessun movimento di identità, governance basata sui ruoli, consenso applicato. È lo standard che un brand come Ferrari richiede."
      />
      <div class="w-full max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 mb-2" data-reveal data-reveal-delay="0.22">
        {privacyPoints.map((p) => (
          <div class="frl-panel frl-panel--rosso text-left">
            <p class="frl-card-title text-[1.05rem] mb-1.5"><span data-lang-en>{p.en}</span><span data-lang-it>{p.it}</span></p>
            <T as="p" class="text-[0.95rem] text-[var(--ink-secondary)] leading-relaxed" en={p.bodyEn} it={p.bodyIt} />
          </div>
        ))}
      </div>
      <a href={href(base, '/create')}
         class="inline-flex items-center gap-3 px-9 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-semibold tracking-wide uppercase bg-[var(--accent-primary)] text-[var(--color-carbonio)] hover:bg-[var(--accent-hover)] transition-colors rounded-sm" data-reveal data-reveal-delay="0.35">
        <span data-lang-en>Next: Create</span><span data-lang-it>Avanti: Crea</span>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </Slide>

    <!-- ── MOCKUP: RT-CDP Collaboration live demo ─────────────────── -->
    <RtcdpMockup sectionId="define" slug="ferrari-racing" />

  </DeckContainer>
</BaseLayout>

<style>
  /* Define = an apex on the racing line. A small racing-line/apex motif marks
     this phase; cards ride the shared .frl-* system. Explicit rgba only. */
  .dfn-apex {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    width: min(28rem, 60vw);
    margin: 0 auto clamp(1.4rem, 3.4vh, 2.6rem);
  }
  .dfn-apex-track {
    flex: 1 1 auto;
    height: 2px;
    border-radius: 2px;
  }
  .dfn-apex-track:first-child {
    background: linear-gradient(to right, rgba(255,242,0,0.05), rgba(255,242,0,0.85));
  }
  .dfn-apex-track:last-child {
    background: linear-gradient(to right, rgba(255,242,0,0.85), rgba(255,40,0,0.6));
  }
  .dfn-apex-node {
    width: 13px;
    height: 13px;
    box-shadow: 0 0 0 5px rgba(255,242,0,0.14);
  }

  /* frl cards on the carbon (inverse) slides: keep contrast readable */
  .dfn-on-dark { background: rgba(23, 23, 28, 0.72); border-color: rgba(255,255,255,0.12); }
  .dfn-title-dark { color: var(--ink-inverse); }

  /* Cards enter as if the lap sweeps left-to-right through the apex */
  @media (prefers-reduced-motion: no-preference) {
    .dfn-flow > * { transition-delay: calc(var(--dfn-i, 0) * 60ms); }
  }
</style>
