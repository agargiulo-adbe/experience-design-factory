---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const channels = [
  {
    en: 'Owned', it: 'Owned',
    subEn: 'HP homepage & app', subIt: 'Homepage e app HP',
    bodyEn: 'The on-brand hero unit goes live on the HP homepage, the partner’s highest-traffic, fully-owned surface.',
    bodyIt: 'L’unità hero on-brand va live sulla homepage HP, la superficie di proprietà del partner con più traffico.',
  },
  {
    en: 'Social', it: 'Social',
    subEn: 'Feed & stories', subIt: 'Feed e stories',
    bodyEn: 'The same approved creative, sized for social, engages the defined Tifosi audiences on the partner’s channels.',
    bodyIt: 'La stessa creatività approvata, adattata al social, ingaggia le audience Tifosi definite sui canali del partner.',
  },
  {
    en: 'Commerce & CTV', it: 'Commerce & CTV',
    subEn: 'Retail media & connected TV', subIt: 'Retail media e TV connessa',
    bodyEn: 'On-brand content extends into retail media and CTV, reaching fans across the partner’s full commerce footprint.',
    bodyIt: 'Il contenuto on-brand si estende a retail media e CTV, raggiungendo i fan sull’intera presenza commerce del partner.',
  },
];

const kpis = [
  { stat: '+34%', en: 'CTR vs. manual', it: 'CTR vs. manuale' },
  { stat: '3×', en: 'ROAS', it: 'ROAS' },
  { stat: '2×', en: 'conversions', it: 'conversioni' },
];
---
<BaseLayout title="Activate" pageSolutions={['genstudio']}>
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/analisi')} prevHref={href(base, '/create')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('billboard')} imageClass="opacity-30" scrim="bg-[var(--surface-inverse)]/80" />
      <div class="act-cover w-full max-w-4xl mx-auto flex flex-col items-center text-center">
        <div class="act-apex" aria-hidden="true">
          <svg viewBox="0 0 320 44" width="320" height="44" fill="none" preserveAspectRatio="xMidYMid meet">
            <path d="M6 38 C 92 38, 118 8, 200 8 S 314 20, 314 20" stroke="rgba(255,40,0,0.55)" stroke-width="2" stroke-linecap="round" fill="none" />
            <circle cx="160" cy="9" r="6" fill="rgba(255,40,0,1)" />
            <circle cx="160" cy="9" r="11" stroke="rgba(255,242,0,0.85)" stroke-width="1.5" fill="none" />
          </svg>
          <T en="APEX" it="APEX" as="span" class="act-apex-label" />
        </div>
        <T en="ACTIVATE" it="ATTIVA" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1.25rem,3.4vh,2.4rem)]" />
        <T
          as="h1" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.5rem,4.4vh,3.25rem)]" style="font-size: clamp(2.75rem, 6.5vw, 6rem);"
          en="Live on the partner’s channels."
          it="Live sui canali del partner."
        />
        <T
          as="p"
          class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
          en="The approved, on-brand content reaches the jointly-defined audiences — on the partner’s homepage, social, CTV and retail media."
          it="Il contenuto approvato e on-brand raggiunge le audience definite insieme — sulla homepage del partner, su social, CTV e retail media."
        />
      </div>
    </Slide>

    <!-- ── SLIDE 1: On their turf ─────────────────────────────────── -->
    <Slide id="slide-activate" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-track-night')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <div class="act-frame frl-bg w-full max-w-6xl mx-auto">
        <div class="act-frame-head">
          <div class="act-lede min-w-0">
            <T en="ON THEIR TURF" it="SUL LORO CAMPO" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-[clamp(0.6rem,1.6vh,1.1rem)]" />
            <T
              as="h2" class="slide-title text-[var(--ink-inverse)] mb-[clamp(0.75rem,2vh,1.4rem)]" style="font-size: clamp(2.25rem, 5.2vw, 4.5rem);"
              en="The HP homepage, on-brand"
              it="La homepage HP, on-brand"
            />
            <T
              as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] leading-relaxed"
              en="The partner publishes to its owned channels, engaging the defined Tifosi audiences exactly where it already has presence and trust."
              it="Il partner pubblica sui propri canali di proprietà, ingaggiando le audience Tifosi definite proprio dove ha già presenza e fiducia."
            />
          </div>
          <div class="act-line frl-line" aria-hidden="true">
            <span class="frl-node"></span>
            <span class="frl-line-track"></span>
            <span class="frl-node frl-node--giallo"></span>
          </div>
        </div>
        <div class="act-channels" data-reveal data-reveal-delay="0.22">
          {channels.map((c) => (
            <div class="frl-card act-channel text-left">
              <p class="act-channel-name"><span data-lang-en>{c.en}</span><span data-lang-it>{c.it}</span></p>
              <p class="act-channel-sub"><span data-lang-en>{c.subEn}</span><span data-lang-it>{c.subIt}</span></p>
              <T as="p" class="frl-card-body" en={c.bodyEn} it={c.bodyIt} />
            </div>
          ))}
        </div>
        <p class="act-note frl-src text-center">
          <span data-lang-en>Partner names & logos illustrative — HP homepage shown as a guiding example</span>
          <span data-lang-it>Nomi e loghi partner illustrativi — homepage HP mostrata come esempio guida</span>
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Results in GenStudio ──────────────────────────── -->
    <Slide id="slide-results-partner" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('data-telemetry')} imageClass="opacity-18" scrim="bg-[var(--surface-inverse)]/88" />
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="act-results frl-bg flex-1 min-w-0 flex flex-col">
          <T en="RESULTS IN GENSTUDIO" it="RISULTATI IN GENSTUDIO" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-3" />
          <T
            as="h2" class="slide-title text-[var(--ink-inverse)] mb-4" style="font-size: clamp(2rem, 4vw, 3.5rem);"
            en="The partner sees performance, in one place"
            it="Il partner vede la performance, in un unico posto"
          />
          <T
            as="p" class="text-[clamp(1rem,1.3vw,1.25rem)] text-[var(--color-grigio-300)] leading-relaxed mb-5"
            en="Campaign results flow back to the partner inside GenStudio for Performance Marketing: impressions, CTR, conversions, ROAS, with the depth to optimize in-flight and plan the next drop."
            it="I risultati di campagna tornano al partner dentro GenStudio for Performance Marketing: impression, CTR, conversioni, ROAS, con la profondità per ottimizzare in corsa e pianificare il prossimo drop."
          />
          <div class="act-kpis" data-reveal data-reveal-delay="0.22">
            {kpis.map((k) => (
              <div class="frl-card act-kpi">
                <p class="act-kpi-value">{k.stat}</p>
                <T as="p" class="frl-card-body" en={k.en} it={k.it} />
              </div>
            ))}
          </div>
          <p class="act-note frl-src mb-4">
            <span data-lang-en>Illustrative results — closed-loop measurement, closed-beta figures</span>
            <span data-lang-it>Risultati illustrativi — misurazione closed-loop, dati closed-beta</span>
          </p>
          <a href={href(base, '/analisi')} data-nav-solution="cja"
             class="act-cta inline-flex items-center gap-3 no-underline" data-reveal data-reveal-delay="0.35">
            <span data-lang-en>Next: Analytics</span><span data-lang-it>Avanti: Analisi</span>
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <MediaDemoSlot id="activate-results-demo" label="GenStudio — Campaign results" />
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* ── Activate = the apex: the lap commits to the racing line ──────── */
  .act-apex {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    margin-bottom: clamp(1rem, 3vh, 2rem);
  }
  .act-apex-label {
    font-family: var(--font-display); font-weight: 700;
    font-size: 0.72rem; letter-spacing: 0.34em; text-transform: uppercase;
    color: var(--color-giallo-modena);
  }

  /* Framed content panels (apex on the lap) — explicit asfalto rgba */
  .act-frame, .act-results {
    border: 1px solid rgba(255,40,0,0.28);
    border-radius: 6px;
    box-shadow: inset 0 2px 0 0 rgba(255,40,0,0.9);
    padding: clamp(1.4rem, 3vh, 2.4rem) clamp(1.4rem, 3vw, 2.6rem);
  }
  .act-frame-head {
    display: flex; flex-direction: column;
    margin-bottom: clamp(1.1rem, 2.6vh, 1.9rem);
  }
  .act-line { margin-top: clamp(1rem, 2.4vh, 1.6rem); }

  .act-channels {
    display: grid; grid-template-columns: 1fr; gap: 1.1rem;
  }
  @media (min-width: 768px) {
    .act-channels { grid-template-columns: repeat(3, 1fr); }
  }
  .act-channel-name {
    font-family: var(--font-display); font-weight: 700; font-size: 1.15rem;
    color: var(--color-rosso-corsa); margin-bottom: 0.2rem;
  }
  .act-channel-sub {
    font-size: 0.95rem; font-weight: 600; color: var(--ink-inverse);
    margin-bottom: 0.8rem;
  }

  .act-kpis {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem;
    margin-bottom: 1rem;
  }
  .act-kpi { align-items: center; text-align: center; }
  .act-kpi-value {
    font-family: var(--font-display); font-weight: 700; line-height: 1;
    font-size: clamp(1.9rem, 3.6vw, 2.85rem); color: var(--color-rosso-corsa);
    letter-spacing: -0.02em; font-feature-settings: 'tnum' 1;
    margin-bottom: 0.55rem;
  }

  .act-note {
    color: var(--color-grigio-400);
    margin-top: clamp(0.9rem, 2.4vh, 1.6rem);
  }

  .act-cta {
    align-self: flex-start;
    padding: 0.85rem 2rem;
    font-size: clamp(0.95rem, 1.1vw, 1.1rem); font-weight: 600;
    letter-spacing: 0.04em; text-transform: uppercase;
    background: var(--color-rosso-corsa); color: var(--color-carbonio);
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }
  .act-cta:hover { background: var(--color-rosso-scuro); }
</style>
