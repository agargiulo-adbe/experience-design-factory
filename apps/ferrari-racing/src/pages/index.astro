---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import { cite } from '../data/sources';
import { STATS } from '../data/stats';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Two market-signal cards — ~400M is authoritative on protagonisti/slide-tifosi
const arenaStats = [
  { stat: '70%', en: 'of the web unreachable via third-party cookies*', it: 'del web irraggiungibile via cookie di terze parti*' },
  { stat: '88%', en: 'of sports organizations already collect first-party fan data*', it: 'delle organizzazioni sportive raccoglie già dati fan first-party*' },
];

const journey = [
  { num: '01', en: 'Protagonists', it: 'Protagonisti', subEn: 'Ferrari · Partner · Tifosi', subIt: 'Ferrari · Partner · Tifosi', href: '/protagonisti' },
  { num: '02', en: 'Define', it: 'Definisci', subEn: 'Data Collaboration', subIt: 'Data Collaboration', href: '/define', solution: 'rtcdp-collab' },
  { num: '03', en: 'Create', it: 'Crea', subEn: 'GenStudio + Express', subIt: 'GenStudio + Express', href: '/create', solution: 'genstudio,express' },
  { num: '04', en: 'Activate', it: 'Attiva', subEn: 'On-brand, on their channels', subIt: 'On-brand, sui loro canali', href: '/activate', solution: 'genstudio' },
  { num: '05', en: 'Analytics', it: 'Analisi', subEn: 'One CJA, all partners', subIt: 'Una CJA, tutti i partner', href: '/analisi', solution: 'cja' },
  { num: '06', en: 'Proof', it: 'La Prova', subEn: 'Case studies & value', subIt: 'Case study e valore', href: '/proof' },
  { num: '07', en: 'The Loop', it: 'Il Loop', subEn: 'Season over season', subIt: 'Stagione dopo stagione', href: '/loop' },
];
---
<BaseLayout title="Pole Position">
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/protagonisti')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-track-night')} imageClass="opacity-45" scrim="bg-gradient-to-t from-[var(--surface-inverse)] via-[var(--surface-inverse)]/74 to-[var(--surface-inverse)]/50" />
      <p class="slide-eyebrow text-[var(--accent-secondary)] mb-5" data-reveal>FERRARI RACING × ADOBE</p>
      <T en="Pole Position" it="Pole Position" as="h1" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(3.5rem, 9vw, 8rem); text-transform: uppercase;" />
      <T
        as="p"
        class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
        en="Fan data that turns a sponsorship into a partnership you can measure all season, from Maranello to every fan."
        it="Il dato dei tifosi che trasforma una sponsorship in una partnership misurabile per tutta la stagione, da Maranello a ogni tifoso."
      />
      <div class="flex items-center justify-center gap-3 mt-9" data-reveal data-reveal-delay="0.3">
        <span class="px-3 py-1.5 text-xs font-semibold tracking-widest uppercase rounded-sm bg-[var(--accent-primary)] text-white">Scuderia Ferrari HP</span>
        <span class="text-[var(--color-grigio-400)] text-sm">
          <span data-lang-en>powered by Adobe</span><span data-lang-it>con Adobe</span>
        </span>
      </div>
      <p class="mt-7 text-center text-[0.58rem] tracking-widest uppercase text-[var(--color-grigio-500)] max-w-2xl mx-auto">
        <span data-lang-en>Concept demo — illustrative scenario not commissioned by Ferrari · Public data cited at sources</span>
        <span data-lang-it>Demo concettuale — scenario illustrativo non commissionato da Ferrari · Dati pubblici citati alle fonti</span>
      </p>
    </Slide>

    <!-- ── SLIDE 1: The Arena ─────────────────────────────────────── -->
    <Slide id="slide-arena" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-grid')} imageClass="opacity-12" scrim="bg-[var(--surface-inverse)]/88" />
      <T en="THE NEW ARENA" it="LA NUOVA ARENA" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
        en="Attention is the race.<br/>Data decides who wins."
        it="L'attenzione è la gara.<br/>Il dato decide chi vince."
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-4"
        en="The stadium is now the whole media ecosystem. As third-party signals fade, first-party fan data is the ground sponsors and rights-holders win on together."
        it="Lo stadio è ormai l'intero ecosistema media. Con i segnali di terze parti che spariscono, è il dato fan first-party il terreno su cui sponsor e rights-holder vincono insieme."
      />
      <div class="w-full max-w-3xl mx-auto grid md:grid-cols-2 gap-5" data-reveal data-reveal-delay="0.22">
        {arenaStats.map((s) => (
          <div class="p-6 bg-[var(--color-grafite)]/40 border border-white/10 rounded-sm text-center">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-3" style="font-size: clamp(2.25rem, 4vw, 3.25rem);">{s.stat}</p>
            <T as="p" class="text-sm text-[var(--color-grigio-300)] leading-relaxed" en={s.en} it={s.it} />
          </div>
        ))}
      </div>
      <p class="mt-5 text-center text-[0.62rem] tracking-widest uppercase text-[var(--color-grigio-500)]">
        <span data-lang-en>* market estimate · Source: {cite('ferrari_fy2025', 'ibm_ferrari_2026')}</span>
        <span data-lang-it>* stima di mercato · Fonte: {cite('ferrari_fy2025', 'ibm_ferrari_2026')}</span>
      </p>
    </Slide>

    <!-- ── SLIDE 2: The Shift ─────────────────────────────────────── -->
    <Slide id="slide-shift" bg="brand" align="center">
      <T en="FROM LOGO TO LOOP" it="DAL LOGO AL LOOP" as="p" class="slide-eyebrow text-white/75 mb-5" />
      <T
        as="h2" class="slide-title text-white mb-6" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
        en="The logo gets you on the grid. The data loop wins the race."
        it="Il logo ti mette in griglia. Il loop di dati vince la gara."
      />
      <T
        as="p" class="text-[clamp(1.1rem,1.6vw,1.5rem)] text-white/85 max-w-3xl mb-12"
        en="The winning model is a data loop: define audiences together, create on-brand, activate on the partner's channels, measure every campaign. Do that and the value compounds season after season."
        it="Il modello vincente è un loop di dati: definire insieme le audience, creare on-brand, attivare sui canali del partner, misurare ogni campagna. Così il valore si accumula stagione dopo stagione."
      />
      <div class="w-full max-w-3xl mx-auto grid grid-cols-3 gap-6" data-reveal data-reveal-delay="0.25">
        <div class="text-center">
          <p class="font-[family-name:var(--font-display)] font-bold text-white leading-none mb-2" style="font-size: clamp(2rem,4vw,3.25rem);">{STATS.sponsorship.value}</p>
          <T as="p" class="text-sm text-white/80" en={STATS.sponsorship.en} it={STATS.sponsorship.it} />
        </div>
        <div class="text-center">
          <p class="font-[family-name:var(--font-display)] font-bold text-white leading-none mb-2" style="font-size: clamp(2rem,4vw,3.25rem);">{STATS.growth.value}</p>
          <T as="p" class="text-sm text-white/80" en={STATS.growth.en} it={STATS.growth.it} />
        </div>
        <div class="text-center">
          <p class="font-[family-name:var(--font-display)] font-bold text-white leading-none mb-2" style="font-size: clamp(2rem,4vw,3.25rem);">{STATS.mau.value}</p>
          <T as="p" class="text-sm text-white/80" en={STATS.mau.en} it={STATS.mau.it} />
        </div>
      </div>
      <p class="mt-8 text-center text-[0.62rem] tracking-widest uppercase text-white/45">
        <span data-lang-en>Sources: {cite('ferrari_fy2025', 'ibm_ferrari_2026')}</span>
        <span data-lang-it>Fonti: {cite('ferrari_fy2025', 'ibm_ferrari_2026')}</span>
      </p>
    </Slide>

    <!-- ── SLIDE 3: Journey ───────────────────────────────────────── -->
    <Slide id="slide-journey" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-carbon')} imageClass="opacity-20" scrim="bg-[var(--surface-inverse)]/85" />
      <T en="THE RACE PLAN" it="IL PIANO GARA" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-4" style="font-size: clamp(2.25rem, 4.4vw, 3.75rem);"
        en="Seven chapters. One virtuous loop."
        it="Sette capitoli. Un unico loop virtuoso."
      />
      <div class="w-full max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-3 gap-3" data-reveal data-reveal-delay="0.2">
        {journey.map((step) => (
          <a href={href(base, step.href)} data-nav-solution={step.solution ?? undefined}
             class="group p-4 bg-[var(--color-grafite)]/35 border border-white/10 rounded-sm text-left hover:border-[var(--accent-primary)]/60 transition-colors no-underline flex items-baseline gap-3">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] text-sm shrink-0">{step.num}</p>
            <div>
              <p class="text-base font-semibold text-[var(--ink-inverse)] mb-0.5"><span data-lang-en>{step.en}</span><span data-lang-it>{step.it}</span></p>
              <p class="text-sm text-[var(--color-grigio-400)]"><span data-lang-en>{step.subEn}</span><span data-lang-it>{step.subIt}</span></p>
            </div>
          </a>
        ))}
        <a href={href(base, '/protagonisti')}
           class="inline-flex items-center justify-center gap-3 px-4 py-4 text-[clamp(0.95rem,1.1vw,1.15rem)] font-semibold tracking-wide uppercase bg-[var(--accent-primary)] text-[var(--color-carbonio)] hover:bg-[var(--accent-hover)] transition-colors rounded-sm no-underline" data-reveal data-reveal-delay="0.4">
          <span data-lang-en>Lights out</span><span data-lang-it>Semaforo verde</span>
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
