---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import { cite } from '../data/sources';
import { STATS } from '../data/stats';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const loopSteps = [
  { num: '01', en: 'Define', it: 'Definisci', toolEn: 'Real-Time CDP Collaboration', toolIt: 'Real-Time CDP Collaboration', descEn: 'Audiences built together, privacy-safe', descIt: 'Audience costruite insieme, privacy-safe' },
  { num: '02', en: 'Create', it: 'Crea', toolEn: 'GenStudio + Adobe Express', toolIt: 'GenStudio + Adobe Express', descEn: 'On-brand assets at scale', descIt: 'Asset on-brand su larga scala' },
  { num: '03', en: 'Activate', it: 'Attiva', toolEn: 'Partner channels', toolIt: 'Canali del partner', descEn: 'Live where the fans already are', descIt: 'Vivi dove i tifosi sono già' },
  { num: '04', en: 'Measure', it: 'Misura', toolEn: 'Campaign results in GenStudio', toolIt: 'Risultati in GenStudio', descEn: "Each partner's dashboard — results, not guesses", descIt: 'Dashboard per partner — risultati, non ipotesi' },
  { num: '05', en: 'Aggregate', it: 'Aggrega', toolEn: 'Ferrari CJA', toolIt: 'Ferrari CJA', descEn: 'One Ferrari-wide view of value', descIt: 'Una visione del valore su tutta Ferrari' },
];

const engineStack = [
  { name: 'Real-Time CDP Collaboration', en: 'Define audiences together, within the clean room', it: 'Definisci le audience insieme, nel perimetro della clean room' },
  { name: 'GenStudio for Performance Marketing', en: 'Create at scale, enforce brand, prove partner results — automatically', it: 'Crea su larga scala, applica il brand, dimostra i risultati — automaticamente' },
  { name: 'Adobe Express', en: 'On-brand for every partner, at scale', it: 'On-brand per ogni partner, su larga scala' },
  { name: 'Customer Journey Analytics (CJA)', en: 'Measurement across all of Ferrari', it: 'Misurazione su tutta Ferrari' },
  { name: 'Adobe Experience Platform', en: 'The foundation the loop runs on', it: 'La fondazione su cui gira il loop' },
];

const prizeStats = [
  { stat: STATS.sponsorship.value, en: STATS.sponsorship.en, it: STATS.sponsorship.it },
  { stat: STATS.growth.value, en: 'year-over-year growth — and compounding', it: 'crescita anno su anno — che si accumula' },
  { stat: STATS.tifosi.value, en: 'Tifosi in the loop', it: 'Tifosi nel loop' },
];

/* Apex geometry for the closed racing-line loop (viewBox 0 0 200 200).
   Five phases spaced around the circuit, define at the top, running clockwise. */
const loopApexes = [
  { x: 100, y: 26 },
  { x: 162, y: 78 },
  { x: 138, y: 158 },
  { x: 62, y: 158 },
  { x: 38, y: 78 },
];
---
<BaseLayout title="The Loop">
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/casi-duso')} prevHref={href(base, '/proof')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('podium')} imageClass="opacity-30" scrim="bg-[var(--surface-inverse)]/78" />

      <!-- Closed racing-line loop: the lap that repeats, faster each pass -->
      <div class="loop-ring mb-[clamp(1.5rem,4.4vh,3rem)]" data-reveal data-reveal-delay="0.15" aria-hidden="true">
        <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none">
          <circle cx="100" cy="100" r="82" stroke="rgba(255,255,255,0.08)" stroke-width="1" fill="none" />
          <circle class="loop-ring__flow" cx="100" cy="100" r="82" stroke="var(--color-rosso-corsa)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-dasharray="404 111" stroke-dashoffset="0" />
          {loopApexes.map((a, i) => (
            <circle cx={a.x} cy={a.y} r={i === 0 ? 6 : 4.5} fill={i === 0 ? 'var(--color-giallo-modena)' : 'var(--color-rosso-corsa)'} stroke="var(--color-carbonio)" stroke-width="1.5" />
          ))}
          <path d="M100 20 l-6 9 h12 z" fill="var(--color-giallo-modena)" stroke="none" />
        </svg>
      </div>

      <T en="THE LOOP" it="IL LOOP" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1rem,3vh,2rem)]" />
      <T
        as="h1" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.5rem,4.4vh,3rem)]" style="font-size: clamp(2.75rem, 6.4vw, 5.75rem);"
        en="The virtuous loop."
        it="Il loop virtuoso."
      />
      <T
        as="p"
        class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
        en="Define → create → activate → measure → aggregate → define again — better every time."
        it="Definisci → crea → attiva → misura → aggrega → definisci di nuovo — meglio ogni volta."
      />
    </Slide>

    <!-- ── SLIDE 1: The Loop ──────────────────────────────────────── -->
    <Slide id="slide-loop" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-track-night')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <T en="END-TO-END" it="END-TO-END" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-3" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(1.85rem, 3.9vw, 3.25rem);"
        en="Every campaign makes the next one smarter"
        it="Ogni campagna rende la prossima più intelligente"
      />

      <!-- The lap as diagram: closed circuit with the five phase apexes on it -->
      <div class="loop-circuit w-full max-w-6xl mx-auto" data-reveal data-reveal-delay="0.2">
        <div class="loop-circuit__track" aria-hidden="true">
          <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none" preserveAspectRatio="xMidYMid meet">
            <circle cx="100" cy="100" r="84" stroke="rgba(255,255,255,0.10)" stroke-width="1" fill="none" />
            <circle class="loop-circuit__flow" cx="100" cy="100" r="84" stroke="var(--color-rosso-corsa)" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="6 12" />
            {loopApexes.map((a, i) => (
              <circle cx={a.x} cy={a.y} r="5" fill={i === 0 ? 'var(--color-giallo-modena)' : 'var(--color-rosso-corsa)'} stroke="var(--color-carbonio)" stroke-width="1.5" />
            ))}
          </svg>
        </div>
        <div class="loop-circuit__nodes">
          {loopSteps.map((step) => (
            <div class="loop-node">
              <p class="loop-node__num">{step.num}</p>
              <p class="loop-node__phase"><span data-lang-en>{step.en}</span><span data-lang-it>{step.it}</span></p>
              <p class="loop-node__tool"><span data-lang-en>{step.toolEn}</span><span data-lang-it>{step.toolIt}</span></p>
              <p class="loop-node__desc"><span data-lang-en>{step.descEn}</span><span data-lang-it>{step.descIt}</span></p>
            </div>
          ))}
        </div>
      </div>

      <T
        as="p" class="text-[clamp(1rem,1.3vw,1.25rem)] text-[var(--color-grigio-300)] max-w-3xl mx-auto mt-6"
        en="Then back to step 1. Season over season, the collaboration compounds."
        it="Poi di nuovo allo step 1. Stagione dopo stagione, la collaborazione si accumula."
      />
    </Slide>

    <!-- ── SLIDE 2: The Engine ────────────────────────────────────── -->
    <Slide id="slide-engine" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-carbon')} imageClass="opacity-20" scrim="bg-[var(--surface-inverse)]/85" />
      <T en="THE ENGINE" it="IL MOTORE" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-3" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(1.85rem, 3.9vw, 3.25rem);"
        en="One connected system"
        it="Un unico sistema connesso"
      />
      <div class="engine-stack w-full max-w-5xl mx-auto" data-reveal data-reveal-delay="0.2">
        {engineStack.map((tool, i) => (
          <div class="engine-row">
            <div class="engine-row__rail" aria-hidden="true">
              <span class="engine-row__node"></span>
              {i < engineStack.length - 1 && <span class="engine-row__line"></span>}
            </div>
            <div class="engine-row__body">
              <p class="engine-row__name">{tool.name}</p>
              <p class="engine-row__desc"><span data-lang-en>{tool.en}</span><span data-lang-it>{tool.it}</span></p>
            </div>
          </div>
        ))}
      </div>
      <T
        as="p" class="text-[clamp(1.05rem,1.4vw,1.35rem)] font-semibold text-[var(--ink-inverse)] max-w-3xl mx-auto mt-6"
        en="One engine, five products, no seams between them."
        it="Un motore, cinque prodotti, senza discontinuità tra loro."
      />
    </Slide>

    <!-- ── SLIDE 3: The Prize ─────────────────────────────────────── -->
    <Slide id="slide-roi" bg="brand" align="center">
      <T en="THE PRIZE" it="IL PREMIO" as="p" class="slide-eyebrow text-white/75 mb-5" />
      <T
        as="h2" class="slide-title text-white mb-4" style="font-size: clamp(2rem, 4.4vw, 3.75rem);"
        en="Turn data into the next pole position"
        it="Trasforma il dato nella prossima pole position"
      />
      <T
        as="p" class="text-[clamp(1rem,1.35vw,1.25rem)] text-white/85 max-w-3xl mx-auto mb-4"
        en="With proof of value, Ferrari keeps and grows its sponsors, commands a price premium and attracts net-new partners, and the result compounds season after season."
        it="Con la prova del valore, Ferrari trattiene e fa crescere i suoi sponsor, impone un premium di prezzo e attrae partner del tutto nuovi, e il risultato si accumula stagione dopo stagione."
      />
      <div class="prize-stats w-full max-w-3xl mx-auto" data-reveal data-reveal-delay="0.22">
        {prizeStats.map((s) => (
          <div class="prize-stat">
            <p class="prize-stat__value">{s.stat}</p>
            <T as="p" class="prize-stat__label" en={s.en} it={s.it} />
          </div>
        ))}
      </div>
      <T
        as="p" class="text-[clamp(0.95rem,1.15vw,1.15rem)] italic text-white/85 max-w-3xl mx-auto mt-4 mb-3"
        en="From Maranello to every fan, and back again as data."
        it="Da Maranello a ogni tifoso, e ritorno come dato."
      />
      <a href={href(base, '/')}
         class="inline-flex items-center gap-3 px-9 py-3 text-[clamp(1rem,1.2vw,1.2rem)] font-semibold tracking-wide uppercase bg-white text-[var(--color-carbonio)] hover:bg-white/90 transition-colors rounded-sm" data-reveal data-reveal-delay="0.4">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3a5 5 0 1 0 4.9 6M8 3V1M8 3l2 1.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span data-lang-en>Restart the lap</span><span data-lang-it>Ricomincia il giro</span>
      </a>
      <p class="mt-2 text-center text-[0.62rem] tracking-widest uppercase text-white/45">
        <span data-lang-en>Source: {cite('ferrari_fy2025', 'ibm_ferrari_2026')}</span>
        <span data-lang-it>Fonte: {cite('ferrari_fy2025', 'ibm_ferrari_2026')}</span>
      </p>
    </Slide>

  </DeckContainer>

  <style>
    /* ── Cover: the racing line closed into a repeating lap ────────── */
    .loop-ring {
      width: clamp(9rem, 18vh, 15rem);
      aspect-ratio: 1 / 1;
      margin-inline: auto;
    }
    @media (prefers-reduced-motion: no-preference) {
      .loop-ring__flow { animation: loop-spin 6s linear infinite; transform-origin: 100px 100px; }
      @keyframes loop-spin { to { stroke-dashoffset: -515; } }
    }

    /* ── Loop diagram: circuit ring with the five phase nodes on it ── */
    .loop-circuit {
      position: relative;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 0.9rem;
      align-items: stretch;
    }
    .loop-circuit__track {
      position: absolute;
      inset: -0.75rem 0 -0.75rem 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.55;
      display: flex; justify-content: center;
    }
    .loop-circuit__track svg { width: min(46vh, 30rem); height: 100%; }
    @media (prefers-reduced-motion: no-preference) {
      .loop-circuit__flow { animation: loop-dash 3.4s linear infinite; transform-origin: 100px 100px; }
      @keyframes loop-dash { to { stroke-dashoffset: -108; } }
    }
    .loop-circuit__nodes {
      position: relative;
      z-index: 1;
      display: contents;
    }
    .loop-node {
      background: rgba(23, 23, 28, 0.72);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 4px;
      padding: 1.1rem 1.05rem 1.15rem;
      text-align: left;
      display: flex; flex-direction: column;
      min-width: 0;
    }
    .loop-node__num {
      font-family: var(--font-display); font-weight: 700;
      font-size: 0.95rem; color: var(--color-rosso-corsa);
      letter-spacing: 0.02em; margin-bottom: 0.35rem;
    }
    .loop-node__phase {
      font-size: 1.05rem; font-weight: 600; line-height: 1.2;
      color: var(--ink-inverse); margin-bottom: 0.4rem;
    }
    .loop-node__tool {
      font-size: 0.8rem; font-weight: 600; line-height: 1.35;
      color: var(--accent-secondary); margin-bottom: 0.5rem;
    }
    .loop-node__desc {
      font-size: 0.82rem; line-height: 1.5;
      color: var(--color-grigio-300);
    }

    /* ── Engine: connected stack on a single running rail ──────────── */
    .engine-stack { display: flex; flex-direction: column; gap: 0; }
    .engine-row { display: flex; gap: 1.1rem; align-items: stretch; text-align: left; }
    .engine-row__rail {
      position: relative; flex: 0 0 auto; width: 1.1rem;
      display: flex; flex-direction: column; align-items: center;
    }
    .engine-row__node {
      width: 0.7rem; height: 0.7rem; border-radius: 50%;
      background: var(--color-rosso-corsa);
      box-shadow: 0 0 0 3px rgba(255,40,0,0.18);
      margin-top: 0.55rem; flex: 0 0 auto;
    }
    .engine-row__line {
      flex: 1 1 auto; width: 2px;
      background: linear-gradient(to bottom, var(--color-rosso-corsa), rgba(255,40,0,0.25));
      margin: 0.25rem 0 -0.1rem;
    }
    .engine-row__body {
      padding: 0.55rem 0 0.85rem;
      min-width: 0;
    }
    .engine-row:last-child .engine-row__body { padding-bottom: 0; }
    .engine-row__name {
      font-size: 1.02rem; font-weight: 600; line-height: 1.25;
      color: var(--ink-inverse); margin-bottom: 0.2rem;
    }
    .engine-row__desc {
      font-size: 0.9rem; line-height: 1.5;
      color: var(--color-grigio-300);
    }

    /* ── Prize: metric row ─────────────────────────────────────────── */
    .prize-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; }
    .prize-stat { text-align: center; min-width: 0; }
    .prize-stat__value {
      font-family: var(--font-display); font-weight: 700;
      color: #fff; line-height: 1; margin-bottom: 0.4rem;
      font-size: clamp(1.5rem, 3vw, 2.5rem); letter-spacing: -0.02em;
    }
    .prize-stat__label { font-size: 0.95rem; line-height: 1.4; color: rgba(255,255,255,0.85); }
  </style>
</BaseLayout>
