---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import ScopingCalculator from '@edf/core/blocks/scoping/ScopingCalculator.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { SEED_SCENARIOS, ASSUMPTION_META, RIGOR_LABELS, DISCLAIMER, METRICS, FIELD_AUDIT, COST_DRIVERS, COST_MODEL_SUMMARY } from '../data/scoping';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const site = Astro.site ? Astro.site.toString().replace(/\/$/, '') : '';
const experienceUrl = site + href(base, '/scoping');
---
<BaseLayout title="Licensing & Scoping" pageSolutions={['scoping']}>
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/')} prevHref={href(base, '/casi-duso')}>

    <!-- SLIDE 0: Cover -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <T en="LICENSING & SCOPING" it="LICENSING E SCOPING" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-5" />
      <T as="h1" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(2.5rem, 6vw, 5rem);"
        en="Two products.<br/>One clear estimate." it="Due prodotti.<br/>Una stima chiara." />
      <T as="p" class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
        en="RTCDP Collaboration and CJA share the Adobe Experience Platform foundation and integrate, yet they license independently, on different metrics. Model both here."
        it="RTCDP Collaboration e CJA condividono la fondazione Adobe Experience Platform e si integrano, ma si licenziano in modo indipendente, su metriche diverse. Modellali qui." />
      <T as="p" class="slide-caption text-[var(--color-grigio-400)] mt-6 text-sm max-w-2xl mx-auto"
        en={`Terminology: “Data Collaboration” here means Adobe Real-Time CDP Collaboration.`}
        it={`Terminologia: “Data Collaboration” qui indica Adobe Real-Time CDP Collaboration.`} />
    </Slide>

    <!-- SLIDE 1: The two licensing metrics, explained with examples -->
    <Slide id="slide-metrics" bg="inverse" align="center">
      <T en="LICENSING METRICS" it="METRICHE DI LICENSING" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T as="h2" class="slide-title text-[var(--ink-inverse)] mb-7" style="font-size: clamp(1.7rem, 3.4vw, 2.9rem);"
        en="Two products. Two metrics. How each is measured." it="Due prodotti. Due metriche. Come si misura ciascuno." />
      <div class="sc-metrics">
        {METRICS.map((m, i) => (
          <article class="sc-metric-card">
            <header class="sc-metric-head">
              <span class="sc-metric-idx">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <p class="sc-metric-product"><span data-lang-en>{m.product.en}</span><span data-lang-it>{m.product.it}</span></p>
                <p class="sc-metric-metric"><span data-lang-en>{m.metric.en}</span><span data-lang-it>{m.metric.it}</span></p>
              </div>
            </header>
            <p class="sc-metric-what"><span data-lang-en>{m.what.en}</span><span data-lang-it>{m.what.it}</span></p>
            <ul class="sc-metric-list">
              {m.consumes.map((c) => (
                <li><span data-lang-en>{c.en}</span><span data-lang-it>{c.it}</span></li>
              ))}
            </ul>
            <div class="sc-metric-example">
              <span class="sc-metric-example-tag"><span data-lang-en>EXAMPLE</span><span data-lang-it>ESEMPIO</span></span>
              <p><span data-lang-en>{m.example.en}</span><span data-lang-it>{m.example.it}</span></p>
            </div>
          </article>
        ))}
      </div>
    </Slide>

    <!-- SLIDE: How the annual cost is built (4 drivers + Ferrari read) -->
    <Slide id="slide-model" bg="inverse" align="center">
      <T en="PERIMETER & COST" it="PERIMETRO E COSTO" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T as="h2" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(1.7rem, 3.4vw, 2.9rem);"
        en="Four things, one perimeter." it="Quattro voci, un perimetro." />
      <div class="sc-drivers">
        {COST_DRIVERS.map((d) => (
          <article class="sc-driver-card">
            <span class="sc-driver-tag"><span data-lang-en>{d.tag.en}</span><span data-lang-it>{d.tag.it}</span></span>
            <p class="sc-driver-title"><span data-lang-en>{d.title.en}</span><span data-lang-it>{d.title.it}</span></p>
            <p class="sc-driver-body"><span data-lang-en>{d.body.en}</span><span data-lang-it>{d.body.it}</span></p>
            <p class="sc-driver-ferrari"><span data-lang-en>{d.ferrari.en}</span><span data-lang-it>{d.ferrari.it}</span></p>
          </article>
        ))}
      </div>
      <T as="p" class="sc-model-summary" en={COST_MODEL_SUMMARY.en} it={COST_MODEL_SUMMARY.it} />
    </Slide>

    <!-- SLIDE 2: Assumptions & rigor -->
    <Slide id="slide-assumptions" bg="inverse" align="left">
      <T en="ASSUMPTIONS" it="ASSUNZIONI" as="p" class="slide-eyebrow text-[var(--accent-primary)] mb-4" />
      <T as="h2" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(1.8rem, 3.6vw, 3rem);"
        en="Every number, classified." it="Ogni numero, classificato." />
      <ul class="sc-assume">
        {ASSUMPTION_META.map((m) => (
          <li class={`sc-chip sc-${m.tag}`}>
            <span class="sc-tag"><span data-lang-en>{RIGOR_LABELS[m.tag].en}</span><span data-lang-it>{RIGOR_LABELS[m.tag].it}</span></span>
            <span class="sc-txt"><span data-lang-en>{m.en}</span><span data-lang-it>{m.it}</span></span>
          </li>
        ))}
      </ul>
    </Slide>

    <!-- SLIDE 2: The calculator (full-bleed interactive; exempt from audit:deck) -->
    <Slide id="slide-calculator" bg="inverse" align="center">
      <ScopingCalculator
        projectSlug="ferrari-racing"
        supabaseUrl={SUPABASE_URL}
        supabaseAnonKey={SUPABASE_ANON_KEY}
        experienceUrl={experienceUrl}
        fields={FIELD_AUDIT}
      />
    </Slide>

    <!-- SLIDE 3: Disclaimer -->
    <Slide id="slide-disclaimer" bg="brand" align="center">
      <T en="IMPORTANT" it="IMPORTANTE" as="p" class="slide-eyebrow mb-4" />
      <T as="p" class="slide-lead max-w-3xl mx-auto" en={DISCLAIMER.en} it={DISCLAIMER.it} />
    </Slide>

  </DeckContainer>

  <script is:inline define:vars={{ seeds: SEED_SCENARIOS }}>
    // Hand the seed scenarios to the calculator island.
    window.__edfScopingSeeds = seeds;
  </script>

  <style>
    .sc-assume { display: grid; grid-template-columns: 1fr; gap: 0.5rem; max-width: 60rem; }
    @media (min-width: 768px) { .sc-assume { grid-template-columns: 1fr 1fr; } }
    .sc-chip { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.5rem 0.75rem; border-radius: 5px; border: 1px solid var(--line-subtle); background: rgba(255,255,255,0.03); }
    .sc-tag { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; }
    .sc-fact .sc-tag { color: #4ade80; }
    .sc-inference .sc-tag { color: var(--accent-secondary); }
    .sc-sales-order .sc-tag { color: var(--accent-primary); }
    .sc-txt { font-size: 0.8rem; color: var(--color-grigio-300); }

    /* Licensing-metrics teaching slide */
    .sc-metrics { display: grid; grid-template-columns: 1fr; gap: 1.25rem; max-width: 68rem; width: 100%; margin: 0 auto; text-align: left; }
    @media (min-width: 860px) { .sc-metrics { grid-template-columns: 1fr 1fr; } }
    .sc-metric-card { display: flex; flex-direction: column; gap: 0.85rem; padding: 1.4rem 1.5rem; border: 1px solid var(--line-subtle); border-radius: 8px; background: color-mix(in srgb, var(--surface-inverse) 82%, #fff 5%); }
    .sc-metric-head { display: flex; align-items: baseline; gap: 0.9rem; }
    .sc-metric-idx { font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; color: var(--accent-primary); line-height: 1; }
    .sc-metric-product { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; color: var(--ink-inverse); }
    .sc-metric-metric { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-secondary); font-weight: 700; margin-top: 0.15rem; }
    .sc-metric-what { font-size: 0.86rem; line-height: 1.5; color: var(--color-grigio-300); }
    .sc-metric-list { display: flex; flex-direction: column; gap: 0.4rem; padding-left: 0; list-style: none; }
    .sc-metric-list li { position: relative; padding-left: 1.05rem; font-size: 0.78rem; line-height: 1.45; color: var(--color-grigio-300); }
    .sc-metric-list li::before { content: ""; position: absolute; left: 0; top: 0.5em; width: 5px; height: 5px; border-radius: 50%; background: var(--accent-primary); }
    .sc-metric-example { border-left: 3px solid var(--accent-secondary); padding: 0.5rem 0 0.5rem 0.85rem; background: rgba(255,242,0,0.04); border-radius: 0 4px 4px 0; }
    .sc-metric-example-tag { display: inline-block; font-size: 0.6rem; letter-spacing: 0.1em; font-weight: 800; color: var(--accent-secondary); margin-bottom: 0.3rem; }
    .sc-metric-example p { font-size: 0.8rem; line-height: 1.5; color: var(--ink-inverse); }

    /* Cost-composition slide */
    .sc-drivers { display: grid; grid-template-columns: 1fr; gap: 1rem; max-width: 70rem; width: 100%; margin: 0 auto; text-align: left; }
    @media (min-width: 860px) { .sc-drivers { grid-template-columns: 1fr 1fr; } }
    .sc-driver-card { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.15rem 1.3rem; border: 1px solid var(--line-subtle); border-radius: 8px; background: color-mix(in srgb, var(--surface-inverse) 82%, #fff 5%); }
    .sc-driver-tag { display: inline-block; align-self: flex-start; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; color: var(--accent-secondary); border: 1px solid rgba(255,242,0,0.4); border-radius: 4px; padding: 0.12rem 0.45rem; }
    .sc-driver-title { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; color: var(--ink-inverse); }
    .sc-driver-body { font-size: 0.9rem; line-height: 1.5; color: var(--color-grigio-300); }
    .sc-driver-ferrari { font-size: 0.9rem; line-height: 1.5; color: var(--ink-inverse); border-left: 3px solid var(--accent-primary); padding-left: 0.7rem; }
    .sc-model-summary { max-width: 62rem; margin: 1.1rem auto 0; font-size: 0.88rem; line-height: 1.55; color: var(--color-grigio-300); text-align: center; }
  </style>
</BaseLayout>
