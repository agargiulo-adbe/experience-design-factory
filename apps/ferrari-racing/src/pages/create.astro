---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import MockupSlide from '@edf/core/blocks/immersive/MockupSlide.astro';
import GenstudioMockup from '@edf/core/blocks/immersive/GenstudioMockup.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import imgPit from '../assets/generated/bg-pit.webp';
import imgTifosi from '../assets/generated/tifosi.webp';
import imgTelemetry from '../assets/generated/data-telemetry.webp';
import imgCarbon from '../assets/generated/bg-carbon.webp';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const genstudioCards = [
  { en: 'Brief → variants', it: 'Brief → varianti', bodyEn: 'One campaign brief becomes dozens of channel-ready cuts for hero, social and display, in minutes.', bodyIt: 'Un brief di campagna diventa decine di versioni pronte per hero, social e display, in pochi minuti.' },
  { en: 'Channel-ready formats', it: 'Formati pronti per i canali', bodyEn: 'Every variant exports in the exact sizes each placement needs, from homepage banner to Stories.', bodyIt: 'Ogni variante esce nei formati esatti richiesti da ogni placement, dal banner homepage alle Stories.' },
  { en: 'Ferrari brand kit built-in', it: 'Brand kit Ferrari integrato', bodyEn: 'Rosso Corsa, the Cavallino Rampante and typography are pre-loaded, so partners start on-brand.', bodyIt: 'Rosso Corsa, il Cavallino Rampante e la tipografia sono già caricati: i partner partono on-brand.' },
];

const guardrailPoints = [
  { en: 'Pre-publication check', it: 'Controllo pre-pubblicazione', bodyEn: 'GenStudio checks every asset against Ferrari guidelines for Rosso Corsa, logo usage and tone before it can go live.', bodyIt: 'GenStudio verifica ogni asset rispetto alle linee guida Ferrari su Rosso Corsa, uso del logo e tono prima che vada online.' },
  { en: 'Post-publication monitoring', it: 'Monitoraggio post-pubblicazione', bodyEn: 'Live campaigns are watched continuously, so brand drift gets flagged instead of discovered later.', bodyIt: 'Le campagne live sono monitorate di continuo, così le deviazioni di brand si segnalano invece di scoprirle dopo.' },
  { en: 'Trust, by design', it: 'Fiducia by design', bodyEn: 'Automated compliance is what lets Ferrari open its brand to partner teams at scale, with no creative bottleneck.', bodyIt: 'La conformità automatizzata è ciò che permette a Ferrari di aprire il proprio brand ai team partner su larga scala, senza colli di bottiglia creativi.' },
];

const expressCards = [
  { en: 'Brand-locked templates', it: 'Template brand-locked', bodyEn: 'Colours, logo and layout stay locked, so partners edit only what they should.', bodyIt: 'Colori, logo e layout restano bloccati, così i partner modificano solo ciò che devono.' },
  { en: 'Social posts & banners', it: 'Post social & banner', bodyEn: 'Non-designers adapt approved assets for every placement in a few clicks.', bodyIt: 'Chi non è designer adatta gli asset approvati per ogni placement in pochi clic.' },
  { en: 'Fast, safe, consistent', it: 'Veloce, sicuro, coerente', bodyEn: 'Every partner team ships on-brand work without a creative bottleneck.', bodyIt: 'Ogni team partner produce lavoro on-brand senza colli di bottiglia creativi.' },
];
---
<BaseLayout title="Create" pageSolutions={['genstudio','express']}>
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/activate')} prevHref={href(base, '/define')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('content-studio')} imageClass="opacity-30" scrim="bg-[var(--surface-inverse)]/80" />
      <!-- racing line: apex after Define -->
      <div class="cr-apex-rail" data-reveal data-reveal-delay="0.1" aria-hidden="true">
        <span class="cr-apex-step cr-apex-step--done"><span class="frl-node"></span><span class="cr-apex-word">Define</span></span>
        <span class="frl-line-track cr-apex-seg"></span>
        <span class="cr-apex-step cr-apex-step--now"><span class="frl-node frl-node--giallo"></span><span class="cr-apex-word cr-apex-word--now">Create</span></span>
        <span class="cr-apex-seg cr-apex-seg--ghost"></span>
        <span class="cr-apex-step"><span class="cr-apex-dot-ghost"></span><span class="cr-apex-word cr-apex-word--ghost">Activate</span></span>
      </div>
      <T en="CREATE" it="CREA" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-5" />
      <T
        as="h1" class="slide-title text-[var(--ink-inverse)] mb-6" style="font-size: clamp(2.75rem, 6.5vw, 6rem);"
        en="On-brand in minutes,<br/>not weeks."
        it="On-brand in minuti,<br/>non settimane."
      />
      <T
        as="p"
        class="slide-lead text-[var(--color-grigio-300)] max-w-3xl mx-auto"
        en="Partners create campaign content for their own channels, always inside Ferrari's brand guardrails."
        it="I partner creano contenuti di campagna per i propri canali, sempre dentro i guardrail di brand Ferrari."
      />
    </Slide>

    <!-- ── SLIDE 1: GenStudio for Performance Marketing ───────────── -->
    <Slide id="slide-genstudio" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-pit')} imageClass="opacity-15" scrim="bg-[var(--surface-inverse)]/88" />
      <T en="GENSTUDIO FOR PERFORMANCE MARKETING" it="GENSTUDIO FOR PERFORMANCE MARKETING" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-[clamp(1.25rem,3.5vh,2.5rem)]" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-[clamp(1.5rem,4.5vh,3rem)]" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
        en="One brief. Every variant."
        it="Un brief. Ogni variante."
      />
      <div data-demo-flex class="w-full max-w-6xl mx-auto flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <T
            as="p" class="text-[clamp(1.1rem,1.5vw,1.4rem)] text-[var(--color-grigio-300)] max-w-2xl mb-[clamp(1.75rem,5vh,3.25rem)] leading-relaxed"
            en="A partner like HP generates on-brand campaign variants for its homepage, social and display in minutes, using GenStudio for Performance Marketing."
            it="Un partner come HP genera in pochi minuti varianti di campagna on-brand per la propria homepage, i social e il display, con GenStudio for Performance Marketing."
          />
          <div class="w-full grid md:grid-cols-3 gap-4 mb-[clamp(1.5rem,4.5vh,2.75rem)] text-left" data-reveal data-reveal-delay="0.22">
            {genstudioCards.map((c, i) => (
              <div class="frl-card frl-card--tight">
                <span class="frl-mark">{i + 1}</span>
                <p class="frl-card-title" style="font-size:1rem;"><span data-lang-en>{c.en}</span><span data-lang-it>{c.it}</span></p>
                <p class="frl-card-body"><span data-lang-en>{c.bodyEn}</span><span data-lang-it>{c.bodyIt}</span></p>
              </div>
            ))}
          </div>
          <span class="frl-line w-full max-w-md" data-reveal data-reveal-delay="0.35">
            <span class="frl-node"></span>
            <span class="frl-line-track"></span>
            <span class="inline-flex items-center px-3 py-1.5 text-xs font-semibold tracking-widest uppercase rounded-sm bg-[var(--accent-primary)] text-white flex-shrink-0">
              1 brief → 12 variants · 2 min
            </span>
          </span>
        </div>
        <MediaDemoSlot id="create-genstudio-demo" label="GenStudio — Demo" />
      </div>
    </Slide>

    <!-- ── SLIDE 2: Brand Guardrails ──────────────────────────────── -->
    <Slide id="slide-guardrails" bg="brand" align="center" data-solution="brand">
      <T en="BRAND GUARDRAILS" it="GUARDRAIL DI BRAND" as="p" class="slide-eyebrow text-white/75 mb-5" />
      <T
        as="h2" class="slide-title text-white mb-8" style="font-size: clamp(2.25rem, 4.6vw, 4rem);"
        en="The Cavallino stays perfect."
        it="Il Cavallino resta perfetto."
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.5vw,1.4rem)] text-white/85 max-w-3xl mb-10"
        en="GenStudio for Performance Marketing enforces Ferrari's guidelines on Rosso Corsa, logo usage and tone. Only compliant work goes live."
        it="GenStudio for Performance Marketing applica le linee guida Ferrari su Rosso Corsa, uso del logo e tono. Solo il lavoro conforme va online."
      />
      <div class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5 text-left" data-reveal data-reveal-delay="0.25">
        {guardrailPoints.map((p) => (
          <div class="cr-guard-card">
            <span class="cr-guard-tick" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5l3 3 6-7" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <p class="text-base font-semibold text-white mb-1.5"><span data-lang-en>{p.en}</span><span data-lang-it>{p.it}</span></p>
            <p class="text-sm text-white/85 leading-relaxed"><span data-lang-en>{p.bodyEn}</span><span data-lang-it>{p.bodyIt}</span></p>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── MOCKUP: GenStudio live demo ──────────────────────────── -->
    <GenstudioMockup
      sectionId="create"
      slug="ferrari-racing"
      variantImages={[imgPit, imgTifosi, imgTelemetry, imgCarbon]}
    />

    <!-- ── SLIDE 3: Adobe Express ─────────────────────────────────── -->
    <Slide id="slide-express" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('billboard')} imageClass="opacity-18" scrim="bg-[var(--surface-inverse)]/86" />
      <T en="ADOBE EXPRESS" it="ADOBE EXPRESS" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
      <T
        as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2.25rem, 4.4vw, 3.75rem);"
        en="Every partner team, on-brand"
        it="Ogni team partner, on-brand"
      />
      <T
        as="p" class="text-[clamp(1.05rem,1.5vw,1.4rem)] text-[var(--color-grigio-300)] max-w-3xl mb-6"
        en="Non-designers on the partner side turn approved assets into social posts and banners with brand-locked Adobe Express templates, fast, safe and consistent."
        it="Chi non è designer, sul lato partner, trasforma gli asset approvati in post social e banner con i template brand-locked di Adobe Express, in modo veloce, sicuro e coerente."
      />
      <div class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-5 mb-4 text-left" data-reveal data-reveal-delay="0.22">
        {expressCards.map((c) => (
          <div class="frl-card frl-card--tight">
            <p class="frl-card-title" style="font-size:1rem;"><span data-lang-en>{c.en}</span><span data-lang-it>{c.it}</span></p>
            <p class="frl-card-body"><span data-lang-en>{c.bodyEn}</span><span data-lang-it>{c.bodyIt}</span></p>
          </div>
        ))}
      </div>
      <a href={href(base, '/activate')}
         class="inline-flex items-center gap-3 px-9 py-4 text-[clamp(1rem,1.2vw,1.2rem)] font-semibold tracking-wide uppercase bg-[var(--accent-primary)] text-[var(--color-carbonio)] hover:bg-[var(--accent-hover)] transition-colors rounded-sm" data-reveal data-reveal-delay="0.4">
        <span data-lang-en>Now activate it</span><span data-lang-it>Ora attivala</span>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </Slide>

    <!-- ── MOCKUP: Express live demo ─────────────────────────────── -->
    <MockupSlide mockupId="express" sectionId="create" slug="ferrari-racing" />

  </DeckContainer>

  <style>
    /* ── Create = the next apex on the racing line, after Define ─────── */
    .cr-apex-rail {
      display: flex; align-items: center; justify-content: center;
      gap: 0.6rem; margin: 0 auto 1.6rem; max-width: 34rem;
    }
    .cr-apex-step { display: inline-flex; align-items: center; gap: 0.5rem; flex: 0 0 auto; }
    .cr-apex-seg { flex: 1 1 auto; min-width: 1.75rem; height: 2px; }
    .cr-apex-seg--ghost {
      border-radius: 2px;
      background: repeating-linear-gradient(90deg, rgba(255,255,255,0.28) 0 4px, transparent 4px 9px);
    }
    .cr-apex-word {
      font-family: var(--font-display); font-weight: 700; font-size: 0.82rem;
      letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-grigio-300);
    }
    .cr-apex-word--now { color: var(--color-giallo-modena); }
    .cr-apex-word--ghost { color: var(--color-grigio-500); }
    .cr-apex-step--done .frl-node { background: rgba(255,40,0,0.55); }
    .cr-apex-dot-ghost {
      flex: 0 0 auto; width: 9px; height: 9px; border-radius: 50%;
      border: 1.5px solid var(--color-grigio-500); background: transparent;
    }

    /* Tighter card rhythm for the 3-up grids on Create */
    .frl-card--tight { padding: 1.15rem 1.2rem 1.1rem; }

    /* Guardrail cards on the brand (Rosso Corsa) surface — explicit rgba only */
    .cr-guard-card {
      position: relative;
      background: rgba(23, 23, 28, 0.28);
      border: 1px solid rgba(255, 255, 255, 0.22);
      border-radius: 4px;
      padding: 1.5rem 1.4rem 1.35rem;
      box-shadow: inset 0 2px 0 0 rgba(255, 242, 0, 0.85);
      min-width: 0;
    }
    .cr-guard-tick {
      display: inline-flex; align-items: center; justify-content: center;
      width: 1.75rem; height: 1.75rem; border-radius: 4px;
      background: rgba(11, 11, 13, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.3);
      margin-bottom: 0.85rem;
    }
  </style>
</BaseLayout>
