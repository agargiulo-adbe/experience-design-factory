---
import BaseLayout from '../layouts/BaseLayout.astro';
import FerrariNav from '../components/FerrariNav.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import T from '@edf/core/blocks/i18n/T.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';
import { cite } from '../data/sources';
import { STATS } from '../data/stats';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const cases = [
  {
    org: 'NBCUniversal',
    en: 'One of the largest premium audiences in the US. Real-Time CDP Collaboration matched audiences with an advertiser, activated, and closed the loop with privacy-safe measurement (beta results).',
    it: 'Una delle audience premium più grandi degli Stati Uniti. Con Real-Time CDP Collaboration ha allineato le audience con un advertiser, attivato e chiuso il loop con misurazione privacy-safe (risultati beta).',
    stats: [['10×', 'match rate'], ['2×', 'conversions'], ['90%', 'lift']],
  },
  {
    org: 'Alterra Mountain Co.',
    en: 'The Ikon Pass company. Fragmented data and CTV challenges solved by activating first-party data privacy-first with Real-Time CDP Collaboration. (Adobe Summit 2025)',
    it: 'La società Ikon Pass. Dati frammentati e sfide CTV risolti attivando i dati first-party in modo privacy-first con Real-Time CDP Collaboration. (Adobe Summit 2025)',
    stats: [['+30%', 'conversions'], ['1', 'clean room']],
  },
];

const valueRights = [
  { en: 'Expand the sponsor roster & improve retention', it: 'Amplia il roster sponsor e migliora la retention' },
  { en: 'Increase the value of existing partnerships', it: 'Aumenta il valore delle partnership esistenti' },
  { en: 'Command a price premium with proven audiences', it: 'Ottieni un price premium con audience dimostrate' },
  { en: 'Attract net-new partners with data-backed value', it: 'Attrai nuovi partner con valore basato sul dato' },
];
const valueSponsors = [
  { en: 'New channels & insights to reach the right fans', it: 'Nuovi canali e insight per i tifosi giusti' },
  { en: 'Better outcomes via privacy-safe personalization', it: 'Risultati migliori con personalizzazione privacy-safe' },
  { en: 'Improved, measurable ROI on sponsorship spend', it: 'ROI migliore e misurabile sulla spesa sponsorship' },
];
---
<BaseLayout title="Proof">
  <div class="fixed top-0 left-0 right-0 z-50">
    <FerrariNav currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/loop')} prevHref={href(base, '/analisi')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('podium')} imageClass="opacity-40" scrim="bg-[var(--surface-inverse)]/82" />
      <div class="w-full max-w-4xl mx-auto flex flex-col items-center text-center">
        <div class="pv-lap" data-reveal data-reveal-delay="0.1" aria-hidden="true">
          <span class="pv-lap-flag"></span>
          <span class="pv-lap-track"></span>
          <T en="THE PROOF" it="LA PROVA" as="span" class="pv-lap-tag text-[var(--accent-secondary)]" />
        </div>
        <T
          as="h2" class="slide-title text-[var(--ink-inverse)] mt-[clamp(1.5rem,4vh,2.75rem)] mb-[clamp(1.5rem,4.5vh,3rem)]" style="font-size: clamp(3rem, 7vw, 6.5rem);"
          en="It already works." it="Funziona già."
        />
        <T
          as="p" class="text-[clamp(1.15rem,1.7vw,1.6rem)] text-[var(--color-grigio-300)] max-w-3xl leading-relaxed"
          en="This isn't a promise. Publishers and brands are already winning with Adobe data collaboration, and Ferrari's own fan data shows the appetite is there."
          it="Non è una promessa. Publisher e brand vincono già con la data collaboration Adobe, e i dati fan di Ferrari mostrano che l'appetito c'è."
        />
      </div>
    </Slide>

    <!-- ── SLIDE 1: Case studies ──────────────────────────────────── -->
    <Slide id="slide-cases" bg="inverse" align="center">
      <div class="pv-shell frl-bg-soft" data-reveal>
        <div class="pv-head">
          <T en="CASE STUDIES" it="CASE STUDY" as="p" class="frl-tag" />
          <T
            as="h2" class="slide-title text-[var(--ink-primary)] mt-2" style="font-size: clamp(2rem, 4.2vw, 3.5rem);"
            en="Winning, in the real world" it="Si vince, nel mondo reale"
          />
        </div>
        <div class="pv-cases" data-reveal data-reveal-delay="0.18">
          {cases.map((c) => (
            <div class="frl-panel frl-panel--rosso">
              <div class="frl-panel-head">
                <span class="font-[family-name:var(--font-display)] font-bold text-[var(--ink-primary)] text-[1.15rem]">{c.org}</span>
              </div>
              <div class="pv-figs">
                {c.stats.map(([v, l]) => (
                  <div class="pv-fig">
                    <span class="frl-figure text-[var(--color-rosso-corsa)]">{v}</span>
                    <span class="pv-fig-label">{l}</span>
                  </div>
                ))}
              </div>
              <T as="p" class="frl-panel-body" en={c.en} it={c.it} />
            </div>
          ))}
        </div>
        <p class="pv-src">
          <span data-lang-en>Sources: {cite('adobe_rtcdp_blog', 'adobe_summit_alterra')}</span>
          <span data-lang-it>Fonti: {cite('adobe_rtcdp_blog', 'adobe_summit_alterra')}</span>
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 1b: Ferrari fan signals ─────────────────────────── -->
    <Slide id="slide-fan-signals" bg="inverse" align="center">
      <SlideBackdrop slot="backdrop" {...mediaProps('bg-carbon')} imageClass="opacity-20" scrim="bg-[var(--surface-inverse)]/85" />
      <div class="w-full max-w-5xl mx-auto flex flex-col items-center text-center">
        <T en="YOUR FAN DATA" it="I TUOI DATI FAN" as="p" class="slide-eyebrow text-[var(--accent-secondary)] mb-4" />
        <T
          as="h2" class="slide-title text-[var(--ink-inverse)] mb-5" style="font-size: clamp(2rem, 4.2vw, 3.5rem);"
          en="The Tifosi are already responding." it="I Tifosi stanno già rispondendo."
        />
        <T
          as="p" class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-grigio-300)] max-w-3xl mb-[clamp(1.5rem,5vh,2.75rem)]"
          en="The 2025 app relaunch, powered by first-party fan signals, moved the numbers that matter. Ferrari's own data shows a fan base that is ready for a data-driven partnership model."
          it="Il rilancio dell'app 2025, alimentato dai segnali fan first-party, ha mosso i numeri che contano. I dati di Ferrari mostrano una fan base che è pronta per un modello di partnership basato sul dato."
        />
        <div class="pv-signals" data-reveal data-reveal-delay="0.22">
          <div class="frl-stat pv-signal">
            <p class="frl-stat-value" style="font-size: clamp(2rem,3.6vw,3rem);">{STATS.raceday.value}</p>
            <T as="p" class="frl-stat-label" en={STATS.raceday.en} it={STATS.raceday.it} />
          </div>
          <div class="frl-stat pv-signal">
            <p class="frl-stat-value" style="font-size: clamp(2rem,3.6vw,3rem);">{STATS.downloads.value}</p>
            <T as="p" class="frl-stat-label" en={STATS.downloads.en} it={STATS.downloads.it} />
          </div>
          <div class="frl-stat pv-signal">
            <p class="frl-stat-value" style="font-size: clamp(2rem,3.6vw,3rem);">{STATS.mau.value}</p>
            <T as="p" class="frl-stat-label" en={STATS.mau.en} it={STATS.mau.it} />
          </div>
        </div>
        <p class="pv-src mt-[clamp(1.25rem,4vh,2rem)] text-center">
          <span data-lang-en>Source: {cite('ibm_ferrari_2026')}</span>
          <span data-lang-it>Fonte: {cite('ibm_ferrari_2026')}</span>
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 2: The value of getting it right ─────────────────── -->
    <Slide id="slide-value" bg="brand" align="center">
      <div class="w-full max-w-5xl mx-auto flex flex-col items-center text-center">
        <T en="THE VALUE OF GETTING IT RIGHT" it="IL VALORE DI FARLO BENE" as="p" class="slide-eyebrow text-white/75 mb-5" />
        <T
          as="h2" class="slide-title text-white mb-9" style="font-size: clamp(2rem, 4.2vw, 3.5rem);"
          en="Everyone crosses the line first" it="Tutti tagliano il traguardo per primi"
        />
        <div class="pv-value" data-reveal data-reveal-delay="0.2">
          <div class="pv-value-panel">
            <T en="For Ferrari Racing" it="Per Ferrari Racing" as="p" class="pv-value-head" />
            <ul class="pv-value-list">
              {valueRights.map((v) => (
                <li class="pv-value-item">
                  <span class="pv-value-node" aria-hidden="true"></span>
                  <span data-lang-en>{v.en}</span><span data-lang-it>{v.it}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="pv-value-panel">
            <T en="For the Partner Sponsors" it="Per i Partner Sponsor" as="p" class="pv-value-head" />
            <ul class="pv-value-list">
              {valueSponsors.map((v) => (
                <li class="pv-value-item">
                  <span class="pv-value-node" aria-hidden="true"></span>
                  <span data-lang-en>{v.en}</span><span data-lang-it>{v.it}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <T
          as="p" class="mt-9 font-[family-name:var(--font-display)] italic text-white/90 text-[clamp(1.1rem,1.6vw,1.5rem)]"
          en="Now, the loop that makes it repeatable." it="Ora, il loop che lo rende ripetibile."
        />
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>

<style>
  /* ── Proof — designed data over the racing line ─────────────────── */
  /* Cover: start line / lap tag */
  .pv-lap { display: flex; align-items: center; gap: 0.75rem; }
  .pv-lap-flag {
    width: 12px; height: 12px; border-radius: 2px;
    background: repeating-conic-gradient(#F4F4F2 0% 25%, rgba(23,23,28,0.9) 0% 50%) 0 / 6px 6px;
  }
  .pv-lap-track {
    width: clamp(2.5rem, 6vw, 5rem); height: 2px; border-radius: 2px;
    background: linear-gradient(to right, rgba(255,40,0,0.15), var(--color-rosso-corsa));
  }
  .pv-lap-tag { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; }

  /* Case studies shell — designed data card on a light racing surface */
  .pv-shell {
    width: 100%; max-width: 64rem; margin-inline: auto;
    padding: clamp(1.5rem, 3.5vh, 2.5rem) clamp(1.5rem, 3vw, 2.75rem);
    border: 1px solid var(--line-subtle); border-radius: 6px;
    box-shadow: inset 0 3px 0 0 var(--color-rosso-corsa);
    text-align: left;
  }
  .pv-head { margin-bottom: clamp(1.25rem, 3vh, 1.9rem); }
  .pv-head .frl-tag { color: var(--color-rosso-corsa); }
  .pv-cases { display: grid; grid-template-columns: 1fr; gap: clamp(1rem, 2.4vh, 1.5rem); }
  @media (min-width: 768px) { .pv-cases { grid-template-columns: 1fr 1fr; } }
  .frl-panel-head { border-bottom-color: rgba(255,40,0,0.35); }

  .pv-figs { display: flex; flex-wrap: wrap; gap: 1.1rem 1.6rem; margin-bottom: 0.9rem; }
  .pv-fig { display: flex; flex-direction: column; }
  .pv-fig-label {
    font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-grigio-400); margin-top: 0.3rem;
  }

  .pv-src {
    margin-top: clamp(1rem, 3.5vh, 1.75rem);
    font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-grigio-400);
  }

  /* Fan signals — three measured figures on the telemetry rail */
  .pv-signals {
    width: 100%; max-width: 48rem; margin-inline: auto;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 2.5vw, 2rem);
  }
  .pv-signal {
    border-top: 2px solid rgba(255,40,0,0.55);
    padding-top: 0.9rem;
  }
  .pv-signal .frl-stat-value { color: var(--color-rosso-corsa); margin-bottom: 0.6rem; }
  .pv-signal .frl-stat-label { color: var(--color-grigio-300); }

  /* Value — two lanes with rosso lead markers on the brand slide */
  .pv-value {
    width: 100%; max-width: 64rem; margin-inline: auto;
    display: grid; grid-template-columns: 1fr; gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 768px) { .pv-value { grid-template-columns: 1fr 1fr; } }
  .pv-value-panel {
    background: rgba(23,23,28,0.28);
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 4px; box-shadow: inset 0 2px 0 0 rgba(255,242,0,0.85);
    padding: clamp(1.25rem, 2.4vh, 1.6rem) clamp(1.25rem, 2vw, 1.6rem);
    text-align: left;
  }
  .pv-value-head {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: #FFFFFF; margin-bottom: 1rem;
  }
  .pv-value-list { display: flex; flex-direction: column; gap: 0.7rem; }
  .pv-value-item {
    display: flex; align-items: flex-start; gap: 0.7rem;
    color: rgba(255,255,255,0.92); font-size: 0.98rem; line-height: 1.5;
  }
  .pv-value-node {
    margin-top: 0.5rem; flex-shrink: 0;
    width: 0.5rem; height: 0.5rem; border-radius: 1px;
    background: var(--color-giallo-modena);
  }
</style>
