---
import { href } from '@edf/core/utils/url.js';

interface Props {
  currentPath: string;
  base: string;
}

const { currentPath, base } = Astro.props;

const sections = [
  { slug: '',              label: 'Cover',         solution: null },
  { slug: 'scenario',     label: 'Scenario',       solution: null },
  { slug: 'fondazione',   label: 'Foundation',     solution: null },
  { slug: 'convergenza',  label: 'CJA',            solution: 'cja' },
  { slug: 'connessioni',  label: 'Connessioni',    solution: 'data-collab' },
  { slug: 'roadmap',      label: 'Roadmap',        solution: 'rtcdp,ajo,mix-modeler' },
  { slug: 'casi-duso',    label: 'Casi d\'uso',     solution: null },
];

function isActive(slug: string) {
  const norm = currentPath.replace(/\/+$/, '');
  if (slug === '') return norm.endsWith('/trenitalia-connessioni') || norm.endsWith('/index');
  return norm.endsWith('/' + slug);
}
---
<nav
  class="flex items-center justify-between px-6 py-3 bg-[var(--color-carbonio)]/95 backdrop-blur-sm border-b border-[var(--color-binario)]"
  aria-label="Navigazione esperienza"
>
  <a
    href={href(base, '/')}
    class="flex items-center gap-2.5 no-underline group flex-shrink-0"
    aria-label="Home — Connessioni Intelligenti"
  >
    <span class="inline-flex items-center justify-center w-7 h-7 rounded bg-[var(--accent-primary)] flex-shrink-0" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect x="1" y="6" width="12" height="1.5" rx="0.75" fill="white"/>
        <rect x="1" y="3" width="12" height="1.5" rx="0.75" fill="white" opacity="0.6"/>
        <rect x="1" y="9" width="12" height="1.5" rx="0.75" fill="white" opacity="0.6"/>
      </svg>
    </span>
    <span class="text-sm font-semibold text-[var(--color-ghiaccio)] group-hover:text-white transition-colors font-[family-name:var(--font-display)] whitespace-nowrap">
      Connessioni Intelligenti
    </span>
    <span class="hidden 2xl:inline text-[0.6rem] font-bold tracking-widest uppercase text-[var(--color-ghiaccio)]/40 ml-1 whitespace-nowrap">
      FS × Adobe
    </span>
  </a>

  <ol class="hidden md:flex flex-nowrap items-center gap-0.5 min-w-0 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden" role="list">
    {sections.filter(s => s.slug !== '').map((s, i) => (
      <li
        data-nav-solution={s.solution ?? undefined}
        role="listitem"
        class="flex-shrink-0"
      >
        <a
          href={href(base, s.slug ? '/' + s.slug : '/')}
          class={[
            'block whitespace-nowrap px-2.5 py-1.5 text-xs font-medium rounded-sm transition-colors no-underline',
            isActive(s.slug)
              ? 'bg-[var(--accent-primary)]/15 text-[var(--accent-primary)] border border-[var(--accent-primary)]/30'
              : 'text-[var(--color-grigio-300)] hover:text-[var(--color-ghiaccio)] hover:bg-[var(--color-binario)]',
          ].join(' ')}
          aria-current={isActive(s.slug) ? 'page' : undefined}
        >
          <span class="text-[var(--color-grigio-500)] mr-1 tabular-nums">
            {String(i + 1).padStart(2, '0')}
          </span>
          {s.label}
        </a>
      </li>
    ))}
  </ol>

  <div class="flex items-center gap-3 flex-shrink-0">
    <span class="hidden 2xl:inline text-[0.65rem] tracking-widest uppercase text-[var(--color-grigio-500)] whitespace-nowrap">
      Live Pitch
    </span>
    <a
      href={href(base, '/admin')}
      class="text-[0.7rem] font-semibold tracking-wider uppercase px-3 py-1.5 border border-[var(--color-binario)] text-[var(--color-grigio-400)] hover:text-[var(--color-ghiaccio)] hover:border-[var(--color-grigio-500)] rounded-sm transition-colors no-underline"
      data-admin-only
    >
      Admin
    </a>
  </div>
</nav>
