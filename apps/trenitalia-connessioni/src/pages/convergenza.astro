---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const fontiDati = [
  { label: 'Adobe Analytics ×2',    node: 'AA', desc: 'Sito istituzionale + funnel acquisto Frecce' },
  { label: 'App Trenitalia',        node: 'AP', desc: 'Streaming events · notifiche · uso in-app' },
  { label: 'Oracle Responsys',      node: 'OR', desc: 'Open rate · risposta email · campagne CRM' },
  { label: 'Salesforce Data Cloud', node: 'SF', desc: 'Profili CRM · storico clienti' },
  { label: 'FS Park',               node: 'FP', desc: 'Parcheggio · accessi hub · segnali mobilità', rosso: true },
];

const fasiFase1 = [
  { fase: 'Fase 1', label: 'Convergenza analytics', desc: 'CJA unifica le due istanze Adobe Analytics. Prima vista end-to-end: dalla homepage al checkout, senza toccare l\'infrastruttura.' },
  { fase: 'Fase 2', label: 'Journey full-funnel', desc: 'Aggiunta app, Oracle Responsys (connettore AEP nativo), Salesforce Data Cloud via MuleSoft. Journey analysis cross-sistema.' },
  { fase: 'Fase 3', label: 'Attivazione & evoluzione', desc: 'RTCDP, AJO, Data Collaboration. Target esteso al funnel e all\'app. Data Collaboration FS Park × Trenitalia.', rosso: true },
];
---
<BaseLayout
  title="CJA: il layer di convergenza"
  description="Customer Journey Analytics connette le due istanze Adobe Analytics e tutti i sistemi — senza disruption, in fasi incrementali."
  pageSolutions={['cja']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/connessioni')}
    prevHref={href(base, '/fondazione')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center" data-solution="cja">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg"></div>
        <div class="fs-grid"></div>
      </div>
      <CoverHero
        eyebrow="03 · Customer Journey Analytics"
        numeral="03"
        title="CJA: il layer di convergenza"
        lead="Una vista unica del journey, senza migrare né dismettere nulla. CJA lavora sopra i sistemi che già avete e per la prima volta li fa parlare tra loro."
        size="phase"
        tone="ink"
        signature={false}
      />

      <!-- Le fonti come stazioni che convergono su un nodo unico -->
      <div class="relative w-full max-w-3xl mx-auto mt-9 mb-1" data-reveal data-reveal-delay="0.3">
        <div class="fs-line-h" style="top: 1.45rem; left: 8%; right: 8%;"></div>
        <div class="relative flex justify-between items-start px-[4%]">
          <div class="flex flex-col items-center gap-2.5 text-center">
            <span class="fs-node" data-active>AA</span>
            <span class="fs-node-label">Sistemi frammentati</span>
          </div>
          <div class="flex flex-col items-center gap-2.5 text-center">
            <span class="fs-node fs-node--rosso" data-active>CJA</span>
            <span class="fs-node-label">Il layer di convergenza</span>
          </div>
          <div class="flex flex-col items-center gap-2.5 text-center">
            <span class="fs-node" data-active>1</span>
            <span class="fs-node-label">Un journey leggibile</span>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: CJA come hub di convergenza ──────────────────── -->
    <Slide id="slide-convergenza" bg="primary" align="center" data-solution="cja">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg"></div>
        <div class="fs-grid"></div>
      </div>
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-primary)]/92"
      />
      <p class="fs-panel-tag text-center mb-4" data-reveal>
        COME FUNZIONA · CONNETTORI NATIVI, DATI SEMPRE IN AEP
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Tutte le fonti. Un'unica vista. Zero disruption.
      </h2>

      <div
        class="w-full max-w-6xl mx-auto grid grid-cols-[1fr_92px_1.15fr] gap-4 items-center"
        data-reveal
        data-reveal-delay="0.2"
      >
        <!-- Fonti dati : stazioni sulla linea -->
        <div class="flex flex-col gap-2">
          {fontiDati.map((f) => (
            <div class="flex items-center gap-3.5">
              <span class={`fs-node ${f.rosso ? 'fs-node--rosso' : ''} flex-shrink-0`} data-active style="width:2.5rem;height:2.5rem;font-size:0.82rem;">{f.node}</span>
              <div class="min-w-0 flex-1 text-left">
                <p class="text-[1.02rem] font-semibold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-tight">{f.label}</p>
                <p class="text-[0.88rem] text-[var(--color-grigio-200)] leading-snug">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CJA hub : il nodo di convergenza dove le linee si incontrano -->
        <div class="relative flex flex-col items-center justify-center h-full">
          <div class="absolute top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-[rgba(245,166,35,0.55)] to-transparent" aria-hidden="true"/>
          <span class="fs-node fs-node--rosso relative z-10" data-active style="width:3.6rem;height:3.6rem;font-size:0.78rem;font-weight:600;letter-spacing:0.04em;">CJA</span>
        </div>

        <!-- Output: journey unificato -->
        <div class="fs-panel fs-panel--rosso h-full flex flex-col justify-center">
          <p class="fs-panel-tag mb-4" style="color: rgba(226,0,26,0.98);">
            Vista Unificata del Journey
          </p>
          {[
            { label: 'Identità stitched', value: 'Davide Ferretti · CartaFreccia 4892-XX' },
            { label: 'Touchpoint risolti', value: '6 sistemi → 1 profilo journey' },
            { label: 'Journey completezza', value: 'Ricerca → Booking → App → Parcheggio' },
            { label: 'Cross-sell signal', value: 'Parcheggio ricorrente + abbonamento in scadenza' },
          ].map((a) => (
            <div class="mb-3 last:mb-0">
              <span class="block text-[0.76rem] text-[var(--color-grigio-300)] uppercase tracking-wide leading-tight mb-0.5">{a.label}</span>
              <span class="block text-[1.05rem] text-[var(--ink-primary)] leading-snug">{a.value}</span>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1b: CJA è / non è — disambiguazione ─────────────── -->
    <Slide id="slide-cja-vs-cdp" bg="secondary" align="center" data-solution="cja">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg-soft"></div>
        <div class="fs-grid"></div>
      </div>
      <p class="fs-panel-tag text-center mb-4" data-reveal>
        DISAMBIGUAZIONE · CJA ≠ CDP
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Cosa fa CJA — e cosa no.
      </h2>
      <p
        class="text-center text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-7"
        style="font-size: clamp(0.95rem, 1.1vw, 1.05rem);"
        data-reveal
        data-reveal-delay="0.12"
      >
        Chiarire il perimetro evita mesi di equivoci: CJA è il layer di analytics del journey,
        non la CDP operativa. Sono complementari.
      </p>

      <div class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-6" data-reveal data-reveal-delay="0.16">
        <div class="fs-panel text-left">
          <p class="text-[0.85rem] font-bold tracking-widest uppercase text-emerald-400 mb-4">CJA È · Analytics</p>
          <ul class="space-y-3.5 text-[1rem] text-[var(--color-grigio-200)] leading-snug">
            <li class="flex gap-3"><span class="text-emerald-400 flex-shrink-0 mt-px">✓</span>Legge e analizza il journey cross-sistema</li>
            <li class="flex gap-3"><span class="text-emerald-400 flex-shrink-0 mt-px">✓</span>Connette segnali da fonti diverse in un'unica timeline</li>
            <li class="flex gap-3"><span class="text-emerald-400 flex-shrink-0 mt-px">✓</span>Produce insight, segmenti e attribution</li>
          </ul>
        </div>
        <div class="fs-panel fs-panel--rosso text-left">
          <p class="text-[0.85rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-4">CJA NON È · non sostituisce una CDP</p>
          <ul class="space-y-3.5 text-[1rem] text-[var(--color-grigio-200)] leading-snug">
            <li class="flex gap-3"><span class="text-[var(--accent-primary)] flex-shrink-0 mt-px">✗</span>Non raccoglie profili operativi real-time (è RTCDP)</li>
            <li class="flex gap-3"><span class="text-[var(--accent-primary)] flex-shrink-0 mt-px">✗</span>Non invia campagne né messaggi (è AJO + Responsys)</li>
            <li class="flex gap-3"><span class="text-[var(--accent-primary)] flex-shrink-0 mt-px">✗</span>Non sostituisce Oracle Responsys né Salesforce CRM</li>
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Demo CJA Workspace ───────────────────────────── -->
    <Slide id="slide-demo-cja" bg="primary" align="center" data-solution="cja">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg"></div>
        <div class="fs-grid"></div>
      </div>
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="fs-panel-tag mb-4" data-reveal>
            ADOBE CUSTOMER JOURNEY ANALYTICS
          </p>
          <h2
            class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.75rem, 3.2vw, 2.9rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.08"
          >
            Il journey di Davide,<br/>visto per la prima volta.
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-normal max-w-2xl mb-5"
            style="font-size: clamp(0.95rem, 1.1vw, 1.05rem);"
            data-reveal
            data-reveal-delay="0.14"
          >
            CJA Workspace ricostruisce il percorso completo: ricerca su trenitalia.com,
            abbandono del funnel a metà checkout, ritorno da push app, prenotazione parcheggio
            FS Park, acquisto biglietto, viaggio, NPS post-arrivo. Tutto su una sola
            timeline, come non era mai stato possibile vederlo.
          </p>

          <div
            class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-3 mb-4"
            data-reveal
            data-reveal-delay="0.2"
          >
            {[
              { metric: '6→1', label: 'istanze analytics convergenti', sub: 'da 2 Analytics separati + 4 altre fonti' },
              { metric: '360°', label: 'vista del journey cliente', sub: 'dal primo click all\'uscita dal parcheggio' },
              { metric: '< 1h', label: 'time-to-insight', sub: 'query su miliardi di eventi in tempo reale' },
            ].map((m) => (
              <div class="fs-card text-center">
                <p class="fs-stat-value mb-1.5" style="font-size: clamp(2rem, 3.4vw, 2.9rem);">{m.metric}</p>
                <p class="fs-card-title mb-1" style="font-size: 0.98rem;">{m.label}</p>
                <p class="text-[0.82rem] text-[var(--color-grigio-300)] leading-snug">{m.sub}</p>
              </div>
            ))}
          </div>
          <p class="text-center fs-stat-src tracking-widest uppercase">
            Fonte: Adobe Customer Journey Analytics · benchmark Adobe 2024
          </p>
        </div>
        <MediaDemoSlot id="cja-workspace-demo" label="CJA Workspace — Demo FS Journey" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Content Analytics ────────────────────────────── -->
    <Slide id="slide-content-analytics" bg="secondary" align="center" data-solution="cja">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg-soft"></div>
        <div class="fs-grid"></div>
      </div>
      <p class="fs-panel-tag text-center mb-4" data-reveal>
        ADOBE CONTENT ANALYTICS · SU AEM
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.6vw, 2.4rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Quale contenuto converte davvero?
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-snug max-w-2xl mx-auto mb-6"
        style="font-size: clamp(0.95rem, 1.25vw, 1.15rem);"
        data-reveal
        data-reveal-delay="0.14"
      >
        Content Analytics — costruito su CJA e integrato con AEM — analizza le caratteristiche
        dei contenuti (formato, stile visivo, posizione, lunghezza) e le correla con engagement
        e conversione. Il team editoriale AEM ottimizza sui dati, non più a intuito.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.2"
      >
        {[
          {
            label: 'Attributi analizzati',
            rosso: false,
            items: [
              'Immagini: soggetto, colore, composizione',
              'Testo: tono, lunghezza, call-to-action',
              'Layout: posizione, gerarchia visiva',
              'Formato: video vs. carousel vs. hero static',
            ],
          },
          {
            label: 'Insight azionabili per AEM',
            rosso: true,
            items: [
              'Quali offerte homepage generano più click su funnel',
              'Quali CTA X-GO e CartaFreccia convertono meglio',
              'Stagionalità dei contenuti ad alto engagement',
              'A/B test guided da attributi, non solo da varianti manuali',
            ],
          },
        ].map((col) => (
          <div class="fs-panel text-left" class:list={[col.rosso && 'fs-panel--rosso']}>
            <p class="fs-panel-tag mb-3" style={col.rosso ? 'color: rgba(226,0,26,0.98);' : ''}>{col.label}</p>
            <ul class="space-y-1.5">
              {col.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.96rem] leading-tight text-[var(--color-grigio-200)]">
                  <span class={`flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full ${col.rosso ? 'bg-[var(--accent-primary)]' : 'bg-[rgba(245,166,35,0.95)]'}`} aria-hidden="true"/>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 4: Le 3 fasi ─────────────────────────────────────── -->
    <Slide id="slide-fasi" bg="primary" align="center" data-solution="cja">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg"></div>
        <div class="fs-grid"></div>
      </div>
      <!-- Prose (left) + phase stations on the line (right), title stays centred -->
      <div class="w-full max-w-6xl mx-auto grid md:grid-cols-[0.8fr_1.2fr] gap-8 items-center">
        <div class="text-left">
          <p class="fs-panel-tag mb-4" data-reveal>
            APPROCCIO GRADUALE · ZERO BIG BANG
          </p>
          <h2
            class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.6rem, 2.9vw, 2.6rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.08"
          >
            Tre fasi. Valore ad ogni passo.
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-snug"
            style="font-size: clamp(0.9rem, 1.1vw, 1.05rem);"
            data-reveal
            data-reveal-delay="0.14"
          >
            Nessun sistema viene dismesso. Ogni fase aggiunge intelligence e porta valore
            misurabile prima di passare alla successiva.
          </p>
        </div>

        <div
          class="relative w-full flex flex-col gap-3 pl-2"
          data-reveal
          data-reveal-delay="0.2"
        >
          <!-- vertical signal line threading the three phase-nodes -->
          <div class="absolute left-[1.05rem] top-4 bottom-4 w-px bg-gradient-to-b from-[rgba(245,166,35,0.9)] via-[rgba(245,166,35,0.4)] to-[rgba(226,0,26,0.6)]" aria-hidden="true"/>
          {fasiFase1.map((f, i) => (
            <div class="relative flex items-start gap-4">
              <span class={`fs-node ${f.rosso ? 'fs-node--rosso' : ''} relative z-10 flex-shrink-0`} data-active style="width:2.2rem;height:2.2rem;font-size:0.9rem;">{i + 1}</span>
              <div class="fs-card flex-1 min-w-0 text-left" class:list={[f.rosso && 'fs-panel--rosso']} style="padding: 0.85rem 1.1rem;">
                <div class="flex items-center gap-3 mb-1.5 flex-wrap">
                  <span class="fs-panel-tag" style={f.rosso ? 'color: rgba(226,0,26,0.98);' : ''}>{f.fase}</span>
                  <p class="fs-card-title" style="font-size: 1.1rem;">{f.label}</p>
                </div>
                <p class="fs-card-body" style="font-size: 0.98rem;">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <p class="mt-5 text-center fs-stat-src tracking-widest uppercase" data-reveal data-reveal-delay="0.3">
        Ipotesi di percorso per discussione — tempistiche da definire con FS Technology
      </p>

      <div class="mt-4 text-center" data-reveal data-reveal-delay="0.38">
        <a
          href={href(base, '/connessioni')}
          class="inline-flex items-center gap-3 px-8 py-3.5 text-base font-semibold tracking-wide bg-[var(--accent-primary)] text-white hover:opacity-90 transition-opacity duration-300 font-[family-name:var(--font-display)] rounded-sm"
        >
          Connessioni intelligenti: FS Park × Trenitalia
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
