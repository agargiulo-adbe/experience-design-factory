---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const fontiDati = [
  { label: 'Adobe Analytics #1',   icon: '📊', desc: 'Homepage · navigazione sito istituzionale' },
  { label: 'Adobe Analytics #2',   icon: '📊', desc: 'Funnel acquisto Frecce · comportamento booking' },
  { label: 'App Trenitalia',        icon: '📱', desc: 'Streaming events · notifiche · uso in-app' },
  { label: 'Oracle Responsys',      icon: '📧', desc: 'Risposta email · open rate · campagne CRM' },
  { label: 'Salesforce Data Cloud', icon: '☁️', desc: 'Profili CRM · storico clienti · Data Cloud' },
  { label: 'FS Park',               icon: '🅿️', desc: 'Prenotazioni parcheggio · accessi hub · segnali mobilità' },
];

const fasiFase1 = [
  { fase: 'Fase 1', label: 'Convergenza analytics', desc: 'CJA unifica le due istanze Adobe Analytics. Prima vista end-to-end: dalla homepage al checkout, senza toccare l\'infrastruttura.', colore: 'var(--accent-primary)' },
  { fase: 'Fase 2', label: 'Journey full-funnel', desc: 'Aggiunta app, Oracle Responsys (connettore AEP nativo), Salesforce Data Cloud via MuleSoft. Journey analysis cross-sistema.', colore: 'var(--accent-secondary)' },
  { fase: 'Fase 3', label: 'Attivazione & evoluzione', desc: 'RTCDP, AJO, Data Collaboration. Target esteso al funnel e all\'app. Data Collaboration FS Park × Trenitalia.', colore: 'var(--color-grigio-300)' },
];
---
<BaseLayout
  title="CJA: il layer di convergenza"
  description="Customer Journey Analytics connette le due istanze Adobe Analytics e tutti i sistemi — senza disruption, in fasi incrementali."
  pageSolutions={['cja']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/connessioni')}
    prevHref={href(base, '/fondazione')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center" data-solution="cja">
      <CoverHero
        eyebrow="03 · Customer Journey Analytics"
        numeral="03"
        title="CJA: il layer di convergenza"
        lead="Una vista unica del journey — senza migrare nulla, senza dismettere niente. CJA si posiziona sopra ogni sistema esistente e per la prima volta li fa parlare tra loro."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: CJA come hub di convergenza ──────────────────── -->
    <Slide id="slide-convergenza" bg="primary" align="center" data-solution="cja">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-primary)]/92"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>
        COME FUNZIONA
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(2rem, 3.8vw, 3.5rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Tutte le fonti. Un'unica vista. Zero disruption.
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-8"
        style="font-size: clamp(0.95rem, 1.25vw, 1.15rem);"
        data-reveal
        data-reveal-delay="0.14"
      >
        CJA ingerisce dati da ogni touchpoint via Adobe Experience Platform — connettori nativi
        per Oracle Responsys, Salesforce Data Cloud e gli Analytics esistenti. I dati non si
        spostano mai verso sistemi esterni: rimangono in AEP, sotto governance GDPR.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid grid-cols-[1fr_80px_1fr] gap-4 items-center"
        data-reveal
        data-reveal-delay="0.2"
      >
        <!-- Fonti dati -->
        <div class="flex flex-col gap-2">
          {fontiDati.map((f) => (
            <div class="flex items-center gap-3 p-3 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-sm text-[var(--ink-secondary)] text-left">
              <span class="text-lg flex-shrink-0" aria-hidden="true">{f.icon}</span>
              <div class="min-w-0 flex-1 text-left">
                <p class="text-xs font-semibold text-[var(--ink-primary)] font-[family-name:var(--font-display)]">{f.label}</p>
                <p class="text-xs text-[var(--ink-tertiary)] leading-snug">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CJA hub -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-px flex-1 bg-gradient-to-b from-transparent to-[var(--accent-primary)]" aria-hidden="true"/>
          <div class="w-16 h-16 rounded-full bg-[var(--accent-primary)] flex items-center justify-center flex-shrink-0 shadow-lg shadow-[var(--accent-primary)]/30">
            <span class="text-[0.55rem] font-bold text-white text-center leading-tight uppercase tracking-wider">CJA</span>
          </div>
          <div class="w-px flex-1 bg-gradient-to-b from-[var(--accent-primary)] to-transparent" aria-hidden="true"/>
        </div>

        <!-- Output: journey unificato -->
        <div class="p-5 bg-[var(--accent-primary)]/8 border border-[var(--accent-primary)]/25 rounded-sm h-full flex flex-col justify-center">
          <p class="text-xs font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-4">
            Vista Unificata del Journey
          </p>
          {[
            { label: 'Identità stitched', value: 'Marco Ferretti · CartaFreccia 4892-XX · app_user_9812' },
            { label: 'Touchpoint risolti', value: '6 sistemi → 1 profilo journey' },
            { label: 'Journey completezza', value: 'Ricerca sito → Booking → App → Parcheggio → Post-viaggio' },
            { label: 'Content performance', value: 'Quale contenuto AEM guida la conversione' },
            { label: 'Cross-sell signal', value: 'Parcheggio ricorrente + abbonamento in scadenza → opportunità' },
          ].map((a) => (
            <div class="mb-3 last:mb-0">
              <span class="block text-[0.65rem] text-[var(--ink-tertiary)] uppercase tracking-wide mb-0.5">{a.label}</span>
              <span class="text-xs text-[var(--ink-primary)] leading-snug">{a.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- CJA ≠ CDP — disambiguazione proattiva -->
      <div class="mt-8 w-full max-w-4xl mx-auto p-4 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] border-l-2 border-l-[var(--accent-secondary)] rounded-sm" data-reveal data-reveal-delay="0.3">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-1.5">CJA È · Analytics</p>
            <ul class="space-y-1 text-xs text-[var(--ink-secondary)]">
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">✓</span>Legge e analizza il journey cross-sistema</li>
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">✓</span>Connette segnali da fonti diverse in un'unica timeline</li>
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">✓</span>Produce insight, segmenti, attribution</li>
            </ul>
          </div>
          <div>
            <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-1.5">CJA NON È · non sostituisce una CDP</p>
            <ul class="space-y-1 text-xs text-[var(--ink-secondary)]">
              <li class="flex gap-2"><span class="text-[var(--accent-primary)] flex-shrink-0">✗</span>Non raccoglie profili operativi real-time (quello è RTCDP)</li>
              <li class="flex gap-2"><span class="text-[var(--accent-primary)] flex-shrink-0">✗</span>Non invia campagne né messaggi (quello è AJO + Responsys)</li>
              <li class="flex gap-2"><span class="text-[var(--accent-primary)] flex-shrink-0">✗</span>Non sostituisce Oracle Responsys né Salesforce CRM</li>
            </ul>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Demo CJA Workspace ───────────────────────────── -->
    <Slide id="slide-demo-cja" bg="primary" align="center" data-solution="cja">
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col items-center">
          <p class="slide-eyebrow text-[var(--accent-primary)] mb-5" data-reveal>
            ADOBE CUSTOMER JOURNEY ANALYTICS
          </p>
          <h2
            class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
            style="font-size: clamp(2rem, 3.8vw, 3.5rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.08"
          >
            Il journey di Marco,<br/>visto per la prima volta.
          </h2>
          <p
            class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mb-8"
            style="font-size: clamp(0.95rem, 1.25vw, 1.15rem);"
            data-reveal
            data-reveal-delay="0.14"
          >
            CJA Workspace ricostruisce il percorso completo: ricerca su trenitalia.com,
            abbandono del funnel a metà checkout, ritorno da push app, prenotazione parcheggio
            FS Park, acquisto biglietto, viaggio, NPS post-arrivo. Tutto su una sola
            timeline — per la prima volta nella storia del Gruppo.
          </p>

          <div
            class="w-full max-w-4xl mx-auto grid md:grid-cols-3 gap-4 mb-6"
            data-reveal
            data-reveal-delay="0.2"
          >
            {[
              { metric: '6→1', label: 'istanze analytics convergenti', sub: 'da 2 Analytics separati + 4 altre fonti' },
              { metric: '360°', label: 'vista del journey cliente', sub: 'dal primo click all\'uscita dal parcheggio' },
              { metric: '< 1h', label: 'time-to-insight', sub: 'query su miliardi di eventi in tempo reale' },
            ].map((m) => (
              <div class="text-center p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
                <p class="data-number text-[var(--accent-primary)] mb-1">{m.metric}</p>
                <p class="text-sm font-medium text-[var(--ink-primary)] font-[family-name:var(--font-display)] mb-0.5">{m.label}</p>
                <p class="text-xs text-[var(--ink-tertiary)]">{m.sub}</p>
              </div>
            ))}
          </div>
          <p class="text-center text-[0.62rem] tracking-widest uppercase text-[var(--color-grigio-300)]">
            Fonte: Adobe Customer Journey Analytics · benchmark Adobe 2024
          </p>
        </div>
        <MediaDemoSlot id="cja-workspace-demo" label="CJA Workspace — Demo FS Journey" />
      </div>
    </Slide>

    <!-- ── SLIDE 3: Content Analytics ────────────────────────────── -->
    <Slide id="slide-content-analytics" bg="secondary" align="center" data-solution="cja">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-5" data-reveal>
        ADOBE CONTENT ANALYTICS · SU AEM
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
        style="font-size: clamp(2rem, 3.8vw, 3.5rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Quale contenuto<br/>guida davvero la conversione?
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-8"
        style="font-size: clamp(0.95rem, 1.25vw, 1.15rem);"
        data-reveal
        data-reveal-delay="0.14"
      >
        Content Analytics — costruito su CJA e integrato con AEM — analizza le caratteristiche
        dei contenuti (formato, stile visivo, posizione, lunghezza) e le correla con engagement
        e conversione. Il team editoriale AEM smette di ottimizzare per l'intuizione
        e inizia a ottimizzare per i dati.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid md:grid-cols-2 gap-5"
        data-reveal
        data-reveal-delay="0.2"
      >
        {[
          {
            label: 'Attributi analizzati',
            items: [
              'Immagini: soggetto, colore, composizione',
              'Testo: tono, lunghezza, call-to-action',
              'Layout: posizione, gerarchia visiva',
              'Formato: video vs. carousel vs. hero static',
            ],
          },
          {
            label: 'Insight azionabili per AEM',
            items: [
              'Quali offerte homepage generano più click su funnel',
              'Quali CTA X-GO e CartaFreccia convertono meglio',
              'Stagionalità dei contenuti ad alto engagement',
              'A/B test guided da attributi, non solo da varianti manuali',
            ],
          },
        ].map((col) => (
          <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-xs font-bold tracking-widest uppercase text-[var(--accent-secondary)] mb-4">{col.label}</p>
            <ul class="space-y-2">
              {col.items.map((item) => (
                <li class="flex items-start gap-2 text-sm text-[var(--ink-secondary)]">
                  <span class="flex-shrink-0 mt-1.5 w-1 h-1 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 4: Le 3 fasi ─────────────────────────────────────── -->
    <Slide id="slide-fasi" bg="primary" align="center" data-solution="cja">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-5" data-reveal>
        APPROCCIO GRADUALE · ZERO BIG BANG
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(2rem, 3.8vw, 3.5rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Tre fasi. Valore ad ogni passo.
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-8"
        style="font-size: clamp(0.95rem, 1.25vw, 1.15rem);"
        data-reveal
        data-reveal-delay="0.14"
      >
        Nessun sistema viene dismesso. Ogni fase aggiunge intelligence — e porta valore
        misurabile prima di passare alla successiva.
      </p>

      <div
        class="w-full max-w-4xl mx-auto flex flex-col gap-4"
        data-reveal
        data-reveal-delay="0.2"
      >
        {fasiFase1.map((f) => (
          <div class="flex items-start gap-5 p-5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <div class="flex flex-col items-center gap-2 flex-shrink-0">
              <div class="w-2 h-2 rounded-full" style={`background: ${f.colore};`} aria-hidden="true"/>
              <div class="w-px flex-1" style={`background: ${f.colore}; opacity: 0.25;`} aria-hidden="true"/>
            </div>
            <div class="flex-1 min-w-0 text-left">
              <div class="flex items-center gap-3 mb-1 flex-wrap">
                <span class="text-[0.6rem] font-bold tracking-widest uppercase px-2 py-0.5 rounded-sm" style={`color: ${f.colore}; background: color-mix(in srgb, ${f.colore} 12%, transparent);`}>
                  {f.fase}
                </span>
                <p class="text-sm font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)]">{f.label}</p>
              </div>
              <p class="text-sm text-[var(--ink-secondary)] leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-5 text-center text-[0.6rem] tracking-widest uppercase text-[var(--color-grigio-300)]" data-reveal data-reveal-delay="0.3">
        Ipotesi di percorso per discussione — tempistiche da definire con FS Technology
      </p>

      <div class="mt-6" data-reveal data-reveal-delay="0.38">
        <a
          href={href(base, '/connessioni')}
          class="inline-flex items-center gap-3 px-8 py-4 text-base font-semibold tracking-wide bg-[var(--accent-primary)] text-white hover:opacity-90 transition-opacity duration-300 font-[family-name:var(--font-display)]"
        >
          Connessioni intelligenti: FS Park × Trenitalia
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
