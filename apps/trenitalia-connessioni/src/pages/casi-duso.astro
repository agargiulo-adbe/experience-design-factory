---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// ── I 3 casi core, riepilogati in dettaglio (dalla sezione Connessioni) ──
const coreCases = [
  {
    tag: 'Caso 01 · Abbonamento',
    title: 'Il pendolare che non sa ancora di voler rinnovare',
    persona: 'Marco',
    scenario: 'Abbonamento mensile Frecce Milano–Roma. Negli ultimi 14 giorni i viaggi calano del 40%: CJA rileva l\'anomalia 18 giorni prima della scadenza, molto prima della classica email di rinnovo Responsys.',
    segnale: 'Frequenza viaggi –40% in 14 gg + apertura email CartaFreccia scesa al 12% (vs 35% media)',
    azione: 'Responsys invia un\'offerta di rinnovo personalizzata; AJO sceglie canale e timing ottimali (push app se mobile, email se desktop) nel momento di massima propensione.',
    prodotti: ['CJA', 'RT-CDP', 'AJO', 'Oracle Responsys'],
    impatto: '+22% rinnovo abbonamenti su early trigger vs campagne batch',
    colore: 'var(--accent-primary)',
  },
  {
    tag: 'Caso 02 · FS Park × Trenitalia',
    title: 'Il parcheggio come leva di cross-sell',
    persona: 'Marco',
    scenario: 'Marco prenota un Frecciarossa e 3 ore dopo cerca "parcheggio Milano Centrale" senza convertire. Oggi FS Park e Trenitalia non comunicano: paga un parcheggio concorrente su un\'app terza.',
    segnale: 'Ricerca parcheggio post-booking + 0 conversioni FS Park nel 90-day window',
    azione: 'Clean room di Data Collaboration: FS Park riceve il segnale d\'interesse senza mai vedere l\'identità di Marco. Bundle parcheggio + biglietto in-app, 20% sul primo utilizzo.',
    prodotti: ['CJA', 'Data Collaboration', 'AJO'],
    impatto: '€ 8–15 di ricavo accessorio per viaggio · 0% infrastruttura · GDPR-safe',
    colore: 'var(--accent-secondary)',
  },
  {
    tag: 'Caso 03 · Loyalty Frecce',
    title: 'Dalla singola tratta alla relazione',
    persona: 'Sofia',
    scenario: 'Sofia prenota in business 3 volte al mese, senza abbonamento né CartaFreccia. CJA la classifica come "alto LTV latente" su frequenza × ticket × canale — ma nessun sistema oggi la riconosce.',
    segnale: 'Frequenza ≥ 3 viaggi/mese × ticket medio > €80 × 0 loyalty card',
    azione: 'Onboarding CartaFreccia personalizzato: "Viaggi già regolarmente — i tuoi punti ti stanno aspettando." Accumulo retroattivo sugli ultimi 3 acquisti.',
    prodotti: ['CJA', 'RT-CDP', 'Oracle Responsys'],
    impatto: 'Conversione in loyalty member di clienti alto-valore oggi non tracciati',
    colore: 'var(--color-grigio-300)',
  },
];

// ── Da esplorare insieme — nuovi casi d'uso, per tema ──────────────
// Struttura: scenario / segnale / azione / impatto (da validare sul campo)
const explore = {
  retention: [
    {
      title: 'Service recovery da infomobilità',
      scenario: 'Un cliente Frecce subisce un ritardo > 30 min. CJA rileva l\'evento in real-time tramite il segnale infomobilità — prima ancora che il cliente apra l\'app o si lamenti.',
      segnale: 'Evento ritardo > 30 min su treno prenotato + profilo cliente attivo in CJA',
      azione: 'AJO attiva journey di recovery proattivo: notifica con scuse, opzione rebooking assistito, bonus punti CartaFreccia e 1 ora FS Park in omaggio — tutto automatico, canale preferito.',
      impatto: 'Il disservizio diventa un momento di loyalty. Atteso: riduzione reclami post-ritardo e churn associato — KPI da validare sul campo.',
      capability: ['CJA (evento disservizio)', 'AJO real-time', 'Oracle Responsys / push'],
    },
    {
      title: 'Churn prevention abbonamenti',
      scenario: 'Un abbonato mensile Frecce mostra segnali di disengagement nei 30 giorni pre-scadenza: frequenza in calo, email non aperte, accessi app ridotti.',
      segnale: 'Frequenza viaggi –30% + open rate email <15% + login app ridotto nei 30 gg pre-scadenza',
      azione: 'RT-CDP e AJO attivano un journey di retention mirato: offerta personalizzata, canale ottimale, timing di massima propensione. Estende il Caso 01 con modello predittivo AI.',
      impatto: 'Retention proattiva invece di win-back reattivo. Atteso: incremento rinnovi anticipati — KPI da validare.',
      capability: ['CJA', 'RT-CDP', 'AJO', 'AI predittiva'],
    },
    {
      title: 'NPS closed-loop',
      scenario: 'I sondaggi NPS raccolgono feedback 2×/mese. Oggi restano come report statici: né i detrattori né i promotori ricevono follow-up automatizzato.',
      segnale: 'Risposta NPS < 6 (detractor) o > 8 (promoter) + profilo attivo in CJA',
      azione: 'AJO: journey recovery per detrattori (ascolto, compenso, escalation); journey advocacy per promotori (referral CartaFreccia). Il feedback smette di essere inerte.',
      impatto: 'Chiude il cerchio sui sondaggi già raccolti. Atteso: miglioramento NPS e riduzione abbandono tra detrattori — KPI da validare.',
      capability: ['CJA (evento feedback)', 'AJO', 'Oracle Responsys'],
    },
  ],
  growth: [
    {
      title: 'Funnel giovani X-GO',
      scenario: 'Gli under-30 acquistano carnet o biglietti singoli ripetutamente ma non passano all\'abbonamento X-GO. Il segmento ha alta frequenza d\'acquisto ma LTV sottoutilizzato.',
      segnale: 'Età < 30 + acquisto carnet ≥ 2 in 60 gg + 0 abbonamenti X-GO attivi',
      azione: 'Journey app-first e gamificato: nudge sui punti accumulati, sfide di frequenza, offerta tempo-limitata abbonamento X-GO con vantaggi visibili in-app. GenStudio produce le varianti creative.',
      impatto: 'Conversione carnet→abbonamento. Atteso: incremento LTV segmento youth, oggi under-served — KPI da validare.',
      capability: ['CJA', 'RT-CDP', 'AJO', 'Adobe Target', 'GenStudio'],
    },
    {
      title: 'Corporate & business travel',
      scenario: 'Sofia prenota in business 3 volte al mese senza abbonamento né CartaFreccia. CJA la classifica come "alto LTV latente" su frequenza × ticket medio × canale — ma nessun sistema la riconosce come tale oggi.',
      segnale: 'Frequenza ≥ 3 viaggi/mese × ticket medio >€80 × 0 loyalty card × 0 corporate account',
      azione: 'Journey account-based con RTCDP: invito personalizzato a CartaFreccia Business, proposta Frecce Corporate, riconoscimento del valore storico. Canale: email + LinkedIn (B2B).',
      impatto: 'Monetizza il segmento business ad alto valore. Atteso: incremento conversioni CartaFreccia Business — KPI da validare.',
      capability: ['CJA (LTV latente)', 'RT-CDP', 'AJO'],
    },
    {
      title: 'Bundle mobilità cross-brand',
      scenario: 'Oltre FS Park: un cliente prenota Frecce e in passato ha usato bike sharing o bus. CJA vede il pattern multi-modale — ma il Gruppo non lo connette a partner last-mile.',
      segnale: 'Booking Frecce + pattern mobilità multi-modale storico + area geografica di arrivo',
      azione: 'Data Collaboration con partner last-mile (bus, micro-mobility, hotel): bundle porta-a-porta attivato senza scambio di PII tra enti. Attribuzione misurabile cross-brand.',
      impatto: 'Ecosistema FS esteso: ricavo accessorio oltre FS Park. Esperienza door-to-door misurabile — KPI da validare.',
      capability: ['Data Collaboration', 'CJA (attribution)', 'AJO'],
    },
  ],
  intelligence: [
    {
      title: 'Content intelligence su AEM',
      scenario: 'Il team editoriale pubblica decine di varianti ogni settimana senza sapere quale formato, CTA o immagine guida davvero il booking su trenitalia.com.',
      segnale: 'Attributi contenuto AEM (formato, CTA, layout) correlati a dati CJA di engagement e conversione',
      azione: 'Content Analytics identifica i pattern ad alto impatto; il team AEM ottimizza su dati. A/B test guidati da attributi, non solo varianti manuali.',
      impatto: 'Ottimizzazione editoriale data-driven. Atteso: incremento conversioni organiche da sito — KPI da validare.',
      capability: ['Content Analytics', 'CJA', 'AEM'],
    },
    {
      title: 'Media mix & budget what-if',
      scenario: 'FS investe in campagna TV estiva per X-GO + paid digital + email Responsys senza poter misurare il reale contributo incrementale di ciascun canale né l\'effetto halo.',
      segnale: 'Dati spesa media per canale + CJA multi-touch + conversioni per campagna',
      azione: 'Mix Modeler simula scenari what-if: quanti biglietti/abbonamenti spostando €X da TV a digital? Raccomandazione automatica con Causal AI — non solo correlazione.',
      impatto: 'ROI media ottimizzato e decisioni di budget causali. Già nella Roadmap Fase 3 — KPI da validare.',
      capability: ['Mix Modeler', 'CJA (multi-touch)'],
    },
  ],
};
---
<BaseLayout
  title="Casi d'uso · recap e da esplorare"
  description="Riepilogo dei tre casi d'uso core e una mappa estesa di ulteriori casi d'uso FS × Adobe da esplorare insieme."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/')}
    prevHref={href(base, '/roadmap')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <CoverHero
        eyebrow="06 · Casi d'uso"
        numeral="06"
        title="Undici scenari di valore, un'unica fondazione."
        lead="Scenari illustrativi, tutti calati sul Gruppo FS — dalla retention al cross-sell d'ecosistema. La stessa fondazione CJA + RT-CDP li abilita tutti."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Recap dei 3 casi core ─────────────────────────── -->
    <Slide id="slide-recap" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>Tre journey, in dettaglio</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-2 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.7vw, 2.2rem);"
        data-reveal data-reveal-delay="0.08"
      >
        Tre scenari raccontati end-to-end.
      </h2>

      <div class="w-full max-w-6xl mx-auto flex flex-col gap-1" data-reveal data-reveal-delay="0.16">
        {coreCases.map((uc) => (
          <div class="px-3.5 py-0.5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 max-w-[15rem]">
                <p class="text-[0.6rem] font-bold tracking-widest uppercase mb-0.5" style={`color: ${uc.colore};`}>{uc.tag}</p>
                <h3 class="text-base font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-tight mb-0.5">{uc.title}</h3>
                <div class="flex flex-wrap gap-1">
                  {uc.prodotti.map((p) => (
                    <span class="text-[0.58rem] font-semibold px-1.5 py-0.5 rounded-sm bg-[var(--surface-tertiary)] text-[var(--ink-secondary)]">{p}</span>
                  ))}
                </div>
              </div>
              <div class="flex-1 grid md:grid-cols-3 gap-x-2 gap-y-0 text-[0.55rem] leading-none text-[var(--ink-secondary)]">
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">SCENARIO</p>
                  <p class="leading-tight">{uc.scenario}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">SEGNALE CJA</p>
                  <p class="leading-tight">{uc.segnale}</p>
                  <div class="mt-1 pt-1 border-t border-[var(--line-subtle)]">
                    <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">AZIONE</p>
                    <p class="leading-tight">{uc.azione}</p>
                  </div>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">IMPATTO ATTESO</p>
                  <p class="leading-tight font-semibold text-[var(--ink-primary)]">{uc.impatto}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2: Da esplorare · Retention & Loyalty ────────────── -->
    <Slide id="slide-explore-retention" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>Altri scenari · Retention &amp; Loyalty</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-2 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.7vw, 2.2rem);"
        data-reveal data-reveal-delay="0.08"
      >
        Retention & Loyalty
      </h2>
      <p class="text-center text-[0.66rem] leading-tight text-[var(--ink-secondary)] max-w-2xl mx-auto mb-1.5" data-reveal data-reveal-delay="0.12">
        Trattenere vale più che riacquisire. La stessa fondazione che anticipa il rinnovo anticipa anche il disservizio, la disdetta e il malcontento.
      </p>
      <div class="w-full max-w-6xl mx-auto flex flex-col gap-1" data-reveal data-reveal-delay="0.18">
        {explore.retention.map((c) => (
          <div class="px-3.5 py-0.5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 max-w-[10.5rem]">
                <h3 class="text-base font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-tight mb-0.5">{c.title}</h3>
                <div class="flex flex-wrap gap-1">
                  {c.capability.map((cap) => (
                    <span class="text-[0.58rem] font-semibold px-1.5 py-0.5 rounded-sm bg-[var(--surface-tertiary)] text-[var(--ink-secondary)]">{cap}</span>
                  ))}
                </div>
              </div>
              <div class="flex-1 grid md:grid-cols-4 gap-x-2 gap-y-0 text-[0.55rem] leading-none text-[var(--ink-secondary)]">
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">SCENARIO</p>
                  <p class="leading-tight">{c.scenario}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">SEGNALE CJA</p>
                  <p class="leading-tight">{c.segnale}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">AZIONE</p>
                  <p class="leading-tight">{c.azione}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">IMPATTO ATTESO</p>
                  <p class="leading-tight font-semibold text-[var(--ink-primary)]">{c.impatto}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: Da esplorare · Acquisition & Ecosystem ────────── -->
    <Slide id="slide-explore-growth" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>Altri scenari · Acquisition &amp; Ecosystem</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-2 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.7vw, 2.2rem);"
        data-reveal data-reveal-delay="0.08"
      >
        Acquisition & Ecosystem
      </h2>
      <p class="text-center text-[0.66rem] leading-tight text-[var(--ink-secondary)] max-w-2xl mx-auto mb-1.5" data-reveal data-reveal-delay="0.12">
        Crescere sui segmenti giusti — giovani, business — ed estendere il valore oltre il treno, dentro l'intero ecosistema di mobilità FS.
      </p>
      <div class="w-full max-w-6xl mx-auto flex flex-col gap-1" data-reveal data-reveal-delay="0.18">
        {explore.growth.map((c) => (
          <div class="px-3.5 py-0.5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 max-w-[10.5rem]">
                <h3 class="text-base font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-tight mb-0.5">{c.title}</h3>
                <div class="flex flex-wrap gap-1">
                  {c.capability.map((cap) => (
                    <span class="text-[0.58rem] font-semibold px-1.5 py-0.5 rounded-sm bg-[var(--surface-tertiary)] text-[var(--ink-secondary)]">{cap}</span>
                  ))}
                </div>
              </div>
              <div class="flex-1 grid md:grid-cols-4 gap-x-2 gap-y-0 text-[0.55rem] leading-none text-[var(--ink-secondary)]">
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">SCENARIO</p>
                  <p class="leading-tight">{c.scenario}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">SEGNALE CJA</p>
                  <p class="leading-tight">{c.segnale}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">AZIONE</p>
                  <p class="leading-tight">{c.azione}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-0.5">IMPATTO ATTESO</p>
                  <p class="leading-tight font-semibold text-[var(--ink-primary)]">{c.impatto}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 4: Da esplorare · Intelligence & Optimization ────── -->
    <Slide id="slide-explore-intelligence" bg="primary" align="center">
      <p class="slide-eyebrow text-center text-[var(--color-grigio-300)] mb-4" data-reveal>Altri scenari · Intelligence &amp; Optimization</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-2 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.7vw, 2.2rem);"
        data-reveal data-reveal-delay="0.08"
      >
        Intelligence & Optimization
      </h2>
      <p class="text-center text-[0.66rem] leading-tight text-[var(--ink-secondary)] max-w-2xl mx-auto mb-1.5" data-reveal data-reveal-delay="0.12">
        Quando la fondazione è solida, i dati non descrivono soltanto: ottimizzano contenuti e budget, e rendono causale ciò che oggi è correlazionale.
      </p>
      <div class="w-full max-w-6xl mx-auto flex flex-col gap-8" data-reveal data-reveal-delay="0.18">
        {explore.intelligence.map((c) => (
          <div class="px-4 py-4 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 max-w-[11rem]">
                <h3 class="text-base font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-snug mb-2">{c.title}</h3>
                <div class="flex flex-wrap gap-1">
                  {c.capability.map((cap) => (
                    <span class="text-[0.58rem] font-semibold px-1.5 py-0.5 rounded-sm bg-[var(--surface-tertiary)] text-[var(--ink-secondary)]">{cap}</span>
                  ))}
                </div>
              </div>
              <div class="flex-1 grid md:grid-cols-4 gap-x-3 gap-y-1.5 text-[0.66rem] leading-snug text-[var(--ink-secondary)]">
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-1">SCENARIO</p>
                  <p class="leading-snug">{c.scenario}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-1">SEGNALE CJA</p>
                  <p class="leading-snug">{c.segnale}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-1">AZIONE</p>
                  <p class="leading-snug">{c.azione}</p>
                </div>
                <div>
                  <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--ink-tertiary)] mb-1">IMPATTO ATTESO</p>
                  <p class="leading-snug font-semibold text-[var(--ink-primary)]">{c.impatto}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 5: Sintesi + invito ──────────────────────────────── -->
    <Slide id="slide-sintesi" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-binari')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-secondary)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>Una fondazione, molti casi d'uso</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.9rem, 3.6vw, 3rem); max-width: 60rem;"
        data-reveal data-reveal-delay="0.08"
      >
        Undici scenari. Un'unica fondazione dati.
      </h2>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 mb-7" data-reveal data-reveal-delay="0.16">
        {[
          { n: '11', l: 'Scenari illustrativi', s: 'Ancorati al mondo FS: Frecce · CartaFreccia · FS Park · X-GO' },
          { n: '4', l: 'Aree di valore', s: 'Retention · Growth · Ecosystem · Intelligence' },
          { n: '1', l: 'Fondazione condivisa', s: 'Ogni scenario riusa CJA + RT-CDP' },
          { n: '100%', l: 'GDPR-compliant', s: 'Clean room · governance dati' },
        ].map((m) => (
          <div class="p-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-2" style="font-size: clamp(1.6rem, 2.6vw, 2.2rem);">{m.n}</p>
            <p class="text-xs font-bold text-[var(--ink-primary)] leading-tight mb-1">{m.l}</p>
            <p class="text-[0.68rem] text-[var(--ink-tertiary)] leading-tight">{m.s}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-base text-[var(--ink-secondary)] max-w-2xl mx-auto" data-reveal data-reveal-delay="0.24">
        Sono scenari di ispirazione, non promesse di numeri — calati sul Gruppo FS. Scegliamo insieme quali prototipare per primi: la fondazione è la stessa, il valore è cumulativo.
      </p>
    </Slide>

  </DeckContainer>
</BaseLayout>
