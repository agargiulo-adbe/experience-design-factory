---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// ── I 3 casi core, riepilogati in dettaglio (dalla sezione Connessioni) ──
const coreCases = [
  {
    tag: 'Caso 01 · Rinnovo',
    title: 'Il rinnovo che si anticipa',
    persona: 'Davide',
    scenario: 'Abbonamento mensile Frecce Milano–Roma: in 14 giorni i viaggi calano del 40%. CJA coglie l\'anomalia 18 giorni prima della scadenza.',
    segnale: 'Viaggi –40% in 14 gg + apertura email CartaFreccia al 12% (vs 35%).',
    azione: 'Responsys invia l\'offerta di rinnovo; AJO sceglie canale e timing al picco di propensione.',
    recap: 'Viaggi –40% in 14 giorni: CJA coglie l\'anomalia 18 giorni prima della scadenza. Responsys e AJO attivano il rinnovo al momento giusto.',
    prodotti: ['CJA', 'RT-CDP', 'AJO'],
    impatto: '+22% rinnovi su early trigger.',
    colore: 'var(--accent-primary)',
  },
  {
    tag: 'Caso 02 · Cross-sell',
    title: 'Il parcheggio come cross-sell',
    persona: 'Davide',
    scenario: 'Davide prenota un Frecciarossa, poi cerca "parcheggio Milano Centrale" senza convertire. FS Park e Trenitalia non si parlano.',
    segnale: 'Ricerca parcheggio post-booking + 0 conversioni FS Park in 90 giorni.',
    azione: 'Clean room Data Collaboration: FS Park riceve il segnale senza vedere l\'identità. Bundle parcheggio + biglietto, –20%.',
    recap: 'Cerca parcheggio dopo il booking, ma FS Park e Trenitalia non si parlano. Clean room Data Collaboration: bundle parcheggio + biglietto.',
    prodotti: ['CJA', 'Data Collab.', 'AJO'],
    impatto: '€ 8–15 di ricavo accessorio per viaggio · GDPR-safe.',
    colore: 'var(--accent-secondary)',
  },
  {
    tag: 'Caso 03 · Loyalty',
    title: 'Dalla tratta alla relazione',
    persona: 'Elena',
    scenario: 'Elena viaggia in business 3 volte al mese, senza abbonamento né CartaFreccia. CJA la vede come "alto LTV latente" — nessun sistema la riconosce.',
    segnale: 'Frequenza ≥ 3 viaggi/mese × ticket medio > €80 × 0 loyalty card.',
    azione: 'Onboarding CartaFreccia mirato con accumulo retroattivo sugli ultimi 3 acquisti.',
    recap: 'Business 3×/mese senza loyalty card: CJA la legge come "alto LTV latente". Onboarding CartaFreccia con accumulo retroattivo.',
    prodotti: ['CJA', 'RT-CDP', 'Responsys'],
    impatto: 'Clienti alto-valore non tracciati diventano loyalty member.',
    colore: 'var(--color-grigio-300)',
  },
];

// ── Da esplorare insieme — nuovi casi d'uso, in coppie tematiche ──
// 8 scenari su 4 slide (2 per slide): situazione / risposta Adobe / impatto atteso.
const cRecovery = {
  title: 'Service recovery da infomobilità',
  situazione: 'Un cliente Frecce subisce un ritardo > 30 min. CJA rileva l\'evento in real-time, prima ancora che se ne accorga.',
  risposta: 'AJO attiva un recovery proattivo: scuse, rebooking assistito, bonus CartaFreccia e 1 ora FS Park.',
  impatto: 'Meno reclami e churn — da validare.',
  capability: ['CJA', 'AJO real-time', 'Responsys'],
};
const cChurn = {
  title: 'Churn prevention abbonamenti',
  situazione: 'Un abbonato mensile mostra disengagement pre-scadenza: viaggi in calo, email non aperte, meno accessi app.',
  risposta: 'RT-CDP e AJO attivano un journey di retention: offerta, canale e timing ottimali, con AI predittiva.',
  impatto: 'Retention proattiva, non win-back reattivo — da validare.',
  capability: ['CJA', 'RT-CDP', 'AJO'],
};
const cNps = {
  title: 'NPS closed-loop',
  situazione: 'I sondaggi NPS raccolgono feedback 2×/mese, ma restano report statici: nessun follow-up automatizzato.',
  risposta: 'AJO: recovery per i detrattori (ascolto, compenso), advocacy per i promotori (referral CartaFreccia).',
  impatto: 'NPS migliore e meno abbandono tra i detrattori — da validare.',
  capability: ['CJA', 'AJO', 'Responsys'],
};
const cYouth = {
  title: 'Funnel giovani X-GO',
  situazione: 'Gli under-30 comprano carnet ripetuti ma non passano all\'abbonamento X-GO: alta frequenza, LTV sottoutilizzato.',
  risposta: 'Journey app-first gamificato: nudge sui punti, sfide di frequenza, offerta X-GO a tempo. GenStudio crea le varianti.',
  impatto: 'Conversione carnet → abbonamento, più LTV youth — da validare.',
  capability: ['CJA', 'RT-CDP', 'AJO', 'GenStudio'],
};
const cCorporate = {
  title: 'Corporate & business travel',
  situazione: 'Elena viaggia in business 3×/mese senza loyalty card. Oggi nessun sistema la vede; CJA la legge come "alto LTV latente".',
  risposta: 'Journey account-based con RTCDP: invito a CartaFreccia Business e Frecce Corporate. Canale email + LinkedIn.',
  impatto: 'Monetizza il segmento business ad alto valore — da validare.',
  capability: ['CJA', 'RT-CDP', 'AJO'],
};
const cBundle = {
  title: 'Bundle mobilità cross-brand',
  situazione: 'Un cliente prenota Frecce e ha usato bus o bike sharing. CJA vede il pattern, ma manca il link ai partner last-mile.',
  risposta: 'Data Collaboration con partner last-mile: bundle porta-a-porta senza scambio di PII. Attribuzione cross-brand.',
  impatto: 'Ricavo accessorio oltre FS Park, viaggio door-to-door — da validare.',
  capability: ['Data Collab.', 'CJA', 'AJO'],
};
const cContent = {
  title: 'Content intelligence su AEM',
  situazione: 'Il team editoriale pubblica decine di varianti a settimana senza sapere quale formato o CTA guida il booking su trenitalia.com.',
  risposta: 'Content Analytics identifica i pattern ad alto impatto; il team AEM ottimizza sui dati. A/B test guidati da attributi.',
  impatto: 'Più conversioni organiche da sito — da validare.',
  capability: ['Content Analytics', 'CJA', 'AEM'],
};
const cMediaMix = {
  title: 'Media mix & budget what-if',
  situazione: 'FS investe in TV estiva + paid digital + email Responsys senza misurare il contributo reale di ogni canale.',
  risposta: 'Mix Modeler simula scenari what-if: quanti biglietti spostando €X da TV a digital? Raccomandazione con Causal AI.',
  impatto: 'ROI media ottimizzato, budget causale (Roadmap Fase 3) — da validare.',
  capability: ['Mix Modeler', 'CJA'],
};

const exploreSlides = [
  { id: 'slide-explore-retention',    eyebrow: 'Altri scenari · Retention & Loyalty',  eyebrowColor: 'var(--accent-primary)',   title: 'Retention & Loyalty',      accent: 'var(--accent-primary)',   cards: [cRecovery, cChurn] },
  { id: 'slide-explore-loyalty',      eyebrow: 'Altri scenari · Loyalty & Acquisition', eyebrowColor: 'var(--accent-secondary)', title: 'Loyalty & Acquisition',    accent: 'var(--accent-secondary)', cards: [cNps, cYouth] },
  { id: 'slide-explore-growth',       eyebrow: 'Altri scenari · Acquisition & Ecosystem', eyebrowColor: 'var(--accent-secondary)', title: 'Acquisition & Ecosystem', accent: 'var(--accent-secondary)', cards: [cCorporate, cBundle] },
  { id: 'slide-explore-intelligence', eyebrow: 'Altri scenari · Intelligence & Optimization', eyebrowColor: 'var(--color-grigio-300)', title: 'Intelligence & Optimization', accent: 'var(--color-grigio-300)', cards: [cContent, cMediaMix] },
];
---
<BaseLayout
  title="Casi d'uso · recap e da esplorare"
  description="Riepilogo dei tre casi d'uso core e una mappa estesa di ulteriori casi d'uso FS × Adobe da esplorare insieme."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/')}
    prevHref={href(base, '/roadmap')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <CoverHero
        eyebrow="06 · Casi d'uso"
        numeral="06"
        title="Undici scenari di valore, un'unica fondazione."
        lead="Scenari illustrativi, tutti calati sul Gruppo FS, dalla retention al cross-sell d'ecosistema. La stessa fondazione CJA + RT-CDP li abilita tutti."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Recap dei 3 casi core ─────────────────────────── -->
    <Slide id="slide-recap" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>Tre journey, in dettaglio</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.05;"
        data-reveal data-reveal-delay="0.08"
      >
        Tre scenari raccontati end-to-end.
      </h2>

      <div class="w-full max-w-6xl mx-auto flex flex-col gap-3" data-reveal data-reveal-delay="0.16">
        {coreCases.map((uc) => (
          <div class="px-6 py-3 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-md text-left" style={`border-left: 4px solid ${uc.colore};`}>
            <div class="flex items-center gap-8">
              <div class="flex-shrink-0 w-[17rem]">
                <p class="text-[0.76rem] font-bold tracking-widest uppercase mb-1" style={`color: ${uc.colore};`}>{uc.tag}</p>
                <h3 class="text-[1.2rem] font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-snug">{uc.title}</h3>
              </div>
              <div class="flex-1">
                <p class="text-[0.98rem] leading-snug text-[var(--color-grigio-200)]">{uc.recap}</p>
                <p class="text-[0.98rem] leading-snug font-semibold text-[var(--ink-primary)] mt-1">
                  <span class="text-[var(--color-grigio-300)] font-bold uppercase tracking-wide text-[0.72rem]">Impatto · </span>{uc.impatto}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 2-5: Da esplorare · 4 coppie tematiche (2 card each) ── -->
    {exploreSlides.map((s) => (
      <Slide id={s.id} bg="primary" align="center">
        <p class="slide-eyebrow text-center mb-4" style={`color: ${s.eyebrowColor};`} data-reveal>{s.eyebrow}</p>
        <h2
          class="text-center text-[var(--ink-primary)] mb-3 font-[family-name:var(--font-display)]"
          style="font-size: clamp(1.6rem, 2.6vw, 2.2rem); font-weight: 600; letter-spacing: -0.02em;"
          data-reveal data-reveal-delay="0.08"
        >
          {s.title}
        </h2>
        <div class="w-full max-w-6xl mx-auto flex flex-col gap-3.5">
          {s.cards.map((c) => (
            <div class="px-7 py-3 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left flex items-center">
              <div class="flex items-center gap-8 w-full">
                <div class="flex-shrink-0 w-[17rem]">
                  <h3 class="text-[1.2rem] font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-snug mb-2">{c.title}</h3>
                  <div class="flex flex-wrap gap-1.5 mb-2">
                    {c.capability.map((cap) => (
                      <span class="text-[0.74rem] font-semibold px-2 py-0.5 rounded-sm bg-[var(--surface-tertiary)] text-[var(--color-grigio-200)]">{cap}</span>
                    ))}
                  </div>
                  <p class="text-[0.95rem] leading-snug font-semibold" style={`color: ${s.accent};`}>{c.impatto}</p>
                </div>
                <div class="flex-1 grid md:grid-cols-2 gap-x-10 gap-y-1">
                  <div>
                    <p class="text-[0.76rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-1.5">SITUAZIONE</p>
                    <p class="text-[1rem] leading-snug text-[var(--color-grigio-200)]">{c.situazione}</p>
                  </div>
                  <div>
                    <p class="text-[0.76rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-1.5">RISPOSTA ADOBE</p>
                    <p class="text-[1rem] leading-snug text-[var(--color-grigio-200)]">{c.risposta}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Slide>
    ))}

    <!-- ── SLIDE 5: Sintesi + invito ──────────────────────────────── -->
    <Slide id="slide-sintesi" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-binari')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-secondary)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>Una fondazione, molti casi d'uso</p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.9rem, 3.6vw, 3rem); max-width: 60rem;"
        data-reveal data-reveal-delay="0.08"
      >
        Undici scenari. Un'unica fondazione dati.
      </h2>
      <div class="w-full max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 mb-7" data-reveal data-reveal-delay="0.16">
        {[
          { n: '11', l: 'Scenari illustrativi', s: 'Ancorati al mondo FS: Frecce · CartaFreccia · FS Park · X-GO' },
          { n: '4', l: 'Aree di valore', s: 'Retention · Growth · Ecosystem · Intelligence' },
          { n: '1', l: 'Fondazione condivisa', s: 'Ogni scenario riusa CJA + RT-CDP' },
          { n: '100%', l: 'GDPR-compliant', s: 'Clean room · governance dati' },
        ].map((m) => (
          <div class="p-5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-2" style="font-size: clamp(1.8rem, 2.8vw, 2.4rem);">{m.n}</p>
            <p class="text-[0.95rem] font-bold text-[var(--ink-primary)] leading-snug mb-1">{m.l}</p>
            <p class="text-[0.8rem] text-[var(--color-grigio-300)] leading-snug">{m.s}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-base text-[var(--ink-secondary)] max-w-2xl mx-auto" data-reveal data-reveal-delay="0.24">
        Sono scenari di ispirazione calati sul Gruppo FS, non promesse di numeri. Scegliamo insieme quali prototipare per primi: la fondazione è la stessa, il valore si somma nel tempo.
      </p>
    </Slide>

  </DeckContainer>
</BaseLayout>
