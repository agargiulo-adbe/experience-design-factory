---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const journey = [
  { num: '01', label: 'Scenario',     sub: 'Il viaggio del cliente oggi',        href: '/scenario',       solution: null },
  { num: '02', label: 'Foundation',   sub: 'Le fondamenta che avete già',        href: '/fondazione',     solution: null },
  { num: '03', label: 'CJA',          sub: 'Il layer di convergenza',            href: '/convergenza',    solution: 'cja' },
  { num: '04', label: 'Connessioni',  sub: 'FS Park × Trenitalia · Data Collab', href: '/connessioni',    solution: 'data-collab' },
  { num: '05', label: 'Roadmap',      sub: 'Mix Modeler · RTCDP · AJO',         href: '/roadmap',        solution: 'rtcdp,ajo,mix-modeler' },
  { num: '06', label: 'Casi d\'uso',   sub: 'Recap dei casi core · e da esplorare', href: '/casi-duso',      solution: null },
];

const fsStats = [
  { value: '€16,5B', label: 'ricavi operativi 2024', sub: '+12% vs 2023 · Gruppo FS' },
  { value: '840M+',  label: 'passeggeri/anno',        sub: 'tra tutti i brand del Gruppo' },
  { value: '100B€',  label: 'Piano Strategico 2025–29', sub: 'investimenti programmati' },
];
---
<BaseLayout
  title="Connessioni Intelligenti"
  description="Come Customer Journey Analytics trasforma la complessità multi-sistema del Gruppo FS in un vantaggio competitivo concreto."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/scenario')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg"></div>
        <div class="fs-grid"></div>
      </div>
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-stazione')}
        imageClass="opacity-20"
        scrim="bg-[var(--color-carbonio)]/90"
      />
      <CoverHero
        eyebrow="L'intelligenza di ogni viaggio"
        title="Connessioni Intelligenti"
        lead="Ogni viaggio lascia segnali sparsi su più sistemi. Customer Journey Analytics li mette in fila e li rende leggibili come un unico percorso."
        size="hero"
        tone="ink"
        primary="FS Group"
        secondary="Adobe"
      />
      <p class="mt-5 text-center text-[0.75rem] tracking-widest uppercase text-[var(--color-grigio-300)] max-w-2xl mx-auto">
        Scenario concettuale · dati pubblici e illustrativi citati alle fonti · non commissionato da FS Italiane
      </p>

      <!-- I due viaggiatori come stazioni sulla linea -->
      <div class="relative w-full max-w-2xl mx-auto mt-9 mb-1" data-reveal data-reveal-delay="0.3">
        <div class="fs-line-h" style="top: 1.45rem; left: 6%; right: 6%;"></div>
        <div class="relative flex justify-between items-start px-[3%]">
          <div class="flex flex-col items-center gap-2.5 text-center max-w-[15rem]">
            <span class="fs-node fs-node--rosso" data-active>D</span>
            <span class="fs-node-label">Davide — pendolare business Milano–Roma</span>
          </div>
          <div class="flex flex-col items-center gap-2.5 text-center max-w-[15rem]">
            <span class="fs-node" data-active>E</span>
            <span class="fs-node-label">Elena — direttrice marketing, frequent flyer</span>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: Contesto FS ───────────────────────────────────── -->
    <Slide id="slide-fs-context" bg="primary" align="center">
      <div slot="backdrop" class="absolute inset-0">
        <div class="fs-bg"></div>
        <div class="fs-grid"></div>
      </div>
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-binari')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <div class="w-full max-w-5xl mx-auto">
        <p class="fs-panel-tag mb-3" data-reveal>IL CONTESTO STRATEGICO</p>
        <h2
          class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
          style="font-size: clamp(2rem, 3.6vw, 3.4rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
          data-reveal
          data-reveal-delay="0.08"
        >
          Un Gruppo in piena accelerazione
        </h2>
        <p
          class="text-[var(--ink-secondary)] max-w-3xl mb-7"
          style="font-size: clamp(1rem, 1.25vw, 1.2rem); line-height: 1.55;"
          data-reveal
          data-reveal-delay="0.15"
        >
          Il Piano Strategico 2025–2029 destina oltre €100 miliardi alle infrastrutture e lancia
          un Piano Tecnologico da oltre €20B al 2034. La foundation digitale è già partita con la
          piattaforma agentica del Q1 2026. CJA è il layer di intelligenza che la completa.
        </p>

        <!-- Le tre cifre come stazioni sulla linea del Gruppo -->
        <div class="relative pt-6" data-reveal data-reveal-delay="0.22">
          <div class="fs-line-h" style="top: 0.5rem; left: 8%; right: 8%;"></div>
          <div class="grid grid-cols-3 gap-6">
            {fsStats.map((m, i) => (
              <div class="relative text-center">
                <span class={`fs-node ${i === 0 ? 'fs-node--rosso' : ''} absolute left-1/2 -translate-x-1/2 -top-[3.4rem]`} data-active></span>
                <p class="fs-stat-value mb-2">{m.value}</p>
                <p class="fs-stat-label font-medium mb-1">{m.label}</p>
                <p class="fs-stat-src">{m.sub}</p>
              </div>
            ))}
          </div>
        </div>

        <p class="fs-panel-src mt-8">
          Fonte:&nbsp;
          <a href="https://www.fsitaliane.it/content/fsitaliane/it/media/comunicati-stampa/2024/12/12/gruppo-fs-piano-strategico-2025-2029-100-miliardi-investimenti-accompagnare-crescita-paese.html" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
            Gruppo FS, Piano Strategico 2025–2029 (dic 2024)
          </a>
          &nbsp;·&nbsp;
          <a href="https://www.fsitaliane.it/it/media/comunicati-stampa/2025/4/3/risultati-bilancio-2024-gruppofs.html" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
            Bilancio 2024 (apr 2025)
          </a>
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Roadmap del percorso ──────────────────────────── -->
    <Slide id="slide-journey" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--accent-primary)]/88"
      />
      <div class="w-full max-w-5xl mx-auto">
        <p class="fs-panel-tag text-center mb-3" style="color: rgba(242,244,248,0.78);" data-reveal>
          IL PERCORSO
        </p>
        <h2
          class="font-[family-name:var(--font-display)] text-[var(--color-ghiaccio)] mb-4 text-center mx-auto max-w-3xl"
          style="font-size: clamp(2.05rem, 3.5vw, 3.1rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;"
          data-reveal
          data-reveal-delay="0.08"
          data-edf-chapters
        >
          Sei capitoli. Due viaggiatori. Un'intelligenza.
        </h2>
        <p
          class="text-[clamp(0.9rem,1.05vw,1.05rem)] leading-[1.55] text-[var(--color-ghiaccio)]/80 max-w-2xl mx-auto text-center mb-8"
          data-reveal
          data-reveal-delay="0.15"
        >
          Si parte da dati che esistono ma non si parlano e si arriva a una piattaforma
          dove ogni connessione conta, per il cliente come per il Gruppo.
        </p>

        <!-- La linea che collega i sei capitoli, come una mappa schematica -->
        <div class="relative pt-6" data-reveal data-reveal-delay="0.22">
          <div class="fs-line-h" style="top: 0.5rem; left: 5%; right: 5%; background: linear-gradient(90deg, rgba(242,244,248,0) 0%, rgba(242,244,248,0.9) 12%, rgba(242,244,248,0.9) 88%, rgba(242,244,248,0) 100%); box-shadow: 0 0 12px rgba(242,244,248,0.35);"></div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            {journey.map((step) => (
              <a
                href={href(base, step.href)}
                data-nav-solution={step.solution ?? undefined}
                data-edf-journey-card
                class="journey-card relative px-4 pt-5 pb-3.5 border border-[var(--color-ghiaccio)]/25 rounded-md text-left text-[var(--color-ghiaccio)] transition-colors no-underline group"
              >
                <span class="absolute -top-[1.65rem] left-1/2 -translate-x-1/2 size-3 rounded-full bg-[var(--color-ghiaccio)] ring-4 ring-[var(--accent-primary)] group-hover:bg-white transition-colors"></span>
                <p class="text-xs font-semibold text-[var(--color-ghiaccio)]/55 mb-1 font-[family-name:var(--font-display)] tabular-nums" data-edf-cardnum>
                  {step.num}
                </p>
                <p class="text-[1.05rem] font-semibold text-[var(--color-ghiaccio)] mb-1 font-[family-name:var(--font-display)]">
                  {step.label}
                </p>
                <p class="text-[0.82rem] leading-[1.4] text-[var(--color-ghiaccio)]/75">{step.sub}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="text-center mt-8" data-reveal data-reveal-delay="0.35">
          <a
            href={href(base, '/scenario')}
            class="inline-flex items-center gap-3 px-9 py-2.5 text-[clamp(1rem,1.2vw,1.15rem)] font-semibold tracking-wide bg-[var(--color-ghiaccio)] text-[var(--color-carbonio)] hover:bg-white transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--color-ghiaccio)] focus-visible:outline-offset-4 font-[family-name:var(--font-display)]"
          >
            Inizia il percorso
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Slide>

  </DeckContainer>

  <script is:inline>
  (function () {
    var KEY = 'edf-solutions-trenitalia-connessioni';
    var GATES = [null, null, ['cja'], ['data-collab'], ['rtcdp', 'ajo', 'mix-modeler'], null];
    var WORDS = ['zero', 'uno', 'due', 'tre', 'quattro', 'cinque', 'sei'];

    function activeIds() {
      var p = new URLSearchParams(location.search).get('s');
      if (p) return p.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
      try { var st = localStorage.getItem(KEY); if (st) return JSON.parse(st); } catch (_) {}
      return null;
    }
    function count() {
      var ids = activeIds();
      if (!ids) return GATES.length;
      var n = 0;
      GATES.forEach(function(g) {
        if (!g || g.some(function(id) { return ids.indexOf(id) !== -1; })) n++;
      });
      return n;
    }
    function label(n) {
      var w = WORDS[n] || String(n);
      return w.charAt(0).toUpperCase() + w.slice(1) + ' capitoli';
    }
    function renumber() {
      var n = 1;
      document.querySelectorAll('[data-edf-journey-card]').forEach(function(card) {
        var hidden = card.offsetParent === null || getComputedStyle(card).display === 'none';
        if (hidden) return;
        var numEl = card.querySelector('[data-edf-cardnum]');
        if (numEl) numEl.textContent = ('0' + n).slice(-2);
        n++;
      });
    }
    function apply() {
      var txt = label(count()) + '. Due viaggiatori. Un\'intelligenza.';
      document.querySelectorAll('[data-edf-chapters]').forEach(function(el) { el.textContent = txt; });
      renumber();
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply); else apply();
    document.addEventListener('astro:page-load', apply);
    window.addEventListener('storage', function(e) { if (e.key === KEY) apply(); });
  })();
  </script>
</BaseLayout>
