---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const journey = [
  { num: '01', label: 'Scenario',     sub: 'Il viaggio del cliente oggi',        href: '/scenario',       solution: null },
  { num: '02', label: 'Foundation',   sub: 'La fondazione che avete già',        href: '/fondazione',     solution: null },
  { num: '03', label: 'CJA',          sub: 'Il layer di convergenza',            href: '/convergenza',    solution: 'cja' },
  { num: '04', label: 'Connessioni',  sub: 'FS Park × Trenitalia · Data Collab', href: '/connessioni',    solution: 'data-collab' },
  { num: '05', label: 'Roadmap',      sub: 'Mix Modeler · RTCDP · AJO',         href: '/roadmap',        solution: 'rtcdp,ajo,mix-modeler' },
  { num: '06', label: 'Casi d\'uso',   sub: 'Recap dei casi core · e da esplorare', href: '/casi-duso',      solution: null },
];

const fsStats = [
  { value: '€16,5B', label: 'ricavi operativi 2024', sub: '+12% vs 2023 · Gruppo FS' },
  { value: '840M+',  label: 'passeggeri/anno',        sub: 'tra tutti i brand del Gruppo' },
  { value: '100B€',  label: 'Piano Strategico 2025–29', sub: 'investimenti programmati' },
];
---
<BaseLayout
  title="Connessioni Intelligenti"
  description="Come Customer Journey Analytics trasforma la complessità multi-sistema del Gruppo FS in un vantaggio competitivo concreto."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer nextHref={href(base, '/scenario')}>

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="inverse" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-stazione')}
        imageClass="opacity-20"
        scrim="bg-[var(--color-carbonio)]/90"
      />
      <CoverHero
        eyebrow="FS Group × Adobe"
        title="Connessioni Intelligenti"
        lead="Ogni viaggio genera segnali preziosi. Customer Journey Analytics li connette — e trasforma la complessità multi-sistema in intelligenza attivabile."
        size="hero"
        tone="inverse"
        primary="FS Group"
        secondary="Adobe"
      />
      <p class="mt-5 text-center text-[0.58rem] tracking-widest uppercase text-[var(--color-ghiaccio)]/35 max-w-2xl mx-auto">
        Scenario concettuale · dati pubblici e illustrativi citati alle fonti · non commissionato da FS Italiane
      </p>
      <div class="flex gap-8 mt-6 justify-center flex-wrap" data-reveal data-reveal-delay="0.3">
        <div class="flex items-center gap-2.5 text-[var(--color-ghiaccio)]/65">
          <div class="size-7 rounded-full bg-[var(--accent-primary)]/20 flex items-center justify-center text-sm font-bold text-[var(--accent-primary)] font-[family-name:var(--font-display)]">M</div>
          <p class="text-sm font-medium text-[var(--color-ghiaccio)]/65">Marco — pendolare business Milano–Roma</p>
        </div>
        <div class="flex items-center gap-2.5 text-[var(--color-ghiaccio)]/65">
          <div class="size-7 rounded-full bg-[var(--accent-secondary)]/20 flex items-center justify-center text-sm font-bold text-[var(--accent-secondary)] font-[family-name:var(--font-display)]">S</div>
          <p class="text-sm font-medium text-[var(--color-ghiaccio)]/65">Sofia — direttrice marketing, frequent flyer</p>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1: Contesto FS ───────────────────────────────────── -->
    <Slide id="slide-fs-context" bg="primary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-binari')}
        imageClass="opacity-12"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        IL CONTESTO STRATEGICO
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un Gruppo in piena accelerazione
      </h2>
      <p
        class="text-[var(--ink-secondary)] leading-relaxed max-w-2xl mx-auto mb-10"
        style="font-size: clamp(1.1rem, 1.45vw, 1.4rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        Il Piano Strategico 2025–2029 destina oltre €100 miliardi alle infrastrutture e lancia
        un Piano Tecnologico da oltre €20B al 2034. La foundation digitale — con la nuova piattaforma
        agentica lanciata nel Q1 2026 — è il punto di partenza. CJA è il layer di intelligenza che
        la completa.
      </p>

      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-3 gap-6"
        data-reveal
        data-reveal-delay="0.22"
      >
        {fsStats.map((m) => (
          <div class="text-center p-6 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm">
            <p
              class="font-[family-name:var(--font-display)] font-bold text-[var(--accent-primary)] leading-none mb-2"
              style="font-size: clamp(2rem, 3.8vw, 3.2rem);"
            >
              {m.value}
            </p>
            <p class="text-sm font-medium text-[var(--ink-primary)] mb-0.5">{m.label}</p>
            <p class="text-xs text-[var(--ink-tertiary)]">{m.sub}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-[0.62rem] tracking-widest uppercase text-[var(--ink-secondary)]/40">
        Fonte:&nbsp;
        <a href="https://www.fsitaliane.it/content/fsitaliane/it/media/comunicati-stampa/2024/12/12/gruppo-fs-piano-strategico-2025-2029-100-miliardi-investimenti-accompagnare-crescita-paese.html" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
          Gruppo FS, Piano Strategico 2025–2029 (dic 2024)
        </a>
        &nbsp;·&nbsp;
        <a href="https://www.fsitaliane.it/it/media/comunicati-stampa/2025/4/3/risultati-bilancio-2024-gruppofs.html" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100">
          Bilancio 2024 (apr 2025)
        </a>
      </p>
    </Slide>

    <!-- ── SLIDE 2: Roadmap del percorso ──────────────────────────── -->
    <Slide id="slide-journey" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-10"
        scrim="bg-[var(--accent-primary)]/88"
      />
      <p class="slide-eyebrow text-center text-[var(--color-ghiaccio)]/70 mb-5" data-reveal>
        IL PERCORSO
      </p>
      <h2
        class="font-[family-name:var(--font-display)] text-[var(--color-ghiaccio)] mb-4"
        style="font-size: clamp(2.25rem, 4.4vw, 4rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
        data-edf-chapters
      >
        Sei capitoli. Due viaggiatori. Un'intelligenza.
      </h2>
      <p
        class="text-[clamp(1.05rem,1.4vw,1.3rem)] text-[var(--color-ghiaccio)]/75 max-w-2xl mb-10"
        data-reveal
        data-reveal-delay="0.15"
      >
        Da uno scenario in cui i dati esistono ma non si parlano, a una piattaforma in cui
        ogni connessione genera valore — per il cliente e per il Gruppo.
      </p>

      <div
        class="w-full max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-3 gap-4 mb-10"
        data-reveal
        data-reveal-delay="0.22"
      >
        {journey.map((step) => (
          <a
            href={href(base, step.href)}
            data-nav-solution={step.solution ?? undefined}
            data-edf-journey-card
            class="p-5 bg-[var(--color-ghiaccio)]/10 border border-[var(--color-ghiaccio)]/20 rounded-sm text-left hover:bg-[var(--color-ghiaccio)]/18 transition-colors no-underline group"
          >
            <p class="text-sm font-semibold text-[var(--color-ghiaccio)]/50 mb-1 font-[family-name:var(--font-display)] tabular-nums" data-edf-cardnum>
              {step.num}
            </p>
            <p class="text-base font-semibold text-[var(--color-ghiaccio)] mb-0.5 font-[family-name:var(--font-display)]">
              {step.label}
            </p>
            <p class="text-xs text-[var(--color-ghiaccio)]/60">{step.sub}</p>
          </a>
        ))}
      </div>

      <div data-reveal data-reveal-delay="0.35">
        <a
          href={href(base, '/scenario')}
          class="inline-flex items-center gap-3 px-10 py-5 text-[clamp(1.05rem,1.3vw,1.3rem)] font-semibold tracking-wide bg-[var(--color-ghiaccio)] text-[var(--color-carbonio)] hover:bg-white transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-[var(--color-ghiaccio)] focus-visible:outline-offset-4 font-[family-name:var(--font-display)]"
        >
          Inizia il percorso
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Slide>

  </DeckContainer>

  <script is:inline>
  (function () {
    var KEY = 'edf-solutions-trenitalia-connessioni';
    var GATES = [null, null, ['cja'], ['data-collab'], ['rtcdp', 'ajo', 'mix-modeler'], null];
    var WORDS = ['zero', 'uno', 'due', 'tre', 'quattro', 'cinque', 'sei'];

    function activeIds() {
      var p = new URLSearchParams(location.search).get('s');
      if (p) return p.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
      try { var st = localStorage.getItem(KEY); if (st) return JSON.parse(st); } catch (_) {}
      return null;
    }
    function count() {
      var ids = activeIds();
      if (!ids) return GATES.length;
      var n = 0;
      GATES.forEach(function(g) {
        if (!g || g.some(function(id) { return ids.indexOf(id) !== -1; })) n++;
      });
      return n;
    }
    function label(n) {
      var w = WORDS[n] || String(n);
      return w.charAt(0).toUpperCase() + w.slice(1) + ' capitoli';
    }
    function renumber() {
      var n = 1;
      document.querySelectorAll('[data-edf-journey-card]').forEach(function(card) {
        var hidden = card.offsetParent === null || getComputedStyle(card).display === 'none';
        if (hidden) return;
        var numEl = card.querySelector('[data-edf-cardnum]');
        if (numEl) numEl.textContent = ('0' + n).slice(-2);
        n++;
      });
    }
    function apply() {
      var txt = label(count()) + '. Due viaggiatori. Un\'intelligenza.';
      document.querySelectorAll('[data-edf-chapters]').forEach(function(el) { el.textContent = txt; });
      renumber();
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply); else apply();
    document.addEventListener('astro:page-load', apply);
    window.addEventListener('storage', function(e) { if (e.key === KEY) apply(); });
  })();
  </script>
</BaseLayout>
