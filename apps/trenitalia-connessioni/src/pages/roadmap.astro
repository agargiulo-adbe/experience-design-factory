---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const roadmapPhases = [
  {
    fase: 'Fase 1',
    label: 'Convergenza',
    colore: 'var(--accent-primary)',
    headline: 'CJA: la vista unificata',
    prodotti: ['Customer Journey Analytics', 'Adobe Analytics (×2)', 'Content Analytics'],
    deliverable: 'Prima vista end-to-end del journey. Identità stitching cross-domain. Workspace FS + Content Analytics su AEM.',
    kpi: 'Meno blind spot · vista journey completa · AEM data-driven',
    attiva: true,
  },
  {
    fase: 'Fase 2',
    label: 'Attivazione',
    colore: 'var(--accent-secondary)',
    headline: 'RTCDP + AJO: dal dato all\'azione',
    prodotti: ['Adobe Real-Time CDP', 'Adobe Journey Optimizer', 'Adobe Target (extension)'],
    deliverable: 'RTCDP profili unificati real-time. AJO orchestra il journey omnicanale sopra Responsys. Target esteso a funnel e app.',
    kpi: 'Più rinnovi · meno abbandono funnel · più engagement app — da validare',
    attiva: true,
  },
  {
    fase: 'Fase 3',
    label: 'Intelligence',
    colore: 'var(--color-grigio-300)',
    headline: 'Mix Modeler + Data Collaboration',
    prodotti: ['Adobe Mix Modeler', 'Adobe Data Collaboration', 'Adobe GenStudio'],
    deliverable: 'Mix Modeler ottimizza il budget media cross-canale. Data Collaboration FS Park × Trenitalia a regime. GenStudio + Target per creative performance.',
    kpi: 'ROI media ottimizzato · Revenue bundle misurabile — da validare',
    attiva: false,
  },
];

const mixModelerCapabilita = [
  {
    label: 'Media Mix Modeling (MMM)',
    desc: 'Modella il contributo incrementale di TV, digital, email e offline, e misura l\'effetto halo tra canali.',
    differenza: 'CJA analizza il singolo cliente; MMM misura l\'impatto aggregato degli investimenti media.',
  },
  {
    label: 'Budget Optimization',
    desc: 'Scenario what-if: quanti abbonamenti genera spostare €1M da TV a paid digital? Riallocazione automatica.',
    differenza: 'Ottimizza la spesa CartaFreccia, X-GO e Frecciarossa vs yield reale di ogni tariffa.',
  },
  {
    label: 'Causal AI & Attribution',
    desc: 'Unisce multi-touch attribution (CJA) e market mix modeling: visione causale, non solo correlazionale.',
    differenza: 'Il connettore nativo CJA→Mix Modeler porta i dati person-level nel modello, dove pesano davvero.',
  },
];
---
<BaseLayout
  title="Roadmap Adobe · FS Group"
  description="Il percorso evolutivo in tre fasi: CJA convergenza, RTCDP+AJO attivazione, Mix Modeler+Data Collaboration intelligence strategica."
  pageSolutions={['rtcdp', 'ajo', 'mix-modeler']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/casi-duso')}
    prevHref={href(base, '/connessioni')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <CoverHero
        eyebrow="05 · Roadmap"
        numeral="05"
        title="La roadmap verso l'eccellenza"
        lead="Tre fasi, nessun big bang. Ognuna porta valore misurabile e prepara il terreno alla successiva: CJA subito, l'attivazione a seguire, l'intelligence strategica nel tempo."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Le 3 fasi ─────────────────────────────────────── -->
    <Slide id="slide-3fasi" bg="primary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dashboard')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <p class="fs-panel-tag text-center mb-3" data-reveal>
        L'ECOSISTEMA ADOBE PER FS · TRE FASI
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-8 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.5rem, 2.4vw, 2.1rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Da analytics a intelligence. Passo dopo passo.
      </h2>

      <div class="relative w-full max-w-6xl mx-auto" data-reveal data-reveal-delay="0.18">
        <span class="fs-line-h hidden md:block" style="top: 1.45rem; left: 16.6%; right: 16.6%;" aria-hidden="true"></span>
        <div class="grid md:grid-cols-3 gap-5 relative items-stretch">
          {roadmapPhases.map((phase, i) => (
            <div class="flex flex-col items-center h-full">
              <span
                class="fs-node mb-4 relative z-10"
                data-active={phase.attiva ? '' : undefined}
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <div class="fs-panel w-full text-left flex flex-col gap-3 h-full">
                <div>
                  <div class="flex items-baseline gap-2.5 mb-1">
                    <span class="fs-panel-tag" style={`color: ${phase.colore};`}>{phase.fase}</span>
                    <span class="fs-node-label uppercase tracking-widest text-[0.72rem]">{phase.label}</span>
                  </div>
                  <p class="fs-panel-head" style="font-size: 1.28rem;">{phase.headline}</p>
                </div>
                <div>
                  <p class="fs-panel-tag mb-1.5" style="color: rgba(242,244,248,0.55);">PRODOTTI</p>
                  <ul class="space-y-1">
                    {phase.prodotti.map((p) => (
                      <li class="flex items-center gap-2.5 fs-card-body">
                        <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${phase.colore};`} aria-hidden="true"/>
                        {p}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="pt-3 mt-auto border-t border-[var(--line-subtle)]">
                  <p class="fs-panel-tag mb-1" style="color: rgba(242,244,248,0.55);">KPI TARGET</p>
                  <p class="fs-card-body italic text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.95);">{phase.kpi}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1b: Fase 1 Deep-dive · CJA ──────────────────────── -->
    <Slide id="slide-fase1-cja" bg="secondary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <div class="flex items-center justify-center gap-3 mb-3" data-reveal>
        <span class="fs-node" data-active aria-hidden="true">01</span>
        <p class="fs-panel-tag">FASE 1 · CUSTOMER JOURNEY ANALYTICS · SUBITO</p>
      </div>
      <h2
        class="text-center text-[var(--ink-primary)] mb-7 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.5rem, 2.2vw, 2.1rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Intelligence dal day one.<br/>Zero big bang.
      </h2>

      <div
        class="w-full max-w-6xl mx-auto grid md:grid-cols-2 gap-5 items-stretch"
        data-reveal
        data-reveal-delay="0.18"
      >
        <!-- Cosa consegna Fase 1 -->
        <div class="fs-panel text-left flex flex-col h-full">
          <p class="fs-panel-tag mb-3">COSA CONSEGNA FASE 1</p>
          <ul class="space-y-2.5">
            {[
              { label: 'Convergenza Analytics ×2', desc: 'Le due istanze Adobe Analytics unificate in CJA: prima vista end-to-end dalla homepage al checkout.' },
              { label: 'Content Analytics su AEM', desc: 'Quali contenuti e CTA guidano il booking — ottimizzazione editoriale data-driven su trenitalia.com.' },
              { label: 'Workspace FS personalizzato', desc: 'Panel Davide e Elena, segmenti CartaFreccia, cohort abbonamenti. Insight in settimane.' },
              { label: 'Governance dati AEP', desc: 'Classificazione, policy, audit trail. Pseudonimizzazione all\'ingestion contro il rischio PII.' },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"/>
                <p class="fs-panel-body">
                  <strong class="font-semibold text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.99);">{item.label}: </strong>{item.desc}
                </p>
              </li>
            ))}
          </ul>
        </div>

        <!-- Perché ora -->
        <div class="fs-panel fs-panel--rosso text-left flex flex-col h-full">
          <p class="fs-panel-tag mb-3" style="color: rgba(226,0,26,0.98);">PERCHÉ INIZIARE ADESSO</p>
          <ul class="space-y-2.5">
            {[
              { label: 'Adobe Analytics già attivo ×2', desc: 'Il Gruppo ha già le due istanze: Fase 1 lavora su ciò che esiste, senza nuove raccolte.' },
              { label: 'AEM su Edge Delivery', desc: 'Content Analytics non richiede infrastruttura aggiuntiva — integrazione in-product.' },
              { label: 'Connettori nativi AEP', desc: 'Responsys e Salesforce Data Cloud hanno connettori AEP pronti: la pipeline si attiva, non si costruisce.' },
              { label: 'Governance come risposta al rischio', desc: 'L\'incidente dati Trenitalia (giu 2026) conferma il rischio dei PII non governati. AEP governa by design.' },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                <p class="fs-panel-body">
                  <strong class="font-semibold text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.99);">{item.label}: </strong>{item.desc}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: RTCDP + AJO ───────────────────────────────────── -->
    <Slide id="slide-rtcdp-ajo" bg="secondary" align="center" data-solution="rtcdp">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <div class="flex items-center justify-center gap-3 mb-3" data-reveal>
        <span class="fs-node" data-active aria-hidden="true">02</span>
        <p class="fs-panel-tag" style="color: var(--accent-secondary);">FASE 2 · REAL-TIME CDP + ADOBE JOURNEY OPTIMIZER</p>
      </div>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.5rem, 2.2vw, 2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Dal profilo al momento giusto. Sempre.
      </h2>

      <div
        class="w-full max-w-6xl mx-auto grid md:grid-cols-2 gap-5 items-stretch"
        data-reveal
        data-reveal-delay="0.18"
      >
        <!-- RTCDP -->
        <div class="fs-panel text-left flex flex-col h-full">
          <p class="fs-panel-tag mb-1.5" style="color: var(--accent-secondary);">ADOBE REAL-TIME CDP</p>
          <h3 class="fs-panel-head mb-3" style="font-size: 1.28rem;">Profili unificati in tempo reale</h3>
          <ul class="space-y-2.5">
            {[
              { label: 'Profilo unificato', desc: 'Identità risolta tra CJA, Salesforce, Responsys, App e FS Park — aggiornata in <1s.' },
              { label: 'Segmenti streaming', desc: 'Segmento "in scadenza 30gg + attivo nei 14gg" → disponibile in real-time per AJO.' },
              { label: 'Governance GDPR', desc: 'Labels, policy di utilizzo e audit trail su ogni dato usato in campagna.' },
              { label: 'Connettori nativi', desc: 'Out-of-the-box con Responsys, Salesforce Data Cloud, AEM, Analytics.' },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                <p class="fs-panel-body">
                  <strong class="font-semibold text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.99);">{item.label}: </strong>{item.desc}
                </p>
              </li>
            ))}
          </ul>
        </div>

        <!-- AJO -->
        <div class="fs-panel text-left flex flex-col h-full">
          <p class="fs-panel-tag mb-1.5" style="color: var(--accent-secondary);">ADOBE JOURNEY OPTIMIZER</p>
          <h3 class="fs-panel-head mb-2" style="font-size: 1.28rem;">Il journey come esperienza</h3>
          <p class="text-[0.95rem] text-emerald-400 font-semibold mb-3 leading-snug">
            AJO orchestra SOPRA Responsys, non lo sostituisce: è il layer di decisione e timing.
          </p>
          <ul class="space-y-2.5">
            {[
              { label: 'Journey orchestration', desc: 'Canvas visuale: trigger CJA → canale → esecuzione su Responsys, push app o AEM.' },
              { label: 'Decisioni AI', desc: 'L\'AI seleziona messaggio, canale e timing ottimali per ogni profilo.' },
              { label: 'Target esteso', desc: 'Adobe Target oggi solo homepage → con AJO+RTCDP si estende a funnel e app.' },
              { label: 'Soppressione intelligente', desc: 'Chi ha già rinnovato non riceve la push. Frequenza cappata. Zero over-messaging.' },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                <p class="fs-panel-body">
                  <strong class="font-semibold text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.99);">{item.label}: </strong>{item.desc}
                </p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Mix Modeler ───────────────────────────────────── -->
    <Slide id="slide-mix-modeler" bg="primary" align="center" data-solution="mix-modeler">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <div class="flex items-center justify-center gap-3 mb-3" data-reveal>
        <span class="fs-node" aria-hidden="true">03</span>
        <p class="fs-panel-tag">FASE 3 · ADOBE MIX MODELER · CAUSAL AI SUL BUDGET MEDIA</p>
      </div>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.4vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Ogni euro di marketing: dove rende di più?
      </h2>

      <div
        class="w-full max-w-6xl mx-auto flex flex-col gap-3"
        data-reveal
        data-reveal-delay="0.2"
      >
        {mixModelerCapabilita.map((cap, i) => (
          <div class="fs-panel text-left grid md:grid-cols-[auto_13rem_1fr_1fr] gap-x-6 gap-y-2 items-center" style="padding-top: 1.1rem; padding-bottom: 1.1rem;">
            <span class="fs-mark hidden md:inline-flex" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <p class="fs-panel-head" style="font-size: 1.12rem;">{cap.label}</p>
            </div>
            <div>
              <p class="fs-panel-tag mb-1" style="color: rgba(242,244,248,0.55);">COSA FA</p>
              <p class="fs-card-body">{cap.desc}</p>
            </div>
            <div>
              <p class="fs-panel-tag mb-1">DIMENSIONE UNICA</p>
              <p class="fs-card-body">{cap.differenza}</p>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3b: Mix Modeler · use case FS ───────────────────── -->
    <Slide id="slide-mix-usecase" bg="secondary" align="center" data-solution="mix-modeler">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <p class="fs-panel-tag text-center mb-3" data-reveal>
        MIX MODELER · USE CASE FS · SCENARIO ILLUSTRATIVO
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-8 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.7rem, 2.8vw, 2.6rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        €2M spostati da TV a digital.<br/>Misurati, non intuiti.
      </h2>
      <div class="w-full max-w-4xl mx-auto fs-panel text-left flex flex-col gap-4" data-reveal data-reveal-delay="0.16">
        <p class="fs-panel-body" style="font-size: 1.05rem;">
          FS investe in una campagna TV estiva per X-GO e Frecciarossa, affiancata da paid digital
          ed email Oracle Responsys. Oggi il contributo reale di ciascun canale resta opaco.
        </p>
        <p class="fs-panel-body" style="font-size: 1.05rem;">
          Mix Modeler misura l'incremento prenotazioni attribuibile a ogni canale, l'effetto halo
          TV→digital e la saturazione per canale. <strong class="text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.99);">Output: spostare
          €2M da TV a paid digital</strong> per massimizzare le prenotazioni Frecciarossa nel Q3.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 4: GenStudio ─────────────────────────────────────── -->
    <Slide id="slide-genstudio" bg="secondary" align="center" data-solution="mix-modeler">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <p class="fs-panel-tag text-center mb-3" style="color: var(--accent-secondary);" data-reveal>
        ACCELERATORE CREATIVO · ADOBE GENSTUDIO FOR PERFORMANCE MARKETING
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.4vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        La creatività alla velocità della personalizzazione.
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-4 mb-4 items-stretch"
        data-reveal
        data-reveal-delay="0.2"
      >
        {[
          {
            icon: '🎨',
            label: 'GenStudio · Varianti on-brand',
            desc: 'Email, social, banner per ogni segmento CJA — nel brand system FS, in minuti.',
          },
          {
            icon: '🎯',
            label: 'Adobe Target · Personalizzazione on-site',
            desc: 'A/B test e 1:1 su trenitalia.com e funnel — guidati dai segmenti RTCDP.',
          },
          {
            icon: '🔬',
            label: 'Experimentation Accelerator',
            desc: 'Test scalabile: ipotesi → esperimento → vincitore in produzione. L\'AI suggerisce cosa testare.',
          },
        ].map((item) => (
          <div class="fs-card text-left flex flex-col gap-1.5 h-full">
            <span class="fs-mark mb-1" aria-hidden="true">{item.icon}</span>
            <p class="fs-card-title">{item.label}</p>
            <p class="fs-card-body">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="w-full max-w-5xl mx-auto fs-panel mb-6" data-reveal data-reveal-delay="0.26">
        <p class="fs-panel-body text-center">
          <strong class="text-[var(--ink-primary)]" style="color: rgba(242,244,248,0.99);">Il loop creativo:</strong> CJA + Mix Modeler identificano → GenStudio genera → Target testa → Experimentation scala → Responsys distribuisce. Review umana a ogni step.
        </p>
      </div>

      <a
        href={href(base, '/casi-duso')}
        class="inline-flex items-center gap-3 px-8 py-2.5 text-base font-semibold tracking-wide bg-[var(--accent-primary)] text-white hover:opacity-90 transition-opacity duration-300 font-[family-name:var(--font-display)]"
        data-reveal
        data-reveal-delay="0.28"
      >
        I casi d'uso
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </Slide>

  </DeckContainer>
</BaseLayout>
