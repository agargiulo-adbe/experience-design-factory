---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const roadmapPhases = [
  {
    fase: 'Fase 1',
    label: 'Convergenza',
    colore: 'var(--accent-primary)',
    headline: 'CJA: la vista unificata',
    prodotti: ['Customer Journey Analytics', 'Adobe Analytics (×2)', 'Content Analytics'],
    deliverable: 'Prima vista end-to-end del journey. Identità stitching cross-domain. Workspace FS + Content Analytics su AEM.',
    kpi: 'Meno blind spot · vista journey completa · AEM data-driven',
  },
  {
    fase: 'Fase 2',
    label: 'Attivazione',
    colore: 'var(--accent-secondary)',
    headline: 'RTCDP + AJO: dal dato all\'azione',
    prodotti: ['Adobe Real-Time CDP', 'Adobe Journey Optimizer', 'Adobe Target (extension)'],
    deliverable: 'RTCDP profili unificati real-time. AJO orchestra il journey omnicanale sopra Responsys. Target esteso a funnel e app.',
    kpi: 'Più rinnovi · meno abbandono funnel · più engagement app — da validare',
  },
  {
    fase: 'Fase 3',
    label: 'Intelligence',
    colore: 'var(--color-grigio-300)',
    headline: 'Mix Modeler + Data Collaboration',
    prodotti: ['Adobe Mix Modeler', 'Adobe Data Collaboration', 'Adobe GenStudio'],
    deliverable: 'Mix Modeler ottimizza il budget media cross-canale. Data Collaboration FS Park × Trenitalia a regime. GenStudio + Target per creative performance.',
    kpi: 'ROI media ottimizzato · Revenue bundle misurabile — da validare',
  },
];

const mixModelerCapabilita = [
  {
    label: 'Media Mix Modeling (MMM)',
    desc: 'Modella il contributo incrementale di TV, digital, email, organico e offline — e misura l\'effetto halo tra canali.',
    differenza: 'CJA analizza il singolo cliente; MMM misura l\'impatto aggregato degli investimenti media a portafoglio.',
  },
  {
    label: 'Budget Optimization',
    desc: 'Scenario what-if: quanti abbonamenti genera spostare €1M da TV a paid digital? Riallocazione automatica.',
    differenza: 'Ottimizza la spesa per CartaFreccia, X-GO e Frecciarossa vs yield reale di ogni tariffa.',
  },
  {
    label: 'Causal AI & Attribution',
    desc: 'Combina multi-touch attribution (CJA) e market mix modeling per una visione causale, non solo correlazionale.',
    differenza: 'Il connettore nativo CJA→Mix Modeler porta i dati person-level nel modello: massima precisione.',
  },
];
---
<BaseLayout
  title="Roadmap Adobe · FS Group"
  description="Il percorso evolutivo in tre fasi: CJA convergenza, RTCDP+AJO attivazione, Mix Modeler+Data Collaboration intelligence strategica."
  pageSolutions={['rtcdp', 'ajo', 'mix-modeler']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/casi-duso')}
    prevHref={href(base, '/connessioni')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center" data-solution="rtcdp">
      <CoverHero
        eyebrow="05 · Roadmap"
        numeral="05"
        title="La roadmap verso l'eccellenza"
        lead="Tre fasi. Nessun big bang. Ogni fase porta valore misurabile — e costruisce la fondazione per la successiva. CJA ora, attivazione domani, intelligence strategica nel tempo."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Le 3 fasi ─────────────────────────────────────── -->
    <Slide id="slide-3fasi" bg="primary" align="center" data-solution="rtcdp">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dashboard')}
        imageClass="opacity-10"
        scrim="bg-[var(--surface-primary)]/90"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        L'ECOSISTEMA ADOBE PER FS · TRE FASI
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.5rem, 2.4vw, 2.1rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Da analytics a intelligence. Passo dopo passo.
      </h2>

      <div
        class="w-full max-w-6xl mx-auto grid md:grid-cols-3 gap-4"
        data-reveal
        data-reveal-delay="0.18"
      >
        {roadmapPhases.map((phase) => (
          <div class="px-5 py-3.5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left flex flex-col gap-2.5">
            <div>
              <div class="flex items-center gap-2 mb-1.5">
                <span class="inline-block text-[0.72rem] font-bold tracking-widest uppercase px-2 py-0.5 rounded-sm" style={`color: ${phase.colore}; background: color-mix(in srgb, ${phase.colore} 14%, transparent);`}>
                  {phase.fase}
                </span>
                <p class="text-[0.8rem] text-[var(--color-grigio-300)]">{phase.label}</p>
              </div>
              <p class="text-[1.15rem] font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-tight">{phase.headline}</p>
            </div>
            <div>
              <p class="text-[0.72rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-1">PRODOTTI</p>
              <ul class="space-y-0.5">
                {phase.prodotti.map((p) => (
                  <li class="flex items-center gap-2 text-[0.9rem] text-[var(--color-grigio-200)] leading-snug">
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${phase.colore};`} aria-hidden="true"/>
                    {p}
                  </li>
                ))}
              </ul>
            </div>
            <div class="pt-2.5 border-t border-[var(--line-subtle)] mt-auto">
              <p class="text-[0.72rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-1">KPI TARGET</p>
              <p class="text-[0.9rem] text-[var(--ink-primary)] font-semibold leading-snug italic">{phase.kpi}</p>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 1b: Fase 1 Deep-dive · CJA ──────────────────────── -->
    <Slide id="slide-fase1-cja" bg="secondary" align="center" data-solution="rtcdp">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        FASE 1 · CUSTOMER JOURNEY ANALYTICS · SUBITO
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-5 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.55rem, 2.6vw, 2.5rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Intelligence dal day one.<br/>Zero big bang.
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.18"
      >
        <!-- Cosa consegna Fase 1 -->
        <div class="p-3.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-2">COSA CONSEGNA FASE 1</p>
          <ul class="space-y-1">
            {[
              { label: 'Convergenza Analytics ×2', desc: 'Le due istanze Adobe Analytics (sito + funnel) unificate in CJA: prima vista end-to-end dalla homepage al checkout.' },
              { label: 'Content Analytics su AEM', desc: 'Quali contenuti, CTA e formati guidano il booking — ottimizzazione editoriale data-driven su trenitalia.com e siti del Gruppo.' },
              { label: 'Workspace FS personalizzato', desc: 'Panel Davide (pendolare), Panel Elena (business), segmenti CartaFreccia, cohort analysis abbonamenti. Insight pronti in settimane.' },
              { label: 'Governance dati AEP', desc: 'Classificazione dati, policy di utilizzo, audit trail completo. Pseudonimizzazione all\'ingestion: risposta strutturale al rischio PII dispersi.' },
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-base">
                <span class="flex-shrink-0 mt-1 w-1.5 h-1.5 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"/>
                <p class="leading-tight">
                  <strong class="font-semibold text-[var(--ink-primary)]">{item.label}: </strong><span class="text-[0.85rem] text-[var(--color-grigio-200)]">{item.desc}</span>
                </p>
              </li>
            ))}
          </ul>
        </div>

        <!-- Perché ora -->
        <div class="p-3.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--accent-secondary)] mb-2">PERCHÉ INIZIARE ADESSO</p>
          <ul class="space-y-1">
            {[
              { label: 'Adobe Analytics già attivo ×2', desc: 'Il Gruppo ha già le due istanze. Fase 1 non richiede nuove raccolte dati — si lavora su ciò che esiste.' },
              { label: 'AEM su Edge Delivery', desc: 'Content Analytics non richiede infrastruttura aggiuntiva su trenitalia.com — integrazione in-product.' },
              { label: 'Connettori nativi AEP', desc: 'Oracle Responsys e Salesforce Data Cloud hanno connettori nativi AEP pronti: la pipeline dati si attiva, non si costruisce.' },
              { label: 'Governance come risposta al rischio', desc: 'L\'incidente dati Trenitalia (giugno 2026) conferma che PII su sistemi non governati moltiplicano il rischio. AEP centralizza la governance by design.' },
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-base">
                <span class="flex-shrink-0 mt-1 w-1.5 h-1.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                <p class="leading-tight">
                  <strong class="font-semibold text-[var(--ink-primary)]">{item.label}: </strong><span class="text-[0.85rem] text-[var(--color-grigio-200)]">{item.desc}</span>
                </p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: RTCDP + AJO ───────────────────────────────────── -->
    <Slide id="slide-rtcdp-ajo" bg="secondary" align="center" data-solution="rtcdp">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-6" data-reveal>
        FASE 2 · REAL-TIME CDP + ADOBE JOURNEY OPTIMIZER
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.55rem, 2.6vw, 2.5rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Dal profilo al momento giusto.<br/>Sempre.
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-2 gap-4"
        data-reveal
        data-reveal-delay="0.18"
      >
        <!-- RTCDP -->
        <div class="p-3.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--accent-secondary)] mb-2">ADOBE REAL-TIME CDP</p>
          <h3 class="text-base font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] mb-2">Profili unificati in tempo reale</h3>
          <ul class="space-y-1">
            {[
              { label: 'Profilo unificato', desc: 'Risoluzione identità tra CJA, Salesforce, Oracle Responsys, App e FS Park — profilo aggiornato in <1s.' },
              { label: 'Segmenti streaming', desc: 'Segmento "abbonamento in scadenza 30gg + attivo nei 14gg" → disponibile in real-time per AJO.' },
              { label: 'Governance GDPR', desc: 'Labels sui dati, policy di utilizzo, audit trail completo su ogni dato utilizzato in ogni campagna.' },
              { label: 'Connettori nativi', desc: 'Out-of-the-box con Oracle Responsys, Salesforce Data Cloud, AEM, Adobe Analytics.' },
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-base">
                <span class="flex-shrink-0 mt-1 w-1.5 h-1.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                <p class="leading-tight">
                  <strong class="font-semibold text-[var(--ink-primary)]">{item.label}: </strong><span class="text-[0.85rem] text-[var(--color-grigio-200)]">{item.desc}</span>
                </p>
              </li>
            ))}
          </ul>
        </div>

        <!-- AJO -->
        <div class="p-3.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
          <p class="text-[0.6rem] font-bold tracking-widest uppercase text-[var(--accent-secondary)] mb-2">ADOBE JOURNEY OPTIMIZER</p>
          <h3 class="text-base font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] mb-1">Il journey come esperienza</h3>
          <p class="text-[0.82rem] text-emerald-400 font-semibold mb-2 leading-snug">
            AJO orchestra SOPRA Oracle Responsys — non lo sostituisce. Responsys resta il motore email; AJO è il layer di decisione e timing. Connettore nativo disponibile.
          </p>
          <ul class="space-y-1">
            {[
              { label: 'Journey orchestration', desc: 'Canvas visuale: trigger CJA → decisione canale → esecuzione su Oracle Responsys (email), push app o AEM.' },
              { label: 'Decisioni AI', desc: 'AI engine seleziona il messaggio migliore, il canale ottimale e il timing perfetto per ogni profilo.' },
              { label: 'Target esteso', desc: 'Adobe Target attivo solo sull\'homepage oggi → con AJO+RTCDP si estende a funnel di acquisto e app nativa.' },
              { label: 'Soppressione intelligente', desc: 'Chi ha già rinnovato non riceve la push. Frequenza cappata per profilo. Zero over-messaging.' },
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-base">
                <span class="flex-shrink-0 mt-1 w-1.5 h-1.5 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"/>
                <p class="leading-tight">
                  <strong class="font-semibold text-[var(--ink-primary)]">{item.label}: </strong><span class="text-[0.85rem] text-[var(--color-grigio-200)]">{item.desc}</span>
                </p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 3: Mix Modeler ───────────────────────────────────── -->
    <Slide id="slide-mix-modeler" bg="primary" align="center" data-solution="mix-modeler">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        FASE 3 · ADOBE MIX MODELER · CAUSAL AI SUL BUDGET MEDIA
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-8 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.4vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Ogni euro di marketing: dove rende di più?
      </h2>

      <div
        class="w-full max-w-6xl mx-auto flex flex-col gap-3"
        data-reveal
        data-reveal-delay="0.2"
      >
        {mixModelerCapabilita.map((cap) => (
          <div class="px-5 py-3 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm text-left grid md:grid-cols-[210px_1fr_1fr] gap-5 items-center">
            <div>
              <p class="text-[1.05rem] font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-snug">{cap.label}</p>
            </div>
            <div>
              <p class="text-[0.68rem] font-bold tracking-widest uppercase text-[var(--color-grigio-300)] mb-0.5">COSA FA</p>
              <p class="text-[0.85rem] text-[var(--color-grigio-200)] leading-snug">{cap.desc}</p>
            </div>
            <div>
              <p class="text-[0.68rem] font-bold tracking-widest uppercase text-[var(--accent-primary)] mb-0.5">DIMENSIONE UNICA</p>
              <p class="text-[0.85rem] text-[var(--color-grigio-200)] leading-snug">{cap.differenza}</p>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3b: Mix Modeler · use case FS ───────────────────── -->
    <Slide id="slide-mix-usecase" bg="secondary" align="center" data-solution="mix-modeler">
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        MIX MODELER · USE CASE FS · SCENARIO ILLUSTRATIVO
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-8 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.7rem, 2.8vw, 2.6rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        €2M spostati da TV a digital.<br/>Misurati, non intuiti.
      </h2>
      <div class="w-full max-w-4xl mx-auto space-y-5 text-left" data-reveal data-reveal-delay="0.16">
        <p class="text-[1.05rem] text-[var(--color-grigio-200)] leading-relaxed">
          FS investe in una campagna TV estiva per X-GO e Frecciarossa, affiancata da paid digital
          ed email Oracle Responsys. Oggi il contributo reale di ciascun canale resta opaco.
        </p>
        <p class="text-[1.05rem] text-[var(--color-grigio-200)] leading-relaxed">
          Mix Modeler misura l'incremento prenotazioni attribuibile a ogni canale, l'effetto halo
          TV→digital e la saturazione per canale. <strong class="text-[var(--ink-primary)]">Output: spostare
          €2M da TV a paid digital</strong> per massimizzare le prenotazioni Frecciarossa nel Q3.
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 4: GenStudio ─────────────────────────────────────── -->
    <Slide id="slide-genstudio" bg="secondary" align="center" data-solution="mix-modeler">
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        ACCELERATORE CREATIVO · ADOBE GENSTUDIO FOR PERFORMANCE MARKETING
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-7 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.4vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        La creatività alla velocità della personalizzazione.
      </h2>

      <div
        class="w-full max-w-5xl mx-auto grid md:grid-cols-3 gap-4 mb-4"
        data-reveal
        data-reveal-delay="0.2"
      >
        {[
          {
            icon: '🎨',
            label: 'GenStudio · Varianti on-brand',
            desc: 'Email, social, banner per ogni segmento CJA — nel brand system FS, in minuti.',
          },
          {
            icon: '🎯',
            label: 'Adobe Target · Personalizzazione on-site',
            desc: 'A/B test e 1:1 su trenitalia.com e funnel — guidati dai segmenti RTCDP.',
          },
          {
            icon: '🔬',
            label: 'Experimentation Accelerator',
            desc: 'Test scalabile: ipotesi → esperimento → vincitore in produzione. L\'AI suggerisce cosa testare.',
          },
        ].map((item) => (
          <div class="px-4 py-3.5 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm text-left">
            <p class="text-xl mb-1.5" aria-hidden="true">{item.icon}</p>
            <p class="text-[1.02rem] font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] mb-1 leading-snug">{item.label}</p>
            <p class="text-[0.85rem] text-[var(--color-grigio-300)] leading-snug">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="w-full max-w-5xl mx-auto px-5 py-2.5 bg-[var(--surface-secondary)] border border-[var(--line-subtle)] rounded-sm mb-6" data-reveal data-reveal-delay="0.26">
        <p class="text-[0.88rem] text-[var(--color-grigio-200)] text-center leading-snug">
          <strong class="text-[var(--ink-primary)]">Il loop creativo:</strong> CJA + Mix Modeler identificano → GenStudio genera → Target testa → Experimentation scala → Responsys distribuisce. Review umana a ogni step.
        </p>
      </div>

      <a
        href={href(base, '/casi-duso')}
        class="inline-flex items-center gap-3 px-8 py-3 text-base font-semibold tracking-wide bg-[var(--accent-primary)] text-white hover:opacity-90 transition-opacity duration-300 font-[family-name:var(--font-display)]"
        data-reveal
        data-reveal-delay="0.28"
      >
        I casi d'uso
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </Slide>

  </DeckContainer>
</BaseLayout>
