---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import MediaDemoSlot from '@edf/core/blocks/immersive/MediaDemoSlot.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const useCases = [
  {
    id: 'uc1',
    tag: 'Use Case 01 · Rinnovo',
    title: 'Il rinnovo che si anticipa',
    persona: 'Davide',
    scenario: 'Davide ha un abbonamento mensile Frecce Milano–Roma. Negli ultimi 14 giorni ha ridotto i viaggi del 40%. CJA rileva l\'anomalia comportamentale 18 giorni prima della scadenza — molto prima che Oracle Responsys invii la classica email di rinnovo.',
    segnale: 'Frequenza viaggi –40% in 14 gg + apertura email CartaFreccia caduta a 12% (vs 35% media)',
    azione: 'Oracle Responsys invia un\'offerta di rinnovo personalizzata — non generica. AJO orchestra il canale ottimale (push app se mobile, email se desktop) nel momento di maggiore propensione all\'acquisto.',
    impatto: '+22% rinnovi su early trigger',
    recap: 'Viaggi –40% in 14 giorni: CJA coglie l\'anomalia 18 giorni prima della scadenza. Responsys e AJO attivano il rinnovo puntuale.',
    colore: 'var(--accent-primary)',
  },
  {
    id: 'uc2',
    tag: 'Use Case 02 · Cross-sell',
    title: 'Il parcheggio come cross-sell',
    persona: 'Davide',
    scenario: 'Davide prenota un Frecciarossa e, 3 ore dopo, CJA rileva che ha cercato "parcheggio Milano Centrale" su trenitalia.com senza convertire. FS Park e Trenitalia non comunicano: Davide va su un\'app terza e paga parcheggio concorrente.',
    segnale: 'Ricerca parcheggio post-booking + 0 conversioni su FS Park nel 90-day window',
    azione: 'Data Collaboration clean room: FS Park riceve il segnale di interesse senza mai vedere l\'identità di Davide. Campagna mirata: offerta parcheggio+biglietto bundled in-app, 20% sconto primo utilizzo.',
    impatto: '€ 8–15 di ricavo accessorio/viaggio',
    recap: 'Cerca parcheggio dopo il booking, ma FS Park e Trenitalia non si parlano. Clean room Data Collaboration: bundle parcheggio + biglietto.',
    colore: 'var(--accent-secondary)',
  },
  {
    id: 'uc3',
    tag: 'Use Case 03 · Loyalty',
    title: 'Dalla tratta alla relazione',
    persona: 'Elena',
    scenario: 'Elena prenota sempre in business class, 3 volte al mese. Non ha un abbonamento, non ha CartaFreccia. CJA classifica Elena come "cliente ad alto LTV latente" basandosi su frequenza × ticket medio × canale — ma nessun sistema la conosce come tale.',
    segnale: 'Frequenza ≥ 3 viaggi/mese × ticket medio >€80 × 0 loyalty card registrata',
    azione: 'Campagna di onboarding CartaFreccia personalizzata: "Ti viaggi regolarmente — i tuoi punti non stanno aspettando." Offerta: accumulo punti retroattivo sugli ultimi 3 acquisti.',
    impatto: 'Clienti alto-valore diventano loyalty member',
    recap: 'Business 3×/mese senza loyalty card: CJA la legge come "alto LTV latente". Onboarding CartaFreccia con accumulo retroattivo.',
    colore: 'var(--color-grigio-300)',
  },
];
---
<BaseLayout
  title="Connessioni FS Park × Trenitalia"
  description="Use case concreti di cross-sell e Data Collaboration tra FS Park e Trenitalia, orchestrati da Adobe CJA e Adobe Data Collaboration."
  pageSolutions={['data-collab']}
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/roadmap')}
    prevHref={href(base, '/convergenza')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center" data-solution="data-collab">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <CoverHero
        eyebrow="04 · Connessioni"
        numeral="04"
        title="FS Park × Trenitalia: connessioni intelligenti"
        lead="Il viaggio non inizia al binario e non finisce all'arrivo. Ogni touchpoint, dal parcheggio alla lounge, è un'occasione di relazione: CJA la rende visibile e Data Collaboration la rende azionabile."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Il gap di oggi ────────────────────────────────── -->
    <Slide id="slide-gap" bg="primary" align="center" data-solution="data-collab">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-parcheggio')}
        imageClass="opacity-[0.06]"
        scrim="bg-transparent"
      />
      <p class="slide-eyebrow text-center text-[var(--accent-primary)] mb-4" data-reveal>
        IL GAP ATTUALE
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Dati che non si parlano. Revenue sul tavolo.
      </h2>
      <p
        class="text-center text-[var(--ink-secondary)] leading-snug max-w-3xl mx-auto mb-7"
        style="font-size: clamp(0.95rem, 1.15vw, 1.1rem);"
        data-reveal
        data-reveal-delay="0.13"
      >
        Ogni sistema conosce solo la propria fetta di cliente. Nella distanza tra quello che sa
        e quello che non vede si nasconde il valore lasciato sul tavolo.
      </p>

      {/* Three station-nodes on the signal line: each system sits on the same rail
          yet never shares what it sees. The line is drawn but the nodes stay dark. */}
      <div class="relative w-full max-w-6xl mx-auto" data-reveal data-reveal-delay="0.18">
        <span class="fs-line-h hidden md:block" style="top: 1.45rem; left: 16.6%; right: 16.6%;" aria-hidden="true"></span>
        <div class="grid md:grid-cols-3 gap-5 relative">
          {[
            {
              brand: 'FS Park',
              rosso: false,
              sa: 'Chi ha prenotato · quando · dove · durata sosta',
              nonSa: 'Se ha viaggiato in Frecce · se ha abbonamento · se è CartaFreccia',
              gap: 'Nessuna offerta bundled. Parcheggio = commodity.',
            },
            {
              brand: 'Trenitalia',
              rosso: true,
              sa: 'Storico biglietti · classe · frequenza · canale',
              nonSa: 'Se ha usato FS Park · se ha cercato parcheggio · dove arriva',
              gap: 'Bundle viaggio + parcheggio invisibile. Revenue perso.',
            },
            {
              brand: 'Oracle Responsys',
              rosso: false,
              sa: 'Open rate · click · programma CRM · device',
              nonSa: 'Se ha appena prenotato · abbonamento in scadenza · LTV reale',
              gap: 'Campagne a calendario, non contestuali. Disiscrizioni alte.',
            },
          ].map((item, i) => (
            <div class="flex flex-col items-center">
              <span class:list={["fs-node mb-4 relative z-10", item.rosso && "fs-node--rosso"]} aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="fs-card w-full text-left flex flex-col gap-2.5">
                <p class="fs-card-title mb-0.5">{item.brand}</p>
                <p class="fs-card-body">
                  <span class="font-bold tracking-wider uppercase text-emerald-400 text-[0.76rem]">SA · </span>{item.sa}
                </p>
                <p class="fs-card-body">
                  <span class="font-bold tracking-wider uppercase text-[var(--accent-primary)] text-[0.76rem]">NON SA · </span>{item.nonSa}
                </p>
                <p class="text-[0.92rem] text-[var(--color-grigio-300)] italic leading-snug pt-3 mt-auto border-t border-[var(--line-subtle)]">{item.gap}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 1b: Perché serve Data Collaboration ─────────────── -->
    <Slide id="slide-why-collab" bg="secondary" align="center" data-solution="data-collab">
      <div slot="backdrop" class="fs-bg-soft"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        PERCHÉ SERVE DATA COLLABORATION — ANCHE DENTRO IL GRUPPO FS
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-8 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.7rem, 2.9vw, 2.6rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Stesso Gruppo, entità separate.<br/>La clean room è obbligatoria.
      </h2>

      {/* Two entities on the same rail — the clean room is the node where their
          audiences meet without exchanging PII in the clear. */}
      <div class="relative w-full max-w-5xl mx-auto" data-reveal data-reveal-delay="0.16">
        <div class="flex items-center justify-center gap-4 mb-8" aria-hidden="true">
          <span class="fs-node">FP</span>
          <span class="fs-line-h relative flex-1 max-w-[7rem]" style="position: relative; top: auto; left: auto; right: auto;"></span>
          <span class="fs-node fs-node--rosso" data-active>CR</span>
          <span class="fs-line-h relative flex-1 max-w-[7rem]" style="position: relative; top: auto; left: auto; right: auto;"></span>
          <span class="fs-node">TR</span>
        </div>
        <div class="grid md:grid-cols-2 gap-5 text-left">
          <div class="fs-panel">
            <p class="fs-panel-tag">Entità separate</p>
            <p class="fs-panel-body mt-3">
              FS Park e Trenitalia sono <strong class="text-[var(--ink-primary)]">entità giuridiche separate</strong>.
              Il GDPR impone che la condivisione di dati personali identificativi tra società distinte passi da
              consenso, DPA formale e minimizzazione dei dati.
            </p>
          </div>
          <div class="fs-panel fs-panel--rosso">
            <p class="fs-panel-tag" style="color: rgba(226,0,26,0.98);">La clean room</p>
            <p class="fs-panel-body mt-3">
              CJA analizza i comportamenti aggregati di entrambe, ma <strong class="text-[var(--ink-primary)]">non può attivare
              campagne cross-entità su PII senza una clean room</strong>. Adobe Data Collaboration risolve il nodo:
              fa incontrare le audience senza scambiare dati in chiaro, resta GDPR-compliant e misura l'attribuzione.
            </p>
          </div>
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Use Cases ─────────────────────────────────────── -->
    <Slide id="slide-usecases" bg="secondary" align="center" data-solution="data-collab">
      <div slot="backdrop" class="fs-bg-soft"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        TRE USE CASE · ROI MISURABILE
      </p>
      <h2
        class="text-center text-[var(--ink-primary)] mb-6 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.55rem, 2.5vw, 2rem); line-height: 1.05;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Dalla data intelligence all'azione concreta.
      </h2>

      {/* Three use-cases threaded on one vertical rail — each is a station on the
          same line, tagged, recapped, with its measurable impact called out. */}
      <div
        class="relative w-full max-w-6xl mx-auto flex flex-col gap-4"
        data-reveal
        data-reveal-delay="0.18"
      >
        {useCases.map((uc, i) => (
          <div class:list={["fs-panel text-left", uc.id === "uc1" && "fs-panel--rosso"]}>
            <div class="flex items-center gap-8">
              <div class="flex-shrink-0 w-[17rem] flex items-start gap-4">
                <span class:list={["fs-node flex-shrink-0", uc.id === "uc1" && "fs-node--rosso"]} data-active aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <p class="fs-panel-tag mb-1">{uc.tag}</p>
                  <h3 class="text-[1.15rem] font-bold text-[var(--ink-primary)] font-[family-name:var(--font-display)] leading-snug">{uc.title}</h3>
                </div>
              </div>
              <div class="flex-1 grid md:grid-cols-[2.2fr_1fr] gap-x-8 items-center">
                <p class="fs-panel-body">{uc.recap}</p>
                <div>
                  <p class="fs-panel-tag mb-1">Impatto</p>
                  <p class="fs-panel-figure" style="font-size: 1.15rem;">{uc.impatto}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Slide>

    <!-- ── SLIDE 3: Data Collaboration — come funziona ────────────── -->
    <Slide id="slide-data-collab" bg="primary" align="left" data-solution="data-collab">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <div data-demo-flex class="w-full flex items-start gap-8">
        <div class="flex-1 min-w-0 flex flex-col text-left">
          <p class="slide-eyebrow text-[var(--accent-secondary)] mb-4" data-reveal>
            ADOBE DATA COLLABORATION
          </p>
          <h2
            class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.5rem, 2.4vw, 2.1rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.08"
          >
            Privacy-first. Revenue-positive.
          </h2>
          <p
            class="text-[var(--color-grigio-200)] leading-snug mb-6"
            style="font-size: clamp(0.9rem, 1.05vw, 1rem);"
            data-reveal
            data-reveal-delay="0.14"
          >
            Adobe Data Collaboration crea una clean room tra FS Park e Trenitalia: collaborano
            sull'overlap dei clienti senza mai scambiarsi PII. Audience matching GDPR-compliant e campagne misurabili.
          </p>

          {/* Four sequential nodes on a single connected rail: hash → overlap →
              activate → attribute. The line runs left of the nodes, top to bottom. */}
          <div class="relative flex flex-col gap-4 pl-1" data-reveal data-reveal-delay="0.2">
            <span
              class="absolute w-[2px] left-[calc(1.45rem-1px)] top-6 bottom-6"
              style="background: linear-gradient(180deg, rgba(245,166,35,0) 0%, rgba(245,166,35,0.9) 12%, rgba(245,166,35,0.9) 88%, rgba(245,166,35,0) 100%); box-shadow: 0 0 10px rgba(245,166,35,0.45);"
              aria-hidden="true"
            ></span>
            {[
              {
                step: '01',
                label: 'Hashing & Match',
                desc: 'Entrambe portano i segmenti come hash pseudonimi — mai dati in chiaro.',
              },
              {
                step: '02',
                label: 'Clean Room Overlap',
                desc: 'Si calcola l\'overlap: quanti clienti FS Park hanno viaggiato in Frecce.',
              },
              {
                step: '03',
                label: 'Audience Activation',
                desc: 'L\'audience si attiva in Responsys e nell\'app — senza trasferire dati.',
              },
              {
                step: '04',
                label: 'Attribution chiara',
                desc: 'Conversione attribuita con modello fractional: FS Park, Trenitalia, Adobe.',
              },
            ].map((s) => (
              <div class="relative flex gap-4 items-start">
                <span class="fs-node flex-shrink-0 relative z-10" style="width: 2.9rem; height: 2.9rem; font-size: 0.95rem;" aria-hidden="true">
                  {s.step}
                </span>
                <div class="flex-1 min-w-0 pt-1">
                  <p class="text-[1.1rem] font-semibold text-[var(--ink-primary)] font-[family-name:var(--font-display)] mb-0.5 leading-tight">{s.label}</p>
                  <p class="text-[0.96rem] text-[var(--color-grigio-200)] leading-snug">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <MediaDemoSlot id="data-collab-demo" label="Adobe Data Collaboration — Clean Room FS" />
      </div>
    </Slide>

    <!-- ── SLIDE 4: AEP Data Governance & Security ────────────────── -->
    <Slide id="slide-governance" bg="secondary" align="center" data-solution="data-collab">
      <div slot="backdrop" class="fs-bg-soft"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <p class="slide-eyebrow text-center text-[var(--accent-secondary)] mb-4" data-reveal>
        AEP · DATA GOVERNANCE & SECURITY
      </p>
      <h2
        class="text-[var(--ink-primary)] mb-4 font-[family-name:var(--font-display)]"
        style="font-size: clamp(1.5rem, 2.4vw, 2.1rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Un'unica piattaforma governata. Un solo perimetro.
      </h2>
      <p
        class="text-center text-[var(--ink-secondary)] leading-snug max-w-4xl mx-auto mb-6"
        style="font-size: clamp(0.92rem, 1.05vw, 1rem);"
        data-reveal
        data-reveal-delay="0.14"
      >
        PII sparsi su sei sistemi moltiplicano la superficie di attacco. Centralizzando in AEP,
        il Gruppo passa da sei perimetri a uno solo, che protegge RTCDP, CJA, AJO e Data Collaboration.
      </p>

      {/* Four controls of the single governed perimeter — numbered marks, no emoji. */}
      <div
        class="w-full max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 mb-4"
        data-reveal
        data-reveal-delay="0.2"
      >
        {[
          { n: '01', label: 'Sensitivity labels', desc: 'Ogni campo classificato per sensibilità — PII protetto by design.' },
          { n: '02', label: 'Usage policy enforce', desc: 'Policy applicate in automatico: nessuna attivazione fuori consenso.' },
          { n: '03', label: 'Audit trail completo', desc: 'Log di ogni accesso — chi tocca cosa, e quando.' },
          { n: '04', label: 'Pseudonimizzazione', desc: 'Identità su hash — mai PII in chiaro fuori perimetro.' },
        ].map((p) => (
          <div class="fs-card text-left flex flex-col gap-2.5">
            <span class="fs-mark" aria-hidden="true">{p.n}</span>
            <p class="fs-card-title">{p.label}</p>
            <p class="fs-card-body">{p.desc}</p>
          </div>
        ))}
      </div>

      <div
        class="fs-panel fs-panel--rosso max-w-5xl mx-auto flex items-start gap-4 text-left"
        data-reveal
        data-reveal-delay="0.3"
      >
        <svg class="flex-shrink-0 mt-0.5" width="24" height="24" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2l6.5 3v5c0 4-2.8 6.7-6.5 8-3.7-1.3-6.5-4-6.5-8V5L10 2z" stroke="rgba(226,0,26,0.95)" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
        <p class="fs-panel-body">
          <strong class="text-[var(--ink-primary)]">Perché conta oggi:</strong> il caso pubblico di violazione dati
          che ha coinvolto Trenitalia nel giugno 2026 ricorda quanto pesi il rischio quando i dati personali
          vivono sparsi. Un perimetro unico e governato è la risposta strutturale.
          <span class="block mt-2 text-[0.72rem] tracking-wide uppercase text-[var(--color-grigio-300)]">Rif. cronaca pubblica · sky.it/cronaca (giu 2026) — illustrativo</span>
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 5: Il valore end-to-end ─────────────────────────── -->
    <Slide id="slide-value" bg="brand" align="center" data-solution="data-collab">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-viaggio')}
        imageClass="opacity-10"
        scrim="bg-[var(--accent-primary)]/88"
      />
      <div slot="backdrop" class="fs-grid" style="opacity: 0.28;"></div>
      <p class="slide-eyebrow text-center text-[var(--color-ghiaccio)]/75 mb-4" data-reveal>
        IL VALORE COMPLESSIVO
      </p>
      <h2
        class="font-[family-name:var(--font-display)] text-[var(--color-ghiaccio)] mb-4"
        style="font-size: clamp(1.6rem, 2.6vw, 2.2rem); font-weight: 600; line-height: 1.05; letter-spacing: -0.02em;"
        data-reveal
        data-reveal-delay="0.08"
      >
        Ogni viaggio. Ogni parcheggio. Una relazione.
      </h2>
      <p
        class="text-[var(--color-ghiaccio)]/85 leading-snug max-w-2xl mx-auto mb-4"
        style="font-size: clamp(0.92rem, 1.1vw, 1.05rem);"
        data-reveal
        data-reveal-delay="0.15"
      >
        CJA + Data Collaboration legge ogni touchpoint come un segnale di relazione e lo traduce
        in un'azione pertinente. Basta batch-and-blast e dati chiusi nei silos.
      </p>

      {/* Four terminal stations on the rosso ground — the end-to-end payoff, each
          station a measured outcome. Ghiaccio ink on rosso for AA contrast. */}
      <div class="relative w-full max-w-4xl mx-auto mb-6" data-reveal data-reveal-delay="0.22">
        <span class="hidden md:block absolute top-0 left-[10%] right-[10%] h-[2px]" style="background: linear-gradient(90deg, rgba(242,244,248,0) 0%, rgba(242,244,248,0.55) 12%, rgba(242,244,248,0.55) 88%, rgba(242,244,248,0) 100%);" aria-hidden="true"></span>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3.5 md:pt-6">
          {[
            { value: '+18%', label: 'LTV medio cliente cross-brand', sub: 'Benchmark Adobe Travel & Transport' },
            { value: '–35%', label: 'Costo di acquisizione abbonamento', sub: 'Early-trigger vs batch — stima illustrativa' },
            { value: '€12–18', label: 'Revenue accessorio/viaggio (stima)', sub: 'Bundle parcheggio + servizi correlati' },
            { value: '100%', label: 'GDPR-compliant', sub: 'Zero PII condivisi tra FS Park e Trenitalia' },
          ].map((m) => (
            <div class="relative text-center px-3 py-4 bg-[var(--color-ghiaccio)]/10 border border-[var(--color-ghiaccio)]/25 rounded-sm">
              <span class="hidden md:block absolute -top-[calc(1.5rem+5px)] left-1/2 -translate-x-1/2 w-2.5 h-2.5 rounded-full bg-[var(--color-ghiaccio)]" style="box-shadow: 0 0 10px rgba(242,244,248,0.7);" aria-hidden="true"></span>
              <p
                class="font-[family-name:var(--font-display)] font-bold text-[var(--color-ghiaccio)] leading-none mb-1.5"
                style="font-size: clamp(1.8rem, 2.8vw, 2.4rem);"
              >
                {m.value}
              </p>
              <p class="text-[0.98rem] font-medium text-[var(--color-ghiaccio)]/90 mb-1 leading-snug">{m.label}</p>
              <p class="text-[0.78rem] text-[var(--color-ghiaccio)]/70 leading-snug">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>

      <a
        href={href(base, '/roadmap')}
        class="inline-flex items-center gap-3 px-8 py-3 text-base font-semibold tracking-wide bg-[var(--color-ghiaccio)] text-[var(--color-carbonio)] hover:bg-white transition-colors duration-300 font-[family-name:var(--font-display)]"
        data-reveal
        data-reveal-delay="0.3"
      >
        Roadmap: i prossimi passi
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </Slide>

  </DeckContainer>
</BaseLayout>
