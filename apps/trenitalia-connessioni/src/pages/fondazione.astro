---
import BaseLayout from '../layouts/BaseLayout.astro';
import TreniNavigation from '../components/TreniNavigation.astro';
import DeckContainer from '@edf/core/blocks/immersive/DeckContainer.astro';
import Slide from '@edf/core/blocks/immersive/Slide.astro';
import CoverHero from '@edf/core/blocks/CoverHero.astro';
import SlideBackdrop from '@edf/core/blocks/SlideBackdrop.astro';
import { href } from '@edf/core/utils/url.js';
import { mediaProps } from '../../assets.index';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const strati = [
  {
    layer: 'Content & Experience',
    color: 'var(--accent-primary)',
    prodotti: [
      { nome: 'AEM Sites / Edge Delivery', stato: 'Attivo', desc: 'trenitalia.com + ~33 siti · cloud, edge, fast' },
    ],
  },
  {
    layer: 'Analytics & Behavioral Data',
    color: 'var(--color-ambra)',
    prodotti: [
      { nome: 'Adobe Analytics (×2)', stato: 'Attivo', desc: 'Sito istituzionale + funnel acquisto' },
      { nome: 'Adobe Target',          stato: 'Parziale', desc: 'Solo homepage · assente su funnel e app' },
    ],
  },
  {
    layer: 'CRM & Marketing Automation',
    color: 'var(--color-grigio-300)',
    prodotti: [
      { nome: 'Oracle Responsys',    stato: 'Attivo', desc: 'CartaFreccia · X-GO · 611+ email/anno' },
      { nome: 'Salesforce CRM',      stato: 'Foundation 2026', desc: 'Backbone operativo · MuleSoft · Data Cloud' },
    ],
  },
  {
    layer: 'Intelligence Layer',
    color: 'var(--color-grigio-500)',
    prodotti: [
      { nome: 'Customer Journey Analytics', stato: 'Opportunità', desc: 'Il layer mancante — converge i segnali in una vista unica' },
    ],
  },
];

const statoTone = (stato) =>
  stato === 'Attivo'          ? 'bg-emerald-500/15 text-emerald-400' :
  stato === 'Parziale'        ? 'bg-[var(--accent-secondary)]/15 text-[var(--accent-secondary)]' :
  stato === 'Opportunità'     ? 'bg-[var(--accent-primary)]/15 text-[var(--accent-primary)]' :
                                'bg-[var(--color-binario)] text-[var(--color-grigio-200)]';
---
<BaseLayout
  title="Le fondamenta che avete già"
  description="AEM, Adobe Analytics, Target, Oracle Responsys, Salesforce: fondamenta solide. CJA è il layer di intelligence che le completa."
>
  <div class="fixed top-0 left-0 right-0 z-50">
    <TreniNavigation currentPath={currentPath} base={base} />
  </div>

  <DeckContainer
    nextHref={href(base, '/convergenza')}
    prevHref={href(base, '/scenario')}
  >

    <!-- ── SLIDE 0: Cover ─────────────────────────────────────────── -->
    <Slide id="slide-cover" bg="primary" align="center">
      <div slot="backdrop" class="fs-bg"></div>
      <div slot="backdrop" class="fs-grid"></div>
      <CoverHero
        eyebrow="02 · Foundation"
        numeral="02"
        title="Le fondamenta che avete già"
        lead="Ciò che funziona resta al suo posto. Il lavoro è collegare i sistemi che avete già e aggiungere lo strato di intelligence che oggi manca."
        size="phase"
        tone="ink"
        signature={false}
      />
    </Slide>

    <!-- ── SLIDE 1: Ecosistema a strati (nodi sulla linea del segnale) ── -->
    <Slide id="slide-ecosystem" bg="primary" align="center">
      <div slot="backdrop" class="fs-bg-soft"></div>
      <div slot="backdrop" class="fs-grid"></div>

      <div class="w-full max-w-6xl mx-auto">
        <div class="text-center mb-6">
          <p class="fs-panel-tag inline-block" data-reveal>
            L'ECOSISTEMA ATTUALE · CJA SI AGGIUNGE SOPRA
          </p>
          <h2
            class="text-[var(--ink-primary)] mt-3 font-[family-name:var(--font-display)]"
            style="font-size: clamp(1.6rem, 2.3vw, 2.1rem); font-weight: 600; line-height: 1.06; letter-spacing: -0.02em;"
            data-reveal
            data-reveal-delay="0.08"
          >
            Un ecosistema ricco. Un layer da completare.
          </h2>
        </div>

        {/* strati: Oracle Responsys fonte campione email luglio 2026 · AEM fonte osservazione pubblica · Salesforce v. slide successiva */}
        <div class="relative flex flex-col gap-3">
          {/* la linea del segnale che infila i nodi-stazione */}
          <div class="fs-line-h hidden md:block" style="left: 1.45rem; top: 1.45rem; bottom: 1.45rem; width: 2px; height: auto; background: linear-gradient(180deg, rgba(245,166,35,0) 0%, rgba(245,166,35,0.9) 8%, rgba(245,166,35,0.9) 92%, rgba(245,166,35,0) 100%);" aria-hidden="true"></div>

          {strati.map((strato, i) => (
            <div
              class="relative grid md:grid-cols-[15rem_1fr] items-center gap-4 md:pl-0"
              data-reveal
              data-reveal-delay={(0.16 + i * 0.07).toFixed(2)}
            >
              <div class="flex items-center gap-4">
                <span
                  class="fs-node flex-shrink-0 relative z-10"
                  data-active
                  style={`border-color: ${strato.color}; box-shadow: 0 0 18px ${strato.color}55;`}
                  aria-hidden="true"
                >{i + 1}</span>
                <p class="fs-node-label font-semibold uppercase tracking-widest leading-tight" style={`color: ${strato.color}; font-size: 0.82rem;`}>
                  {strato.layer}
                </p>
              </div>

              <div class={`grid gap-3 ${strato.prodotti.length > 1 ? 'md:grid-cols-2' : 'grid-cols-1'}`}>
                {strato.prodotti.map((p) => (
                  <div class="fs-card flex items-center gap-4" style="padding: 0.85rem 1.1rem;">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2.5 flex-wrap mb-1">
                        <p class="fs-card-title" style="font-size: 1.1rem;">{p.nome}</p>
                        <span class={['text-[0.72rem] font-bold px-2 py-0.5 rounded-sm tracking-wide uppercase flex-shrink-0', statoTone(p.stato)].join(' ')}>
                          {p.stato}
                        </span>
                      </div>
                      <p class="fs-card-body" style="font-size: 0.95rem; line-height: 1.4;">{p.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </Slide>

    <!-- ── SLIDE 2: Salesforce Foundation — il nuovo backbone ─────── -->
    <Slide id="slide-salesforce" bg="secondary" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-dati')}
        imageClass="opacity-08"
        scrim="bg-[var(--surface-secondary)]/94"
      />
      <div slot="backdrop" class="fs-bg-soft"></div>

      <div class="w-full max-w-6xl mx-auto">
        <div class="fs-panel fs-panel--rosso mb-5" data-reveal>
          <p class="fs-panel-tag">FS TECHNOLOGY + SALESFORCE · Q1 2026</p>
          <h2 class="fs-panel-head mt-1 mb-3" style="font-size: clamp(1.5rem, 2.3vw, 2.1rem);">
            La foundation agentica è partita.<br/>Adobe si innesta su di essa.
          </h2>
          <p class="fs-panel-body max-w-4xl" style="font-size: clamp(0.98rem, 1.1vw, 1.08rem); line-height: 1.62;">
            A marzo 2026 FS Technology ha lanciato con Salesforce una piattaforma agentica che unisce
            Trenitalia, Busitalia, FS Park e FS Logistix in un unico backbone CRM — MuleSoft come
            integration engine, Data Cloud come layer dati. Adobe CJA ingerisce da Data Cloud via
            connettore nativo e aggiunge l'intelligenza del journey che nessun CRM genera da solo.
          </p>
        </div>

        <div
          class="grid md:grid-cols-3 gap-4 mb-4"
          data-reveal
          data-reveal-delay="0.14"
        >
          {[
            {
              n: '01',
              prodotto: 'Salesforce CRM',
              ruolo: 'Backbone operativo',
              adobe: 'Adobe CJA legge i profili CRM e li arricchisce con behavioral journey data',
            },
            {
              n: '02',
              prodotto: 'MuleSoft',
              ruolo: 'Integration engine',
              adobe: 'Già in campo → feed dati verso AEP/CJA senza nuova infrastruttura',
            },
            {
              n: '03',
              prodotto: 'Salesforce Data Cloud',
              ruolo: 'Layer dati centralizzato',
              adobe: 'Connettore nativo AEP: data flow da Data Cloud verso CJA e RTCDP',
            },
          ].map((item) => (
            <div class="fs-card flex flex-col">
              <div class="flex items-center gap-3 mb-2">
                <span class="fs-mark" aria-hidden="true">{item.n}</span>
                <div>
                  <p class="fs-card-title" style="font-size: 1.1rem;">{item.prodotto}</p>
                  <p class="text-[0.78rem] text-[var(--accent-secondary)] font-semibold uppercase tracking-wide">{item.ruolo}</p>
                </div>
              </div>
              <p class="fs-card-body" style="font-size: 0.95rem;">
                <strong class="text-[var(--accent-secondary)]">Adobe:</strong> {item.adobe}
              </p>
            </div>
          ))}
        </div>

        <p class="fs-panel-src text-center" data-reveal data-reveal-delay="0.24">
          Fonte:&nbsp;
          <a href="https://www.fsnews.it/it/focus-on/innovazione/2026/3/5/fs-technology-salesforce-foundation-digitale.html" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-80">
            fsnews.it — FS Technology + Salesforce Foundation Digitale (mar 2026)
          </a>
        </p>
      </div>
    </Slide>

    <!-- ── SLIDE 3: La scelta · non disruption, connessione ──────── -->
    <Slide id="slide-choice" bg="brand" align="center">
      <SlideBackdrop
        slot="backdrop"
        {...mediaProps('bg-binari')}
        imageClass="opacity-08"
        scrim="bg-[var(--accent-primary)]/90"
      />
      <div class="w-full max-w-3xl mx-auto text-left">
        <p class="slide-eyebrow text-[var(--color-ghiaccio)]/70 mb-8" data-reveal>
          IL PRINCIPIO GUIDA
        </p>
        <div class="fs-quote" data-reveal data-reveal-delay="0.08">
          <h2
            class="fs-quote-text text-[var(--color-ghiaccio)] font-[family-name:var(--font-display)]"
            style="font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 700; line-height: 1.0; letter-spacing: -0.03em;"
          >
            Non sostituire.<br/>Connettere.
          </h2>
        </div>
        <p
          class="text-[var(--color-ghiaccio)]/85 leading-relaxed max-w-2xl mt-6 mb-10"
          style="font-size: clamp(1.1rem, 1.5vw, 1.4rem);"
          data-reveal
          data-reveal-delay="0.16"
        >
          Oracle Responsys continua a eseguire le campagne, Salesforce a gestire i profili,
          AEM a consegnare i contenuti. CJA si aggiunge come layer che li legge tutti e restituisce,
          per la prima volta, una vista del journey completa e pronta all'uso.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 max-w-2xl"
          data-reveal
          data-reveal-delay="0.24"
        >
          <a
            href={href(base, '/convergenza')}
            class="flex-1 inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-semibold tracking-wide bg-[var(--color-ghiaccio)] text-[var(--color-carbonio)] hover:bg-white transition-colors duration-300 font-[family-name:var(--font-display)]"
          >
            CJA: il layer di convergenza
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Slide>

  </DeckContainer>
</BaseLayout>
