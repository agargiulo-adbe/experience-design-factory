{
  "name": "experience-design-factory",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter generazioni-maxmara dev",
    "dev:ferrari": "pnpm --filter ferrari-racing dev",
    "dev:unicredit": "pnpm --filter unicredit-engagement dev",
    "dev:console": "pnpm --filter console dev",
    "dev:showcase": "pnpm --filter factory-showcase dev",
    "dev:trenitalia": "pnpm --filter trenitalia-connessioni dev",
    "dev:atelier": "pnpm --filter atelier dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "assets:build": "pnpm --filter generazioni-maxmara assets:build",
    "audit:deck:all": "pnpm --filter generazioni-maxmara audit:deck && pnpm --filter unicredit-engagement audit:deck && pnpm --filter ferrari-racing audit:deck && pnpm --filter trenitalia-connessioni audit:deck && pnpm --filter atelier audit:deck",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.28.0",
    "vitest": "^2.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "playwright": "^1.49.1",
    "prettier": "^3.5.3",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.7.0"
}
