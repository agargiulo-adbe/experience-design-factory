{
  "name": "@agargiulo-adbe/experience-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./blocks/*": "./src/blocks/*",
    "./layouts/*": "./src/layouts/*",
    "./theme/*": "./src/theme/*",
    "./schema": "./src/schema/index.ts",
    "./registry": "./src/registry/index.ts",
    "./i18n": "./src/i18n/index.ts"
  },
  "scripts": {
    "build": "echo 'Core is consumed as source by Astro — no build needed'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
