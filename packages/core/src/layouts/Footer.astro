---
interface Props {
  base: string;
}

const { base } = Astro.props;
---

<footer class="py-12 md:py-16 bg-[var(--surface-inverse)] text-[var(--ink-inverse)]" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <div>
        <p class="font-[family-name:var(--font-display)] text-2xl font-light mb-2">Generazioni</p>
        <p class="text-sm text-[var(--color-grigio-400)]">
          Un progetto <span class="text-[var(--color-grigio-300)]">Max Mara</span> × <span class="text-[var(--accent-secondary)]">Adobe</span>
        </p>
      </div>
      <div class="text-right">
        <p class="text-xs text-[var(--color-grigio-500)]">
          Experience Design by Adobe. Tutti i contenuti sono a scopo dimostrativo.
        </p>
        <p class="text-xs text-[var(--color-grigio-500)] mt-1">
          © {new Date().getFullYear()} Experience Design Factory
        </p>
      </div>
    </div>
  </div>
</footer>
