---
interface Product {
  name: string;
  description: string;
}

interface Props {
  title: string;
  body: string;
  products: Product[];
}

const { title, body, products } = Astro.props;
---

<section class="py-16 md:py-24 bg-[var(--surface-primary)]" data-block="product-gateway">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="max-w-2xl mb-12 md:mb-16">
      <p class="text-xs font-medium tracking-[0.1em] uppercase text-[var(--accent-primary)] mb-4">
        Pezzi d'ingresso
      </p>
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw+0.5rem,3rem)] font-light leading-[1.15] text-[var(--ink-primary)] mb-4">
        {title}
      </h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed">
        {body}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <article class="group relative bg-[var(--surface-secondary)] rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-[var(--duration-normal)]">
          <div class="aspect-[4/5] bg-[var(--surface-tertiary)] relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center text-[var(--ink-tertiary)] opacity-30">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.75" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-[var(--duration-normal)]"></div>
          </div>
          <div class="p-5">
            <h3 class="text-base font-medium text-[var(--ink-primary)] mb-1.5">
              {product.name}
            </h3>
            <p class="text-sm text-[var(--ink-tertiary)] leading-relaxed">
              {product.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
