---
interface Props {
  value: string;
  label: string;
  context?: string;
  source?: string;
  variant?: 'default' | 'large' | 'inline';
}

const { value, label, context, source, variant = 'default' } = Astro.props;
const isLarge = variant === 'large';
---

<div class:list={[
  "py-12 md:py-16",
  isLarge ? "bg-[var(--surface-secondary)]" : "bg-[var(--surface-primary)]"
]} data-block="metric-callout" data-variant={variant}>
  <div class:list={[
    "max-w-5xl mx-auto px-6 md:px-12",
    isLarge ? "text-center" : "flex flex-col md:flex-row md:items-baseline gap-4 md:gap-8"
  ]}>
    <p class:list={[
      "font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)]",
      isLarge ? "text-[clamp(3rem,8vw,7rem)] leading-none mb-4" : "text-[clamp(2.5rem,4vw,4rem)] leading-none md:flex-shrink-0"
    ]}>
      {value}
    </p>
    <div class:list={[isLarge && "max-w-xl mx-auto"]}>
      <p class:list={[
        "text-[var(--ink-primary)]",
        isLarge ? "text-xl md:text-2xl font-[family-name:var(--font-display)] font-light leading-snug mb-3" : "text-base leading-relaxed"
      ]}>
        {label}
      </p>
      {context && (
        <p class="text-sm text-[var(--ink-tertiary)] leading-relaxed mt-2">
          {context}
        </p>
      )}
      {source && (
        <p class="text-xs text-[var(--ink-tertiary)] mt-3 opacity-60">
          Fonte: {source}
        </p>
      )}
    </div>
  </div>
</div>
