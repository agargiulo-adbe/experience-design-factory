---
interface TimelineEntry {
  year: string;
  title: string;
  body?: string;
  highlight?: boolean;
}

interface Props {
  title: string;
  entries: TimelineEntry[];
}

const { title, entries } = Astro.props;
---

<section class="py-20 md:py-32 bg-[var(--surface-primary)]" data-block="timeline">
  <div class="max-w-5xl mx-auto px-6 md:px-12">
    <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw+0.5rem,3rem)] font-light leading-[1.15] text-[var(--ink-primary)] mb-14 md:mb-20">
      {title}
    </h2>

    <div class="relative" role="list" aria-label="Linea del tempo">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-[var(--line-default)]" aria-hidden="true"></div>

      <div class="space-y-10 md:space-y-14">
        {entries.map((entry) => (
          <div class="relative pl-12 md:pl-20" role="listitem">
            <!-- Dot -->
            <div class:list={[
              "absolute left-4 md:left-8 top-1.5 w-2.5 h-2.5 rounded-full -translate-x-1/2 ring-4 ring-[var(--surface-primary)]",
              entry.highlight ? "bg-[var(--accent-primary)]" : "bg-[var(--line-default)]"
            ]} aria-hidden="true"></div>

            <div>
              <p class:list={[
                "text-sm font-medium tracking-wide mb-1",
                entry.highlight ? "text-[var(--accent-primary)]" : "text-[var(--ink-tertiary)]"
              ]}>
                {entry.year}
              </p>
              <h3 class:list={[
                "font-[family-name:var(--font-display)] text-xl md:text-2xl font-light leading-snug",
                entry.highlight ? "text-[var(--ink-primary)]" : "text-[var(--ink-secondary)]"
              ]}>
                {entry.title}
              </h3>
              {entry.body && (
                <p class="text-sm text-[var(--ink-tertiary)] leading-relaxed mt-2 max-w-lg">
                  {entry.body}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
