---
/**
 * HowItWorks — a discreet "Scopri come →" affordance that opens a CENTRED overlay
 * dialog explaining the technology in plain language (Adobe products in context).
 *
 * Robust-by-construction: the dialog is centred, width ≤ min(720px,60vw), and
 * `max-height: calc(100dvh - 2*--slide-safe-inset)`. The content must fit that
 * height WITHOUT scrolling (keep the copy short) — a projected keynote never
 * scrolls. A full-viewport scrim sits behind it.
 *
 * - Does NOT change slide; opens/closes over the deck. Esc / × / click-outside.
 * - Focus-trapped; respects prefers-reduced-motion; locks the deck while open.
 *
 * Body content via the default slot (keep it to a few short lines).
 */
interface Props {
  label?: string;
  title: string;
  /** Slide background tone — sets an AA-contrast trigger colour. */
  tone?: 'onLight' | 'onDark';
  class?: string;
}
const { label = 'Scopri come', title, tone = 'onLight', class: className } = Astro.props;
const panelId = 'hiw-' + title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const triggerColor = tone === 'onDark' ? 'text-[var(--ink-inverse)]' : 'text-[var(--ink-secondary)]';
---
<div class:list={["hiw inline-block", className]} data-hiw>
  <button
    type="button"
    class:list={["hiw-trigger inline-flex items-center gap-2 text-[clamp(0.95rem,1.1vw,1.15rem)] font-medium tracking-wide underline underline-offset-4 decoration-1 hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-[var(--accent-primary)] focus-visible:outline-offset-4", triggerColor]}
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls={panelId}
    data-hiw-open
  >
    {label}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <div class="hiw-overlay fixed inset-0 z-[60] bg-black/45 opacity-0 pointer-events-none transition-opacity duration-300" data-hiw-overlay></div>

  <div
    id={panelId}
    class="hiw-panel fixed left-1/2 top-1/2 z-[61] w-[min(720px,60vw)] bg-[var(--surface-primary)] rounded-xl shadow-2xl opacity-0 pointer-events-none transition-opacity duration-300"
    style="transform: translate(-50%, -50%); max-height: calc(100dvh - 2 * var(--slide-safe-inset));"
    role="dialog"
    aria-modal="true"
    aria-label={title}
    data-hiw-panel
    inert
  >
    <div class="flex flex-col p-9 md:p-11 text-left">
      <div class="flex items-start justify-between gap-6 mb-6">
        <h3 class="font-[family-name:var(--font-display)] font-light text-[clamp(1.7rem,2.6vw,2.4rem)] leading-tight text-[var(--ink-primary)]">{title}</h3>
        <button type="button" class="hiw-close flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-[var(--ink-secondary)] hover:bg-[var(--surface-secondary)] focus-visible:outline-2 focus-visible:outline-[var(--accent-primary)] focus-visible:outline-offset-2" aria-label="Chiudi" data-hiw-close>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" stroke-linecap="round"/></svg>
        </button>
      </div>
      <div class="hiw-body space-y-5"><slot /></div>
    </div>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .hiw-overlay { transition: none; }
  }
</style>

<script>
  function wireHowItWorks() {
    const lockDeck = (locked: boolean) => {
      const deck = document.querySelector('[data-deck]');
      if (!deck) return;
      if (locked) deck.setAttribute('data-deck-lock', '');
      else deck.removeAttribute('data-deck-lock');
    };

    document.querySelectorAll<HTMLElement>('[data-hiw]').forEach((root) => {
      if (root.dataset.hiwReady) return;
      root.dataset.hiwReady = 'true';

      const trigger = root.querySelector<HTMLButtonElement>('[data-hiw-open]');
      const panel = root.querySelector<HTMLElement>('[data-hiw-panel]');
      const overlay = root.querySelector<HTMLElement>('[data-hiw-overlay]');
      const closeBtn = root.querySelector<HTMLButtonElement>('[data-hiw-close]');
      if (!trigger || !panel || !overlay) return;

      const focusable = () => Array.from(
        panel.querySelectorAll<HTMLElement>('a[href],button,textarea,input,select,[tabindex]:not([tabindex="-1"])')
      ).filter((el) => !el.hasAttribute('disabled'));

      const onKey = (e: KeyboardEvent) => {
        if (e.key === 'Escape') { e.preventDefault(); close(); return; }
        if (e.key === 'Tab') {
          const items = focusable();
          if (!items.length) return;
          const first = items[0], last = items[items.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      };

      function open() {
        // Move overlay + panel to <body> so they escape the deck's transformed
        // slide and become true viewport-fixed top-level elements.
        document.body.appendChild(overlay);
        document.body.appendChild(panel);
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        panel.classList.remove('opacity-0', 'pointer-events-none');
        panel.removeAttribute('inert');
        trigger.setAttribute('aria-expanded', 'true');
        lockDeck(true);
        document.addEventListener('keydown', onKey, true);
        (closeBtn ?? focusable()[0])?.focus();
      }
      function close() {
        overlay.classList.add('opacity-0', 'pointer-events-none');
        panel.classList.add('opacity-0', 'pointer-events-none');
        panel.setAttribute('inert', '');
        trigger.setAttribute('aria-expanded', 'false');
        lockDeck(false);
        document.removeEventListener('keydown', onKey, true);
        trigger.focus();
      }

      trigger.addEventListener('click', (e) => { e.stopPropagation(); open(); });
      overlay.addEventListener('click', (e) => { e.stopPropagation(); close(); });
      closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); close(); });
    });
  }

  wireHowItWorks();
  document.addEventListener('astro:after-swap', wireHowItWorks);
</script>
