---
/**
 * HowItWorks — a discreet "Scopri come →" affordance that expands its content
 * INLINE, in place, pushing the content below it down (soft GSAP height tween,
 * ~450ms quiet ease). No overlay, no scrim, no position:fixed — the text simply
 * "blossoms" where you are and closes the same way.
 *
 * - Lives in the normal slide flow → the expanded content must still respect the
 *   deck invariants (no clip outside the viewport, no hidden scroll, ≥16px rhythm,
 *   AA contrast). The audit expands it and re-measures the slide.
 * - prefers-reduced-motion: instant toggle (no animation), content not skipped.
 *
 * Body content via the default slot (the validated paragraphs).
 */
interface Props {
  label?: string;
  title: string;
  /** Slide background tone — sets an AA-contrast trigger colour. */
  tone?: 'onLight' | 'onDark';
  class?: string;
}
const { label = 'Scopri come', title, tone = 'onLight', class: className } = Astro.props;
const regionId = 'hiw-' + title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const triggerColor = tone === 'onDark' ? 'text-[var(--ink-inverse)]' : 'text-[var(--ink-secondary)]';
---
<div class:list={["hiw", className]} data-hiw>
  <button
    type="button"
    class:list={["hiw-trigger inline-flex items-center gap-2 text-[clamp(0.95rem,1.1vw,1.15rem)] font-medium tracking-wide underline underline-offset-4 decoration-1 hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-[var(--accent-primary)] focus-visible:outline-offset-4", triggerColor]}
    aria-expanded="false"
    aria-controls={regionId}
    data-hiw-open
  >
    {label}
    <svg class="hiw-arrow transition-transform duration-300" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <div id={regionId} class="hiw-region overflow-hidden" style="height: 0; opacity: 0;" data-hiw-region aria-hidden="true">
    <div class="hiw-body pt-2 space-y-4 text-left"><slot /></div>
  </div>
</div>

<script>
  function wireHowItWorks() {
    const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLElement>('[data-hiw]').forEach((root) => {
      if (root.dataset.hiwReady) return;
      root.dataset.hiwReady = 'true';

      const trigger = root.querySelector<HTMLButtonElement>('[data-hiw-open]');
      const region = root.querySelector<HTMLElement>('[data-hiw-region]');
      const arrow = root.querySelector<SVGElement>('.hiw-arrow');
      if (!trigger || !region) return;
      let open = false;

      async function setOpen(next: boolean) {
        open = next;
        trigger!.setAttribute('aria-expanded', String(next));
        if (next) region!.removeAttribute('aria-hidden'); else region!.setAttribute('aria-hidden', 'true');
        if (arrow) arrow.style.transform = next ? 'rotate(90deg)' : 'none';

        if (REDUCED) {
          region!.style.height = next ? 'auto' : '0';
          region!.style.opacity = next ? '1' : '0';
          return;
        }
        const { gsap } = await import('gsap');
        if (next) {
          region!.style.height = 'auto';
          const h = region!.offsetHeight;
          region!.style.height = '0';
          gsap.to(region!, { height: h, opacity: 1, duration: 0.45, ease: 'power2.out',
            onComplete: () => { region!.style.height = 'auto'; } });
        } else {
          const h = region!.offsetHeight;
          gsap.fromTo(region!, { height: h }, { height: 0, opacity: 0, duration: 0.4, ease: 'power2.inOut' });
        }
      }

      trigger.addEventListener('click', (e) => { e.stopPropagation(); setOpen(!open); });
      // Esc collapses (no focus trap needed — content is in normal flow)
      trigger.addEventListener('keydown', (e) => { if (e.key === 'Escape' && open) { e.preventDefault(); setOpen(false); } });
    });
  }

  wireHowItWorks();
  document.addEventListener('astro:after-swap', wireHowItWorks);
</script>
