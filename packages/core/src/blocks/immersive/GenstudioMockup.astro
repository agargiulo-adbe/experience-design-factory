  font-size: clamp(0.68rem, 0.9vw, 0.82rem);
  font-family: -apple-system,'Segoe UI',Inter,sans-serif;
  padding: 0.4rem 1.25rem;
  border-radius: 20px;
  text-align: center;
  letter-spacing: 0.01em;
  line-height: 1.4;
  max-width: 58rem;
}
</style>

<script is:inline define:vars={{ slug }}>
(function () {
  var PROMPT = 'Race day emotion — Ferrari × HP — speed precision victory Tifosi';
  var PHASES = ['brief', 'generating', 'variants'];
  var currentPhase = 0;
  var typingInterval = null;

  var slide = document.querySelector('[data-mockup-slide="genstudio"]');
  if (!slide) return;

  var CAPTIONS = {
    brief: {
      en: 'Set brand, persona and channels — GenStudio auto-fills the brief for Ferrari × HP',
      it: 'Brand, persona e canali — GenStudio compila il brief Ferrari × HP in automatico'
    },
    generating: {
      en: 'Adobe AI generating channel-ready variants — brand score applied to each ad',
      it: "L'AI Adobe genera varianti pronte per i canali — brand score calcolato su ogni ad"
    },
    variants: {
      en: '4 HP × Ferrari variants ready — brand-scored, compliant, one click to publish',
      it: '4 varianti HP × Ferrari pronte — brand score, conformi, un clic per pubblicare'
    }
  };

  function setCaption(name) {
    var cap = CAPTIONS[name];
    if (!cap) return;
    var enEl = slide.querySelector('[data-gs-cap="en"]');
    var itEl = slide.querySelector('[data-gs-cap="it"]');
    if (enEl) enEl.textContent = cap.en;
    if (itEl) itEl.textContent = cap.it;
  }

  function showPhase(name) {
    slide.querySelectorAll('[data-gs-phase]').forEach(function (el) {
      el.hidden = el.getAttribute('data-gs-phase') !== name;
    });
    if (name === 'brief') typePrompt();
    if (name === 'generating') animateGenerate();
    setCaption(name);
  }

  function typePrompt() {
    var el = slide.querySelector('[data-gs-typed]');
    if (!el) return;
    clearInterval(typingInterval);
    el.textContent = '';
    var i = 0;
    typingInterval = setInterval(function () {
      if (i >= PROMPT.length) { clearInterval(typingInterval); return; }
      el.textContent += PROMPT[i++];
    }, 40);
  }

  function animateGenerate() {
    var btn = slide.querySelector('[data-gs-generate]');
    if (!btn) return;
    btn.classList.add('gs-generate-btn-pulse');
    setTimeout(function () { btn.classList.remove('gs-generate-btn-pulse'); }, 1000);
  }

  function init() {
    currentPhase = 0;
    showPhase('brief');
    setCaption('brief');
  }

  // Reset to brief when slide becomes active via deck navigation
  slide.addEventListener('playSlide', init);

  // Intercept deck navigation to advance/retreat between phases
  function patchDeck() {
    var deck = window.__edfDeck;
    if (!deck) return;
    var origNext = deck.next.bind(deck);
    var origPrev = deck.prev.bind(deck);
    deck.next = function () {
      if (deck.slides[deck.index] === slide && currentPhase < PHASES.length - 1) {
        currentPhase++;
        showPhase(PHASES[currentPhase]);
        return;
      }
      origNext();
    };
    deck.prev = function () {
      if (deck.slides[deck.index] === slide && currentPhase > 0) {
        currentPhase--;
        showPhase(PHASES[currentPhase]);
        return;
      }
      origPrev();
    };
  }

  // astro:page-load fires after DeckContainer has initialized __edfDeck
  document.addEventListener('astro:page-load', patchDeck, { once: true });
})();
</script>
