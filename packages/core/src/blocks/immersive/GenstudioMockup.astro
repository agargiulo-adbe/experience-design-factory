  flex-wrap: wrap;
}
.gs-prompt-cursor {
  color: #1473E6;
  animation: gs-blink 1s step-end infinite;
  font-weight: 300;
}
@keyframes gs-blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
.gs-param-tags { display: flex; gap: 0.3rem; flex-wrap: wrap; flex-basis: 100%; }
.gs-tag {
