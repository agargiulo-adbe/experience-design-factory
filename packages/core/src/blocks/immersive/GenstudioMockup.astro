}
.gs-param-filled { border-color: #1473E6; background: #f0f7ff; color: #1473E6; }
.gs-param-prompt { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; min-width: 12rem; }
.gs-prompt-area {
  min-height: 2rem;
  padding: 0.3rem 0.5rem;
  border: 1px solid #d0d0d0; border-radius: 4px;
