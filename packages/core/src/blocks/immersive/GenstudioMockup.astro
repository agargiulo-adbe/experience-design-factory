  font-size: 0.48rem; color: #1473E6; font-weight: 500;
}
.gs-tag-x { opacity: 0.5; }

/* Typed text animation */
.gs-prompt-text { color: #1a1a1a; }

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .gs-score-spinner,
  .gs-gen-avatar,
  .gs-gen-image,
  .gs-gen-line,
  .gs-gen-cta,
  .gs-prompt-cursor { animation: none; opacity: 1; }
  .gs-phase-variants .gs-variant-col { animation: none; }
}

/* ── Caption overlay ─────────────────────────────────────────── */
.gs-caption-bar {
  position: absolute;
  bottom: 4.5rem;
