  flex-shrink: 0;
}
.gs-ad-footer-text { font-size: 0.45rem; color: #555; font-weight: 500; }
.gs-ad-learn-more {
  font-size: 0.45rem; font-family: inherit; font-weight: 700;
  padding: 0.15rem 0.5rem;
  background: #1473E6; color: #fff;
  border: none; border-radius: 3px; cursor: pointer;
}

/* Generate button in variants */
.gs-variants-bottom {
  display: flex;
  justify-content: center;
  padding: 0.5rem 0;
  flex-shrink: 0;
}

/* Generate button */
.gs-generate-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.45rem 1.5rem;
  background: #1473E6;
  color: #fff;
  font-size: 0.7rem; font-family: inherit; font-weight: 600;
  border: none; border-radius: 20px; cursor: pointer;
  transition: background 0.15s;
}
.gs-generate-btn:hover { background: #0d5abf; }
.gs-generate-btn-secondary { background: #f5f5f5; color: #333; border: 1px solid #d0d0d0; }
.gs-generate-btn-secondary:hover { background: #e8e8e8; }
.gs-generate-btn-pulse { animation: gs-pulse 1s ease-in-out; }
@keyframes gs-pulse { 0%,100% { box-shadow: none; } 50% { box-shadow: 0 0 0 6px rgba(20,115,230,0.25); } }

/* ── Parameters panel (brief phase) ─────────────────────────── */
.gs-params-panel {
  background: #fff;
  border-top: 1px solid #e0e0e0;
  padding: 0.625rem 0.875rem;
  display: flex;
  align-items: flex-end;
  gap: 1rem;
  flex-shrink: 0;
  flex-wrap: wrap;
}
.gs-params-header {
  display: flex; align-items: center; gap: 0.35rem;
  font-size: 0.6rem; font-weight: 600; color: #333;
  flex-basis: 100%;
}
.gs-params-body {
  display: flex; gap: 0.625rem; flex-wrap: wrap; align-items: flex-end; flex: 1;
}
.gs-param-row { display: flex; flex-direction: column; gap: 0.2rem; }
.gs-param-label { font-size: 0.5rem; color: #888; font-weight: 500; }
.gs-param-select {
  height: 1.5rem;
  padding: 0 0.5rem;
  border: 1px solid #d0d0d0; border-radius: 4px;
