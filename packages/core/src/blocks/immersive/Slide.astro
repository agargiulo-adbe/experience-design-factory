---
/**
 * Slide — a single full-screen keynote slide inside a DeckContainer.
 *
 * Safe-area guarantee: content lives inside the viewport minus ~8% margins,
 * vertically centred, and is height-constrained (max-h-full + min-h-0) so it
 * never pushes past the safe box or clips the title at the top. If a slide's
 * content doesn't fit, SPLIT it into two slides — don't compress.
 *
 * Slots:
 *  - default  → the slide content (centred within the safe area)
 *  - backdrop → full-bleed layers (atmosphere image, scrim) behind the content
 */
type Props = {
  id?: string;
  bg?: 'primary' | 'secondary' | 'inverse' | 'brand';
  align?: 'center' | 'left' | 'split';
  class?: string;
  [key: string]: unknown;
};
const { id, bg = 'primary', align = 'center', class: className, ...rest } = Astro.props as Props;

const bgMap = {
  primary: 'bg-[var(--surface-primary)]',
  secondary: 'bg-[var(--surface-secondary)]',
  inverse: 'bg-[var(--surface-inverse)]',
  brand: 'bg-[var(--accent-primary)]',
};

const innerAlign = {
  center: 'items-center text-center',
  left: 'items-start text-left',
  split: 'items-stretch',
};
// Content is centred on the VIEWPORT centre (not the padded-box centre) so the
// reading band [30%,70%] and the ≥45% space-usage target are mutually satisfiable.
// A symmetric vertical reserve = the chrome band keeps content clear of the deck
// controls (bottom) and the fullscreen button (top). Horizontal gutter via inset.
// (inline style: Tailwind doesn't reliably emit arbitrary `max(var(...))`.)
const safePadding = 'padding-inline: max(var(--slide-safe-inset), 6vw);';
const bound = 'calc(100dvh - 2 * max(var(--deck-chrome-safe), 7vh))';
const innerStyle = align === 'split' ? `height: ${bound};` : `max-height: ${bound};`;
---

<section
  id={id}
  data-slide
  {...rest}
  class:list={["slide relative w-full h-[100dvh] overflow-hidden", bgMap[bg], className]}
>
  <slot name="backdrop" />
  <!-- Safe area: centre content on the viewport centre -->
  <div class="absolute inset-0 flex items-center justify-center" style={safePadding}>
    <div class:list={["slide-inner w-full min-h-0 flex flex-col justify-center", innerAlign[align]]} style={innerStyle}>
      <slot />
    </div>
  </div>
</section>
