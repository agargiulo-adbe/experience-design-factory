---
/**
 * MediaDemoSlot — a dynamic demo media box inside a deck slide.
 *
 * When a slot is active (set via /admin/), the slot shows the configured
 * image or video. When inactive, display:none ensures the parent flex
 * container reflows and text/content takes full width automatically.
 *
 * Logic lives entirely in BaseLayout.astro (is:inline script) — this
 * component has NO script. The admin page writes to localStorage key
 * `edf:media-slots:<project-slug>`.
 */
interface Props {
  id: string;
  label: string;
  aspect?: string;
}

const { id, label, aspect = '16/9' } = Astro.props;
---

<div
  data-media-slot={id}
  data-slot-label={label}
  data-slot-aspect={aspect}
  class="media-demo-slot"
  style={`flex-shrink: 0; display: none; width: 44%; aspect-ratio: ${aspect};`}
>
  <div
    class="media-slot-inner"
    style="width: 100%; height: 100%; border-radius: 2px; overflow: hidden; background: var(--surface-secondary); border: 1px solid var(--line-subtle); display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 8px;"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" style="opacity: 0.3;">
      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <path d="M3 9h18M9 21V9" stroke="currentColor" stroke-width="1.5"/>
    </svg>
    <p style="font-size: 10px; color: var(--ink-tertiary); text-align: center; padding: 0 1rem;">
      Demo slot<br/>{id}
    </p>
  </div>
</div>
