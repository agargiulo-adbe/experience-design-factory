---
/**
 * MockupSlide — slide dedicata al mockup interattivo di un prodotto Adobe.
 * Si comporta come qualsiasi altra slide del deck (data-slide, data-solution).
 * La configurazione delle feature attive viene letta da localStorage al runtime.
 * Inserire DOPO la slide principale del prodotto nella pagina .astro dell'experience.
 */
import { MOCKUP_LIBRARY } from '../../data/mockups';

interface Props {
  mockupId: string;
  /** Slug della sezione in cui è inserita (es. "create", "define", "analisi") */
  sectionId: string;
  /** Project slug per la chiave localStorage */
  slug: string;
  id?: string;
}

const { mockupId, sectionId, slug, id } = Astro.props;
const mockup = MOCKUP_LIBRARY.find(m => m.id === mockupId);
if (!mockup) throw new Error(`MockupSlide: unknown mockupId "${mockupId}"`);
const serializedFeatures = mockup.features.map(f => ({
  id: f.id, nameEn: f.nameEn, nameIt: f.nameIt, descEn: f.descEn, descIt: f.descIt,
}));
---

<section
  data-slide
  data-mockup-slide={mockupId}
  data-mockup-section={sectionId}
  data-solution={mockup.solutionId}
  id={id ?? `slide-mockup-${mockupId}`}
  class="mockup-slide"
>
  <!-- Browser chrome -->
  <div class="ms-chrome" aria-hidden="true">
    <div class="ms-traffic-lights">
      <span class="ms-tl ms-tl-r"></span>
      <span class="ms-tl ms-tl-y"></span>
      <span class="ms-tl ms-tl-g"></span>
    </div>
    <div class="ms-address-bar">experience.adobe.com/{mockupId}</div>
  </div>

  <!-- App shell -->
  <div class="ms-shell">
    <!-- Sidebar: product logo + feature tabs -->
    <aside class="ms-sidebar">
      <div class="ms-logo" aria-label={"Adobe " + mockup.nameEn}>
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <path d="M19 2L30 28H21.5L16 14.5L10.5 28H2L13 2H19Z" fill="#FF0000"/>
        </svg>
        <span>{mockup.nameEn}</span>
      </div>
      <nav class="ms-nav" data-mockup-tabs aria-label="Feature navigation"></nav>
    </aside>

    <!-- Main content area -->
    <div class="ms-main">
      <header class="ms-topbar">
        <span class="ms-breadcrumb">Adobe {mockup.nameEn}</span>
      </header>
      <div class="ms-body" data-mockup-body></div>
    </div>
  </div>

  <!-- Caption overlay: bilingue, risponde a html[data-lang] -->
  <div class="ms-caption-bar">
    <span class="ms-caption-text" data-mockup-caption aria-live="polite">
      <span data-lang-en></span><span data-lang-it></span>
    </span>
  </div>
</section>

<style is:global>
  /* ── MockupSlide — full-bleed browser UI ──────────────────────────────── */
  [data-mockup-slide] {
    position: relative;
    width: 100%;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    background: #f4f4f4;
    overflow: hidden;
    font-family: -apple-system, 'Segoe UI', Inter, sans-serif;
  }

  /* Browser chrome */
  .ms-chrome {
    height: 2.5rem; background: #3c3c3c;
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0 0.875rem; flex-shrink: 0;
  }
  .ms-traffic-lights { display: flex; gap: 5px; }
  .ms-tl { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .ms-tl-r { background: #ff5f57; }
  .ms-tl-y { background: #ffbd2e; }
  .ms-tl-g { background: #28c840; }
  .ms-address-bar {
    flex: 1; max-width: 24rem; margin: 0 auto;
    height: 1.5rem; background: rgba(255,255,255,0.12); border-radius: 4px;
    display: flex; align-items: center; padding: 0 0.5rem;
    font-size: 0.6rem; color: rgba(255,255,255,0.6);
    overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
  }

  /* App shell */
  .ms-shell { flex: 1; min-height: 0; display: flex; }

  /* Sidebar */
  .ms-sidebar {
    width: 3.875rem; background: #1c1c1c;
    display: flex; flex-direction: column; align-items: center;
    padding: 0.625rem 0; flex-shrink: 0;
  }
  .ms-logo {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.375rem 0; margin-bottom: 0.5rem;
    color: #fff; font-size: 0.42rem; font-weight: 700; letter-spacing: 0.04em;
    text-align: center; line-height: 1.2;
  }

  /* Feature tabs — vertical sidebar style (override old pill style) */
  [data-mockup-slide] [data-mockup-tabs] {
    flex: 1; display: flex; flex-direction: column; gap: 0.1rem;
    width: 100%; padding: 0 0.25rem;
  }
  [data-mockup-slide] .mockup-feature-tab {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.45rem 0.25rem; border: none;
    background: transparent; color: rgba(255,255,255,0.4); cursor: pointer;
    border-radius: 6px; font-size: 0.4rem; font-family: inherit;
    letter-spacing: 0.02em; transition: background 0.15s, color 0.15s; width: 100%;
  }
  [data-mockup-slide] .mockup-feature-tab:hover:not(.is-active) {
    background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.65);
  }
  [data-mockup-slide] .mockup-feature-tab.is-active {
    background: rgba(255,40,0,0.2) !important;
    border-color: transparent !important;
    color: #FF6B4D !important;
  }

  /* Main area */
  .ms-main {
    flex: 1; min-width: 0; display: flex; flex-direction: column; background: #fff;
  }
  .ms-topbar {
    height: 2.75rem; background: #fff; border-bottom: 1px solid #e0e0e0;
    display: flex; align-items: center; padding: 0 1rem; flex-shrink: 0;
  }
  .ms-breadcrumb { font-size: 0.65rem; color: #1a1a1a; font-weight: 600; }
  .ms-body {
    flex: 1; min-height: 0; overflow: hidden;
    padding: 1.25rem 1.5rem;
    display: flex; flex-direction: column; gap: 0.875rem;
  }

  /* Scene content (rendered by JS into [data-mockup-body]) */
  .mockup-feature-scene {
    display: flex; flex-direction: column; gap: 0.625rem; height: 100%;
  }
  .mockup-scene-title {
    font-size: clamp(0.9375rem, 1.25vw, 1.25rem); font-weight: 700;
    color: #1a1a1a; margin: 0; letter-spacing: -0.02em; line-height: 1.2;
    font-family: -apple-system, 'Segoe UI', Inter, sans-serif;
  }
  .mockup-scene-desc {
    font-size: clamp(0.6875rem, 0.875vw, 0.875rem); color: #555;
    line-height: 1.55; margin: 0; max-width: 54em;
    font-family: -apple-system, 'Segoe UI', Inter, sans-serif;
  }
  .mockup-scene-visual {
    flex: 1; min-height: 0;
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem; align-content: start;
  }
  .mockup-scene-card {
    background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px;
    padding: 0.75rem; display: flex; flex-direction: column; gap: 0.4rem;
  }
  .mockup-scene-card-label {
    font-size: 0.5625rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.09em; color: #6b7280;
    font-family: -apple-system, 'Segoe UI', Inter, sans-serif;
  }
  .mockup-scene-card-value {
    font-size: clamp(1rem, 1.5vw, 1.375rem); font-weight: 700;
    color: #1a1a1a; font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .mockup-scene-card-bar {
    height: 3px; background: #e5e7eb; border-radius: 2px; overflow: hidden;
  }
  .mockup-scene-card-bar-fill {
    height: 100%; background: #1473E6; border-radius: 2px;
    transition: width 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Caption overlay */
  .ms-caption-bar {
    position: absolute; bottom: 4.5rem; left: 0; right: 0;
    display: flex; justify-content: center; z-index: 20;
    pointer-events: none; padding: 0 2rem;
  }
  .ms-caption-text {
    background: rgba(0,0,0,0.72); backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.92);
    font-size: clamp(0.68rem, 0.9vw, 0.82rem);
    padding: 0.4rem 1.25rem; border-radius: 20px;
    text-align: center; max-width: 58rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .mockup-scene-card-bar-fill { transition: none; }
    [data-mockup-slide] .mockup-feature-tab { transition: none; }
  }
</style>

<script is:inline define:vars={{ mockupId, sectionId, slug, features: serializedFeatures, maxVisible: mockup.maxVisible }}>
(function() {
  var MK_KEY = 'edf:mockup-config:' + slug;
  var currentFeatureIdx = 0;
  var enabledFeatures = [];

  function loadEnabled() {
    try {
      var cfg = JSON.parse(localStorage.getItem(MK_KEY) || '{}');
      if (Array.isArray(cfg[mockupId])) return cfg[mockupId];
    } catch(e) {}
    return features.slice(0, maxVisible).map(function(f) { return f.id; });
  }

  // Representative scene data per feature ID
  var SCENE_DATA = {
    'brief-to-variants':     [{ l:'Varianti generate', v:'4', f:100 },{ l:'Generazione',     v:'8s',    f:15  },{ l:'Brand score',    v:'97%',   f:97  }],
    'brand-check':           [{ l:'Controlli',         v:'12/12', f:100},{ l:'Logo OK',        v:'✓',    f:100 },{ l:'Tone OK',        v:'✓',    f:100 }],
    'channel-activation':    [{ l:'Canali live',       v:'3',     f:75  },{ l:'Meta CTR',       v:'3.2%', f:64  },{ l:'LinkedIn CTR',   v:'1.8%', f:36  }],
    'insights-dashboard':    [{ l:'CTR medio',         v:'2.9%',  f:58  },{ l:'CPA −',          v:'23%',  f:77  },{ l:'ROAS',           v:'4.1×', f:82  }],
    'express-quick-edit':    [{ l:'Templates',         v:'240+',  f:80  },{ l:'Tempo edit',     v:'<2m',  f:30  },{ l:'Brand score',    v:'100%', f:100 }],
    'translation':           [{ l:'Lingue',            v:'40+',   f:100 },{ l:'Accuracy AI',   v:'98%',  f:98  },{ l:'Tempo avg',      v:'12s',  f:20  }],
    'discover-overlap':      [{ l:'Overlap ID',        v:'2.4M',  f:80  },{ l:'Affinità sport', v:'94%',  f:94  },{ l:'Copertura geo',  v:'48',   f:60  }],
    'activate-audiences':    [{ l:'Segmenti',          v:'6',     f:75  },{ l:'CTV reach',      v:'820K', f:82  },{ l:'Paid media',     v:'1.2M', f:60  }],
    'measure-attribution':   [{ l:'Conversioni',       v:'14.2K', f:71  },{ l:'ROAS partner',   v:'3.8×', f:76  },{ l:'Incrementalità', v:'+31%', f:62  }],
    'clean-sketches':        [{ l:'Privacy score',     v:'100%',  f:100 },{ l:'Identità mosse', v:'0',    f:0   },{ l:'Audit log',      v:'✓',    f:100 }],
    'collaboration-starter': [{ l:'Partner onboarded', v:'3',     f:75  },{ l:'IDs supported',  v:'50M',  f:80  },{ l:'Tempo setup',    v:'<24h', f:20  }],
    'cross-partner-view':    [{ l:'Partner',           v:'4',     f:100 },{ l:'Sessioni tot.',  v:'3.2M', f:80  },{ l:'Top ROAS',       v:'5.1×', f:100 }],
    'season-insights':       [{ l:'Gare analizzate',   v:'24',    f:100 },{ l:'Revenue attr.',  v:'€2.8M',f:70  },{ l:'Renewal rate',   v:'87%',  f:87  }],
    'ai-attribution':        [{ l:'Attributi AI',      v:'18',    f:90  },{ l:'Top driver',     v:'Tone', f:80  },{ l:'CPA ottimiz.',   v:'−19%', f:62  }],
    'cross-channel-dashboard':[{ l:'Canali monit.',    v:'6',     f:100 },{ l:'Touchpoints',    v:'8.4M', f:70  },{ l:'Data lag',       v:'<1h',  f:95  }],
    'brand-locked-templates':[{ l:'Template',          v:'240+',  f:80  },{ l:'Brand score',    v:'100%', f:100 },{ l:'Errori brand',   v:'0',    f:0   }],
    'last-mile-edit':        [{ l:'Editor attivi',     v:'12',    f:60  },{ l:'Tempo prod.',    v:'−65%', f:65  },{ l:'Assets out',     v:'340',  f:85  }],
    'express-translation':   [{ l:'Lingue',            v:'40+',   f:100 },{ l:'Regioni',        v:'18',   f:72  },{ l:'Tempo avg',      v:'<15s', f:25  }],
  };

  function renderScene(feature) {
    var tabs = document.querySelector('[data-mockup-slide="' + mockupId + '"] [data-mockup-tabs]');
    var body = document.querySelector('[data-mockup-slide="' + mockupId + '"] [data-mockup-body]');
    var caption = document.querySelector('[data-mockup-slide="' + mockupId + '"] [data-mockup-caption]');
    if (!body) return;

    if (caption) {
      var enSpan = caption.querySelector('[data-lang-en]');
      var itSpan = caption.querySelector('[data-lang-it]');
      if (enSpan) enSpan.textContent = feature.nameEn;
      if (itSpan) itSpan.textContent = feature.nameIt;
    }

    if (tabs) {
      tabs.querySelectorAll('.mockup-feature-tab').forEach(function(t) {
        t.classList.toggle('is-active', t.getAttribute('data-feature-tab') === feature.id);
      });
    }

    var cards = SCENE_DATA[feature.id] || [
      { l: 'Feature', v: '✓', f: 100 },
      { l: 'Status',  v: 'Active', f: 100 },
      { l: 'Score',   v: '—',  f: 0   },
    ];

    body.innerHTML = '<div class="mockup-feature-scene">'
      + '<h3 class="mockup-scene-title">' + feature.nameEn + '</h3>'
      + '<p class="mockup-scene-desc">' + feature.descEn + '</p>'
      + '<div class="mockup-scene-visual">'
      + cards.map(function(c) {
          return '<div class="mockup-scene-card">'
            + '<span class="mockup-scene-card-label">' + c.l + '</span>'
            + '<span class="mockup-scene-card-value">' + c.v + '</span>'
            + '<div class="mockup-scene-card-bar">'
            + '<div class="mockup-scene-card-bar-fill" style="width:0%"></div>'
            + '</div></div>';
        }).join('')
      + '</div></div>';

    requestAnimationFrame(function() {
      body.querySelectorAll('.mockup-scene-card-bar-fill').forEach(function(bar, i) {
        bar.style.width = (cards[i] ? cards[i].f : 0) + '%';
      });
    });
  }

  function buildTabs() {
    var slideEl = document.querySelector('[data-mockup-slide="' + mockupId + '"]');
    var tabs = slideEl && slideEl.querySelector('[data-mockup-tabs]');
    if (!tabs) return;

    tabs.innerHTML = enabledFeatures.map(function(f) {
      return '<button type="button" class="mockup-feature-tab" data-feature-tab="' + f.id + '">'
        + f.nameEn + '</button>';
    }).join('');

    tabs.querySelectorAll('.mockup-feature-tab').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var fid = btn.getAttribute('data-feature-tab');
        for (var i = 0; i < enabledFeatures.length; i++) {
          if (enabledFeatures[i].id === fid) {
            currentFeatureIdx = i;
            renderScene(enabledFeatures[i]);
            return;
          }
        }
      });
    });
  }

  function init() {
    var enabled = loadEnabled();
    enabledFeatures = features.filter(function(f) { return enabled.indexOf(f.id) !== -1; });
    if (enabledFeatures.length === 0) enabledFeatures = features.slice(0, 1);
    currentFeatureIdx = 0;
    buildTabs();
    if (enabledFeatures[0]) renderScene(enabledFeatures[0]);
  }

  // Reset to first feature when slide becomes active via deck navigation
  var slideEl = document.querySelector('[data-mockup-slide="' + mockupId + '"]');
  if (slideEl) {
    slideEl.addEventListener('playSlide', function() {
      currentFeatureIdx = 0;
      if (enabledFeatures[0]) renderScene(enabledFeatures[0]);
    });
  }

  // Listen for config changes from admin console
  try {
    new BroadcastChannel('edf-console').addEventListener('message', function(e) {
      if (e.data && e.data.type === 'edf:mockup-changed' && e.data.project === slug) init();
    });
  } catch(e) {}
  window.addEventListener('storage', function(ev) {
    if (ev.key === MK_KEY) init();
  });

  // Intercept deck navigation to advance/retreat through feature tabs
  function patchDeck() {
    var deck = window.__edfDeck;
    if (!deck || !slideEl) return;
    var origNext = deck.next.bind(deck);
    var origPrev = deck.prev.bind(deck);
    deck.next = function () {
      if (deck.slides[deck.index] === slideEl && currentFeatureIdx < enabledFeatures.length - 1) {
        currentFeatureIdx++;
        renderScene(enabledFeatures[currentFeatureIdx]);
        return;
      }
      origNext();
    };
    deck.prev = function () {
      if (deck.slides[deck.index] === slideEl && currentFeatureIdx > 0) {
        currentFeatureIdx--;
        renderScene(enabledFeatures[currentFeatureIdx]);
        return;
      }
      origPrev();
    };
  }

  // astro:page-load fires after DeckContainer has initialized __edfDeck
  document.addEventListener('astro:page-load', patchDeck, { once: true });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
