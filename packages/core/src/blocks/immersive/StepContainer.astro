---
/**
 * StepContainer — scroll-snap wrapper for immersive step-by-step experiences.
 * Each direct child becomes a full-screen step.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={["step-container", className]}
  data-step-container
>
  <slot />
</div>

<style>
  .step-container {
    height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    .step-container {
      scroll-behavior: auto;
      scroll-snap-type: none;
    }
  }
</style>
