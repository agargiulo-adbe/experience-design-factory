---
/**
 * DeckContainer — keynote presentation wrapper (no scroll).
 * Stacks full-screen <Slide> children; the Deck controller handles horizontal
 * slide transitions, presenter controls, fullscreen and animation activation.
 * Minimal chrome: progress indicator + auto-hiding prev/next + fullscreen.
 */
interface Props {
  /** URL of the next phase — reached by advancing past the last slide. */
  nextHref?: string;
  class?: string;
}
const { nextHref, class: className } = Astro.props;
---

<div
  data-deck
  data-deck-next={nextHref}
  class:list={["deck fixed inset-0 overflow-hidden bg-[var(--surface-primary)]", className]}
>
  <slot />

  <!-- Minimal, auto-hiding chrome. The top is left free for the site Navigation;
       fullscreen lives in the bottom bar so it never collides with the nav. -->
  <div class="deck-chrome">
    <!-- Bottom bar: prev · progress · next · fullscreen -->
    <div class="absolute bottom-[3vh] left-1/2 -translate-x-1/2 flex items-center gap-6">
      <button type="button" data-deck-prev aria-label="Slide precedente" class="deck-btn">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span data-deck-progress class="deck-progress tabular-nums">01 / 01</span>
      <button type="button" data-deck-next aria-label="Slide successiva" class="deck-btn">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button type="button" data-deck-fs aria-label="Schermo intero" class="deck-btn ml-1">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  /* Projection typography — sized for reading at 4–8 m, not the laptop. */
  .slide-eyebrow {
    font-size: clamp(1.05rem, 1.3vw, 1.3rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .slide-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.01em;
    font-weight: 300;
  }
  .slide-lead {
    font-size: clamp(1.5rem, 2.4vw, 2.25rem);
    line-height: 1.32;
  }
  .slide-num {
    font-family: var(--font-display);
    font-size: clamp(6rem, 16vw, 16rem);
    line-height: 0.9;
    font-weight: 300;
  }

  /* Chrome */
  .deck-chrome {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 40;
    transition: opacity 0.3s ease;
  }
  .deck-idle .deck-chrome { opacity: 0; }
  .deck-idle { cursor: none; }
  /* Hide deck chrome while a slide-over (HowItWorks) is open */
  .deck[data-deck-lock] .deck-chrome { opacity: 0; pointer-events: none; }
  .deck-btn {
    width: 3.5rem;      /* 56px — visibile a 3m */
    height: 3.5rem;
    border-radius: 9999px;
    color: var(--ink-secondary);
    background: color-mix(in srgb, var(--surface-primary) 70%, transparent);
    border: 1px solid var(--line-subtle);
    backdrop-filter: blur(6px);
    transition: color 0.2s ease, border-color 0.2s ease;
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .deck-btn:hover { color: var(--accent-primary); border-color: var(--accent-primary); }
  .deck-btn:focus-visible { outline: 2px solid var(--accent-primary); outline-offset: 2px; }
  .deck-progress {
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);   /* era max 1.15rem → ora max 1.4rem */
    letter-spacing: 0.2em;
    font-weight: 600;     /* era 500 → più leggibile su TV */
    color: var(--ink-tertiary);
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .deck-chrome { transition: none; }
  }

  /* ════════════════════════════════════════════════════════════════
     Responsive: auto-optimise the SAME deck from mobile → desktop → giant TV.
     Safe-area + chrome scale by viewport, scoped to [data-deck] so they
     override each experience's :root tokens without any per-app edit.
     Applies to ALL experiences that use DeckContainer.
     ════════════════════════════════════════════════════════════════ */
  /* Phone (portrait) */
  @media (max-width: 640px) {
    [data-deck] { --slide-safe-inset: 18px; --deck-chrome-safe: 74px; }
    [data-deck] .deck-btn { width: 2.75rem; height: 2.75rem; }
    [data-deck] .deck-btn svg { width: 22px; height: 22px; }
    [data-deck] .absolute.bottom-\[3vh\] { gap: 1rem; }
    /* Dense slides scroll (safe-centered) instead of clipping on small screens */
    [data-slide] .slide-inner {
      overflow-y: auto;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
      justify-content: safe center;
    }
  }
  /* Tablet */
  @media (min-width: 641px) and (max-width: 1024px) {
    [data-deck] { --slide-safe-inset: 44px; --deck-chrome-safe: 120px; }
  }
  /* Short viewports (phone landscape) — reclaim vertical space */
  @media (max-height: 520px) {
    [data-deck] { --slide-safe-inset: 16px; --deck-chrome-safe: 60px; }
    [data-slide] .slide-inner { overflow-y: auto; justify-content: safe center; }
  }
  /* Giant TV / 4K — more breathing room + bigger controls for 4–8 m viewing */
  @media (min-width: 2200px) {
    [data-deck] { --slide-safe-inset: 140px; --deck-chrome-safe: 220px; }
    [data-deck] .deck-btn { width: 4.5rem; height: 4.5rem; }
    [data-deck] .deck-btn svg { width: 34px; height: 34px; }
  }
</style>

<script>
  import { initDeck } from '@edf/core/blocks/immersive/deck';
  import { navigate } from 'astro:transitions/client';
  const w = window as Window & { __edfDeck?: { destroy: () => void }; __edfInitDeck?: () => void; __edfNavigate?: (h: string) => void };
  // SPA navigation for cross-section transitions — preserves fullscreen.
  w.__edfNavigate = (href: string) => { try { navigate(href); } catch { window.location.assign(href); } };
  function boot() {
    // Let the custom-slide injector add authored slides before we count them.
    (window as Window & { __edfInjectCustomSlides?: () => void }).__edfInjectCustomSlides?.();
    initDeck();
  }
  w.__edfInitDeck = boot;   // exposed so the injector can re-init after SPA nav
  function teardown() { w.__edfDeck?.destroy(); }
  boot();
  document.addEventListener('astro:after-swap', boot);
  document.addEventListener('astro:before-swap', teardown);
</script>
