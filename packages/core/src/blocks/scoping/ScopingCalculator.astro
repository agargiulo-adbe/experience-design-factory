---
interface FieldDef {
  key: string;
  group: 'collab' | 'cja';
  section: { en: string; it: string };
  label: { en: string; it: string };
  format: 'int' | 'decimal' | 'percent' | 'currency';
  mode?: 'activity' | 'direct';
  toConfirm?: boolean;
  source: { en: string; it: string };
  calc: { en: string; it: string };
  assumption: { en: string; it: string };
}
interface Props {
  projectSlug: string;
  supabaseUrl: string;
  supabaseAnonKey: string;
  experienceUrl: string; // absolute URL of the /scoping/ page for share links
  fields: FieldDef[];
}
const { projectSlug, supabaseUrl, supabaseAnonKey, experienceUrl, fields } = Astro.props;

// Group fields by column, preserving registry order, into { section, items[] }.
function grouped(g: 'collab' | 'cja') {
  const out: { section: { en: string; it: string }; items: FieldDef[] }[] = [];
  for (const f of fields.filter((x) => x.group === g)) {
    let bucket = out.find((b) => b.section.en === f.section.en);
    if (!bucket) { bucket = { section: f.section, items: [] }; out.push(bucket); }
    bucket.items.push(f);
  }
  return out;
}
const collabGroups = grouped('collab');
const cjaGroups = grouped('cja');
const currencyPrefix = '€';
---
<div class="scoping" data-scoping
     data-project={projectSlug}
     data-supabase-url={supabaseUrl}
     data-supabase-key={supabaseAnonKey}
     data-experience-url={experienceUrl}>

  <header class="scoping-header">
    <div>
      <h2 class="scoping-title"><span data-lang-en>License scoping calculator</span><span data-lang-it>Calcolatore di licensing</span></h2>
      <p class="scoping-sub">
        <span data-lang-en>Two independent products, two metrics. Every field is a stated assumption — hover <span class="scoping-i-demo">i</span> for its source, calculation and reasoning.</span>
        <span data-lang-it>Due prodotti indipendenti, due metriche. Ogni campo è un'assunzione dichiarata — passa su <span class="scoping-i-demo">i</span> per fonte, calcolo e ragionamento.</span>
      </p>
    </div>
    <span class="scoping-legend"><span class="scoping-legend-dot"></span><span data-lang-en>Illustrative / client to confirm</span><span data-lang-it>Illustrativo / da confermare</span></span>
  </header>

  <!-- ── Results bar (sticky, always visible) ─────────────────── -->
  <aside class="scoping-results" aria-live="polite">
    <div class="scoping-total-block">
      <span class="scoping-total-label"><span data-lang-en>Total — indicative / year</span><span data-lang-it>Totale — indicativo / anno</span></span>
      <b class="scoping-total-val" data-out="totalCost">—</b>
      <span class="scoping-total-note"><span data-lang-en>Illustrative prices — replace with the Sales Order.</span><span data-lang-it>Prezzi illustrativi — sostituire con il Sales Order.</span></span>
    </div>
    <div class="scoping-res-groups">
      <div class="scoping-res-group">
        <p class="scoping-res-h">Real-Time CDP Collaboration</p>
        <div class="scoping-metric"><span data-lang-en>Est. credits / yr</span><span data-lang-it>Credits stimati / anno</span><b data-out="collabCreditsEstimated">—</b></div>
        <div class="scoping-metric"><span data-lang-en>Billable credits / yr</span><span data-lang-it>Credits fatturabili / anno</span><b data-out="collabBillableCredits">—</b></div>
        <div class="scoping-metric"><span data-lang-en>Collaboration cost</span><span data-lang-it>Costo Collaboration</span><b data-out="collabCost">—</b></div>
      </div>
      <div class="scoping-res-group">
        <p class="scoping-res-h">Customer Journey Analytics</p>
        <div class="scoping-metric"><span data-lang-en>Licensed rows / yr</span><span data-lang-it>Righe licenziate / anno</span><b data-out="cjaRowsPerYear">—</b></div>
        <div class="scoping-metric scoping-guard"><span data-lang-en>Ingestion limit (3×)</span><span data-lang-it>Limite ingestion (3×)</span><b data-out="cjaAnnualIngestionLimit">—</b></div>
        <div class="scoping-metric"><span data-lang-en>CJA cost</span><span data-lang-it>Costo CJA</span><b data-out="cjaCost">—</b></div>
      </div>
    </div>
  </aside>

  <div class="scoping-cols">
    <!-- ── Collaboration column ─────────────────────────────── -->
    <section class="scoping-card" aria-labelledby="sc-collab-h">
      <h3 id="sc-collab-h" class="scoping-card-h">
        <span>Real-Time CDP Collaboration</span>
        <span class="scoping-card-metric">Collaboration Credits</span>
      </h3>

      <div class="scoping-controls">
        <label class="scoping-field">
          <span class="scoping-label"><span data-lang-en>Bundled package allotment</span><span data-lang-it>Allotment del package</span></span>
          <select data-k="collabPackage">
            <option value="none">None (0)</option>
            <option value="prime">Prime (2,500)</option>
            <option value="ultimate">Ultimate (5,000)</option>
          </select>
        </label>
        <label class="scoping-field">
          <span class="scoping-label"><span data-lang-en>Estimation mode</span><span data-lang-it>Modalità di stima</span></span>
          <select data-k="collabMode">
            <option value="activity">Stima da attività · Estimate from activity</option>
            <option value="direct">Crediti diretti · Direct credits</option>
          </select>
        </label>
      </div>

      {collabGroups.map((grp) => (
        <div class="scoping-group" data-group-modes={grp.items.map((i) => i.mode ?? 'both').join(',')}>
          <p class="scoping-group-h"><span data-lang-en>{grp.section.en}</span><span data-lang-it>{grp.section.it}</span></p>
          {grp.items.map((f) => (
            <label class={`scoping-field${f.toConfirm ? ' scoping-so' : ''}`} data-when={f.mode ?? undefined}>
              <span class="scoping-label">
                <span class="scoping-label-txt"><span data-lang-en>{f.label.en}</span><span data-lang-it>{f.label.it}</span></span>
                {f.toConfirm && <span class="scoping-badge"><span data-lang-en>to confirm</span><span data-lang-it>da confermare</span></span>}
                <button type="button" class="scoping-info" aria-label="Audit" tabindex="0">i</button>
                <span class="scoping-tip" role="tooltip">
                  <span class="scoping-tip-row"><b>SOURCE</b><span data-lang-en>{f.source.en}</span><span data-lang-it>{f.source.it}</span></span>
                  <span class="scoping-tip-row"><b>CALC</b><span data-lang-en>{f.calc.en}</span><span data-lang-it>{f.calc.it}</span></span>
                  <span class="scoping-tip-row"><b data-lang-en>ASSUMPTION</b><b data-lang-it>ASSUNZIONE</b><span data-lang-en>{f.assumption.en}</span><span data-lang-it>{f.assumption.it}</span></span>
                </span>
              </span>
              <span class="scoping-input-wrap">
                {f.format === 'currency' && <span class="scoping-prefix">{currencyPrefix}</span>}
                <input type="text" inputmode="decimal" data-k={f.key} data-format={f.format} />
              </span>
            </label>
          ))}
        </div>
      ))}
    </section>

    <!-- ── CJA column ───────────────────────────────────────── -->
    <section class="scoping-card" aria-labelledby="sc-cja-h">
      <h3 id="sc-cja-h" class="scoping-card-h">
        <span>Customer Journey Analytics</span>
        <span class="scoping-card-metric">Rows of Data</span>
      </h3>
      {cjaGroups.map((grp) => (
        <div class="scoping-group">
          <p class="scoping-group-h"><span data-lang-en>{grp.section.en}</span><span data-lang-it>{grp.section.it}</span></p>
          {grp.items.map((f) => (
            <label class={`scoping-field${f.toConfirm ? ' scoping-so' : ''}`}>
              <span class="scoping-label">
                <span class="scoping-label-txt"><span data-lang-en>{f.label.en}</span><span data-lang-it>{f.label.it}</span></span>
                {f.toConfirm && <span class="scoping-badge"><span data-lang-en>to confirm</span><span data-lang-it>da confermare</span></span>}
                <button type="button" class="scoping-info" aria-label="Audit" tabindex="0">i</button>
                <span class="scoping-tip" role="tooltip">
                  <span class="scoping-tip-row"><b>SOURCE</b><span data-lang-en>{f.source.en}</span><span data-lang-it>{f.source.it}</span></span>
                  <span class="scoping-tip-row"><b>CALC</b><span data-lang-en>{f.calc.en}</span><span data-lang-it>{f.calc.it}</span></span>
                  <span class="scoping-tip-row"><b data-lang-en>ASSUMPTION</b><b data-lang-it>ASSUNZIONE</b><span data-lang-en>{f.assumption.en}</span><span data-lang-it>{f.assumption.it}</span></span>
                </span>
              </span>
              <span class="scoping-input-wrap">
                {f.format === 'currency' && <span class="scoping-prefix">{currencyPrefix}</span>}
                <input type="text" inputmode="decimal" data-k={f.key} data-format={f.format} />
              </span>
            </label>
          ))}
        </div>
      ))}
    </section>
  </div>

  <!-- ── Action bar ─────────────────────────────────────────── -->
  <div class="scoping-actions">
    <select data-scoping-picker aria-label="Scenario"></select>
    <input type="text" data-scoping-title placeholder="Scenario name" />
    <select data-scoping-visibility aria-label="Visibility">
      <option value="private">Privato · Private</option>
      <option value="link">Condiviso via link · Shared via link</option>
      <option value="team">Team</option>
    </select>
    <button data-scoping-save><span data-lang-en>Save</span><span data-lang-it>Salva</span></button>
    <button data-scoping-share><span data-lang-en>Share</span><span data-lang-it>Condividi</span></button>
    <button data-scoping-reset><span data-lang-en>Reset</span><span data-lang-it>Reset</span></button>
    <button data-scoping-compare><span data-lang-en>Compare</span><span data-lang-it>Confronta</span></button>
    <span data-scoping-note class="scoping-note"></span>
  </div>
  <div class="scoping-compare" data-scoping-compare-panel hidden>
    <table class="scoping-compare-table"><thead></thead><tbody></tbody></table>
  </div>
</div>

<script>
  import {
    computeSnapshot, type ScopingAssumptions, type UnitPrices,
  } from './cost-model';
  import {
    DEFAULT_ASSUMPTIONS, DEFAULT_PRICES, scenarioIdFromSearch, type Scenario,
  } from './scenario';
  import {
    isLoggedIn, loadLocal, saveLocal, saveRemote, fetchRemoteById, listMine, type StoreCtx,
  } from './scenario-store';

  const PRICE_KEYS = new Set(['pricePerCredit', 'pricePerMillionRows']);
  const CONTROL_KEYS = new Set(['collabMode', 'collabPackage']);

  function initScoping(root: HTMLElement) {
    const ctx: StoreCtx = {
      projectSlug: root.dataset.project!,
      supabaseUrl: root.dataset.supabaseUrl!,
      supabaseAnonKey: root.dataset.supabaseKey!,
    };
    const experienceUrl = root.dataset.experienceUrl!;
    let assumptions: ScopingAssumptions = { ...DEFAULT_ASSUMPTIONS };
    let prices: UnitPrices = { ...DEFAULT_PRICES };
    const note = root.querySelector<HTMLElement>('[data-scoping-note]')!;

    let baseline: any = {};
    try { baseline = JSON.parse(localStorage.getItem('edf:scoping-baseline:' + ctx.projectSlug) || '{}'); } catch { baseline = {}; }
    function applyBaselinePrices() {
      if (baseline.pricePerCredit != null) prices.pricePerCredit = baseline.pricePerCredit;
      if (baseline.pricePerMillionRows != null) prices.pricePerMillionRows = baseline.pricePerMillionRows;
    }

    // ── formatting ──────────────────────────────────────────
    const grp = (n: number, min = 0, max = 0) =>
      new Intl.NumberFormat('en-US', { minimumFractionDigits: min, maximumFractionDigits: max }).format(n);
    const fmt = (n: number) => grp(n);
    const fmtMoney = (n: number | null) =>
      n == null ? '—' : '€' + grp(n, 0, 0);
    const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));

    function fmtField(format: string, v: number): string {
      if (format === 'percent') return grp(v, 0, 2);          // 0–1 decimal
      if (format === 'currency') return grp(v, 2, 2);         // 3.00
      if (format === 'decimal') return grp(v, 0, 2);          // 1.5
      return grp(v, 0, 0);                                    // int with thousands
    }
    const parseField = (s: string) => Number(String(s).replace(/,/g, '').trim());

    function valueFor(k: string): number {
      if (k === 'pricePerCredit') return prices.pricePerCredit ?? 0;
      if (k === 'pricePerMillionRows') return prices.pricePerMillionRows ?? 0;
      return (assumptions as any)[k] ?? 0;
    }

    function writeInputs() {
      root.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-k]').forEach((el) => {
        const k = el.dataset.k!;
        if (CONTROL_KEYS.has(k)) { el.value = (assumptions as any)[k]; return; }
        (el as HTMLInputElement).value = fmtField(el.dataset.format || 'int', valueFor(k));
      });
      // show/hide activity vs direct fields
      root.querySelectorAll<HTMLElement>('.scoping-field[data-when]').forEach((el) => {
        el.style.display = (el.getAttribute('data-when') === assumptions.collabMode) ? '' : 'none';
      });
      root.querySelectorAll<HTMLElement>('.scoping-group[data-group-modes]').forEach((el) => {
        const modes = (el.getAttribute('data-group-modes') || '').split(',');
        const visible = modes.some((m) => m === 'both' || m === assumptions.collabMode);
        el.style.display = visible ? '' : 'none';
      });
    }

    function readInput(el: HTMLInputElement | HTMLSelectElement) {
      const k = el.dataset.k!;
      if (CONTROL_KEYS.has(k)) { (assumptions as any)[k] = el.value; return; }
      const n = parseField((el as HTMLInputElement).value);
      const val = Number.isFinite(n) ? n : 0;
      if (k === 'pricePerCredit') prices.pricePerCredit = val;
      else if (k === 'pricePerMillionRows') prices.pricePerMillionRows = val;
      else (assumptions as any)[k] = val;
    }

    function render() {
      const s = computeSnapshot(assumptions, prices);
      const out = (name: string, v: string) => {
        const el = root.querySelector(`[data-out="${name}"]`);
        if (el) el.textContent = v;
      };
      out('collabCreditsEstimated', fmt(s.collabCreditsEstimated));
      out('collabBillableCredits', fmt(s.collabBillableCredits));
      out('collabCost', fmtMoney(s.collabCost));
      out('cjaRowsPerYear', fmt(s.cjaRowsPerYear));
      out('cjaAnnualIngestionLimit', fmt(s.cjaAnnualIngestionLimit));
      out('cjaCost', fmtMoney(s.cjaCost));
      out('totalCost', fmtMoney(s.totalCost));
    }

    root.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-k]').forEach((el) => {
      el.addEventListener('input', () => { readInput(el); if (el.dataset.k === 'collabMode') writeInputs(); render(); });
      // reformat on blur (don't fight the caret while typing)
      if (el.tagName === 'INPUT') el.addEventListener('blur', () => {
        (el as HTMLInputElement).value = fmtField(el.dataset.format || 'int', valueFor(el.dataset.k!));
      });
    });

    // ── Scenario picker ────────────────────────────────────
    const picker = root.querySelector<HTMLSelectElement>('[data-scoping-picker]')!;
    let scenarios: Scenario[] = [];

    function refreshPicker() {
      picker.innerHTML = '';
      scenarios.forEach((sc, i) => {
        const o = document.createElement('option');
        o.value = String(i);
        o.textContent = sc.title + (sc.visibility !== 'private' ? ` · ${sc.visibility}` : '');
        picker.appendChild(o);
      });
    }

    function applyScenario(sc: Scenario) {
      assumptions = { ...DEFAULT_ASSUMPTIONS, ...sc.assumptions };
      prices = { ...DEFAULT_PRICES, ...sc.prices };
      applyBaselinePrices();
      (root.querySelector('[data-scoping-title]') as HTMLInputElement).value = sc.title;
      (root.querySelector('[data-scoping-visibility]') as HTMLSelectElement).value = sc.visibility;
      writeInputs(); render();
    }

    picker.addEventListener('change', () => {
      const sc = scenarios[Number(picker.value)];
      if (sc) applyScenario(sc);
    });

    // ── Save / Share / Reset ───────────────────────────────
    root.querySelector('[data-scoping-save]')!.addEventListener('click', async () => {
      const title = (root.querySelector('[data-scoping-title]') as HTMLInputElement).value || 'Scenario';
      const visibility = (root.querySelector('[data-scoping-visibility]') as HTMLSelectElement).value as Scenario['visibility'];
      const sc: Scenario = { title, assumptions: { ...assumptions }, prices: { ...prices }, visibility };
      if (isLoggedIn()) {
        try {
          const id = await saveRemote(ctx, sc);
          sc.id = id;
          scenarios.unshift(sc); refreshPicker();
          note.textContent = 'Saved to your account.';
        } catch { note.textContent = 'Save failed — check your connection.'; }
      } else {
        scenarios.unshift(sc); saveLocal(ctx.projectSlug, scenarios.filter((x) => !x.id)); refreshPicker();
        note.textContent = 'Saved locally. Log in from the Console to persist & share.';
      }
    });

    root.querySelector('[data-scoping-share]')!.addEventListener('click', async () => {
      if (!isLoggedIn()) { note.textContent = 'Log in from the Console (/console/) to create a share link.'; return; }
      const title = (root.querySelector('[data-scoping-title]') as HTMLInputElement).value || 'Scenario';
      const sc: Scenario = { title, assumptions: { ...assumptions }, prices: { ...prices }, visibility: 'link' };
      try {
        const id = await saveRemote(ctx, sc);
        const path = location.pathname.replace(/\?.*$/, '');
        const url = (location.origin ? location.origin + path : experienceUrl) + '?scenario=' + id;
        await navigator.clipboard?.writeText(url).catch(() => {});
        note.textContent = 'Share link copied: ' + url;
      } catch { note.textContent = 'Could not create share link.'; }
    });

    // Reset re-applies the first scenario (keeps every field populated, never 0/blank).
    root.querySelector('[data-scoping-reset]')!.addEventListener('click', () => {
      if (scenarios[0]) applyScenario(scenarios[0]);
      note.textContent = '';
    });

    const comparePanel = root.querySelector<HTMLElement>('[data-scoping-compare-panel]')!;
    root.querySelector('[data-scoping-compare]')!.addEventListener('click', () => {
      if (!scenarios.length) { note.textContent = 'No scenarios to compare yet.'; return; }
      const rows: Array<[string, (s: ReturnType<typeof computeSnapshot>) => string]> = [
        ['Billable credits', (s) => fmt(s.collabBillableCredits)],
        ['Collab cost', (s) => fmtMoney(s.collabCost)],
        ['CJA rows / yr', (s) => fmt(s.cjaRowsPerYear)],
        ['Ingestion limit (3×)', (s) => fmt(s.cjaAnnualIngestionLimit)],
        ['CJA cost', (s) => fmtMoney(s.cjaCost)],
        ['Total', (s) => fmtMoney(s.totalCost)],
      ];
      const snaps = scenarios.map((sc) => ({
        title: sc.title,
        snap: computeSnapshot({ ...DEFAULT_ASSUMPTIONS, ...sc.assumptions }, { ...DEFAULT_PRICES, ...sc.prices }),
      }));
      const thead = comparePanel.querySelector('thead')!;
      const tbody = comparePanel.querySelector('tbody')!;
      thead.innerHTML = '<tr><th></th>' + snaps.map((x) => `<th>${esc(x.title)}</th>`).join('') + '</tr>';
      tbody.innerHTML = rows
        .map(([label, f]) => `<tr><td>${label}</td>` + snaps.map((x) => `<td>${f(x.snap)}</td>`).join('') + '</tr>')
        .join('');
      comparePanel.hidden = false;
    });

    // ── Boot ────────────────────────────────────────────────
    const seeded = (window as any).__edfScopingSeeds as Scenario[] | undefined;
    scenarios = (seeded ? seeded.slice() : []).concat(loadLocal(ctx.projectSlug));
    refreshPicker();

    const sharedId = scenarioIdFromSearch(location.search);
    if (sharedId) {
      fetchRemoteById(ctx, sharedId).then((sc) => {
        if (sc) { scenarios.unshift(sc); refreshPicker(); applyScenario(sc); }
      });
    } else if (scenarios[0]) {
      applyScenario(scenarios[0]);
    } else {
      applyBaselinePrices();
      writeInputs(); render();
    }
    if (isLoggedIn()) listMine(ctx).then((mine) => { if (mine.length) { scenarios = mine.concat(scenarios); refreshPicker(); } });
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>('[data-scoping]').forEach((el) => {
      if (el.dataset.scopingReady === '1') return;
      el.dataset.scopingReady = '1';
      initScoping(el);
    });
  }
  bootAll();
  document.addEventListener('astro:page-load', bootAll);
</script>

<style>
  .scoping { display: flex; flex-direction: column; gap: 1.1rem; width: 100%; max-width: 1600px; margin: 0 auto; height: 100%; overflow-y: auto; padding: 1.25rem 1.5rem; box-sizing: border-box; }
  .scoping *, .scoping *::before, .scoping *::after { box-sizing: border-box; }
  .scoping-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .scoping-title { font-family: var(--font-display); font-size: 1.15rem; font-weight: 800; color: var(--ink-inverse, #F4F4F2); letter-spacing: -0.01em; }
  .scoping-sub { font-size: 0.78rem; color: var(--color-grigio-400, #9a9a9a); max-width: 46rem; margin-top: 0.25rem; line-height: 1.5; }
  .scoping-i-demo, .scoping-info { display: inline-flex; align-items: center; justify-content: center; width: 14px; height: 14px; border-radius: 50%; border: 1px solid var(--accent-secondary, #FFF200); color: var(--accent-secondary, #FFF200); font-size: 9px; font-style: italic; font-weight: 700; line-height: 1; }
  .scoping-legend { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.68rem; color: var(--color-grigio-400, #9a9a9a); }
  .scoping-legend-dot { width: 10px; height: 10px; border-radius: 2px; border-left: 3px solid var(--accent-secondary, #FFF200); background: rgba(255,242,0,0.08); }

  .scoping-cols { display: grid; grid-template-columns: 1fr; gap: 1.1rem; }
  @media (min-width: 820px) { .scoping-cols { grid-template-columns: 1fr 1fr; align-items: start; } }
  .scoping-card { min-width: 0; background: color-mix(in srgb, var(--surface-inverse, #0B0B0D) 80%, #fff 5%); border: 1px solid var(--line-subtle, rgba(255,255,255,0.1)); border-radius: 8px; padding: 1.1rem 1.2rem; }
  .scoping-card-h { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem 0.75rem; flex-wrap: wrap; font-family: var(--font-display); font-size: 0.92rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; color: var(--ink-inverse, #F4F4F2); padding-bottom: 0.7rem; margin-bottom: 0.7rem; border-bottom: 1px solid var(--line-subtle, rgba(255,255,255,0.1)); }
  .scoping-card-metric { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.06em; color: var(--accent-secondary, #FFF200); flex-shrink: 0; }
  .scoping-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-bottom: 0.9rem; }
  @media (max-width: 520px) { .scoping-controls { grid-template-columns: 1fr; } }

  .scoping-group { margin-bottom: 0.85rem; }
