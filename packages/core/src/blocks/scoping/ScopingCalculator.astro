---
type Bi = { en: string; it: string };
type DataType = 'official' | 'default-assumption' | 'customer-assumption' | 'price';
interface FieldOption { value: string; label: Bi }
interface FieldDef {
  key: string;
  group: 'collab' | 'cja';
  section: Bi;
  label: Bi;
  format: 'int' | 'decimal' | 'percent' | 'currency';
  input?: 'number' | 'select';
  options?: FieldOption[];
  mode?: string; // one or more collab modes, pipe-separated (e.g. 'simple|detailed')
  category?: string;
  dataType?: DataType;
  advancedOnly?: boolean;
  appliesWhen?: string; // 'key=v1|v2'
  impacts?: Bi;
  hint?: Bi;
  toConfirm?: boolean;
  source: Bi;
  calc: Bi;
  assumption: Bi;
}
interface Props {
  projectSlug: string;
  supabaseUrl: string;
  supabaseAnonKey: string;
  experienceUrl: string; // absolute URL of the /scoping/ page for share links
  fields: FieldDef[];
}
const { projectSlug, supabaseUrl, supabaseAnonKey, experienceUrl, fields } = Astro.props;
import ScopingField from './ScopingField.astro';

const PRESET_CHIPS: { id: string; label: Bi }[] = [
  { id: 'conservative', label: { en: 'Conservative', it: 'Conservativo' } },
  { id: 'base', label: { en: 'Base', it: 'Base' } },
  { id: 'aggressive', label: { en: 'Aggressive', it: 'Ambizioso' } },
  { id: 'custom', label: { en: 'Custom', it: 'Personalizzato' } },
];

// Group fields by column, preserving registry order, into { section, items[] }.
function grouped(g: 'collab' | 'cja') {
  const out: { section: { en: string; it: string }; items: FieldDef[] }[] = [];
  for (const f of fields.filter((x) => x.group === g)) {
    let bucket = out.find((b) => b.section.en === f.section.en);
    if (!bucket) { bucket = { section: f.section, items: [] }; out.push(bucket); }
    bucket.items.push(f);
  }
  return out;
}
const collabGroups = grouped('collab');
const cjaGroups = grouped('cja');

// Metric-explanation tooltips for every licensing concept (generic to the
// Adobe products, hence hardcoded bilingual here — not Ferrari-specific).
const collabResults = [
  { out: 'collabFerrariCost', en: 'Ferrari instance', it: 'Istanza Ferrari',
    tip: { en: 'Ferrari’s own Collaboration instance: Base fee (0 when included) + chargeable credit pack after the package’s bundled credits are netted. On RTCDP Ultimate its ~1,500 credits fall inside the 5,000 included → €0.', it: 'L’istanza Collaboration di Ferrari: Base fee (0 se inclusa) + pacchetto crediti a pagamento dopo aver nettato i crediti inclusi nel pacchetto. Con RTCDP Ultimate i suoi ~1.500 crediti rientrano nei 5.000 inclusi → €0.' } },
  { out: 'collabPartnerCostTotal', en: 'Partner instances', it: 'Istanze partner',
    tip: { en: 'One Collaboration instance per partner sponsor. Per-instance cost (Base fee + credit pack) × the number of partner instances.', it: 'Una istanza Collaboration per partner sponsor. Costo per istanza (Base fee + pacchetto crediti) × il numero di istanze partner.' } },
  { out: 'collabBaseFeeTotal', en: 'Base SKU fees', it: 'Canoni SKU Base',
    tip: { en: 'Sum of the flat annual Base SKU fees across all standalone instances ($20k list each). Included instances (RTCDP customers) contribute €0.', it: 'Somma dei canoni annui flat dello SKU Base su tutte le istanze standalone ($20k listino ciascuna). Le istanze incluse (clienti RTCDP) contribuiscono €0.' } },
  { out: 'collabCost', en: 'Collaboration total', it: 'Totale Collaboration',
    tip: { en: 'Ferrari instance + all partner instances (Base fees + credit packs). Prices are quote-only (illustrative here).', it: 'Istanza Ferrari + tutte le istanze partner (Base fee + pacchetti crediti). I prezzi sono solo da preventivo (qui illustrativi).' } },
];
const cjaResults = [
  { out: 'cjaRowsPerYear', en: 'Licensed rows / yr', it: 'Righe licenziate / anno',
    tip: { en: 'Rows of Data licensed = the contracted analytical capacity (rolling 13-month Core Data window). 1 row = 0.25 KB — CJA’s license metric.', it: 'Rows of Data licenziate = la capacità analitica contrattualizzata (finestra Core Data 13 mesi mobile). 1 riga = 0,25 KB — la metrica di licenza di CJA.' } },
  { out: 'cjaAnnualIngestionLimit', en: 'Ingestion limit (3×)', it: 'Limite ingestion (3×)', guard: true,
    tip: { en: 'Annual Ingestion Limit: you may ingest up to 3× the licensed rows per year. A guardrail on flow, not reporting capacity.', it: 'Annual Ingestion Limit: puoi ingerire fino a 3× le righe licenziate all’anno. Un guardrail sul flusso, non capacità di reporting.' } },
  { out: 'cjaCost', en: 'CJA cost', it: 'Costo CJA',
    tip: { en: 'Licensed rows × price per 1M rows. The price is quote-only (illustrative here).', it: 'Righe licenziate × prezzo per 1M righe. Il prezzo è solo da preventivo (qui illustrativo).' } },
];
const badgeCollab = { en: 'The license metric for Real-Time CDP Collaboration — a finite pool of credits consumed by collaboration activities.', it: 'La metrica di licenza di Real-Time CDP Collaboration — un pool finito di credits consumato dalle attività di collaboration.' };
const badgeCja = { en: 'The license metric for CJA — the daily-average rows of data available for analysis (1 row = 0.25 KB).', it: 'La metrica di licenza di CJA — la media giornaliera di righe di dati disponibili per l’analisi (1 riga = 0,25 KB).' };
const modeTip = { en: 'Simple = quick campaign-count estimate (credits rounded to 10, then to a pack). Detailed = granular per-activity model. Direct = enter a scoped credit total. Mirrors the two Adobe workbook paths.', it: 'Simple = stima rapida per numero di campagne (crediti arrotondati a 10, poi a pacchetto). Detailed = modello granulare per attività. Direct = inserisci un totale crediti già scopato. Rispecchia i due percorsi del workbook Adobe.' };
---
<div class="scoping" data-scoping data-deck-nochrome
     data-project={projectSlug}
     data-supabase-url={supabaseUrl}
     data-supabase-key={supabaseAnonKey}
     data-experience-url={experienceUrl}>

  <header class="scoping-header">
    <div>
      <h2 class="scoping-title"><span data-lang-en>License scoping calculator</span><span data-lang-it>Calcolatore di licensing</span></h2>
      <p class="scoping-sub">
        <span data-lang-en>Two independent products, two metrics. Every field is a stated assumption — click <span class="scoping-i-demo">i</span> for its source, calculation and reasoning.</span>
        <span data-lang-it>Due prodotti indipendenti, due metriche. Ogni campo è un'assunzione dichiarata — clicca su <span class="scoping-i-demo">i</span> per fonte, calcolo e ragionamento.</span>
      </p>
    </div>
    <span class="scoping-legend"><span class="scoping-legend-dot"></span><span data-lang-en>Illustrative / client to confirm</span><span data-lang-it>Illustrativo / da confermare</span></span>
  </header>

  <!-- ── Scenario presets ─────────────────────────────────────── -->
  <div class="scoping-presets" role="group" aria-label="Scenario presets">
    <span class="scoping-presets-label"><span data-lang-en>Scenario</span><span data-lang-it>Scenario</span></span>
    {PRESET_CHIPS.map((c) => (
      <button type="button" class="scoping-chip" data-preset={c.id} aria-pressed="false">
        <span data-lang-en>{c.label.en}</span><span data-lang-it>{c.label.it}</span>
      </button>
    ))}
  </div>

  <!-- ── Results bar (sticky, always visible) ─────────────────── -->
  <aside class="scoping-results" aria-live="polite">
    <div class="scoping-total-block">
      <span class="scoping-total-label"><span data-lang-en>Total — indicative / year</span><span data-lang-it>Totale — indicativo / anno</span></span>
      <b class="scoping-total-val" data-out="totalCost">—</b>
      <span class="scoping-total-note"><span data-lang-en>Illustrative prices — replace with the Sales Order.</span><span data-lang-it>Prezzi illustrativi — sostituire con il Sales Order.</span></span>
    </div>
    <div class="scoping-res-groups">
      <div class="scoping-res-group">
        <p class="scoping-res-h">Real-Time CDP Collaboration</p>
        {collabResults.map((r) => (
          <div class={`scoping-metric${r.guard ? ' scoping-guard' : ''}`}>
            <span class="scoping-mlabel">
              <span data-lang-en>{r.en}</span><span data-lang-it>{r.it}</span>
              <button type="button" class="scoping-info" aria-label="Metric" tabindex="0">i</button>
              <span class="scoping-tip scoping-tip--metric"><span data-lang-en>{r.tip.en}</span><span data-lang-it>{r.tip.it}</span></span>
            </span>
            <b data-out={r.out}>—</b>
          </div>
        ))}
      </div>
      <div class="scoping-res-group">
        <p class="scoping-res-h">Customer Journey Analytics</p>
        {cjaResults.map((r) => (
          <div class={`scoping-metric${r.guard ? ' scoping-guard' : ''}`}>
            <span class="scoping-mlabel">
              <span data-lang-en>{r.en}</span><span data-lang-it>{r.it}</span>
              <button type="button" class="scoping-info" aria-label="Metric" tabindex="0">i</button>
              <span class="scoping-tip scoping-tip--metric"><span data-lang-en>{r.tip.en}</span><span data-lang-it>{r.tip.it}</span></span>
            </span>
            <b data-out={r.out}>—</b>
          </div>
        ))}
      </div>
    </div>
  </aside>

  <!-- ── Guardrail warnings (populated at runtime) ────────────── -->
  <div class="scoping-warnings" data-warnings role="status" aria-live="polite" hidden></div>

  <div class="scoping-cols">
    <!-- ── Collaboration column ─────────────────────────────── -->
    <section class="scoping-card" data-col="collab" aria-labelledby="sc-collab-h">
      <h3 id="sc-collab-h" class="scoping-card-h">
        <span>Real-Time CDP Collaboration</span>
        <span class="scoping-card-metric scoping-badge-tip">Collaboration Credits<button type="button" class="scoping-info" aria-label="Metric" tabindex="0">i</button><span class="scoping-tip scoping-tip--metric scoping-tip--right"><span data-lang-en>{badgeCollab.en}</span><span data-lang-it>{badgeCollab.it}</span></span></span>
      </h3>

      <div class="scoping-controls">
        <label class="scoping-field">
          <span class="scoping-label"><span class="scoping-label-txt"><span data-lang-en>Estimation mode</span><span data-lang-it>Modalità di stima</span></span><button type="button" class="scoping-info" aria-label="Metric" tabindex="0">i</button><span class="scoping-tip scoping-tip--metric"><span data-lang-en>{modeTip.en}</span><span data-lang-it>{modeTip.it}</span></span></span>
          <select data-k="collabMode">
            <option value="detailed">Dettagliata · Detailed scoping</option>
            <option value="simple">Rapida · Simple scoping</option>
            <option value="direct">Crediti diretti · Direct credits</option>
          </select>
        </label>
        <label class="scoping-field">
          <span class="scoping-label"><span data-lang-en>Measurement use-cases</span><span data-lang-it>Casi d'uso measurement</span></span>
          <select data-k="measurementEnabled">
            <option value="true">Sì · Yes</option>
            <option value="false">No</option>
          </select>
        </label>
      </div>

      {collabGroups.map((grp) => (
        <div class="scoping-group" data-group-modes={grp.items.map((i) => i.mode ?? 'both').join(',')}>
          <p class="scoping-group-h"><span data-lang-en>{grp.section.en}</span><span data-lang-it>{grp.section.it}</span></p>
          {grp.items.map((f) => <ScopingField f={f} />)}
        </div>
      ))}

      <label class="scoping-adv-toggle">
        <input type="checkbox" data-advanced-toggle="collab" />
        <span data-lang-en>Advanced assumptions</span><span data-lang-it>Assunzioni avanzate</span>
      </label>

      <button type="button" class="scoping-breakdown-toggle" data-breakdown-toggle="collab" aria-expanded="false">
        <span data-lang-en>Show calculation</span><span data-lang-it>Mostra il calcolo</span>
      </button>
      <div class="scoping-breakdown" data-breakdown="collab" hidden></div>
    </section>

    <!-- ── CJA column ───────────────────────────────────────── -->
    <section class="scoping-card" data-col="cja" aria-labelledby="sc-cja-h">
      <h3 id="sc-cja-h" class="scoping-card-h">
        <span>Customer Journey Analytics</span>
        <span class="scoping-card-metric scoping-badge-tip">Rows of Data<button type="button" class="scoping-info" aria-label="Metric" tabindex="0">i</button><span class="scoping-tip scoping-tip--metric scoping-tip--right"><span data-lang-en>{badgeCja.en}</span><span data-lang-it>{badgeCja.it}</span></span></span>
      </h3>
      {cjaGroups.map((grp) => (
        <div class="scoping-group">
          <p class="scoping-group-h"><span data-lang-en>{grp.section.en}</span><span data-lang-it>{grp.section.it}</span></p>
          {grp.items.map((f) => <ScopingField f={f} />)}
        </div>
      ))}

      <label class="scoping-adv-toggle">
        <input type="checkbox" data-advanced-toggle="cja" />
        <span data-lang-en>Advanced assumptions</span><span data-lang-it>Assunzioni avanzate</span>
      </label>

      <button type="button" class="scoping-breakdown-toggle" data-breakdown-toggle="cja" aria-expanded="false">
        <span data-lang-en>Show calculation</span><span data-lang-it>Mostra il calcolo</span>
      </button>
      <div class="scoping-breakdown" data-breakdown="cja" hidden></div>
    </section>
  </div>

  <!-- ── Action bar ─────────────────────────────────────────── -->
  <div class="scoping-actions">
    <select data-scoping-picker aria-label="Scenario"></select>
    <input type="text" data-scoping-title placeholder="Scenario name" />
    <select data-scoping-visibility aria-label="Visibility">
      <option value="private">Privato · Private</option>
      <option value="link">Condiviso via link · Shared via link</option>
      <option value="team">Team</option>
    </select>
    <button data-scoping-save><span data-lang-en>Save</span><span data-lang-it>Salva</span></button>
    <button data-scoping-share><span data-lang-en>Share</span><span data-lang-it>Condividi</span></button>
    <button data-scoping-reset><span data-lang-en>Reset</span><span data-lang-it>Reset</span></button>
    <button data-scoping-compare><span data-lang-en>Compare</span><span data-lang-it>Confronta</span></button>
    <button data-scoping-export="json"><span data-lang-en>Export JSON</span><span data-lang-it>Esporta JSON</span></button>
    <button data-scoping-export="csv"><span data-lang-en>Export CSV</span><span data-lang-it>Esporta CSV</span></button>
    <span data-scoping-note class="scoping-note"></span>
  </div>
  <div class="scoping-compare" data-scoping-compare-panel hidden>
    <table class="scoping-compare-table"><thead></thead><tbody></tbody></table>
  </div>
</div>

<script>
  import {
    computeSnapshot, computeBreakdown,
    type ScopingAssumptions, type UnitPrices, type LineItem, type Warning,
  } from './cost-model';
  import {
    DEFAULT_ASSUMPTIONS, DEFAULT_PRICES, scenarioIdFromSearch, type Scenario,
  } from './scenario';
  import {
    isLoggedIn, remoteEnabled, clearSession, RemoteError,
    loadLocal, saveLocal, saveRemote, fetchRemoteById, listMine, type StoreCtx,
  } from './scenario-store';

  const langOf = () => (document.documentElement.getAttribute('data-lang') === 'it' ? 'it' : 'en');

  function initScoping(root: HTMLElement) {
    const ctx: StoreCtx = {
      projectSlug: root.dataset.project!,
      supabaseUrl: root.dataset.supabaseUrl!,
      supabaseAnonKey: root.dataset.supabaseKey!,
    };
    const experienceUrl = root.dataset.experienceUrl!;
    let assumptions: ScopingAssumptions = { ...DEFAULT_ASSUMPTIONS };
    let prices: UnitPrices = { ...DEFAULT_PRICES };
    const note = root.querySelector<HTMLElement>('[data-scoping-note]')!;

    let baseline: any = {};
    try { baseline = JSON.parse(localStorage.getItem('edf:scoping-baseline:' + ctx.projectSlug) || '{}'); } catch { baseline = {}; }
    function applyBaselinePrices() {
      if (baseline.pricePerCredit != null) prices.pricePerCredit = baseline.pricePerCredit;
      if (baseline.pricePerMillionRows != null) prices.pricePerMillionRows = baseline.pricePerMillionRows;
    }

    // ── formatting ──────────────────────────────────────────
    const grp = (n: number, min = 0, max = 0) =>
      new Intl.NumberFormat('en-US', { minimumFractionDigits: min, maximumFractionDigits: max }).format(n);
    const fmt = (n: number) => grp(n);
    const fmtMoney = (n: number | null) =>
      n == null ? '—' : '€' + grp(n, 0, 0);
    const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));

    function fmtField(format: string, v: number): string {
      if (format === 'percent') return grp(v, 0, 2);          // 0–1 decimal
      if (format === 'currency') return grp(v, 2, 2);         // 3.00
      if (format === 'decimal') return grp(v, 0, 2);          // 1.5
      return grp(v, 0, 0);                                    // int with thousands
    }
    const parseField = (s: string) => Number(String(s).replace(/,/g, '').trim());

    const PRICE_KEYS = new Set(['pricePerCredit', 'pricePerMillionRows']);
    const isControl = (el: Element) => el.tagName === 'SELECT'; // selects hold string values

    function valueFor(k: string): number {
      if (k === 'pricePerCredit') return prices.pricePerCredit ?? 0;
      if (k === 'pricePerMillionRows') return prices.pricePerMillionRows ?? 0;
      return (assumptions as any)[k] ?? 0;
    }

    // Per-column "Advanced assumptions" state.
    const advState: Record<string, boolean> = { collab: false, cja: false };
    // Which preset (if any) the current state matches; null = custom.
    let activePreset: string | null = null;
    // Baseline used for the "changed vs preset" dots (assumptions + prices).
    let changedBaseline: ScopingAssumptions = { ...DEFAULT_ASSUMPTIONS };
    let changedBaselinePrices: UnitPrices = { ...DEFAULT_PRICES };

    // Evaluate a field's `data-applies` guard: 'key=v1|v2'.
    function appliesOk(el: HTMLElement): boolean {
      const expr = el.getAttribute('data-applies');
      if (!expr) return true;
      const [k, vs] = expr.split('=');
      const allowed = (vs || '').split('|');
      return allowed.includes(String((assumptions as any)[k]));
    }
    function colOf(el: HTMLElement): string {
      return el.closest('[data-col]')?.getAttribute('data-col') || 'collab';
    }

    function writeInputs() {
      root.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-k]').forEach((el) => {
        const k = el.dataset.k!;
        if (isControl(el)) { (el as HTMLSelectElement).value = String((assumptions as any)[k]); return; }
        (el as HTMLInputElement).value = fmtField(el.dataset.format || 'int', valueFor(k));
      });
      // group-level mode gate (hides whole sections in direct mode)
      root.querySelectorAll<HTMLElement>('.scoping-group[data-group-modes]').forEach((el) => {
        const modes = (el.getAttribute('data-group-modes') || '').split(',');
        el.style.display = modes.some((m) => m === 'both' || m.split('|').includes(assumptions.collabMode)) ? '' : 'none';
      });
      // per-field visibility = mode ∧ appliesWhen ∧ (advanced ⇒ column advanced on)
      root.querySelectorAll<HTMLElement>('.scoping-field[data-field]').forEach((el) => {
        const when = el.getAttribute('data-when');
        const modeOk = !when || when.split('|').includes(assumptions.collabMode);
        const advOk = !el.classList.contains('scoping-adv') || advState[colOf(el)];
        el.style.display = (modeOk && appliesOk(el) && advOk) ? '' : 'none';
      });
      updateChangedDots();
    }

    function updateChangedDots() {
      root.querySelectorAll<HTMLElement>('.scoping-field[data-field]').forEach((el) => {
        const k = el.getAttribute('data-field')!;
        const dot = el.querySelector<HTMLElement>('[data-changed-dot]');
        if (!dot) return;
        const cur = PRICE_KEYS.has(k) ? (prices as any)[k] : (assumptions as any)[k];
        const baseVal = PRICE_KEYS.has(k) ? (changedBaselinePrices as any)[k] : (changedBaseline as any)[k];
        dot.hidden = String(cur) === String(baseVal);
      });
    }

    function readInput(el: HTMLInputElement | HTMLSelectElement) {
      const k = el.dataset.k!;
      if (isControl(el)) {
        const raw = (el as HTMLSelectElement).value;
        (assumptions as any)[k] = k === 'measurementEnabled' ? raw === 'true' : raw;
        return;
      }
      const n = parseField((el as HTMLInputElement).value);
      const val = Number.isFinite(n) ? n : 0;
      if (k === 'pricePerCredit') prices.pricePerCredit = val;
      else if (k === 'pricePerMillionRows') prices.pricePerMillionRows = val;
      else (assumptions as any)[k] = val;
    }

    // ── Breakdown drawers + warnings ───────────────────────
    const warnBox = root.querySelector<HTMLElement>('[data-warnings]')!;
    function biSpan(bi: { en: string; it: string }): string {
      return `<span data-lang-en>${esc(bi.en)}</span><span data-lang-it>${esc(bi.it)}</span>`;
    }
    const UNIT_SUFFIX: Record<string, string> = { credits: ' cr', rows: '', ids: '', eur: '', x: '×', runs: '' };
    function lineHtml(li: LineItem): string {
      const v = li.unit === 'eur' ? fmtMoney(li.value) : fmt(Math.round(li.value * 100) / 100) + UNIT_SUFFIX[li.unit];
      return `<div class="scoping-bd-row${li.kind === 'output' ? ' scoping-bd-out' : ''}">`
        + `<div class="scoping-bd-head"><span class="scoping-bd-label">${biSpan(li.label)}</span><b class="scoping-bd-val">${esc(v)}</b></div>`
        + `<code class="scoping-bd-formula">${esc(li.formula)}</code>`
        + `<code class="scoping-bd-sub">${esc(li.substituted)}</code>`
        + `</div>`;
    }
    function renderBreakdowns(bd: ReturnType<typeof computeBreakdown>) {
      const collabEl = root.querySelector<HTMLElement>('[data-breakdown="collab"]')!;
      if (!collabEl.hidden) collabEl.innerHTML = bd.collab.map(lineHtml).join('');
      const cjaEl = root.querySelector<HTMLElement>('[data-breakdown="cja"]')!;
      if (!cjaEl.hidden) {
        const src = bd.cjaSources.map((sc) =>
          `<div class="scoping-bd-src"><span class="scoping-bd-srcname">${sc.id}</span>`
          + `<span class="scoping-bd-srcbar"><span style="width:${sc.weightPct.toFixed(1)}%"></span></span>`
          + `<span class="scoping-bd-srcpct">${sc.weightPct.toFixed(1)}%</span>`
          + `<code class="scoping-bd-sub">${esc(sc.substituted)}</code></div>`).join('');
        cjaEl.innerHTML = `<div class="scoping-bd-sources">${src}</div>` + bd.cja.map(lineHtml).join('');
      }
    }
    function renderWarnings(warns: Warning[]) {
      if (!warns.length) { warnBox.hidden = true; warnBox.innerHTML = ''; return; }
      warnBox.hidden = false;
      warnBox.innerHTML = warns.map((w) =>
        `<p class="scoping-warn scoping-warn-${w.level}"><span class="scoping-warn-ico" aria-hidden="true">${w.level === 'warn' ? '!' : 'i'}</span>${biSpan(w.text)}</p>`).join('');
    }

    function updateChips() {
      root.querySelectorAll<HTMLElement>('[data-preset]').forEach((chip) => {
        const on = chip.getAttribute('data-preset') === (activePreset ?? 'custom');
        chip.setAttribute('aria-pressed', String(on));
      });
    }

    function render() {
      const s = computeSnapshot(assumptions, prices);
      const out = (name: string, v: string) => {
        const el = root.querySelector(`[data-out="${name}"]`);
        if (el) el.textContent = v;
      };
      out('collabCreditsEstimated', fmt(Math.round(s.collabCreditsEstimated)));
      out('collabRecommendedPack', fmt(Math.round(s.collabRecommendedPack)));
      out('collabFerrariCost', fmtMoney(s.collabFerrariCost));
      out('collabPartnerCostTotal', fmtMoney(s.collabPartnerCostTotal));
      out('collabBaseFeeTotal', fmtMoney(s.collabBaseFeeTotal));
      out('collabCost', fmtMoney(s.collabCost));
      out('cjaRowsPerYear', fmt(s.cjaRowsPerYear));
      out('cjaAnnualIngestionLimit', fmt(s.cjaAnnualIngestionLimit));
      out('cjaCost', fmtMoney(s.cjaCost));
      out('totalCost', fmtMoney(s.totalCost));
      const bd = computeBreakdown(assumptions, prices);
      renderWarnings(bd.warnings);
      renderBreakdowns(bd);
      updateChangedDots();
      updateChips();
    }

    root.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-k]').forEach((el) => {
      el.addEventListener('input', () => {
        readInput(el);
        activePreset = null;                 // any manual edit → custom
        if (isControl(el)) writeInputs();    // selects can gate other fields
        render();
      });
      if (el.tagName === 'INPUT') el.addEventListener('blur', () => {
        (el as HTMLInputElement).value = fmtField(el.dataset.format || 'int', valueFor(el.dataset.k!));
      });
    });

    // ── Advanced-assumptions toggles ───────────────────────
    root.querySelectorAll<HTMLInputElement>('[data-advanced-toggle]').forEach((cb) => {
      cb.addEventListener('change', () => { advState[cb.dataset.advancedToggle!] = cb.checked; writeInputs(); });
    });

    // ── Breakdown drawer toggles ───────────────────────────
    root.querySelectorAll<HTMLButtonElement>('[data-breakdown-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const panel = root.querySelector<HTMLElement>(`[data-breakdown="${btn.dataset.breakdownToggle}"]`)!;
        const open = panel.hidden;
        panel.hidden = !open;
        btn.setAttribute('aria-expanded', String(open));
        render();
      });
    });

    // ── Scenario preset chips ──────────────────────────────
    root.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((chip) => {
      chip.addEventListener('click', () => {
        const id = chip.getAttribute('data-preset')!;
        if (id === 'custom') return; // reflects state; not directly selectable
        const sc = scenarios.find((x) => x.preset === id);
        if (sc) applyScenario(sc);
      });
    });

    // ── Scenario picker ────────────────────────────────────
    const picker = root.querySelector<HTMLSelectElement>('[data-scoping-picker]')!;
    let scenarios: Scenario[] = [];

    function refreshPicker() {
      picker.innerHTML = '';
      scenarios.forEach((sc, i) => {
        const o = document.createElement('option');
        o.value = String(i);
        o.textContent = sc.title + (sc.visibility !== 'private' ? ` · ${sc.visibility}` : '');
        picker.appendChild(o);
      });
    }

    function applyScenario(sc: Scenario) {
      assumptions = { ...DEFAULT_ASSUMPTIONS, ...sc.assumptions };
      prices = { ...DEFAULT_PRICES, ...sc.prices };
      applyBaselinePrices();
      activePreset = sc.preset ?? null;
      changedBaseline = { ...assumptions };
      changedBaselinePrices = { ...prices };
      (root.querySelector('[data-scoping-title]') as HTMLInputElement).value = sc.title;
      (root.querySelector('[data-scoping-visibility]') as HTMLSelectElement).value = sc.visibility;
      writeInputs(); render();
    }

    picker.addEventListener('change', () => {
      const sc = scenarios[Number(picker.value)];
      if (sc) applyScenario(sc);
    });

    // ── Save / Share / Reset ───────────────────────────────
    const setNote = (en: string, it: string) => { note.textContent = langOf() === 'it' ? it : en; };
    // Always persist to localStorage so a scenario is NEVER lost, even when the
    // remote write fails (expired session, RLS, offline, unconfigured backend).
    const persistLocal = (sc: Scenario) => {
      scenarios.unshift(sc); saveLocal(ctx.projectSlug, scenarios.filter((x) => !x.id)); refreshPicker();
    };

    root.querySelector('[data-scoping-save]')!.addEventListener('click', async () => {
      const title = (root.querySelector('[data-scoping-title]') as HTMLInputElement).value || 'Scenario';
      const visibility = (root.querySelector('[data-scoping-visibility]') as HTMLSelectElement).value as Scenario['visibility'];
      const sc: Scenario = { title, assumptions: { ...assumptions }, prices: { ...prices }, visibility };

      if (isLoggedIn() && remoteEnabled(ctx)) {
        try {
          sc.id = await saveRemote(ctx, sc);
          scenarios.unshift(sc); refreshPicker();
          setNote('Saved to your account.', 'Salvato sul tuo account.');
          return;
        } catch (e) {
          const status = e instanceof RemoteError ? e.status : -1;
          persistLocal(sc); // never lose the work
          if (status === 401 || status === 403) {
            clearSession(); // the token is dead — reflect logged-out state
            setNote('Session expired — saved locally. Log in again from the Console to sync & share.',
                    'Sessione scaduta — salvato in locale. Rientra dalla Console per sincronizzare e condividere.');
          } else {
            setNote('Cloud save unavailable — saved locally.', 'Salvataggio cloud non disponibile — salvato in locale.');
          }
          return;
        }
      }

      // Anonymous or backend not configured → local save (expected path).
      persistLocal(sc);
      if (isLoggedIn() && !remoteEnabled(ctx)) {
        setNote('Cloud storage not configured — saved locally.', 'Storage cloud non configurato — salvato in locale.');
      } else {
        setNote('Saved locally. Log in from the Console to sync & share.',
                'Salvato in locale. Accedi dalla Console per sincronizzare e condividere.');
      }
    });

    root.querySelector('[data-scoping-share]')!.addEventListener('click', async () => {
      if (!remoteEnabled(ctx)) { setNote('Sharing needs the cloud backend (not configured here).', 'La condivisione richiede il backend cloud (qui non configurato).'); return; }
      if (!isLoggedIn()) { setNote('Log in from the Console (/console/) to create a share link.', 'Accedi dalla Console (/console/) per creare un link di condivisione.'); return; }
      const title = (root.querySelector('[data-scoping-title]') as HTMLInputElement).value || 'Scenario';
      const sc: Scenario = { title, assumptions: { ...assumptions }, prices: { ...prices }, visibility: 'link' };
      try {
        const id = await saveRemote(ctx, sc);
        const path = location.pathname.replace(/\?.*$/, '');
        const url = (location.origin ? location.origin + path : experienceUrl) + '?scenario=' + id;
        await navigator.clipboard?.writeText(url).catch(() => {});
        setNote('Share link copied: ' + url, 'Link di condivisione copiato: ' + url);
      } catch (e) {
        const status = e instanceof RemoteError ? e.status : -1;
        if (status === 401 || status === 403) {
          clearSession();
          setNote('Session expired — log in again from the Console to create a share link.',
                  'Sessione scaduta — rientra dalla Console per creare un link di condivisione.');
        } else {
          setNote('Could not create share link (cloud unavailable).', 'Impossibile creare il link (cloud non disponibile).');
        }
      }
    });

    // Reset re-applies the first scenario (keeps every field populated, never 0/blank).
    root.querySelector('[data-scoping-reset]')!.addEventListener('click', () => {
      if (scenarios[0]) applyScenario(scenarios[0]);
      note.textContent = '';
    });

    const comparePanel = root.querySelector<HTMLElement>('[data-scoping-compare-panel]')!;
    root.querySelector('[data-scoping-compare]')!.addEventListener('click', () => {
      if (!scenarios.length) { note.textContent = 'No scenarios to compare yet.'; return; }
      const rows: Array<[string, (s: ReturnType<typeof computeSnapshot>) => string]> = [
        ['Est. credits / yr', (s) => fmt(Math.round(s.collabCreditsEstimated))],
        ['Recommended pack', (s) => fmt(s.collabRecommendedPack)],
        ['Collab cost', (s) => fmtMoney(s.collabCost)],
        ['CJA rows / yr', (s) => fmt(s.cjaRowsPerYear)],
        ['Ingestion limit (3×)', (s) => fmt(s.cjaAnnualIngestionLimit)],
        ['CJA cost', (s) => fmtMoney(s.cjaCost)],
        ['Total', (s) => fmtMoney(s.totalCost)],
      ];
      const snaps = scenarios.map((sc) => ({
        title: sc.title,
        snap: computeSnapshot({ ...DEFAULT_ASSUMPTIONS, ...sc.assumptions }, { ...DEFAULT_PRICES, ...sc.prices }),
      }));
      const thead = comparePanel.querySelector('thead')!;
      const tbody = comparePanel.querySelector('tbody')!;
      thead.innerHTML = '<tr><th></th>' + snaps.map((x) => `<th>${esc(x.title)}</th>`).join('') + '</tr>';
      tbody.innerHTML = rows
        .map(([label, f]) => `<tr><td>${label}</td>` + snaps.map((x) => `<td>${f(x.snap)}</td>`).join('') + '</tr>')
        .join('');
      comparePanel.hidden = false;
    });

    // ── Export (JSON / CSV) ────────────────────────────────
    function download(name: string, mime: string, text: string) {
      const blob = new Blob([text], { type: mime });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = name; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }
    function scenarioTitle() {
      return (root.querySelector('[data-scoping-title]') as HTMLInputElement).value || 'scenario';
    }
    root.querySelectorAll<HTMLButtonElement>('[data-scoping-export]')!.forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = langOf();
        const snap = computeSnapshot(assumptions, prices);
        const bd = computeBreakdown(assumptions, prices);
        const safe = scenarioTitle().replace(/[^\w.-]+/g, '_');
        if (btn.dataset.scopingExport === 'json') {
          download(`${safe}.scoping.json`, 'application/json',
            JSON.stringify({ title: scenarioTitle(), project: ctx.projectSlug, assumptions, prices, snapshot: snap, breakdown: bd }, null, 2));
        } else {
          const rows: string[][] = [['section', 'line', 'value', 'unit', 'formula', 'substituted']];
          bd.collab.forEach((l) => rows.push(['collaboration', l.label[lang], String(Math.round(l.value * 100) / 100), l.unit, l.formula, l.substituted]));
          bd.cjaSources.forEach((sc) => rows.push(['cja-source', sc.id, String(Math.round(sc.rows)), 'rows', sc.formula, sc.substituted]));
          bd.cja.forEach((l) => rows.push(['cja', l.label[lang], String(Math.round(l.value * 100) / 100), l.unit, l.formula, l.substituted]));
          const csv = rows.map((r) => r.map((c) => `"${String(c).replace(/"/g, '""')}"`).join(',')).join('\n');
          download(`${safe}.scoping.csv`, 'text/csv', csv);
        }
        note.textContent = lang === 'it' ? 'Esportato.' : 'Exported.';
      });
    });

    // ── Info tooltips: click to open (never on hover, so they can't block
    //    the field). Click-away or Esc closes; only one open at a time. ──
    const infoButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('.scoping-info'));
    function closeTips(except?: Element | null) {
      infoButtons.forEach((b) => { if (b !== except) b.setAttribute('aria-expanded', 'false'); });
    }
    infoButtons.forEach((btn) => {
      btn.setAttribute('aria-expanded', 'false');
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = btn.getAttribute('aria-expanded') === 'true';
        closeTips(btn);
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
    });
    root.addEventListener('click', (e) => {
      const t = e.target as Element;
      if (!t.closest('.scoping-info') && !t.closest('.scoping-tip')) closeTips();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeTips(); });

    // ── Boot ────────────────────────────────────────────────
    const seeded = (window as any).__edfScopingSeeds as Scenario[] | undefined;
    scenarios = (seeded ? seeded.slice() : []).concat(loadLocal(ctx.projectSlug));
    refreshPicker();

    const sharedId = scenarioIdFromSearch(location.search);
    if (sharedId) {
      fetchRemoteById(ctx, sharedId).then((sc) => {
        if (sc) { scenarios.unshift(sc); refreshPicker(); applyScenario(sc); }
      });
    } else if (scenarios[0]) {
      applyScenario(scenarios[0]);
    } else {
      applyBaselinePrices();
      writeInputs(); render();
    }
    if (isLoggedIn()) listMine(ctx).then((mine) => { if (mine.length) { scenarios = mine.concat(scenarios); refreshPicker(); } });
  }

  function bootAll() {
    document.querySelectorAll<HTMLElement>('[data-scoping]').forEach((el) => {
      if (el.dataset.scopingReady === '1') return;
      el.dataset.scopingReady = '1';
      initScoping(el);
    });
  }
  bootAll();
  document.addEventListener('astro:page-load', bootAll);
</script>

<!-- is:global — the .scoping-* rules are shared with the ScopingField sub-component
     (Astro scopes <style> per component; the fields live in a different file). All
     selectors are .scoping-prefixed and this component only loads on /scoping/. -->
<style is:global>
  .scoping { display: flex; flex-direction: column; gap: 1.1rem; width: 100%; max-width: 1600px; margin: 0 auto; height: 100%; overflow-y: auto; padding: 1.25rem 1.5rem; box-sizing: border-box; }
  .scoping *, .scoping *::before, .scoping *::after { box-sizing: border-box; }
  .scoping-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .scoping-title { font-family: var(--font-display); font-size: 1.15rem; font-weight: 800; color: var(--ink-inverse, #F4F4F2); letter-spacing: -0.01em; }
  .scoping-sub { font-size: 0.78rem; color: var(--color-grigio-400, #9a9a9a); max-width: 46rem; margin-top: 0.25rem; line-height: 1.5; }
  .scoping-i-demo, .scoping-info { display: inline-flex; align-items: center; justify-content: center; width: 14px; height: 14px; border-radius: 50%; border: 1px solid var(--accent-secondary, #FFF200); color: var(--accent-secondary, #FFF200); font-size: 9px; font-style: italic; font-weight: 700; line-height: 1; }
  .scoping-legend { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.68rem; color: var(--color-grigio-400, #9a9a9a); }
  .scoping-legend-dot { width: 10px; height: 10px; border-radius: 2px; border-left: 3px solid var(--accent-secondary, #FFF200); background: rgba(255,242,0,0.08); }

  .scoping-cols { display: grid; grid-template-columns: 1fr; gap: 1.1rem; }
  @media (min-width: 820px) { .scoping-cols { grid-template-columns: 1fr 1fr; align-items: start; } }
  .scoping-card { min-width: 0; background: color-mix(in srgb, var(--surface-inverse, #0B0B0D) 80%, #fff 5%); border: 1px solid var(--line-subtle, rgba(255,255,255,0.1)); border-radius: 8px; padding: 1.1rem 1.2rem; }
  .scoping-card-h { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem 0.75rem; flex-wrap: wrap; font-family: var(--font-display); font-size: 0.92rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; color: var(--ink-inverse, #F4F4F2); padding-bottom: 0.7rem; margin-bottom: 0.7rem; border-bottom: 1px solid var(--line-subtle, rgba(255,255,255,0.1)); }
  .scoping-card-metric { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.06em; color: var(--accent-secondary, #FFF200); flex-shrink: 0; }
  .scoping-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-bottom: 0.9rem; }
  @media (max-width: 520px) { .scoping-controls { grid-template-columns: 1fr; } }

  .scoping-group { margin-bottom: 0.85rem; }
  .scoping-group-h { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.11em; text-transform: uppercase; color: var(--accent-primary, #FF2800); margin-bottom: 0.5rem; }
  .scoping-field { display: flex; flex-direction: column; gap: 0.22rem; margin-bottom: 0.55rem; font-size: 0.72rem; color: var(--color-grigio-300, #cfcfcf); }
  .scoping-so { border-left: 2px solid var(--accent-secondary, #FFF200); padding-left: 0.55rem; margin-left: -0.05rem; }
  /* inline impact caption — always visible, so the "why" isn't buried in the tooltip */
  .scoping-hint { display: block; margin-top: 0.28rem; font-size: 0.7rem; line-height: 1.45; color: var(--color-grigio-300, #cfcfcf); }
  .scoping-label { display: flex; align-items: center; gap: 0.35rem; position: relative; }
  .scoping-label-txt { flex-shrink: 1; }
  .scoping-badge { font-size: 0.5rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; border-radius: 3px; padding: 0.05rem 0.28rem; white-space: nowrap; border: 1px solid transparent; }
  /* semantic data-type badges — explicit rgba so the audit contrast parser reads them */
  .scoping-badge-official { color: #7ee0a0; border-color: rgba(126,224,160,0.5); background: rgba(126,224,160,0.08); }
  .scoping-badge-default-assumption { color: #cfcfcf; border-color: rgba(207,207,207,0.35); background: rgba(207,207,207,0.06); }
  .scoping-badge-customer-assumption { color: #8fb8ff; border-color: rgba(143,184,255,0.5); background: rgba(143,184,255,0.08); }
  .scoping-badge-price { color: #FFF200; border-color: rgba(255,242,0,0.5); background: rgba(255,242,0,0.08); }
  .scoping-changed { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-primary, #FF2800); flex-shrink: 0; box-shadow: 0 0 0 2px rgba(255,40,0,0.18); }
  .scoping-info { cursor: pointer; flex-shrink: 0; background: transparent; }
  .scoping-input-wrap { position: relative; display: flex; align-items: center; }
  .scoping-prefix { position: absolute; left: 0.55rem; font-size: 0.85rem; color: var(--color-grigio-400, #9a9a9a); pointer-events: none; }
  .scoping-field input, .scoping-field select { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid var(--line-subtle, rgba(255,255,255,0.14)); color: var(--ink-inverse, #F4F4F2); border-radius: 5px; padding: 0.42rem 0.55rem; font-size: 0.85rem; font-variant-numeric: tabular-nums; }
  .scoping-input-wrap:has(.scoping-prefix) input { padding-left: 1.3rem; }
  .scoping-field input:focus, .scoping-field select:focus { outline: none; border-color: var(--accent-primary, #FF2800); }

  /* audit tooltip — click to open (never on hover, so it can't block the field) */
  .scoping-tip { position: absolute; z-index: 40; left: 0; top: calc(100% + 6px); width: min(20rem, 78vw); display: none; flex-direction: column; gap: 0.4rem; padding: 0.65rem 0.75rem; background: #16161a; border: 1px solid var(--line-subtle, rgba(255,255,255,0.16)); border-radius: 6px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); pointer-events: auto; }
  .scoping-info[aria-expanded="true"] ~ .scoping-tip { display: flex; }
  .scoping-info[aria-expanded="true"] { background: var(--accent-secondary, #FFF200); color: #16161a; }
  .scoping-tip-row { display: flex; flex-direction: column; gap: 0.1rem; font-size: 0.72rem; line-height: 1.4; color: var(--color-grigio-300, #cfcfcf); }
  .scoping-tip-row b { font-size: 0.55rem; letter-spacing: 0.1em; font-weight: 800; color: var(--accent-secondary, #FFF200); }
  .scoping-tip--metric { font-size: 0.72rem; line-height: 1.45; color: var(--color-grigio-300, #cfcfcf); font-weight: 400; letter-spacing: 0; text-transform: none; }
  .scoping-tip--right { left: auto; right: 0; }

  /* ── Scenario preset chips ── */
  .scoping-presets { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .scoping-presets-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.11em; text-transform: uppercase; color: var(--color-grigio-400, #9a9a9a); margin-right: 0.2rem; }
  .scoping-chip { cursor: pointer; font-size: 0.72rem; font-weight: 600; color: var(--color-grigio-300, #cfcfcf); background: rgba(255,255,255,0.05); border: 1px solid var(--line-subtle, rgba(255,255,255,0.14)); border-radius: 999px; padding: 0.28rem 0.8rem; }
  .scoping-chip:hover { border-color: var(--accent-primary, #FF2800); color: var(--ink-inverse, #F4F4F2); }
  .scoping-chip[aria-pressed="true"] { background: var(--accent-primary, #FF2800); border-color: var(--accent-primary, #FF2800); color: #fff; }
  .scoping-chip[data-preset="custom"] { border-style: dashed; }

  /* ── Guardrail warnings ── */
  .scoping-warnings { display: flex; flex-direction: column; gap: 0.4rem; }
  .scoping-warn { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.76rem; line-height: 1.45; border-radius: 6px; padding: 0.5rem 0.7rem; border: 1px solid transparent; }
  .scoping-warn-ico { flex-shrink: 0; width: 15px; height: 15px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 800; font-style: italic; margin-top: 1px; }
  .scoping-warn-warn { background: rgba(255,40,0,0.10); border-color: rgba(255,40,0,0.4); color: #ffb3a3; }
  .scoping-warn-warn .scoping-warn-ico { background: var(--accent-primary, #FF2800); color: #fff; font-style: normal; }
  .scoping-warn-info { background: rgba(143,184,255,0.08); border-color: rgba(143,184,255,0.35); color: #b9cdf5; }
  .scoping-warn-info .scoping-warn-ico { background: #8fb8ff; color: #10131a; }

  /* ── Advanced-assumptions toggle ── */
  .scoping-adv-toggle { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; color: var(--color-grigio-300, #cfcfcf); cursor: pointer; margin: 0.35rem 0 0.2rem; }
  .scoping-adv-toggle input { width: auto; }

  /* ── Breakdown drawer ── */
  .scoping-breakdown-toggle { cursor: pointer; font-size: 0.72rem; font-weight: 600; color: var(--accent-secondary, #FFF200); background: transparent; border: 1px solid rgba(255,242,0,0.4); border-radius: 5px; padding: 0.35rem 0.7rem; margin-top: 0.5rem; }
  .scoping-breakdown-toggle:hover { background: rgba(255,242,0,0.08); }
  .scoping-breakdown { margin-top: 0.6rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .scoping-bd-row { border-left: 2px solid var(--line-subtle, rgba(255,255,255,0.16)); padding-left: 0.6rem; display: flex; flex-direction: column; gap: 0.15rem; }
  .scoping-bd-out { border-left-color: var(--accent-primary, #FF2800); }
  .scoping-bd-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.6rem; }
  .scoping-bd-label { font-size: 0.76rem; color: var(--color-grigio-200, #e2e2e2); font-weight: 600; }
  .scoping-bd-val { font-family: var(--font-display); font-size: 0.85rem; color: var(--ink-inverse, #F4F4F2); font-variant-numeric: tabular-nums; }
  .scoping-bd-formula, .scoping-bd-sub { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.66rem; line-height: 1.4; color: var(--color-grigio-400, #9a9a9a); white-space: pre-wrap; word-break: break-word; }
  .scoping-bd-sub { color: var(--color-grigio-300, #cfcfcf); }
  .scoping-bd-sources { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.3rem; }
  .scoping-bd-src { display: grid; grid-template-columns: 3.5rem 1fr 2.6rem; align-items: center; gap: 0.4rem 0.5rem; }
