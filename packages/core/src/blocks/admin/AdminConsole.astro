  }
  .admin-separator {
    color: #9ca3af;
  }
  .admin-project {
    color: #6b7280;
  }
  .admin-badge {
    background: #BE2027;
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.01em;
    margin-left: 0.25rem;
  }
  .admin-back-link {
    display: flex;
    align-items: center;
