  /* ---- Mockup prodotto tab ---- */
  .mockup-product-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.4rem; display: flex; flex-direction: column; gap: 1rem; }
  .mockup-solution-tag { display: inline-block; font-family: 'Menlo','Consolas',monospace; font-size: 0.6875rem; background: #e5e7eb; color: #374151; padding: 2px 7px; border-radius: 4px; }
  .mockup-features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.625rem; }
  @media (max-width: 640px) { .mockup-features-grid { grid-template-columns: 1fr; } }
  .mockup-feature-card { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.875rem; transition: opacity 0.15s, border-color 0.15s; }
  .mockup-feature-card[data-inactive] { opacity: 0.5; border-style: dashed; }
  .mockup-feature-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem; flex-wrap: wrap; }
  .mockup-feature-name { font-size: 0.875rem; font-weight: 600; color: #111827; flex: 1; min-width: 0; }
  .mockup-recommended-badge { font-size: 0.5625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; background: #fef3c7; color: #92400e; border: 1px solid #fde68a; padding: 2px 7px; border-radius: 20px; white-space: nowrap; flex-shrink: 0; }
  .mockup-feature-desc { font-size: 0.75rem; color: #6b7280; line-height: 1.5; margin: 0 0 0.5rem; }
  .mockup-relevant-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .mockup-relevant-tag { font-size: 0.5625rem; font-weight: 600; padding: 1px 6px; border-radius: 20px; background: #EEF2FF; color: #4338ca; white-space: nowrap; }
  .mockup-save-row { display: flex; align-items: center; gap: 0.875rem; padding-top: 0.75rem; border-top: 1px solid #f3f4f6; flex-wrap: wrap; }
  .mockup-active-count { font-size: 0.8125rem; color: #6b7280; margin-left: auto; }

  /* ---- Scoping baseline tab ---- */
  .admin-h2 { font-size: 1.1rem; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
  .admin-help { font-size: 0.85rem; color: #6b7280; margin-bottom: 1rem; max-width: 44rem; }
  .admin-scoping-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; margin-bottom: 1rem; }
  .admin-scoping-grid label { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.8rem; color: #374151; }
  .admin-scoping-grid input { border: 1px solid #d1d5db; border-radius: 4px; padding: 0.4rem 0.5rem; font-size: 0.9rem; }
  .admin-btn { background: #BE2027; color: #fff; border: none; border-radius: 4px; padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 600; cursor: pointer; }
  .admin-btn:hover { background: #a01a20; }
  .admin-note { margin-left: 0.75rem; font-size: 0.8rem; color: #16a34a; }
</style>

<script is:inline define:vars={{ projectSlug, deckHref, SUPABASE_URL, SUPABASE_ANON_KEY, allSolutionIds, pagesMap: PAGE_REGISTRY, mockupLibrary: relevantMockups }}>
(function() {
  var STORAGE_KEY = 'edf:media-slots:' + projectSlug;
  var SOL_STORAGE_KEY = 'edf-solutions-' + projectSlug;
  var PROJECT_SLUG = projectSlug;
  var EXPERIENCE_URL = location.origin + deckHref;

  // ── Solutions (section on/off) ────────────────────────────────
  function loadSolutions() {
    try {
      var raw = localStorage.getItem(SOL_STORAGE_KEY);
      if (raw) return JSON.parse(raw);
    } catch(e) {}
    return null; // null = all active (no restriction)
  }

  function activeSolutionIds() {
    var out = [];
    document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
      if (t.checked) out.push(t.getAttribute('data-solution-toggle'));
    });
    return out;
  }

  function updateSolutionRows() {
    document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
      var row = t.closest('[data-solution-row]');
      if (!row) return;
      if (t.checked) row.removeAttribute('data-inactive');
      else row.setAttribute('data-inactive', '');
    });
  }

  function updateSolutionCount() {
    var badge = document.querySelector('[data-count-sezioni]');
    if (badge) badge.textContent = activeSolutionIds().length + '/' + allSolutionIds.length;
  }

  function saveSolutions() {
    var active = activeSolutionIds();
    try { localStorage.setItem(SOL_STORAGE_KEY, JSON.stringify(active)); } catch(e) {}

    // Shareable ?s= link (omit when all active)
    var input = document.getElementById('sol-share-url');
    if (input) {
      input.value = active.length < allSolutionIds.length
        ? EXPERIENCE_URL + '?s=' + active.join(',')
        : '';
    }

    // Live broadcast to any open deck (same-origin, cross-tab)
    var msg = { type: 'edf:solutions-changed', project: PROJECT_SLUG, activeIds: active };
    try { new BroadcastChannel('edf-console').postMessage(msg); } catch(e) {}

    updateSolutionRows();
    updateSolutionCount();
  }

  function loadConfig() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    } catch(e) { return {}; }
  }

  function saveConfig(config) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(config));
    window.dispatchEvent(new CustomEvent('edf:slots-updated'));
  }

  async function generateShareableLink() {
    var config = loadConfig();
    var customSlides = [];
    try { customSlides = JSON.parse(localStorage.getItem('edf:custom-slides:' + PROJECT_SLUG) || '[]'); } catch (e) {}
    var hasActive = Object.keys(config).some(function(k) {
      return config[k] && config[k].active && config[k].url;
    });

    var genBtn = document.getElementById('generate-link-btn');
    var urlRow = document.getElementById('share-url-row');
    var shareInput = document.getElementById('share-url-input');
    var note = document.getElementById('share-note');

    if (!hasActive && customSlides.length === 0) {
      if (note) { note.textContent = 'Attiva uno slot media o crea una slide personalizzata prima di generare il link.'; note.style.color = '#BE2027'; }
      return;
    }

    // Writes to media_configs require an authenticated console session
    // (shared same-origin via localStorage['edf:sb-session']). The anon key
    // must NOT be used as the write bearer.
    var accessToken = '';
    try { accessToken = (JSON.parse(localStorage.getItem('edf:sb-session') || 'null') || {}).access_token || ''; } catch (e) {}
    if (!accessToken) {
      if (note) { note.textContent = 'Accedi dalla Console (/console/) per generare un link condivisibile.'; note.style.color = '#BE2027'; }
      return;
    }

    // Carry custom slides inside the same shared config blob.
    var shareConfig = Object.assign({}, config);
    if (customSlides.length) shareConfig.__customSlides = customSlides;

    if (genBtn) { genBtn.disabled = true; genBtn.textContent = 'Generazione…'; }
    if (note) { note.textContent = ''; note.style.color = ''; }

    try {
      var res = await fetch(SUPABASE_URL + '/rest/v1/media_configs', {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + accessToken,
          'Content-Type': 'application/json',
          'Prefer': 'return=representation'
        },
        body: JSON.stringify({ project_slug: PROJECT_SLUG, config: shareConfig })
      });
      var rows = await res.json();
      var id = rows && rows[0] && rows[0].id;
      if (!id) throw new Error('no id');

      var shareUrl = EXPERIENCE_URL + '?cfg=' + id;
      if (shareInput) shareInput.value = shareUrl;
      if (urlRow) urlRow.style.display = 'flex';
      if (note) { note.textContent = 'Link generato. Rigenera dopo ogni modifica per aggiornare la configurazione condivisa.'; note.style.color = '#16a34a'; }
    } catch(e) {
      if (note) { note.textContent = 'Errore nella generazione del link. Controlla la connessione e riprova.'; note.style.color = '#BE2027'; }
    } finally {
      if (genBtn) {
        genBtn.disabled = false;
        genBtn.innerHTML = '<svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M8 3v10M3 8h10"/></svg> Genera link condivisibile';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    try { sessionStorage.setItem('edf:console', '1'); } catch(e) {}
    var config = loadConfig();

    // ── Tab switching ──────────────────────────────────────────
    document.querySelectorAll('.admin-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var name = tab.getAttribute('data-tab');
        document.querySelectorAll('.admin-tab').forEach(function(t) {
          var on = t === tab;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        document.querySelectorAll('[data-tabpanel]').forEach(function(p) {
          if (p.getAttribute('data-tabpanel') === name) p.removeAttribute('hidden');
          else p.setAttribute('hidden', '');
        });
      });
    });

    // ── Solutions init ─────────────────────────────────────────
    var savedSolutions = loadSolutions();
    if (savedSolutions) {
      document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
        t.checked = savedSolutions.indexOf(t.getAttribute('data-solution-toggle')) !== -1;
      });
    }
    updateSolutionRows();
    updateSolutionCount();
    // Sync share URL to current state (without forcing a write if untouched)
    (function() {
      var input = document.getElementById('sol-share-url');
      var active = activeSolutionIds();
      if (input) input.value = active.length < allSolutionIds.length ? EXPERIENCE_URL + '?s=' + active.join(',') : '';
    })();

    document.querySelectorAll('[data-solution-toggle]').forEach(function(t) {
      t.addEventListener('change', saveSolutions);
    });

    var solEnableAll = document.getElementById('sol-enable-all');
    if (solEnableAll) solEnableAll.addEventListener('click', function() {
      document.querySelectorAll('[data-solution-toggle]').forEach(function(t) { t.checked = true; });
      saveSolutions();
    });
    var solDisableAll = document.getElementById('sol-disable-all');
    if (solDisableAll) solDisableAll.addEventListener('click', function() {
      document.querySelectorAll('[data-solution-toggle]').forEach(function(t) { t.checked = false; });
      saveSolutions();
    });

    var solCopyBtn = document.getElementById('sol-copy-url');
    var solShareInput = document.getElementById('sol-share-url');
    if (solCopyBtn && solShareInput) {
      solCopyBtn.addEventListener('click', function() {
        var url = solShareInput.value || EXPERIENCE_URL;
        navigator.clipboard.writeText(url).then(function() {
          var orig = solCopyBtn.innerHTML;
          solCopyBtn.textContent = '✓ Copiato!';
          setTimeout(function() { solCopyBtn.innerHTML = orig; }, 2000);
        }).catch(function() { solShareInput.select(); document.execCommand('copy'); });
      });
    }

    // Accordion toggle logic
    document.querySelectorAll('[data-page-toggle]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var slug = btn.getAttribute('data-page-toggle');
        var panel = document.querySelector('[data-slides-panel="' + slug + '"]');
        if (!panel) return;
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        if (expanded) {
          panel.setAttribute('hidden', '');
        } else {
          panel.removeAttribute('hidden');
        }
      });
    });

    // Auto-expand sections that have active slots
    Object.keys(config).forEach(function(slotKey) {
      if (config[slotKey] && config[slotKey].active && config[slotKey].url) {
        var parts = slotKey.split(':');
        if (parts.length >= 2) {
          var slug = parts[0];
          var btn = document.querySelector('[data-page-toggle="' + slug + '"]');
          var panel = document.querySelector('[data-slides-panel="' + slug + '"]');
          if (btn && panel) {
            btn.setAttribute('aria-expanded', 'true');
            panel.removeAttribute('hidden');
          }
        }
      }
    });

    // Populate each slot form from stored config
    document.querySelectorAll('[data-slot-toggle]').forEach(function(toggle) {
      var id = toggle.getAttribute('data-slot-toggle');
      var cfg = config[id] || {};

      toggle.checked = !!cfg.active;

      var urlInput = document.querySelector('[data-slot-url="' + id + '"]');
      if (urlInput && cfg.url) urlInput.value = cfg.url;

      var typeInputs = document.querySelectorAll('[data-slot-type="' + id + '"]');
      var savedType = cfg.type || 'image';
      typeInputs.forEach(function(r) { r.checked = r.value === savedType; });

      var autoplayInputs = document.querySelectorAll('[data-slot-autoplay="' + id + '"]');
      var savedAutoplay = cfg.autoplay || 'auto';
      autoplayInputs.forEach(function(r) { r.checked = r.value === savedAutoplay; });

      var delayInput = document.querySelector('[data-slot-delay="' + id + '"]');
      if (delayInput && cfg.autoplayDelay) delayInput.value = cfg.autoplayDelay;

      var autoplayRow = document.querySelector('[data-autoplay-row="' + id + '"]');
      if (autoplayRow) autoplayRow.style.display = savedType === 'video' ? '' : 'none';

      var delayRow = document.querySelector('[data-delay-row="' + id + '"]');
      if (delayRow) delayRow.style.display = (savedType === 'video' && savedAutoplay === 'delayed') ? '' : 'none';
    });

    // Save buttons
    document.querySelectorAll('[data-slot-save]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-slot-save');
        var currentConfig = loadConfig();

        var urlInput = document.querySelector('[data-slot-url="' + id + '"]');
        var toggleInput = document.querySelector('[data-slot-toggle="' + id + '"]');
        var typeInput = document.querySelector('[data-slot-type="' + id + '"]:checked');
        var autoplayInput = document.querySelector('[data-slot-autoplay="' + id + '"]:checked');
        var delayInput2 = document.querySelector('[data-slot-delay="' + id + '"]');

        currentConfig[id] = {
          active: toggleInput ? toggleInput.checked : false,
          url: urlInput ? urlInput.value.trim() : '',
          type: typeInput ? typeInput.value : 'image',
          autoplay: autoplayInput ? autoplayInput.value : 'auto',
          autoplayDelay: delayInput2 ? (parseInt(delayInput2.value, 10) || 3) : 3,
        };

        saveConfig(currentConfig);

        // Visual feedback
        var feedback = document.querySelector('[data-slot-feedback="' + id + '"]');
        if (feedback) {
          feedback.textContent = '✓ Salvato';
          feedback.classList.add('visible');
          setTimeout(function() { feedback.classList.remove('visible'); }, 2000);
        }
      });
    });

    // Type change → show/hide autoplay row
    document.querySelectorAll('[data-slot-type]').forEach(function(r) {
      r.addEventListener('change', function() {
        var sid = r.getAttribute('data-slot-type');
        var aRow = document.querySelector('[data-autoplay-row="' + sid + '"]');
        if (aRow) aRow.style.display = r.value === 'video' ? '' : 'none';
        if (r.value !== 'video') {
          var dRow = document.querySelector('[data-delay-row="' + sid + '"]');
          if (dRow) dRow.style.display = 'none';
        }
      });
    });

    // Autoplay mode change → show/hide delay row
    document.querySelectorAll('[data-slot-autoplay]').forEach(function(r) {
      r.addEventListener('change', function() {
        var sid = r.getAttribute('data-slot-autoplay');
        var dRow = document.querySelector('[data-delay-row="' + sid + '"]');
        if (dRow) dRow.style.display = r.value === 'delayed' ? '' : 'none';
      });
    });

    // Generate link button
    var genBtn = document.getElementById('generate-link-btn');
    if (genBtn) genBtn.addEventListener('click', generateShareableLink);

    // Copy share URL button
    var copyBtn = document.getElementById('copy-share-url');
    var shareInput = document.getElementById('share-url-input');
    if (copyBtn && shareInput) {
      copyBtn.addEventListener('click', function() {
        var url = shareInput.value;
        if (!url) return;
        navigator.clipboard.writeText(url).then(function() {
          var origHtml = copyBtn.innerHTML;
          copyBtn.textContent = '✓ Copiato!';
          setTimeout(function() { copyBtn.innerHTML = origHtml; }, 2000);
        }).catch(function() {
          shareInput.select();
          document.execCommand('copy');
        });
      });
    }

    // Reset all button
    var resetBtn = document.getElementById('reset-all-slots');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        if (confirm('Eliminare tutte le configurazioni demo slot?')) {
          localStorage.removeItem(STORAGE_KEY);
          window.dispatchEvent(new CustomEvent('edf:slots-updated'));
          location.reload();
        }
      });
    }

    // ════════════════════════════════════════════════════════════════
    //  Custom slides authoring
    // ════════════════════════════════════════════════════════════════
    (function customSlides() {
      var CS_KEY = 'edf:custom-slides:' + PROJECT_SLUG;
      var BG_TONE = { primary: 'light', secondary: 'light', inverse: 'dark', brand: 'dark' };
      var BG_CLASS = { primary: 'bg-[var(--surface-primary)]', secondary: 'bg-[var(--surface-secondary)]', inverse: 'bg-[var(--surface-inverse)]', brand: 'bg-[var(--accent-primary)]' };
      var BG_SWATCH = { primary: 'var(--surface-primary)', secondary: 'var(--surface-secondary)', inverse: 'var(--surface-inverse)', brand: 'var(--accent-primary)' };
      var SECTION_LABEL = {};
      pagesMap.forEach(function (p) { SECTION_LABEL[p.slug] = p.label; });

      var editingId = null;
      var $ = function (sel) { return document.querySelector(sel); };
      var secSel = $('[data-cs-section]'), posSel = $('[data-cs-position]');
      var ebInput = $('[data-cs-eyebrow]'), titleInput = $('[data-cs-title]');
      var blocksWrap = $('[data-cs-blocks]'), preview = $('[data-cs-preview]');
      var listWrap = $('[data-cs-list]'), feedback = $('[data-cs-feedback]');
      var editorTitle = $('[data-cs-editor-title]'), countBadge = $('[data-count-slides]');

      function csLoad() { try { return JSON.parse(localStorage.getItem(CS_KEY) || '[]'); } catch (e) { return []; } }
      function csSave(arr) {
        localStorage.setItem(CS_KEY, JSON.stringify(arr));
        try { new BroadcastChannel('edf-console').postMessage({ type: 'edf:custom-slides-changed', project: PROJECT_SLUG }); } catch (e) {}
        if (countBadge) countBadge.textContent = String(arr.length);
      }

      // ── section + position selects ──
      secSel.innerHTML = pagesMap.map(function (p) { return '<option value="' + p.slug + '">' + p.label + '</option>'; }).join('');
      function fillPositions() {
        var page = pagesMap.filter(function (p) { return p.slug === secSel.value; })[0];
        var opts = '<option value="__end">In fondo alla sezione</option><option value="__start">All\'inizio</option>';
        if (page) opts += page.slides.map(function (s) { return '<option value="' + s.id + '">Dopo: ' + s.label + '</option>'; }).join('');
        posSel.innerHTML = opts;
      }
      secSel.addEventListener('change', function () { fillPositions(); schedulePreview(); });
      fillPositions();

      // ── blocks ──
      function blockNode(type, data) {
        data = data || {};
        var el = document.createElement('div');
        el.className = 'cs-block';
        el.setAttribute('data-block-type', type);
        var label = type === 'text' ? 'Testo' : (type === 'image' ? 'Immagine' : 'Video');
        var tools = '<div class="cs-block-tools">'
          + '<button type="button" class="cs-icon-btn" data-move="up" title="Su">↑</button>'
          + '<button type="button" class="cs-icon-btn" data-move="down" title="Giù">↓</button>'
          + '<button type="button" class="cs-icon-btn" data-remove title="Rimuovi">✕</button></div>';
        var head = '<div class="cs-block-head"><span class="cs-block-type">' + label + '</span>' + tools + '</div>';
        var body = '';
        if (type === 'text') {
          body = '<div class="cs-rt-toolbar">'
            + '<button type="button" class="cs-rt-btn" data-rt="bold"><b>B</b></button>'
            + '<button type="button" class="cs-rt-btn" data-rt="italic"><i>I</i></button>'
            + '<button type="button" class="cs-rt-btn" data-rt="h3">H3</button>'
            + '<button type="button" class="cs-rt-btn" data-rt="ul">•</button>'
            + '<button type="button" class="cs-rt-btn" data-rt="ol">1.</button>'
            + '<button type="button" class="cs-rt-btn" data-rt="link">🔗</button>'
            + '</div>'
            + '<div class="cs-rt-area" contenteditable="true" data-rt-area data-placeholder="Scrivi il testo…">' + (data.html || '') + '</div>';
        } else if (type === 'image') {
          body = '<div class="field-group"><input type="url" class="field-input" data-b-url placeholder="URL immagine (https://…)" value="' + (data.url || '') + '"></div>'
            + '<div class="cs-grid-2" style="margin-top:0.4rem;">'
            + '<input type="text" class="field-input" data-b-alt placeholder="Testo alternativo" value="' + (data.alt || '') + '">'
            + '<input type="text" class="field-input" data-b-caption placeholder="Didascalia (opz.)" value="' + (data.caption || '') + '"></div>';
        } else {
          body = '<div class="field-group"><input type="url" class="field-input" data-b-url placeholder="URL video o YouTube" value="' + (data.url || '') + '"></div>'
            + '<div class="cs-grid-2" style="margin-top:0.4rem;">'
            + '<select class="field-input" data-b-autoplay><option value="auto"' + (data.autoplay !== 'manual' ? ' selected' : '') + '>Autoplay</option><option value="manual"' + (data.autoplay === 'manual' ? ' selected' : '') + '>Con controlli</option></select>'
            + '<input type="text" class="field-input" data-b-caption placeholder="Didascalia (opz.)" value="' + (data.caption || '') + '"></div>';
        }
        el.innerHTML = head + body;
        return el;
      }

      function addBlock(type, data) { blocksWrap.appendChild(blockNode(type, data)); schedulePreview(); }

      document.querySelectorAll('[data-cs-add]').forEach(function (b) {
        b.addEventListener('click', function () { addBlock(b.getAttribute('data-cs-add')); });
      });

      // block tools + rich text (event delegation)
      blocksWrap.addEventListener('click', function (e) {
        var t = e.target.closest('button');
        if (!t) return;
        var block = t.closest('.cs-block');
        if (t.hasAttribute('data-remove')) { block.remove(); schedulePreview(); return; }
        var mv = t.getAttribute('data-move');
        if (mv === 'up' && block.previousElementSibling) { blocksWrap.insertBefore(block, block.previousElementSibling); schedulePreview(); return; }
        if (mv === 'down' && block.nextElementSibling) { blocksWrap.insertBefore(block.nextElementSibling, block); schedulePreview(); return; }
      });
      // preserve selection: run rich-text command on mousedown
      blocksWrap.addEventListener('mousedown', function (e) {
        var t = e.target.closest('[data-rt]');
        if (!t) return;
        e.preventDefault();
        var area = t.closest('.cs-block').querySelector('[data-rt-area]');
        area.focus();
        var cmd = t.getAttribute('data-rt');
        if (cmd === 'bold') document.execCommand('bold');
        else if (cmd === 'italic') document.execCommand('italic');
        else if (cmd === 'h3') { var isH3 = document.queryCommandValue('formatBlock').toLowerCase() === 'h3'; document.execCommand('formatBlock', false, isH3 ? 'P' : 'H3'); }
        else if (cmd === 'ul') document.execCommand('insertUnorderedList');
        else if (cmd === 'ol') document.execCommand('insertOrderedList');
        else if (cmd === 'link') { var u = prompt('URL del link:', 'https://'); if (u) document.execCommand('createLink', false, u); }
        schedulePreview();
      });
      blocksWrap.addEventListener('input', schedulePreview);
      [ebInput, titleInput].forEach(function (i) { i.addEventListener('input', schedulePreview); });
      document.querySelectorAll('[name="cs-bg"]').forEach(function (r) { r.addEventListener('change', schedulePreview); });

      function currentBg() { var r = document.querySelector('[name="cs-bg"]:checked'); return r ? r.value : 'primary'; }

      function readBlocks() {
        var out = [];
        blocksWrap.querySelectorAll('.cs-block').forEach(function (bl) {
          var type = bl.getAttribute('data-block-type');
          if (type === 'text') {
            var html = bl.querySelector('[data-rt-area]').innerHTML.trim();
            if (html && html !== '<br>') out.push({ type: 'text', html: html });
          } else if (type === 'image') {
            var url = bl.querySelector('[data-b-url]').value.trim();
            if (url) out.push({ type: 'image', url: url, alt: bl.querySelector('[data-b-alt]').value.trim(), caption: bl.querySelector('[data-b-caption]').value.trim() });
          } else {
            var vu = bl.querySelector('[data-b-url]').value.trim();
            if (vu) out.push({ type: 'video', url: vu, autoplay: bl.querySelector('[data-b-autoplay]').value, caption: bl.querySelector('[data-b-caption]').value.trim() });
          }
        });
        return out;
      }

      function draft() {
        return { section: secSel.value, after: posSel.value, bg: currentBg(), eyebrow: ebInput.value.trim(), title: titleInput.value.trim(), blocks: readBlocks() };
      }

      // ── live preview (same classes as the deck → coherent) ──
      function videoHtml(url, mode) {
        var yt = String(url).match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
        if (yt) return '<iframe src="https://www.youtube.com/embed/' + yt[1] + '?rel=0" allow="autoplay;encrypted-media" title="v"></iframe>';
        return '<video src="' + url + '" muted></video>';
      }
      function renderPreview() {
        var d = draft();
        preview.className = 'cs-preview-stage cs-slide ' + (BG_CLASS[d.bg] || '');
        preview.setAttribute('data-cs-tone', BG_TONE[d.bg]);
        if (!d.eyebrow && !d.title && d.blocks.length === 0) {
          preview.innerHTML = '<p class="cs-preview-empty">L\'anteprima della slide<br>appare qui</p>';
          return;
        }
        var html = '<div class="cs-content">';
        if (d.eyebrow) html += '<p class="slide-eyebrow cs-eyebrow">' + d.eyebrow.replace(/</g, '&lt;') + '</p>';
        if (d.title) html += '<h2 class="cs-title">' + d.title.replace(/</g, '&lt;') + '</h2>';
        d.blocks.forEach(function (b) {
          if (b.type === 'text') html += '<div class="cs-prose">' + b.html + '</div>';
          else if (b.type === 'image') html += '<figure style="margin:0"><div class="cs-media"><img src="' + b.url + '" alt=""></div>' + (b.caption ? '<figcaption class="cs-caption">' + b.caption + '</figcaption>' : '') + '</figure>';
          else html += '<figure style="margin:0"><div class="cs-media">' + videoHtml(b.url) + '</div>' + (b.caption ? '<figcaption class="cs-caption">' + b.caption + '</figcaption>' : '') + '</figure>';
        });
        html += '</div>';
        preview.innerHTML = html;
      }
      var previewTimer;
      function schedulePreview() { clearTimeout(previewTimer); previewTimer = setTimeout(renderPreview, 140); }

      // ── save / reset ──
      function resetEditor() {
        editingId = null;
        editorTitle.textContent = 'Nuova slide';
        ebInput.value = ''; titleInput.value = '';
        blocksWrap.innerHTML = '';
        document.querySelector('[name="cs-bg"][value="primary"]').checked = true;
        secSel.selectedIndex = 0; fillPositions();
        renderPreview();
      }
      $('[data-cs-reset]').addEventListener('click', resetEditor);

      $('[data-cs-save]').addEventListener('click', function () {
        var d = draft();
        if (!d.title && d.blocks.length === 0) {
          feedback.textContent = 'Aggiungi un titolo o un contenuto.'; feedback.style.color = 'var(--accent-red)'; feedback.classList.add('visible');
          setTimeout(function () { feedback.classList.remove('visible'); }, 2600);
          return;
        }
        var arr = csLoad();
        if (editingId) {
          var i = arr.findIndex(function (s) { return s.id === editingId; });
          if (i !== -1) { d.id = editingId; arr[i] = d; }
        } else {
          d.id = 'cs-' + Date.now().toString(36);
          arr.push(d);
        }
        csSave(arr);
        feedback.textContent = '✓ Salvata'; feedback.style.color = 'var(--accent-green, #16a34a)'; feedback.classList.add('visible');
        setTimeout(function () { feedback.classList.remove('visible'); }, 2200);
        resetEditor(); renderList();
      });

      // ── saved list ──
      function loadForEdit(slide) {
        editingId = slide.id;
        editorTitle.textContent = 'Modifica slide';
        secSel.value = slide.section; fillPositions(); posSel.value = slide.after || '__end';
        (document.querySelector('[name="cs-bg"][value="' + slide.bg + '"]') || {}).checked = true;
        ebInput.value = slide.eyebrow || ''; titleInput.value = slide.title || '';
        blocksWrap.innerHTML = '';
        (slide.blocks || []).forEach(function (b) { blocksWrap.appendChild(blockNode(b.type, b)); });
        renderPreview();
        document.querySelector('[data-tab="slides"]').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function renderList() {
        var arr = csLoad();
        if (countBadge) countBadge.textContent = String(arr.length);
        if (arr.length === 0) { listWrap.innerHTML = '<div class="cs-list-empty">Nessuna slide personalizzata. Creane una qui sopra.</div>'; return; }
        listWrap.innerHTML = arr.map(function (s) {
          var meta = (SECTION_LABEL[s.section] || s.section) + ' · ' + (s.blocks ? s.blocks.length : 0) + ' blocchi';
          return '<div class="cs-item" data-id="' + s.id + '">'
            + '<span class="cs-item-dot" style="background:' + (BG_SWATCH[s.bg] || '') + '"></span>'
            + '<div class="cs-item-main"><p class="cs-item-title">' + (s.title ? s.title.replace(/</g, '&lt;') : '(senza titolo)') + '</p><p class="cs-item-meta">' + meta + '</p></div>'
            + '<div class="cs-item-actions"><button type="button" class="btn-ghost" data-edit>Modifica</button><button type="button" class="btn-ghost" data-del>Elimina</button></div>'
            + '</div>';
        }).join('');
        listWrap.querySelectorAll('.cs-item').forEach(function (row) {
          var id = row.getAttribute('data-id');
          row.querySelector('[data-edit]').addEventListener('click', function () { var s = csLoad().find(function (x) { return x.id === id; }); if (s) loadForEdit(s); });
          row.querySelector('[data-del]').addEventListener('click', function () {
            if (!confirm('Eliminare questa slide?')) return;
            csSave(csLoad().filter(function (x) { return x.id !== id; }));
            renderList();
            if (editingId === id) resetEditor();
          });
        });
      }

      renderPreview();
      renderList();
    })();

    // ════════════════════════════════════════════════════════════════
    //  Mockup prodotto tab
    // ════════════════════════════════════════════════════════════════
    if (mockupLibrary && mockupLibrary.length > 0) (function mockupTab() {
      var MK_KEY = 'edf:mockup-config:' + PROJECT_SLUG;

      function mkLoad() {
        try { return JSON.parse(localStorage.getItem(MK_KEY) || '{}'); } catch (e) { return {}; }
      }

      function mkSave(data) {
        try { localStorage.setItem(MK_KEY, JSON.stringify(data)); } catch (e) {}
        try { new BroadcastChannel('edf-console').postMessage({ type: 'edf:mockup-changed', project: PROJECT_SLUG }); } catch (e) {}
      }

      function getEnabledIds(mockupId) {
        var ids = [];
        document.querySelectorAll('[data-mockup-toggle="' + mockupId + '"]').forEach(function(t) {
          if (t.checked) ids.push(t.getAttribute('data-feature'));
        });
        return ids;
      }

      function updateCountBadge(mockupId) {
        var enabled = getEnabledIds(mockupId);
        var total = document.querySelectorAll('[data-mockup-toggle="' + mockupId + '"]').length;
        var badge = document.querySelector('[data-mockup-count="' + mockupId + '"]');
        if (badge) badge.textContent = enabled.length + '/' + total + ' attive';
      }

      function updateTabBadge() {
        var badge = document.querySelector('[data-count-mockup]');
        if (!badge) return;
        var total = 0;
        document.querySelectorAll('[data-mockup-toggle]').forEach(function(t) {
          if (t.checked) total++;
        });
        badge.textContent = String(total);
      }

      function updateFeatureCard(toggle) {
        var card = toggle.closest('.mockup-feature-card');
        if (card) {
          if (toggle.checked) card.removeAttribute('data-inactive');
          else card.setAttribute('data-inactive', '');
        }
      }

      // Init toggles from localStorage (or defaults = first maxVisible)
      var storedConfig = mkLoad();
      mockupLibrary.forEach(function(mockup) {
        var defaultIds = mockup.features.slice(0, mockup.maxVisible).map(function(f) { return f.id; });
        var enabled = Array.isArray(storedConfig[mockup.id]) ? storedConfig[mockup.id] : defaultIds;

        document.querySelectorAll('[data-mockup-toggle="' + mockup.id + '"]').forEach(function(toggle) {
          toggle.checked = enabled.indexOf(toggle.getAttribute('data-feature')) !== -1;
          updateFeatureCard(toggle);
        });
        updateCountBadge(mockup.id);
      });
      updateTabBadge();

      // Change listeners
      document.querySelectorAll('[data-mockup-toggle]').forEach(function(toggle) {
        toggle.addEventListener('change', function() {
          updateFeatureCard(toggle);
          updateCountBadge(toggle.getAttribute('data-mockup-toggle'));
          updateTabBadge();
        });
      });

      // Attiva tutte / Nessuna
      document.querySelectorAll('[data-mockup-all]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var mid = btn.getAttribute('data-mockup-all');
          document.querySelectorAll('[data-mockup-toggle="' + mid + '"]').forEach(function(t) {
            t.checked = true; updateFeatureCard(t);
          });
          updateCountBadge(mid); updateTabBadge();
        });
      });
      document.querySelectorAll('[data-mockup-none]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var mid = btn.getAttribute('data-mockup-none');
          document.querySelectorAll('[data-mockup-toggle="' + mid + '"]').forEach(function(t) {
            t.checked = false; updateFeatureCard(t);
          });
          updateCountBadge(mid); updateTabBadge();
        });
      });

      // Save
      document.querySelectorAll('[data-mockup-save]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var mid = btn.getAttribute('data-mockup-save');
          var enabled = getEnabledIds(mid);
          var cfg = mkLoad();
          cfg[mid] = enabled;
          mkSave(cfg);
          var fb = document.querySelector('[data-mockup-feedback="' + mid + '"]');
          if (fb) {
            fb.textContent = '✓ Salvato';
            fb.classList.add('visible');
            setTimeout(function() { fb.classList.remove('visible'); }, 2200);
          }
        });
      });
    })();

    // ── Scoping baseline (optional tab) ──────────────────────
    var scopingKey = 'edf:scoping-baseline:' + projectSlug;
    var scopingInputs = document.querySelectorAll('[data-scoping-baseline]');
    if (scopingInputs.length) {
      var savedScoping = {};
      try { savedScoping = JSON.parse(localStorage.getItem(scopingKey) || '{}'); } catch (e) {}
      scopingInputs.forEach(function (el) {
        var k = el.getAttribute('data-scoping-baseline');
        if (savedScoping[k] != null) el.value = savedScoping[k];
      });
      var sBtn = document.querySelector('[data-scoping-baseline-save]');
      var sNote = document.querySelector('[data-scoping-baseline-note]');
      if (sBtn) sBtn.addEventListener('click', function () {
        var out = {};
        scopingInputs.forEach(function (el) { if (el.value !== '') out[el.getAttribute('data-scoping-baseline')] = Number(el.value); });
        localStorage.setItem(scopingKey, JSON.stringify(out));
        if (sNote) sNote.textContent = 'Baseline salvata.';
      });
    }
  });
})();
</script>
