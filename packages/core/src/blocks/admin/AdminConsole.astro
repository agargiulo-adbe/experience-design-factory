    cursor: not-allowed;
  }
  .admin-share-url-row {
    display: flex;
    gap: 0.625rem;
    align-items: stretch;
  }
  .share-url-input {
    flex: 1;
    min-width: 0;
    border: 1px solid #d1d5db;
