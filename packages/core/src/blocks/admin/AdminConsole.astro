  }
  .admin-back-link:hover {
    background: #f3f4f6;
    color: #111827;
  }

  /* ---- Main layout ---- */
  .admin-main {
    padding: 2.5rem 1.5rem;
  }
  .admin-content {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ---- Page title ---- */
  .admin-page-title h1 {
    font-size: 1.75rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }
  .admin-subtitle {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  /* ---- Info box ---- */
  .admin-info-box {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    background: #EEF2FF;
    border: 1px solid #c7d2fe;
    border-radius: 8px;
    padding: 0.875rem 1rem;
    font-size: 0.8125rem;
    color: #3730a3;
    line-height: 1.5;
  }

  /* ---- Tabs ---- */
  .admin-tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: -0.5rem;
  }
  .admin-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #6b7280;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    margin-bottom: -1px;
  }
  .admin-tab:hover { color: #111827; }
  .admin-tab.is-active { color: #BE2027; border-bottom-color: #BE2027; }
  .admin-tab-num {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 22px; height: 20px; padding: 0 6px;
    background: #e5e7eb; color: #374151;
    font-size: 0.6875rem; font-weight: 700; border-radius: 20px;
    font-variant-numeric: tabular-nums;
  }
  .admin-tab.is-active .admin-tab-num { background: #BE2027; color: #fff; }

  .admin-tabpanel { display: flex; flex-direction: column; gap: 2rem; }
  .admin-tabpanel[hidden] { display: none; }

  /* ---- Block header ---- */
  .admin-block-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap;
  }
  .admin-block-title { font-size: 1.125rem; font-weight: 600; color: #111827; margin: 0 0 0.2rem; letter-spacing: -0.01em; }
  .admin-block-sub { font-size: 0.8125rem; color: #6b7280; margin: 0; }
  .admin-bulk-actions { display: flex; gap: 0.5rem; }
  .btn-ghost {
    padding: 0.375rem 0.75rem; background: #fff; color: #6b7280;
    font-size: 0.8125rem; font-family: inherit; font-weight: 500;
    border: 1px solid #d1d5db; border-radius: 6px; cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s; white-space: nowrap;
  }
  .btn-ghost:hover { background: #fef2f2; color: #BE2027; border-color: #BE2027; }

  /* ---- Solution groups ---- */
  .solution-groups { display: flex; flex-direction: column; gap: 1.75rem; }
  .solution-group-label {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.6875rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; margin: 0 0 0.75rem;
  }
  .solution-group-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .solution-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.625rem; }
  @media (max-width: 640px) { .solution-grid { grid-template-columns: 1fr; } }
  .solution-card {
    display: flex; align-items: flex-start; gap: 0.75rem;
    background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
    padding: 0.875rem 1rem; transition: opacity 0.15s, border-color 0.15s;
  }
  .solution-card[data-inactive] { opacity: 0.5; border-style: dashed; }
  .solution-card-main { flex: 1; min-width: 0; }
  .solution-card-top { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem; flex-wrap: wrap; }
  .solution-name { font-size: 0.875rem; font-weight: 600; color: #111827; }
  .solution-short { font-size: 0.625rem; font-weight: 600; padding: 1px 6px; border-radius: 4px; white-space: nowrap; }
  .solution-desc { font-size: 0.75rem; color: #6b7280; line-height: 1.45; margin: 0; }
  .solution-sections { display: flex; align-items: center; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.5rem; }
  .solution-sections-label { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #9ca3af; }
  .section-tag { font-size: 0.625rem; font-weight: 600; padding: 1px 7px; border-radius: 20px; white-space: nowrap; }

  /* ---- Custom slides editor ---- */
  .cs-editor-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start; }
  @media (max-width: 900px) { .cs-editor-layout { grid-template-columns: 1fr; } }
  .cs-editor { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.4rem; display: flex; flex-direction: column; gap: 1rem; }
  .cs-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .cs-bg-row { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .cs-bg-chip { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.8125rem; padding: 0.3rem 0.65rem; border: 1px solid #d1d5db; border-radius: 20px; cursor: pointer; color: #374151; }
  .cs-bg-chip input { accent-color: #BE2027; }
  .cs-bg-chip:has(input:checked) { border-color: #BE2027; color: #BE2027; background: rgba(190,32,39,0.06); }
  .cs-blocks { display: flex; flex-direction: column; gap: 0.6rem; }
  .cs-block { border: 1px solid #e5e7eb; border-radius: 8px; background: #f9fafb; padding: 0.75rem; }
  .cs-block-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; }
  .cs-block-type { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6b7280; }
  .cs-block-tools { display: flex; gap: 0.25rem; }
  .cs-icon-btn { width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid #e5e7eb; background: #fff; border-radius: 5px; cursor: pointer; color: #6b7280; font-size: 0.8rem; line-height: 1; }
  .cs-icon-btn:hover { border-color: #BE2027; color: #BE2027; }
  .cs-add-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .cs-editor-actions { display: flex; align-items: center; gap: 0.75rem; padding-top: 0.25rem; }

  /* Rich-text toolbar + editable area */
  .cs-rt-toolbar { display: flex; gap: 0.15rem; flex-wrap: wrap; margin-bottom: 0.4rem; }
  .cs-rt-btn { min-width: 26px; height: 26px; padding: 0 6px; border: 1px solid #d1d5db; background: #fff; border-radius: 5px; cursor: pointer; font-size: 0.8rem; color: #374151; }
  .cs-rt-btn:hover { background: #fef2f2; color: #BE2027; border-color: #BE2027; }
  .cs-rt-area { min-height: 68px; border: 1px solid #d1d5db; border-radius: 6px; padding: 0.5rem 0.65rem; font-size: 0.875rem; line-height: 1.5; background: #fff; color: #111827; outline: none; }
  .cs-rt-area:focus { border-color: #BE2027; box-shadow: 0 0 0 2px rgba(190,32,39,0.12); }
  .cs-rt-area:empty::before { content: attr(data-placeholder); color: #9ca3af; }

  /* Preview */
  .cs-preview-col { position: sticky; top: 76px; }
  .cs-preview-label { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #9ca3af; margin-bottom: 0.5rem; }
  .cs-preview-label span { font-weight: 500; text-transform: none; letter-spacing: 0; }
  .cs-preview-frame { aspect-ratio: 16 / 9; border-radius: 10px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 8px 30px -10px rgba(0,0,0,0.18); }
  .cs-preview-stage { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 6% 7%; overflow: hidden; }
  .cs-preview-stage .cs-content { gap: 0.6rem; }
  /* Scale deck typography down to fit the preview box */
  .cs-preview-stage .cs-title { font-size: clamp(1rem, 3.2vw, 1.6rem); }
  .cs-preview-stage .slide-eyebrow { font-size: 0.6rem; }
  .cs-preview-stage .cs-prose { font-size: 0.7rem; line-height: 1.5; }
  .cs-preview-stage .cs-media { max-width: 70%; box-shadow: none; }
  .cs-preview-stage .cs-caption { font-size: 0.55rem; }
  .cs-preview-empty { color: var(--ink-tertiary); font-size: 0.8rem; text-align: center; }

  /* Saved list */
  .cs-saved { margin-top: 2rem; }
  .cs-list { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.75rem; }
  .cs-list-empty { color: #9ca3af; font-size: 0.875rem; padding: 1.5rem; text-align: center; background: #fff; border: 1px dashed #e5e7eb; border-radius: 10px; }
  .cs-item { display: flex; align-items: center; gap: 0.9rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 0.75rem 1rem; }
  .cs-item-dot { width: 30px; height: 30px; border-radius: 6px; flex-shrink: 0; border: 1px solid #e5e7eb; }
  .cs-item-main { flex: 1; min-width: 0; }
  .cs-item-title { font-size: 0.875rem; font-weight: 600; color: #111827; }
  .cs-item-meta { font-size: 0.75rem; color: #6b7280; }
  .cs-item-actions { display: flex; gap: 0.4rem; }

  /* ---- Accordion ---- */
  .pages-accordion { display: flex; flex-direction: column; gap: 0.5rem; }
  .page-section { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; }
  .page-toggle {
    width: 100%; display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.25rem; background: transparent; border: none;
    cursor: pointer; text-align: left; transition: background 0.15s;
  }
  .page-toggle:hover { background: #f9fafb; }
  .page-toggle[aria-expanded="true"] { background: #fef2f2; }
  .page-section-label { flex: 1; font-size: 0.9375rem; font-weight: 600; color: #111827; }
  .page-section-count { font-size: 0.8125rem; color: #6b7280; }
  .page-toggle-chevron { flex-shrink: 0; color: #9ca3af; transition: transform 0.2s; }
  .page-toggle[aria-expanded="true"] .page-toggle-chevron { transform: rotate(180deg); }
  .slides-panel { padding: 0 1rem 1rem; }
  .slides-panel[hidden] { display: none; }
  .slides-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }

  /* ---- Slide card (compact) ---- */
  .slide-card {
    background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px;
    padding: 1rem; font-size: 0.875rem;
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .slide-card-header { display: flex; align-items: center; gap: 0.75rem; }
  .slide-card-info { flex: 1; min-width: 0; display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap; }
  .slide-num-badge { display: inline-flex; align-items: center; justify-content: center; min-width: 20px; height: 20px; background: #374151; color: #fff; font-size: 0.625rem; font-weight: 700; border-radius: 50%; padding: 0 2px; flex-shrink: 0; font-variant-numeric: tabular-nums; }
  .slide-id-badge { font-family: 'Menlo','Consolas',monospace; font-size: 0.6875rem; background: #e5e7eb; color: #374151; padding: 2px 6px; border-radius: 4px; white-space: nowrap; }
  .slide-card-label { font-size: 0.875rem; font-weight: 500; color: #374151; }

  /* ---- Toggle switch ---- */
  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
  }
  .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
  }
  .toggle-thumb {
    position: absolute;
    inset: 0;
    background: #d1d5db;
    border-radius: 24px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .toggle-thumb::before {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    left: 3px;
    bottom: 3px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.2s;
    box-shadow: 0 1px 2px rgba(0,0,0,0.15);
  }
  .toggle-switch input:checked + .toggle-thumb {
    background: #BE2027;
  }
  .toggle-switch input:checked + .toggle-thumb::before {
    transform: translateX(20px);
  }
  .toggle-switch input:focus-visible + .toggle-thumb {
    outline: 2px solid #BE2027;
    outline-offset: 2px;
  }

  /* ---- Fields ---- */
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .field-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #6b7280;
  }
  .field-optional {
    font-weight: 400;
    color: #9ca3af;
  }
  .field-input {
    width: 100%;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: #111827;
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .field-input:focus {
    outline: none;
    border-color: #BE2027;
    box-shadow: 0 0 0 2px rgba(190,32,39,0.12);
  }
  .field-input::placeholder {
    color: #9ca3af;
  }
  .field-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .radio-group {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: #374151;
    cursor: pointer;
  }
  .radio-label input[type="radio"] {
    accent-color: #BE2027;
    cursor: pointer;
  }

  /* ---- Card actions ---- */
  .slot-card-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }
  .btn-save {
    padding: 0.4375rem 1rem;
    background: #BE2027;
    color: #fff;
    font-size: 0.875rem;
    font-family: inherit;
    font-weight: 500;
