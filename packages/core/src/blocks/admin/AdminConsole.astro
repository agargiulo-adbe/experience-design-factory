  /* ---- Share panel ---- */
  .admin-share-panel {
    background: #fff;
    border: 1.5px solid #BE2027;
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .admin-share-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .admin-share-title {
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .admin-share-desc {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.5;
  }
  .btn-generate-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5625rem 1.125rem;
    background: #111827;
    color: #fff;
    font-size: 0.875rem;
    font-family: inherit;
    font-weight: 500;
    border: none;
    border-radius: 6px;
