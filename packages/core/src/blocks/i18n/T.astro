---
/**
 * T — bilingual text. Renders BOTH languages; CSS on <html data-lang> shows the
 * active one (instant toggle, no reload). `en`/`it` accept inline HTML (e.g. <br/>).
 * Usage:  <T en="Winning together" it="Vincere insieme" as="h2" class="slide-title" />
 */
interface Props {
  en: string;
  it: string;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  style?: string;
}
const { en, it, as = 'span', class: className, style } = Astro.props;
const Tag = as as any;
---
<Tag class={className} style={style} data-i18n><span data-lang-en set:html={en} /><span data-lang-it set:html={it} /></Tag>
