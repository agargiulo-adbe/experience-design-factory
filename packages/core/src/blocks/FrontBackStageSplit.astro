---
interface AdobeChip {
  id: string;
  name: string;
  claim: string;
}

interface Props {
  phaseId: string;
  phaseLabel: string;
  customerTitle: string;
  customerBody: string;
  adobeStack: AdobeChip[];
  reversed?: boolean;
}

const { phaseId, phaseLabel, customerTitle, customerBody, adobeStack, reversed = false } = Astro.props;
---

<section class="py-16 md:py-24 bg-[var(--surface-primary)]" data-block="front-back-stage" data-phase={phaseId}>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Phase label -->
    <p class="text-xs font-medium tracking-[0.1em] uppercase text-[var(--accent-primary)] mb-10 md:mb-14">
      {phaseLabel}
    </p>

    <!-- Split container -->
    <div class:list={[
      "grid md:grid-cols-2 gap-0 border border-[var(--line-subtle)] rounded-sm overflow-hidden",
      reversed && "md:[direction:rtl] md:[&>*]:[direction:ltr]"
    ]}>
      <!-- FRONT STAGE: Customer view -->
      <div class="p-8 md:p-12 bg-[var(--surface-primary)] border-b md:border-b-0 md:border-r border-[var(--line-subtle)]">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-2 h-2 rounded-full bg-[var(--accent-primary)]" aria-hidden="true"></span>
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-[var(--ink-tertiary)]">
            Ciò che vede la cliente
          </span>
        </div>
        <h3 class="font-[family-name:var(--font-display)] text-[clamp(1.5rem,2vw+0.5rem,2.25rem)] font-light leading-[1.2] text-[var(--ink-primary)] mb-4">
          {customerTitle}
        </h3>
        <div class="text-[var(--ink-secondary)] leading-relaxed space-y-3">
          <Fragment set:html={customerBody} />
        </div>
        <div class="mt-8 relative aspect-[16/10] bg-[var(--surface-secondary)] rounded-sm overflow-hidden">
          <slot name="customer-media" />
          <div class="absolute inset-0 flex items-center justify-center text-[var(--ink-tertiary)] opacity-40">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- BACK STAGE: Adobe platform -->
      <div class="p-8 md:p-12 bg-[var(--surface-secondary)]">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-2 h-2 rounded-full bg-[var(--accent-secondary)]" aria-hidden="true"></span>
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-[var(--ink-tertiary)]">
            Ciò che fa la piattaforma
          </span>
        </div>
        <p class="text-sm text-[var(--ink-secondary)] mb-8 leading-relaxed">
          Dietro l'esperienza che la cliente vive, la piattaforma Adobe orchestra dati, contenuti e decisioni in tempo reale.
        </p>
        <!-- Adobe product chips -->
        <div class="space-y-3" role="list" aria-label="Prodotti Adobe attivi in questa fase">
          {adobeStack.map((product) => (
            <div
              class="group flex items-start gap-4 p-4 bg-[var(--surface-primary)] border border-[var(--line-subtle)] rounded-sm hover:border-[var(--accent-secondary)] transition-colors duration-[var(--duration-normal)]"
              role="listitem"
            >
              <div class="flex-shrink-0 w-8 h-8 rounded-sm bg-[var(--surface-tertiary)] flex items-center justify-center">
                <span class="text-xs font-semibold text-[var(--ink-tertiary)]" aria-hidden="true">
                  {product.name.split(' ').map(w => w[0]).join('').slice(0, 2)}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-[var(--ink-primary)] group-hover:text-[var(--accent-secondary)] transition-colors">
                  {product.name}
                </p>
                <p class="text-xs text-[var(--ink-tertiary)] mt-0.5 leading-relaxed">
                  {product.claim}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
