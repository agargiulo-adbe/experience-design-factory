---
interface Props {
  phaseNumber: number;
  phaseId: string;
  title: string;
  subtitle: string;
  body: string;
  icon?: string;
}

const { phaseNumber, phaseId, title, subtitle, body } = Astro.props;
---

<section class="py-16 md:py-24 bg-[var(--surface-secondary)]" data-block="journey-phase" data-phase={phaseId}>
  <div class="max-w-5xl mx-auto px-6 md:px-12">
    <div class="flex items-baseline gap-4 mb-8">
      <span class="text-[clamp(3rem,6vw,5rem)] font-[family-name:var(--font-display)] font-light text-[var(--accent-primary)] opacity-40 leading-none" aria-hidden="true">
        {String(phaseNumber).padStart(2, '0')}
      </span>
      <div>
        <p class="text-xs font-medium tracking-[0.1em] uppercase text-[var(--accent-primary)] mb-1">
          {subtitle}
        </p>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw+0.5rem,3rem)] font-light leading-[1.15] text-[var(--ink-primary)]">
          {title}
        </h2>
      </div>
    </div>
    <div class="ml-0 md:ml-[calc(clamp(3rem,6vw,5rem)+1rem)] text-[var(--ink-secondary)] leading-relaxed space-y-4 max-w-prose">
      <Fragment set:html={body} />
    </div>
    <slot />
  </div>
</section>
