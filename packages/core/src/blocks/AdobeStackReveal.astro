---
interface ProductInPhase {
  id: string;
  name: string;
  claim: string;
}

interface Phase {
  phaseId: string;
  label: string;
  products: ProductInPhase[];
}

interface Props {
  title: string;
  body: string;
  phases: Phase[];
}

const { title, body, phases } = Astro.props;
---

<section class="py-20 md:py-32 bg-[var(--surface-inverse)] text-[var(--ink-inverse)]" data-block="adobe-stack-reveal">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header -->
    <div class="max-w-3xl mb-16 md:mb-20">
      <p class="text-xs font-medium tracking-[0.1em] uppercase text-[var(--accent-secondary)] mb-4">
        Il motore
      </p>
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,3vw+0.5rem,3.5rem)] font-light leading-[1.1] text-[var(--ink-inverse)] mb-6">
        {title}
      </h2>
      <p class="text-[var(--color-grigio300)] leading-relaxed text-lg">
        {body}
      </p>
    </div>

    <!-- Phases grid -->
    <div class="space-y-12">
      {phases.map((phase, index) => (
        <div class="border-t border-[var(--color-grigio500)]/30 pt-8 reveal-phase" style={`animation-delay: ${index * 150}ms;`}>
          <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-12">
            <!-- Phase label -->
            <div class="md:w-48 flex-shrink-0">
              <p class="text-xs font-medium tracking-[0.1em] uppercase text-[var(--accent-secondary)]">
                {phase.label}
              </p>
            </div>

            <!-- Products -->
            <div class="flex-1 grid sm:grid-cols-2 gap-4">
              {phase.products.map((product) => (
                <div class="group flex items-start gap-3 p-4 rounded-sm border border-[var(--color-grigio500)]/20 hover:border-[var(--accent-secondary)]/50 transition-colors duration-[var(--duration-normal)]">
                  <div class="flex-shrink-0 w-8 h-8 rounded-sm bg-[var(--color-grigio500)]/20 flex items-center justify-center">
                    <span class="text-xs font-semibold text-[var(--accent-secondary)]" aria-hidden="true">
                      {product.name.split(' ').map(w => w[0]).join('').slice(0, 2)}
                    </span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-[var(--ink-inverse)] group-hover:text-[var(--accent-secondary)] transition-colors">
                      {product.name}
                    </p>
                    <p class="text-xs text-[var(--color-grigio400)] mt-0.5 leading-relaxed">
                      {product.claim}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal-phase {
    opacity: 0;
    animation: reveal-up 0.6s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-phase {
      opacity: 1;
      animation: none;
    }
  }
</style>
