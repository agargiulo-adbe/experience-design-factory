---
/**
 * MediaSlot — engine component for manifest-driven imagery.
 * Given a slot (+ optional resolved image) it renders an optimized responsive
 * <Picture> (AVIF/WebP, lazy, alt from the manifest), or a refined palette
 * placeholder when the asset has not been generated yet.
 *
 * The per-client loader (assets.index.ts) resolves slot-id → { slot, src };
 * usage:  <MediaSlot {...mediaProps('monogram-post')} fill />
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { AssetSlot } from '@edf/core/assets/types';
import { ASPECT_CSS } from '@edf/core/assets/types';

// NB: `slot` is a reserved attribute in Astro (named-slot projection), so the
// manifest entry is passed as `media`. Use <MediaSlot {...mediaProps('id')} />.
interface Props {
  media: AssetSlot;
  src?: ImageMetadata | null;
  /** Fill the (positioned) parent instead of using the slot aspect-ratio box. */
  fill?: boolean;
  class?: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
}

const { media, src = null, fill = false, class: className, sizes = '100vw', loading = 'lazy' } = Astro.props;
const ratioStyle = fill ? undefined : `aspect-ratio:${ASPECT_CSS[media.aspect]}`;
const boxClass = fill ? 'absolute inset-0' : 'relative w-full';
---
{src ? (
  <figure class:list={["ms-media overflow-hidden block", boxClass, className]} style={ratioStyle}>
    <Picture
      src={src}
      formats={['avif', 'webp']}
      alt={media.alt}
      widths={[480, 800, 1200, 1800, 2400]}
      sizes={sizes}
      loading={loading}
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover"
    />
  </figure>
) : (
  <figure
    class:list={["ms-placeholder overflow-hidden block flex items-center justify-center", boxClass, className]}
    style={ratioStyle}
    role="img"
    aria-label={media.alt}
  >
    <span class="sr-only">{media.alt}</span>
    <svg class="ms-ph-icon" width="22%" height="22%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="8.5" cy="8.5" r="1.6"/>
      <path d="M21 15l-5-5L5 21" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </figure>
)}

<style>
  .ms-placeholder {
    /* Refined duotone gradient in the brand palette */
    background:
      linear-gradient(135deg,
        var(--surface-inverse) 0%,
        color-mix(in srgb, var(--accent-primary) 80%, var(--surface-inverse)) 45%,
        var(--accent-primary) 70%,
        var(--surface-secondary) 100%);
  }
  .ms-ph-icon { color: color-mix(in srgb, var(--surface-primary) 55%, transparent); }
</style>
