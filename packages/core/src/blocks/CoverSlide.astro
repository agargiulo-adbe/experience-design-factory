---
/**
 * CoverSlide — cinematic, quiet-luxury opening slide for a deck (slide 0).
 * "Tagline hero, co-brand signature": a small eyebrow up top, the tagline as the
 * central display hero, and the Max Mara × Adobe lock-up as a discreet signature
 * at the bottom — where the thin sartorial "filo" draws itself between the two
 * names. Animation runs on slide activation; respects prefers-reduced-motion
 * (static final state). Driven via [data-cover] (animations.ts prepareSlide/playSlide).
 */
import Slide from './immersive/Slide.astro';

interface Props {
  eyebrow?: string;
  tagline: string;
  primary?: string;
  secondary?: string;
  class?: string;
}
const {
  eyebrow = 'GENERAZIONI',
  tagline,
  primary = 'Max Mara',
  secondary = 'Adobe',
  class: className,
} = Astro.props;
---
<Slide id="slide-cover" bg="brand" align="center" class={className}>
  <div data-cover class="w-full flex flex-col items-center">
    <p class="slide-eyebrow text-[var(--ink-primary)]/70 mb-10" data-reveal>{eyebrow}</p>

    <h1 class="slide-title text-[var(--ink-primary)] max-w-5xl" style="font-size: clamp(2.75rem, 6.2vw, 6rem);" data-reveal data-reveal-delay="0.2">{tagline}</h1>

    <!-- co-brand signature: discreet lock-up with the sartorial filo -->
    <div class="cover-names flex items-center justify-center gap-4 md:gap-6 mt-16">
      <span class="cover-word cover-word-mm font-[family-name:var(--font-display)] font-light text-[var(--ink-primary)] leading-none" style="font-size: clamp(1.5rem, 2.6vw, 2.4rem);">{primary}</span>
      <svg class="cover-thread w-14 md:w-24 h-5 overflow-visible flex-shrink-0" viewBox="0 0 120 24" fill="none" aria-hidden="true">
        <path class="cover-thread-path" d="M2 12 H118" stroke="var(--ink-primary)" stroke-width="1.25" stroke-linecap="round"/>
        <circle class="cover-knot" cx="60" cy="12" r="2.4" fill="var(--ink-primary)" opacity="0"/>
      </svg>
      <span class="cover-word cover-word-adobe font-[family-name:var(--font-display)] font-light text-[var(--ink-primary)]/75 leading-none" style="font-size: clamp(1.35rem, 2.2vw, 2rem);">{secondary}</span>
    </div>
  </div>
</Slide>
