---
/**
 * CoverSlide — cinematic, quiet-luxury opening slide for a deck (slide 0).
 * "Tagline hero, co-brand signature": a small eyebrow up top, the tagline as the
 * central display hero, and the Max Mara × Adobe lock-up as a discreet signature
 * at the bottom — where the thin sartorial "filo" draws itself between the two
 * names. Animation runs on slide activation; respects prefers-reduced-motion
 * (static final state). Driven via [data-cover] (animations.ts prepareSlide/playSlide).
 */
import Slide from './immersive/Slide.astro';
import SlideBackdrop from './SlideBackdrop.astro';
import CoBrandSignature from './CoBrandSignature.astro';
import type { ImageMetadata } from 'astro';
import type { AssetSlot } from '@edf/core/assets/types';

interface Props {
  eyebrow?: string;
  tagline: string;
  primary?: string;
  secondary?: string;
  /** Optional atmospheric textile backdrop (always under a brand scrim). */
  bgMedia?: AssetSlot;
  bgSrc?: ImageMetadata | null;
  class?: string;
}
const {
  eyebrow = 'GENERAZIONI',
  tagline,
  primary = 'Max Mara',
  secondary = 'Adobe',
  bgMedia,
  bgSrc = null,
  class: className,
} = Astro.props;
---
<Slide id="slide-cover" bg="brand" align="center" class={className}>
  {bgMedia && <SlideBackdrop slot="backdrop" media={bgMedia} src={bgSrc} imageClass="opacity-15" scrim="bg-[var(--accent-primary)]/82" />}
  <div data-cover class="w-full flex flex-col items-center">
    <p class="slide-eyebrow text-[var(--ink-primary)]/70 mb-10" data-reveal>{eyebrow}</p>

    <h1 class="slide-title text-[var(--ink-primary)] max-w-5xl" style="font-size: clamp(2.75rem, 6.2vw, 6rem);" data-reveal data-reveal-delay="0.2">{tagline}</h1>

    <!-- co-brand signature: discreet lock-up with the sartorial filo (shared component) -->
    <CoBrandSignature primary={primary} secondary={secondary} tone="ink" class="mt-16" />
  </div>
</Slide>
