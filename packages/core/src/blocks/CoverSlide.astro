---
/**
 * CoverSlide — cinematic, quiet-luxury opening slide for a deck (slide 0).
 * Thin wrapper around the shared CoverHero grammar (eyebrow · display tagline ·
 * co-brand sartorial filo), wrapped in a brand <Slide>. Driven via [data-cover]
 * (animations.ts prepareSlide/playSlide); reduced-motion safe.
 */
import Slide from './immersive/Slide.astro';
import SlideBackdrop from './SlideBackdrop.astro';
import CoverHero from './CoverHero.astro';
import type { ImageMetadata } from 'astro';
import type { AssetSlot } from '@edf/core/assets/types';

interface Props {
  eyebrow?: string;
  tagline: string;
  /** Optional atmospheric textile backdrop (always under a brand scrim). */
  bgMedia?: AssetSlot;
  bgSrc?: ImageMetadata | null;
  class?: string;
}
const {
  eyebrow = 'GENERAZIONI',
  tagline,
  bgMedia,
  bgSrc = null,
  class: className,
} = Astro.props;
---
<Slide id="slide-cover" bg="brand" align="center" class={className}>
  {bgMedia && <SlideBackdrop slot="backdrop" media={bgMedia} src={bgSrc} imageClass="opacity-15" scrim="bg-[var(--accent-primary)]/82" />}
  <CoverHero size="hero" eyebrow={eyebrow} title={tagline} tone="ink" />
</Slide>
