---
/**
 * InstagramPost — a credible IG post inside a phone frame, sized to fit whole
 * within a slide's safe area (no clipping at 1920/1440/1280 — invariants c/j/k).
 *
 * The image area is a real IG portrait ratio (4:5) so a 4:5 source shows WHOLE,
 * with no awkward head/foot crop. The phone is width-driven (max-w) so its height
 * is constant across viewports and always fits the slide. Fill it like MediaSlot:
 *   <InstagramPost {...mediaProps('whitney-post')} caption="…" />
 */
import MediaSlot from './MediaSlot.astro';
import type { ImageMetadata } from 'astro';
import type { AssetSlot } from '@edf/core/assets/types';

interface Props {
  media: AssetSlot;
  src?: ImageMetadata | null;
  handle?: string;
  /** Small grey subline under the handle (location or "Sponsorizzato"). */
  subline?: string;
  /** Caption text after the handle. */
  caption?: string;
  /** Likes count label, e.g. "2.418". */
  likes?: string;
  /** Comments count for the "Visualizza tutti i N commenti" line. */
  comments?: string;
  class?: string;
}
const {
  media, src = null, handle = 'maxmara',
  subline = 'Sponsorizzato',
  caption = 'La nuova collezione',
  likes = '2.418',
  comments = '84',
  class: className,
} = Astro.props;
---
<div
  class:list={[
    "ig-phone relative mx-auto w-full max-w-[280px] max-h-[calc(100dvh-180px)] flex flex-col overflow-hidden",
    "rounded-[2.2rem] border-[5px] border-[var(--surface-inverse)] bg-[var(--surface-inverse)] shadow-2xl",
    className,
  ]}
>
  <div class="flex flex-col min-h-0 bg-[var(--surface-primary)] text-[var(--ink-primary)] rounded-[1.7rem] overflow-hidden">
    <!-- speaker pill (modern phone) -->
    <div class="flex items-center justify-center pt-2 pb-1.5">
      <span class="w-16 h-1.5 rounded-full bg-[var(--ink-tertiary)]/25"></span>
    </div>

    <!-- header -->
    <div class="flex items-center gap-2.5 px-3 py-1.5">
      <span class="w-7 h-7 rounded-full bg-[var(--accent-primary)] flex items-center justify-center text-white text-[0.58rem] font-bold flex-shrink-0 tracking-wide">MM</span>
      <div class="leading-tight min-w-0">
        <p class="text-[0.82rem] font-semibold truncate">{handle}</p>
        <p class="text-[0.66rem] text-[var(--ink-tertiary)] -mt-0.5">{subline}</p>
      </div>
      <span class="ml-auto text-[var(--ink-tertiary)] text-lg leading-none">⋯</span>
    </div>

    <!-- image: real IG 4:5 → a 4:5 source shows whole, no crop -->
    <div class="relative w-full aspect-[4/5] overflow-hidden bg-[var(--surface-secondary)] flex-shrink-0">
      <MediaSlot media={media} src={src} fill noText="28,18,44,60" />
    </div>

    <!-- actions -->
    <div class="flex items-center gap-4 px-3 pt-2">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 0 0 0-7.8z"/></svg>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.4 9 9 0 0 1-4-1L3 20l1.1-4.5a8.4 8.4 0 1 1 16.9-4z"/></svg>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="ml-auto" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- likes -->
    <p class="px-3 pt-1.5 text-[0.8rem] font-semibold">Mi piace: {likes}</p>
    <!-- caption -->
    <p class="px-3 pt-0.5 text-[0.8rem] leading-snug"><span class="font-semibold">{handle}</span> {caption}</p>
    <!-- comments -->
    <p class="px-3 pt-1 pb-3 text-[0.72rem] text-[var(--ink-tertiary)]">Visualizza tutti i {comments} commenti</p>
  </div>
</div>
