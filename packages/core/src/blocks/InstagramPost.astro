---
/**
 * InstagramPost — a credible IG post inside a phone frame, sized to fit whole
 * within a slide's safe area. The image area uses MediaSlot (so it fills with
 * the generated asset, or a palette placeholder). Pass the media like MediaSlot:
 *   <InstagramPost {...mediaProps('monogram-post')} />
 */
import MediaSlot from './MediaSlot.astro';
import type { ImageMetadata } from 'astro';
import type { AssetSlot } from '@edf/core/assets/types';

interface Props {
  media: AssetSlot;
  src?: ImageMetadata | null;
  handle?: string;
  /** Caption text after the handle. */
  caption?: string;
  /** Likes count label, e.g. "2.418". */
  likes?: string;
  class?: string;
}
const {
  media, src = null, handle = 'maxmara',
  caption = 'La nuova collezione',
  likes = '2.418',
  class: className,
} = Astro.props;
---
<div
  class:list={[
    "ig-phone relative mx-auto h-full max-h-[76vh] aspect-[9/19] overflow-hidden",
    "rounded-[2.4rem] border-[6px] border-[var(--surface-inverse)] bg-[var(--surface-inverse)] shadow-2xl",
    className,
  ]}
>
  <!-- notch -->
  <div class="absolute top-0 inset-x-0 h-6 z-10 flex items-start justify-center">
    <span class="w-24 h-5 bg-[var(--surface-inverse)] rounded-b-2xl"></span>
  </div>

  <div class="h-full bg-[var(--surface-primary)] flex flex-col text-[var(--ink-primary)]">
    <!-- header -->
    <div class="flex items-center gap-2.5 px-3 pt-6 pb-2">
      <span class="w-8 h-8 rounded-full bg-[var(--accent-primary)] flex items-center justify-center text-white text-[0.62rem] font-bold flex-shrink-0">MM</span>
      <div class="leading-tight">
        <span class="text-[0.82rem] font-semibold">{handle}</span>
        <span class="text-[0.7rem] text-[var(--ink-tertiary)]"> · Sponsorizzato</span>
      </div>
      <span class="ml-auto text-[var(--ink-tertiary)] text-xl leading-none">⋯</span>
    </div>

    <!-- image -->
    <div class="relative w-full flex-1 min-h-0 overflow-hidden bg-[var(--surface-secondary)]">
      <MediaSlot media={media} src={src} fill />
    </div>

    <!-- actions -->
    <div class="flex items-center gap-4 px-3 pt-2.5">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 0 0 0-7.8z"/></svg>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.4 9 9 0 0 1-4-1L3 20l1.1-4.5a8.4 8.4 0 1 1 16.9-4z"/></svg>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="ml-auto" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- likes -->
    <p class="px-3 pt-2 text-[0.82rem] font-semibold">Mi piace: {likes}</p>
    <!-- caption -->
    <p class="px-3 pt-0.5 text-[0.82rem] leading-snug"><span class="font-semibold">{handle}</span> {caption}</p>
    <!-- comments -->
    <p class="px-3 pt-1 pb-3 text-[0.74rem] text-[var(--ink-tertiary)]">Visualizza tutti gli 84 commenti</p>
  </div>
</div>
